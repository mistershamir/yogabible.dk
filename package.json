{
  "name": "yogabible-dk14",
  "version": "1.0.0",
  "description": "A clean, modern rebuild of the Yoga Bible Denmark website, migrated from Squarespace to a custom HTML/CSS/JS implementation.",
  "main": "extracted-custom-script.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "build": "npx @11ty/eleventy",
    "postbuild": "node scripts/minify-js.js && node scripts/purge-css.js && node scripts/critical-css.js && node scripts/seo-validator.js",
    "seo": "node scripts/seo-validator.js",
    "seo:strict": "node scripts/seo-validator.js --strict",
    "start": "npx @11ty/eleventy --serve",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "html-minifier-terser": "^7.2.0",
    "terser": "^5.46.0"
  },
  "dependencies": {
    "@11ty/eleventy-img": "^6.0.4",
    "firebase-admin": "^13.6.1",
    "markdown-it": "^14.1.0",
    "nodemailer": "^8.0.1"
  }
}
