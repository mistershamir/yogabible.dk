}
.footer-sample__col a { display: block; font-size: 14px; padding: 4px 0; opacity: 0.6; transition: opacity 0.2s; }
.footer-sample__col a:hover { opacity: 1; }
.footer-sample__brand { font-size: 22px; font-weight: 800; margin-bottom: 12px; }
.footer-sample__tagline { font-size: 14px; opacity: 0.5; max-width: 260px; }
.footer-sample__bottom {
