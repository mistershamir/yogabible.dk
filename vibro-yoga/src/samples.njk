---
permalink: /samples/
eleventyExcludeFromCollections: true
noindex: true
---
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Vibro Yoga — Design Showcase</title>
<style>
/* ═══════════════════════════════════════════
   FOUNDATION — Variables & Reset
   ═══════════════════════════════════════════ */
:root {
  --rust: #b83210;
  --rust-dark: #9a2a0e;
  --rust-light: #d4441e;
  --orange: #f75c03;
  --orange-light: #ff8a3d;
  --gold: #f0d97a;
  --gold-muted: #d4bf5e;
  --black: #111111;
  --black-card: #1a1816;
  --black-elevated: #242220;
  --cream: #f9f3e6;
  --cream-dark: #ede5ce;
  --cream-warm: #fdfbf7;
  --white: #ffffff;
  --text-on-dark: #f5edd6;
  --text-on-dark-muted: #8a8279;
  --text-on-light: #111111;
  --text-on-light-muted: #6b6560;
  --border-dark: rgba(255,255,255,0.06);
  --border-light: rgba(0,0,0,0.08);
  --radius-sm: 6px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
  --radius-2xl: 24px;
  --radius-pill: 100px;
  --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
  --shadow-md: 0 4px 12px rgba(0,0,0,0.15);
  --shadow-lg: 0 8px 30px rgba(0,0,0,0.2);
  --shadow-glow: 0 0 30px rgba(184,50,16,0.25);
  --shadow-glow-sm: 0 0 15px rgba(184,50,16,0.15);
  --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  --font-display: 'Inter', -apple-system, sans-serif;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: var(--font); line-height: 1.7; color: var(--text-on-light); background: var(--cream); -webkit-font-smoothing: antialiased; }
img { max-width: 100%; display: block; }
a { text-decoration: none; color: inherit; }

.showcase-container { max-width: 1200px; margin: 0 auto; padding: 0 24px; }
.showcase-section { padding: 80px 0; }
.showcase-label {
  display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 0.25em;
  text-transform: uppercase; color: var(--rust); margin-bottom: 8px;
  padding: 4px 12px; background: rgba(184,50,16,0.08); border-radius: var(--radius-pill);
}
.showcase-title { font-size: 32px; font-weight: 800; letter-spacing: -0.02em; margin-bottom: 40px; }
.showcase-subtitle { font-size: 14px; color: var(--text-on-light-muted); margin-top: -32px; margin-bottom: 40px; }
.showcase-grid { display: grid; gap: 24px; }
.showcase-grid--2 { grid-template-columns: 1fr 1fr; }
.showcase-grid--3 { grid-template-columns: 1fr 1fr 1fr; }
.showcase-grid--4 { grid-template-columns: 1fr 1fr 1fr 1fr; }
@media (max-width: 768px) {
  .showcase-grid--2, .showcase-grid--3, .showcase-grid--4 { grid-template-columns: 1fr; }
}
.showcase-divider { height: 1px; background: var(--border-light); margin: 0; }

/* ═══════════════════════════════════════════
   COLOR PALETTE
   ═══════════════════════════════════════════ */
.palette { display: flex; gap: 16px; flex-wrap: wrap; }
.palette__swatch {
  flex: 1; min-width: 140px; height: 120px; border-radius: var(--radius-lg);
  display: flex; flex-direction: column; justify-content: flex-end; padding: 12px 16px;
  font-size: 13px; font-weight: 600; position: relative; overflow: hidden;
  box-shadow: var(--shadow-sm);
}
.palette__swatch span { opacity: 0.8; font-size: 11px; font-weight: 400; }

/* ═══════════════════════════════════════════
   VIBRATION ANIMATIONS
   ═══════════════════════════════════════════ */
@keyframes vibro-breathe {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.03); opacity: 0.92; }
}
@keyframes vibro-pulse-ring {
  0% { transform: scale(0.8); opacity: 0.6; }
  100% { transform: scale(2.5); opacity: 0; }
}
@keyframes vibro-wave {
  0% { transform: translateX(-100%); }
  100% { transform: translateX(100%); }
}
@keyframes vibro-float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-8px); }
}
@keyframes vibro-shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}
@keyframes vibro-ripple {
  0% { transform: scale(0); opacity: 0.5; }
  100% { transform: scale(4); opacity: 0; }
}
@keyframes vibro-glow {
  0%, 100% { box-shadow: 0 0 15px rgba(184,50,16,0.15); }
  50% { box-shadow: 0 0 30px rgba(184,50,16,0.3); }
}
@keyframes vibro-line-draw {
  0% { stroke-dashoffset: 1000; }
  100% { stroke-dashoffset: 0; }
}
@keyframes vibro-subtle-shake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-1px); }
  75% { transform: translateX(1px); }
}
@keyframes vibro-gradient-shift {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ═══════════════════════════════════════════
   BUTTONS
   ═══════════════════════════════════════════ */
.btn-row { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; margin-bottom: 24px; }

.btn {
  display: inline-flex; align-items: center; justify-content: center; gap: 8px;
  font-family: var(--font); font-weight: 600; font-size: 15px;
  border: 2px solid transparent; border-radius: var(--radius-md); cursor: pointer;
  padding: 14px 32px; transition: all 0.3s cubic-bezier(0.4,0,0.2,1);
  position: relative; overflow: hidden; letter-spacing: 0.01em;
}

/* Primary */
.btn-primary { background: var(--rust); color: var(--white); border-color: var(--rust); }
.btn-primary:hover { background: var(--rust-dark); transform: translateY(-2px); box-shadow: var(--shadow-glow); }

/* Secondary */
.btn-secondary { background: var(--orange); color: var(--white); border-color: var(--orange); }
.btn-secondary:hover { background: #e05403; transform: translateY(-2px); box-shadow: 0 0 20px rgba(247,92,3,0.3); }

/* Outline Dark */
.btn-outline-dark { background: transparent; color: var(--text-on-dark); border-color: var(--text-on-dark); }
.btn-outline-dark:hover { background: var(--text-on-dark); color: var(--black); transform: translateY(-2px); }

/* Outline Light */
.btn-outline-light { background: transparent; color: var(--text-on-light); border-color: var(--text-on-light); }
.btn-outline-light:hover { background: var(--text-on-light); color: var(--cream); transform: translateY(-2px); }

/* Ghost */
.btn-ghost { background: transparent; color: var(--rust); border-color: transparent; padding: 14px 16px; }
.btn-ghost:hover { background: rgba(184,50,16,0.06); }

/* Gold */
.btn-gold { background: var(--gold); color: var(--black); border-color: var(--gold); font-weight: 700; }
.btn-gold:hover { background: var(--gold-muted); transform: translateY(-2px); box-shadow: 0 0 20px rgba(240,217,122,0.3); }

/* Sizes */
.btn-sm { padding: 8px 20px; font-size: 13px; }
.btn-lg { padding: 18px 44px; font-size: 17px; }
.btn-xl { padding: 22px 56px; font-size: 18px; border-radius: var(--radius-lg); }

/* Pill */
.btn-pill { border-radius: var(--radius-pill); }

/* Block */
.btn-block { width: 100%; }

/* Icon button */
.btn-icon { width: 48px; height: 48px; padding: 0; border-radius: 50%; }
.btn-icon.btn-lg { width: 56px; height: 56px; }

/* ── Vibration Button Variants ── */

/* Pulse CTA */
.btn-pulse { animation: vibro-glow 2.5s ease-in-out infinite; }

/* Ripple on click */
.btn-ripple { position: relative; overflow: hidden; }
.btn-ripple::after {
  content: ''; position: absolute; width: 20px; height: 20px;
  background: rgba(255,255,255,0.4); border-radius: 50%;
  transform: scale(0); opacity: 0;
}
.btn-ripple:active::after { animation: vibro-ripple 0.6s ease-out; }

/* Shimmer */
.btn-shimmer {
  background: linear-gradient(110deg, var(--rust) 0%, var(--rust) 40%, var(--rust-light) 50%, var(--rust) 60%, var(--rust) 100%);
  background-size: 200% 100%; color: var(--white); border-color: var(--rust);
  animation: vibro-shimmer 3s ease infinite;
}

/* Gradient animated */
.btn-gradient {
  background: linear-gradient(135deg, var(--rust), var(--orange), var(--rust));
  background-size: 200% 200%; color: var(--white); border-color: transparent;
  animation: vibro-gradient-shift 4s ease infinite;
}

/* Breathe */
.btn-breathe { animation: vibro-breathe 4s ease-in-out infinite; }

/* Wave underline */
.btn-wave-underline {
  background: transparent; color: var(--rust); border: none; padding: 14px 4px;
  position: relative;
}
.btn-wave-underline::after {
  content: ''; position: absolute; bottom: 8px; left: 0; right: 0; height: 2px;
  background: var(--rust); border-radius: 2px;
  transform-origin: left; transform: scaleX(0); transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
}
.btn-wave-underline:hover::after { transform: scaleX(1); }

/* ═══════════════════════════════════════════
   EYEBROWS & HEADINGS
   ═══════════════════════════════════════════ */
.eyebrow {
  display: inline-block; font-size: 12px; font-weight: 600; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--rust);
}
.eyebrow--light { color: var(--rust-light); }
.eyebrow--gold { color: var(--gold); }
.eyebrow--muted { color: var(--text-on-light-muted); }
.eyebrow--pill {
  padding: 6px 16px; background: rgba(184,50,16,0.08);
  border-radius: var(--radius-pill); font-size: 11px;
}
.eyebrow--pill-dark {
  padding: 6px 16px; background: rgba(184,50,16,0.15);
  border-radius: var(--radius-pill); font-size: 11px; color: var(--rust-light);
}
.eyebrow--line {
  display: flex; align-items: center; gap: 12px;
}
.eyebrow--line::after {
  content: ''; flex: 1; height: 1px; background: var(--rust); opacity: 0.3; max-width: 60px;
}

.heading-xl { font-size: clamp(44px, 7vw, 88px); font-weight: 800; letter-spacing: -0.03em; line-height: 1.05; }
.heading-lg { font-size: clamp(32px, 5vw, 56px); font-weight: 700; letter-spacing: -0.02em; line-height: 1.1; }
.heading-md { font-size: clamp(24px, 3.5vw, 40px); font-weight: 700; letter-spacing: -0.02em; line-height: 1.15; }
.heading-sm { font-size: clamp(18px, 2.5vw, 28px); font-weight: 700; letter-spacing: -0.01em; line-height: 1.2; }

.text-body { font-size: 17px; line-height: 1.7; }
.text-body-sm { font-size: 15px; line-height: 1.7; }
.text-lead { font-size: 20px; line-height: 1.6; color: var(--text-on-light-muted); }
.text-lead--light { color: var(--text-on-dark-muted); }

/* ═══════════════════════════════════════════
   HEROES
   ═══════════════════════════════════════════ */
.hero-preview { border-radius: var(--radius-xl); overflow: hidden; margin-bottom: 16px; position: relative; }
.hero-preview__label {
  position: absolute; top: 16px; left: 16px; z-index: 10;
  font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase;
  padding: 6px 14px; background: rgba(0,0,0,0.6); color: var(--cream);
  border-radius: var(--radius-pill); backdrop-filter: blur(8px);
}

/* Hero A — Cinematic Dark */
.hero-a {
  min-height: 500px; background: var(--black); color: var(--text-on-dark);
  display: flex; flex-direction: column; justify-content: center; align-items: center;
  text-align: center; padding: 80px 40px; position: relative; overflow: hidden;
}
.hero-a::before {
  content: ''; position: absolute; inset: 0;
  background: radial-gradient(ellipse at 50% 120%, rgba(184,50,16,0.15) 0%, transparent 60%);
}
.hero-a .hero-wave-bg {
  position: absolute; bottom: 0; left: 0; right: 0; height: 200px; opacity: 0.06;
  background: repeating-linear-gradient(0deg, transparent, transparent 8px, var(--rust) 8px, var(--rust) 9px);
  animation: vibro-wave 8s linear infinite;
}
.hero-a > * { position: relative; z-index: 1; }

/* Hero B — Split Layout */
.hero-b {
  min-height: 500px; background: var(--black); color: var(--text-on-dark);
  display: grid; grid-template-columns: 1fr 1fr; overflow: hidden;
}
.hero-b__content { padding: 80px 48px; display: flex; flex-direction: column; justify-content: center; }
.hero-b__visual {
  background: linear-gradient(135deg, var(--black-card), var(--black));
  display: flex; align-items: center; justify-content: center; position: relative;
}
.hero-b__visual .pulse-circles {
  position: relative; width: 200px; height: 200px;
}
.pulse-circle {
  position: absolute; inset: 0; border: 1px solid var(--rust);
  border-radius: 50%; animation: vibro-pulse-ring 3s ease-out infinite;
}
.pulse-circle:nth-child(2) { animation-delay: 0.8s; }
.pulse-circle:nth-child(3) { animation-delay: 1.6s; }

/* Hero C — Minimal Light */
.hero-c {
  min-height: 500px; background: var(--cream); color: var(--text-on-light);
  display: flex; flex-direction: column; justify-content: center;
  padding: 80px 48px; position: relative;
}
.hero-c::after {
  content: ''; position: absolute; right: -100px; top: 50%; transform: translateY(-50%);
  width: 400px; height: 400px; border-radius: 50%;
  background: radial-gradient(circle, rgba(247,92,3,0.08) 0%, transparent 70%);
}

/* Hero D — Gradient Wave */
.hero-d {
  min-height: 500px; color: var(--white);
  background: linear-gradient(135deg, var(--black) 0%, #1a1210 40%, var(--rust-dark) 100%);
  display: flex; flex-direction: column; justify-content: center; align-items: center;
  text-align: center; padding: 80px 40px; position: relative; overflow: hidden;
}
.hero-d .wave-svg { position: absolute; bottom: 0; left: 0; width: 100%; opacity: 0.12; }

/* Hero E — Centered Cream with Gold accent */
.hero-e {
  min-height: 500px; background: var(--cream-warm); color: var(--text-on-light);
  display: flex; flex-direction: column; justify-content: center; align-items: center;
  text-align: center; padding: 80px 40px; position: relative;
  border-bottom: 3px solid var(--gold);
}

/* Hero F — Full dark with floating elements */
.hero-f {
  min-height: 500px; background: var(--black); color: var(--text-on-dark);
  display: flex; flex-direction: column; justify-content: center;
  padding: 80px 48px; position: relative; overflow: hidden;
}
.hero-f .float-orb {
  position: absolute; border-radius: 50%; opacity: 0.08; animation: vibro-float 6s ease-in-out infinite;
}
.hero-f .float-orb--1 { width: 300px; height: 300px; background: var(--rust); top: -80px; right: -60px; }
.hero-f .float-orb--2 { width: 200px; height: 200px; background: var(--orange); bottom: -40px; left: 10%; animation-delay: 2s; }
.hero-f .float-orb--3 { width: 150px; height: 150px; background: var(--gold); top: 30%; right: 20%; animation-delay: 4s; }

/* ═══════════════════════════════════════════
   CARDS
   ═══════════════════════════════════════════ */

/* Card Base */
.card {
  border-radius: var(--radius-lg); padding: 32px; transition: all 0.35s cubic-bezier(0.4,0,0.2,1);
  position: relative; overflow: hidden;
}

/* Dark Card */
.card-dark {
  background: var(--black-card); border: 1px solid var(--border-dark); color: var(--text-on-dark);
}
.card-dark:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: rgba(184,50,16,0.2); }

/* Light Card */
.card-light {
  background: var(--cream-warm); border: 1px solid var(--border-light); color: var(--text-on-light);
}
.card-light:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); border-color: rgba(184,50,16,0.15); }

/* Glass Card */
.card-glass {
  background: rgba(255,255,255,0.05); backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.08); color: var(--text-on-dark);
}
.card-glass:hover { border-color: rgba(184,50,16,0.3); background: rgba(255,255,255,0.08); }

/* Top accent line on hover */
.card-accent::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--rust), var(--orange));
  transform: scaleX(0); transform-origin: left;
  transition: transform 0.35s cubic-bezier(0.4,0,0.2,1);
}
.card-accent:hover::before { transform: scaleX(1); }

/* Gold border card */
.card-gold {
  background: var(--black-card); border: 1px solid var(--gold); color: var(--text-on-dark);
  box-shadow: 0 0 20px rgba(240,217,122,0.08);
}
.card-gold:hover { box-shadow: 0 0 30px rgba(240,217,122,0.15); transform: translateY(-4px); }

/* Session Card */
.session-card { padding: 0; overflow: hidden; }
.session-card__img {
  height: 200px; background: linear-gradient(135deg, var(--black), var(--black-elevated));
  position: relative; display: flex; align-items: center; justify-content: center;
}
.session-card__placeholder {
  font-size: 12px; color: var(--text-on-dark-muted); letter-spacing: 0.1em; text-transform: uppercase;
}
.session-card__badge {
  position: absolute; top: 12px; left: 12px; padding: 5px 14px;
  font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;
  color: var(--white); background: var(--rust); border-radius: var(--radius-pill);
}
.session-card__body { padding: 24px; }
.session-card__title { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
.session-card__tagline { font-size: 12px; font-weight: 600; color: var(--rust); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 12px; }
.session-card__desc { font-size: 15px; color: var(--text-on-dark-muted); line-height: 1.6; margin-bottom: 16px; }
.session-card__meta { display: flex; gap: 16px; font-size: 13px; color: var(--text-on-dark-muted); }

/* Pricing Card */
.pricing-card { text-align: center; padding: 40px 32px; }
.pricing-card__name { font-size: 14px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 8px; }
.pricing-card__price { font-size: 52px; font-weight: 800; letter-spacing: -0.03em; margin-bottom: 4px; }
.pricing-card__currency { font-size: 18px; font-weight: 400; opacity: 0.6; }
.pricing-card__desc { font-size: 14px; opacity: 0.6; margin-bottom: 24px; }
.pricing-card__features { list-style: none; text-align: left; margin-bottom: 32px; }
.pricing-card__features li {
  padding: 8px 0; font-size: 14px; display: flex; align-items: center; gap: 10px;
  border-bottom: 1px solid var(--border-dark);
}
.pricing-card__features li::before { content: '✓'; color: var(--rust); font-weight: 700; }
.pricing-card--featured { border-color: var(--rust); }
.pricing-card--featured::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: linear-gradient(90deg, var(--rust), var(--orange));
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
}

/* Testimonial Card */
.testimonial-card { padding: 32px; }
.testimonial-card__quote {
  font-size: 17px; font-style: italic; line-height: 1.7; margin-bottom: 20px;
  position: relative; padding-left: 20px;
}
.testimonial-card__quote::before {
  content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 3px;
  background: var(--rust); border-radius: 3px;
}
.testimonial-card__author { font-size: 14px; font-weight: 600; }
.testimonial-card__role { font-size: 13px; opacity: 0.5; }

/* Feature Card */
.feature-card { padding: 32px; }
.feature-card__icon {
  width: 48px; height: 48px; border-radius: var(--radius-md);
  background: rgba(184,50,16,0.1); color: var(--rust);
  display: flex; align-items: center; justify-content: center; margin-bottom: 16px;
}
.feature-card__icon--dark { background: rgba(184,50,16,0.15); color: var(--rust-light); }
.feature-card__title { font-size: 18px; font-weight: 700; margin-bottom: 8px; }
.feature-card__text { font-size: 15px; opacity: 0.65; line-height: 1.6; }

/* Info Chip Card */
.chip-card {
  display: flex; align-items: center; gap: 16px; padding: 16px 24px;
  border-radius: var(--radius-lg); font-size: 15px;
}
.chip-card__icon { flex-shrink: 0; color: var(--rust); }

/* ═══════════════════════════════════════════
   BADGES & TAGS
   ═══════════════════════════════════════════ */
.badge {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 5px 14px; font-size: 12px; font-weight: 600;
  border-radius: var(--radius-pill); letter-spacing: 0.03em;
}
.badge-rust { background: var(--rust); color: var(--white); }
.badge-orange { background: var(--orange); color: var(--white); }
.badge-gold { background: var(--gold); color: var(--black); }
.badge-dark { background: var(--black); color: var(--text-on-dark); }
.badge-outline { background: transparent; border: 1px solid var(--rust); color: var(--rust); }
.badge-ghost { background: rgba(184,50,16,0.08); color: var(--rust); }
.badge-lg { padding: 8px 20px; font-size: 14px; }

/* ═══════════════════════════════════════════
   SECTION DIVIDERS
   ═══════════════════════════════════════════ */
.divider-wave { width: 100%; overflow: hidden; line-height: 0; }
.divider-wave svg { width: 100%; height: 48px; }
.divider-gradient {
  height: 2px; border: none;
  background: linear-gradient(90deg, transparent, var(--rust), var(--orange), transparent);
  margin: 40px 0;
}
.divider-dots {
  display: flex; justify-content: center; gap: 8px; padding: 32px 0;
}
.divider-dots span {
  width: 6px; height: 6px; border-radius: 50%; background: var(--rust); opacity: 0.4;
}
.divider-dots span:nth-child(2) { opacity: 0.7; }
.divider-dots span:nth-child(3) { opacity: 1; }
.divider-dots span:nth-child(4) { opacity: 0.7; }
.divider-dots span:nth-child(5) { opacity: 0.4; }

/* ═══════════════════════════════════════════
   CTA SECTIONS
   ═══════════════════════════════════════════ */
.cta-preview { border-radius: var(--radius-xl); overflow: hidden; }

.cta-dark {
  background: linear-gradient(135deg, var(--black) 0%, #1a1210 100%);
  color: var(--text-on-dark); text-align: center; padding: 80px 40px;
}
.cta-gradient {
  background: linear-gradient(135deg, var(--rust-dark) 0%, var(--rust) 50%, var(--orange) 100%);
  color: var(--white); text-align: center; padding: 80px 40px;
}
.cta-light {
  background: var(--cream); color: var(--text-on-light);
  text-align: center; padding: 80px 40px; border: 1px solid var(--border-light);
}
.cta-split {
  display: grid; grid-template-columns: 1fr 1fr;
  background: var(--black); color: var(--text-on-dark); overflow: hidden;
}
.cta-split__content { padding: 60px 48px; display: flex; flex-direction: column; justify-content: center; }
.cta-split__visual {
  background: linear-gradient(135deg, var(--rust-dark), var(--orange));
  display: flex; align-items: center; justify-content: center; padding: 40px;
}
.cta-minimal {
  background: var(--cream-warm); border: 2px solid var(--rust);
  border-radius: var(--radius-xl); color: var(--text-on-light);
  display: flex; align-items: center; justify-content: space-between;
  padding: 40px 48px; gap: 32px;
}

/* ═══════════════════════════════════════════
   FORM ELEMENTS
   ═══════════════════════════════════════════ */
.form-group { display: flex; flex-direction: column; gap: 6px; margin-bottom: 20px; }
.form-label { font-size: 13px; font-weight: 600; letter-spacing: 0.03em; }
.form-input {
  padding: 14px 16px; font-size: 15px; font-family: var(--font);
  border: 1px solid var(--border-light); border-radius: var(--radius-md);
  background: var(--cream-warm); color: var(--text-on-light);
  transition: border-color 0.3s, box-shadow 0.3s;
}
.form-input:focus { outline: none; border-color: var(--rust); box-shadow: 0 0 0 3px rgba(184,50,16,0.12); }
.form-input::placeholder { color: var(--text-on-light-muted); }
.form-input--dark {
  background: var(--black-elevated); border-color: var(--border-dark); color: var(--text-on-dark);
}
.form-input--dark:focus { border-color: var(--rust); box-shadow: 0 0 0 3px rgba(184,50,16,0.2); }
.form-textarea { min-height: 120px; resize: vertical; }

/* ═══════════════════════════════════════════
   NAVIGATION SAMPLES
   ═══════════════════════════════════════════ */
.nav-preview { border-radius: var(--radius-lg); overflow: hidden; margin-bottom: 16px; }
.nav-sample {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 32px; font-size: 15px;
}
.nav-sample__logo { font-size: 20px; font-weight: 800; letter-spacing: -0.02em; }
.nav-sample__links { display: flex; gap: 28px; align-items: center; }
.nav-sample__links a { font-weight: 500; transition: color 0.2s; }
.nav-dark { background: var(--black); color: var(--text-on-dark); }
.nav-dark .nav-sample__links a:hover { color: var(--rust-light); }
.nav-cream { background: var(--cream); color: var(--text-on-light); border: 1px solid var(--border-light); }
.nav-cream .nav-sample__links a:hover { color: var(--rust); }
.nav-glass { background: rgba(17,17,17,0.7); backdrop-filter: blur(12px); color: var(--text-on-dark); }
.nav-glass .nav-sample__links a:hover { color: var(--gold); }

/* ═══════════════════════════════════════════
   VIBRATION ELEMENTS
   ═══════════════════════════════════════════ */
.vibro-element { display: flex; align-items: center; justify-content: center; padding: 48px; }

/* Pulse rings */
.vibro-rings {
  position: relative; width: 120px; height: 120px;
  display: flex; align-items: center; justify-content: center;
}
.vibro-rings__center {
  width: 24px; height: 24px; background: var(--rust); border-radius: 50%;
  position: relative; z-index: 2;
}
.vibro-rings__ring {
  position: absolute; inset: 0; border: 1px solid var(--rust); border-radius: 50%;
  animation: vibro-pulse-ring 3s ease-out infinite;
}
.vibro-rings__ring:nth-child(2) { animation-delay: 1s; }
.vibro-rings__ring:nth-child(3) { animation-delay: 2s; }

/* Sound wave bars */
.vibro-bars { display: flex; gap: 4px; align-items: center; height: 48px; }
.vibro-bars__bar {
  width: 4px; background: var(--rust); border-radius: 4px;
  animation: vibro-bar 1.2s ease-in-out infinite;
}
@keyframes vibro-bar {
  0%, 100% { height: 12px; opacity: 0.4; }
  50% { height: 40px; opacity: 1; }
}
.vibro-bars__bar:nth-child(1) { animation-delay: 0s; }
.vibro-bars__bar:nth-child(2) { animation-delay: 0.15s; }
.vibro-bars__bar:nth-child(3) { animation-delay: 0.3s; }
.vibro-bars__bar:nth-child(4) { animation-delay: 0.45s; }
.vibro-bars__bar:nth-child(5) { animation-delay: 0.6s; }
.vibro-bars__bar:nth-child(6) { animation-delay: 0.45s; }
.vibro-bars__bar:nth-child(7) { animation-delay: 0.3s; }

/* Breathing circle */
.vibro-breath {
  width: 100px; height: 100px; border-radius: 50%;
  background: radial-gradient(circle, var(--rust) 0%, transparent 70%);
  animation: vibro-breathe 5s ease-in-out infinite; opacity: 0.6;
}

/* Concentric circles (static) */
.vibro-concentric {
  width: 160px; height: 160px; position: relative;
  display: flex; align-items: center; justify-content: center;
}
.vibro-concentric__circle {
  position: absolute; border: 1px solid var(--rust); border-radius: 50%;
}

/* Waveform */
.vibro-waveform { height: 60px; display: flex; align-items: center; }
.vibro-waveform svg { width: 200px; height: 60px; }

/* ═══════════════════════════════════════════
   LIST STYLES
   ═══════════════════════════════════════════ */
.check-list { list-style: none; }
.check-list li { display: flex; align-items: flex-start; gap: 10px; padding: 8px 0; font-size: 15px; }
.check-list li::before { content: '✓'; color: var(--rust); font-weight: 700; flex-shrink: 0; }

.numbered-list { list-style: none; counter-reset: items; }
.numbered-list li {
  display: flex; align-items: flex-start; gap: 16px; padding: 12px 0;
  font-size: 15px; counter-increment: items;
}
.numbered-list li::before {
  content: counter(items, decimal-leading-zero);
  font-size: 28px; font-weight: 800; color: var(--rust); opacity: 0.3;
  line-height: 1; flex-shrink: 0; min-width: 36px;
}

/* ═══════════════════════════════════════════
   FOOTER SAMPLES
   ═══════════════════════════════════════════ */
