/* ═══════════════════════════════════════════
   STEP COMPONENT VARIANTS
   ═══════════════════════════════════════════ */
.steps-horizontal { display: flex; gap: 24px; counter-reset: step; }
.steps-horizontal .step-h {
  flex: 1; text-align: center; position: relative; counter-increment: step;
}
.steps-horizontal .step-h__number {
  width: 48px; height: 48px; border-radius: 50%; margin: 0 auto 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; font-weight: 700;
}
.steps-horizontal .step-h__number--rust { background: var(--rust); color: var(--white); }
.steps-horizontal .step-h__number--outline { border: 2px solid var(--rust); color: var(--rust); background: transparent; }
.steps-horizontal .step-h__title { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
.steps-horizontal .step-h__text { font-size: 14px; opacity: 0.6; line-height: 1.5; }
/* Connector line */
.steps-horizontal .step-h:not(:last-child)::after {
  content: ''; position: absolute; top: 24px; left: calc(50% + 32px);
  width: calc(100% - 64px); height: 1px; background: var(--border-dark);
}

