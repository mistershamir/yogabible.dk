---
layout: base.njk
pagination:
  data: resources.entries
  size: 1
  alias: post
permalink: "/ressourcer/{{ post.slug }}/"
eleventyComputed:
  title: "{{ post.title_da }} — Vibro Yoga"
  description: "{{ post.excerpt_da }}"
  lang: "da"
pageType: article
---
{% set tc = i18n.common["da"] %}
{% set entries = resources.entries %}
{% set currentIndex = pagination.pageNumber %}

<article class="vy-post">
  <header class="vy-hero vy-hero--compact">
    <div class="vy-hero__bg"><div class="vy-hero__gradient"></div></div>
    <div class="container vy-hero__content">
      <p class="vy-hero__tagline">{{ post.category }}</p>
      <h1 class="vy-hero__title">{{ post.title_da }}</h1>
      <div class="vy-post__meta">
        <time datetime="{{ post.date }}">{{ post.date }}</time>
        <span>{{ post.readTime_da }}</span>
      </div>
    </div>
  </header>

  <section class="section bg-light">
    <div class="container">
      <nav class="vy-breadcrumb" aria-label="Brødkrumme">
        <ol>
          <li><a href="/">Hjem</a></li>
          <li><a href="/ressourcer/">Ressourcer</a></li>
          <li aria-current="page">{{ post.title_da }}</li>
        </ol>
      </nav>
      <div class="vy-post__body vy-reveal">
        {{ post.content_da | safe }}
      </div>
      <div class="vy-post__footer vy-reveal">
        <a href="/ressourcer/" class="btn btn--outline">&larr; Alle ressourcer</a>
      </div>
      <nav class="vy-post-nav" aria-label="Artikelnavigation">
        {% if currentIndex > 0 %}
          {% set prev = entries[currentIndex - 1] %}
          <a href="/ressourcer/{{ prev.slug }}/" class="vy-post-nav__prev">
            <span>&larr; Forrige</span>
            <strong>{{ prev.title_da }}</strong>
          </a>
        {% endif %}
        {% if currentIndex < entries.length - 1 %}
          {% set next = entries[currentIndex + 1] %}
          <a href="/ressourcer/{{ next.slug }}/" class="vy-post-nav__next">
            <span>Næste &rarr;</span>
            <strong>{{ next.title_da }}</strong>
          </a>
        {% endif %}
      </nav>
    </div>
  </section>
</article>
