# Mindbody API Credentials (set these in Netlify Environment Variables for production)
MB_API_KEY=your_mindbody_api_key
MB_SITE_ID=your_site_id
MB_SOURCE_NAME=your_source_name
MB_SOURCE_PASSWORD=your_source_password
MB_STAFF_USERNAME=your_staff_email
MB_STAFF_PASSWORD=your_staff_password

# Instagram DM Automation (set these in Netlify Environment Variables for production)
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_long_lived_access_token
META_VERIFY_TOKEN=your_webhook_verify_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
INSTAGRAM_ADMIN_KEY=your_admin_api_key

# Optional: Firebase Service Account for Firestore logging
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"yoga-bible-dk-com",...}
