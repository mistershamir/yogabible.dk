# Mindbody API Credentials (set these in Netlify Environment Variables for production)
MB_API_KEY=your_mindbody_api_key
MB_SITE_ID=your_site_id
MB_SOURCE_NAME=your_source_name
MB_SOURCE_PASSWORD=your_source_password
MB_STAFF_USERNAME=your_staff_email
MB_STAFF_PASSWORD=your_staff_password

# Meta Conversions API (server-side pixel relay)
META_PIXEL_ID=your_meta_pixel_id
META_CAPI_ACCESS_TOKEN=your_conversions_api_access_token

# Instagram DM Automation + Facebook Lead Ads Webhook (set in Netlify env vars)
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_long_lived_instagram_access_token
META_VERIFY_TOKEN=your_webhook_verify_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
INSTAGRAM_ADMIN_KEY=your_admin_api_key

# Facebook Lead Ads — Page Access Token
# Needs: leads_retrieval + pages_manage_metadata permissions
# Get from: Meta App Dashboard → Tools → Graph API Explorer → generate Page token
# Webhook URL: https://yogabible.dk/.netlify/functions/facebook-leads-webhook
# Subscribe to: Page → leadgen topic (in Meta App Dashboard → Webhooks)
FB_PAGE_ACCESS_TOKEN=your_facebook_page_access_token

# Firebase Admin SDK (for Firestore + Auth token verification)
# Extract these 3 values from your Firebase service account JSON key
# Generate key at: https://console.firebase.google.com/project/yoga-bible-dk-com/settings/serviceaccounts/adminsdk
FIREBASE_PROJECT_ID=yoga-bible-dk-com
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@yoga-bible-dk-com.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEv...your-key-here...\n-----END PRIVATE KEY-----\n

# Unsubscribe token secret (HMAC-SHA256)
UNSUBSCRIBE_SECRET=yb-unsub-kbh-2026-xK9mPqR7vLs3wN

# Gmail SMTP (for sending emails via nodemailer)
# Generate App Password at: https://myaccount.google.com/apppasswords
GMAIL_USER=info@yogabible.dk
GMAIL_APP_PASSWORD=your_16_char_app_password

# GatewayAPI EU (SMS)
# Token from GatewayAPI dashboard
GATEWAYAPI_TOKEN=your_gatewayapi_token

# e-conomic Accounting API
# App created at: https://secure.e-conomic.com/developer/apps
ECONOMIC_APP_SECRET_TOKEN=your_app_secret_token
ECONOMIC_APP_PUBLIC_TOKEN=your_app_public_token
ECONOMIC_AGREEMENT_GRANT_TOKEN=your_agreement_grant_token
