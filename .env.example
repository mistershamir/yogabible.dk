# Mindbody API Credentials (set these in Netlify Environment Variables for production)
MB_API_KEY=your_mindbody_api_key
MB_SITE_ID=your_site_id
MB_SOURCE_NAME=your_source_name
MB_SOURCE_PASSWORD=your_source_password
MB_STAFF_USERNAME=your_staff_email
MB_STAFF_PASSWORD=your_staff_password

# Meta Conversions API (server-side pixel relay)
META_PIXEL_ID=your_meta_pixel_id
META_CAPI_ACCESS_TOKEN=your_conversions_api_access_token

# Instagram DM Automation (set these in Netlify Environment Variables for production)
META_APP_SECRET=your_meta_app_secret
META_ACCESS_TOKEN=your_long_lived_access_token
META_VERIFY_TOKEN=your_webhook_verify_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
INSTAGRAM_ADMIN_KEY=your_admin_api_key

# Optional: Firebase Service Account for Firestore logging
# FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"yoga-bible-dk-com",...}

# Google Service Account for Sheets/Drive API (Lead Management System)
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Enable Sheets API and Drive API, then share the spreadsheet with the service account email
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project",...}
GOOGLE_SPREADSHEET_ID=1V72sWtw8LmeCVACruGpyTaJragzdlt3Umk2ZV6qxJjM

# Unsubscribe token secret (HMAC-SHA256)
UNSUBSCRIBE_SECRET=yb-unsub-kbh-2026-xK9mPqR7vLs3wN

# GatewayAPI (SMS)
GATEWAYAPI_TOKEN=your_gatewayapi_token

# Gmail OAuth2 (for sending emails via Gmail API)
GMAIL_CLIENT_ID=your_gmail_oauth_client_id
GMAIL_CLIENT_SECRET=your_gmail_oauth_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token
