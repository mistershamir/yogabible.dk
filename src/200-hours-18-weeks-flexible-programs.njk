<!-- Page-specific JS -->
<script>
(function() {
  /* ── Route Tabs ── */
  var tabs = document.querySelectorAll('.p18-tab');
  var routes = document.querySelectorAll('.p18-route');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = tab.getAttribute('data-tab');
      tabs.forEach(function(t) { t.classList.remove('is-active'); });
      routes.forEach(function(r) { r.classList.remove('is-active'); });
      tab.classList.add('is-active');
      var el = document.getElementById('route-' + target);
      if (el) el.classList.add('is-active');
    });
  });

  /* ── Scroll-Draw Vine ── */
  var vineWrap = document.querySelector('[data-p18-scroll-draw]');
  if (vineWrap) {
    var mainPath = vineWrap.querySelector('.p18-vine-path');
    var shadowPath = vineWrap.querySelector('.p18-vine-shadow');
    var allPaths = [mainPath, shadowPath].filter(Boolean);

    allPaths.forEach(function(p) {
      var len = p.getTotalLength();
      p.style.strokeDasharray = len;
      p.style.strokeDashoffset = len;
    });

    function drawVine() {
      var rect = vineWrap.getBoundingClientRect();
      var winH = window.innerHeight;
      var start = winH;
      var end = -rect.height;
      var progress = Math.max(0, Math.min(1, (start - rect.top) / (start - end)));

      allPaths.forEach(function(p) {
        var len = p.getTotalLength();
        p.style.strokeDashoffset = len - (progress * len);
      });
      requestAnimationFrame(drawVine);
    }
    drawVine();
  }

  /* ── Scroll-triggered fade-up ── */
  var fadeEls = document.querySelectorAll('.p18-curr-card, .p18-flex-card');
  if (fadeEls.length && 'IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('p18-visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    fadeEls.forEach(function(el) { obs.observe(el); });
  }
})();
</script>
