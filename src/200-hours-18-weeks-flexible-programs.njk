      title: '200 timer – 8 ugers semi-intensivt program',
      badge: 'Semi-Intensivt',
      blurb: 'Samme <strong>Yoga Alliance–certificerede</strong> uddannelse – fordelt over <strong>8 uger</strong> med et balanceret tempo, der giver plads til integration og hverdagsliv.',
      list: [
        'Flere dage om ugen med blandet teori og praksis',
        'Tid til at fordøje stoffet mellem sessioner',
        '<strong>Mulighed for indkvartering</strong> under forløbet'
      ],
      href: '/200-hours-8-weeks-semi-intensive-programs',
      ctaLabel: 'Gå til 8-ugers semi-intensiv uddannelse \u2192',
      alt: '200-timers – 8 ugers semi-intensivt program'
    }
  };

  var programTitle = document.getElementById('ybProgramTitle');
  var programBadge = document.getElementById('ybProgramBadge');
  var programBlurb = document.getElementById('ybProgramBlurb');
  var programList = document.getElementById('ybProgramList');
  var programCta = document.getElementById('ybProgramCta');
  var programImg = document.getElementById('ybProgramImg');
  var programPills = document.querySelectorAll('.yb-more [data-program]');

  if (programTitle && programBlurb && programCta && programPills.length) {
    var setProgram = function(key) {
      var data = PROGRAM_DATA[key];
      if (!data) return;
      programPills.forEach(function(p) {
        var isActive = p.dataset.program === key;
        p.classList.toggle('is-active', isActive);
        p.setAttribute('aria-selected', isActive);
      });
      programTitle.textContent = data.title;
      if (programBadge) programBadge.textContent = data.badge;
      programBlurb.innerHTML = data.blurb;
      if (programImg) programImg.alt = data.alt;
      if (programList) {
        programList.innerHTML = '';
        data.list.forEach(function(item) {
          var li = document.createElement('li');
          li.innerHTML = item;
          programList.appendChild(li);
        });
      }
      programCta.href = data.href;
      programCta.textContent = data.ctaLabel;
    };
    programPills.forEach(function(p) {
      p.addEventListener('click', function() { setProgram(p.dataset.program); });
    });
    setProgram('4w');
  }
})();
</script>
