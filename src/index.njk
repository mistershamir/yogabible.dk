<!-- ═══════════════════════════════════════════════════════════════
     HOMEPAGE SCRIPTS — Tab switching, scroll effects
     ═══════════════════════════════════════════════════════════════ -->
<script>
(function() {
  // Course Tab Switching
  var tabs = document.querySelectorAll('.yb-courses__tab');
  var panels = document.querySelectorAll('.yb-courses__panel');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var course = this.getAttribute('data-course');

      // Update tabs
      tabs.forEach(function(t) {
        t.classList.remove('yb-courses__tab--active');
        t.setAttribute('aria-selected', 'false');
      });
      this.classList.add('yb-courses__tab--active');
      this.setAttribute('aria-selected', 'true');

      // Update panels
      panels.forEach(function(p) {
        if (p.getAttribute('data-panel') === course) {
          p.classList.add('yb-courses__panel--active');
          p.removeAttribute('hidden');
        } else {
          p.classList.remove('yb-courses__panel--active');
          p.setAttribute('hidden', '');
        }
      });
    });

    // Keyboard navigation
    tab.addEventListener('keydown', function(e) {
      var index = Array.from(tabs).indexOf(this);
      if (e.key === 'ArrowRight') {
        e.preventDefault();
        var next = tabs[(index + 1) % tabs.length];
        next.focus();
        next.click();
      } else if (e.key === 'ArrowLeft') {
        e.preventDefault();
        var prev = tabs[(index - 1 + tabs.length) % tabs.length];
        prev.focus();
        prev.click();
      }
    });
  });

  // Scroll-triggered fade-in animations
  var observerOptions = {
    threshold: 0.1,
    rootMargin: '0px 0px -50px 0px'
  };

  var fadeObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('yb-visible');
        fadeObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.yb-fade-in').forEach(function(el) {
    fadeObserver.observe(el);
  });
})();
</script>
