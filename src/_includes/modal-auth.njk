<!-- Auth Modal -->
<div id="yb-auth-modal" class="yb-auth-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Log ind / Opret konto">
  <div class="yb-auth-modal__overlay" data-yb-auth-close></div>

  <div class="yb-auth-modal__box" data-view="login">
    <button class="yb-auth-modal__close" type="button" data-yb-auth-close aria-label="Luk">&#10005;</button>

    <!-- Visual panel (visible only in register view) -->
    <div class="yb-auth-modal__visual">
      <img class="yb-auth-modal__visual-img" src="/assets/images/member/register-hero.jpg" alt="" loading="lazy">
      <div class="yb-auth-modal__visual-overlay"></div>
      <div class="yb-auth-modal__visual-dots"><span></span><span></span><span></span></div>
      <h3 class="yb-auth-modal__visual-title" data-yj-da>Start din<br>yoga-rejse</h3>
      <h3 class="yb-auth-modal__visual-title" data-yj-en hidden>Begin your<br>yoga journey</h3>
      <p class="yb-auth-modal__visual-sub" data-yj-da>Opret en konto og f&aring; adgang til alle vores klasser og tilbud.</p>
      <p class="yb-auth-modal__visual-sub" data-yj-en hidden>Create an account and get access to all our classes and offers.</p>
    </div>

    <!-- LOGIN VIEW -->
    <div id="yb-auth-login" class="yb-auth-view">
      <div class="yb-auth-modal__header">
        <div class="yb-auth-modal__logo">
          <img src="/assets/images/brand/logo-orange-on-transparent.png" alt="Yoga Bible" loading="lazy" />
        </div>
        <h2 class="yb-auth-modal__title" data-yj-da>Velkommen tilbage</h2>
        <h2 class="yb-auth-modal__title" data-yj-en hidden>Welcome back</h2>
        <p class="yb-auth-modal__subtitle" data-yj-da>Log ind for at se dit skema og medlemskab</p>
        <p class="yb-auth-modal__subtitle" data-yj-en hidden>Sign in to view your schedule and membership</p>
      </div>

      <button type="button" class="yb-auth-google-btn" id="yb-google-signin">
        <svg width="18" height="18" viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <path d="M17.64 9.205c0-.639-.057-1.252-.164-1.841H9v3.481h4.844a4.14 4.14 0 0 1-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615Z" fill="#4285F4"/>
          <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18Z" fill="#34A853"/>
          <path d="M3.964 10.71A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.71V4.958H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.042l3.007-2.332Z" fill="#FBBC05"/>
          <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58Z" fill="#EA4335"/>
        </svg>
        <span data-yj-da>Fortsæt med Google</span>
        <span data-yj-en hidden>Continue with Google</span>
      </button>
      <div class="yb-auth-or-sep">
        <span data-yj-da>eller</span>
        <span data-yj-en hidden>or</span>
      </div>

      <form id="yb-auth-login-form" class="yb-auth-form" novalidate>
        <div class="yb-auth-field">
          <label for="yb-login-email" data-yj-da>Email</label>
          <label for="yb-login-email" data-yj-en hidden>Email</label>
          <input type="email" id="yb-login-email" required autocomplete="email" placeholder="din@email.dk">
        </div>
        <div class="yb-auth-field">
          <label for="yb-login-password" data-yj-da>Adgangskode</label>
          <label for="yb-login-password" data-yj-en hidden>Password</label>
          <input type="password" id="yb-login-password" required autocomplete="current-password" placeholder="&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;&#8226;">
        </div>
        <div class="yb-auth-error" id="yb-login-error" hidden role="alert"></div>
        <button type="submit" class="yb-auth-submit" data-yj-da>Log ind</button>
        <button type="submit" class="yb-auth-submit" data-yj-en hidden>Sign in</button>
      </form>

      <div class="yb-auth-links">
        <a href="#" data-yb-auth-switch="reset" data-yj-da>Glemt adgangskode?</a>
        <a href="#" data-yb-auth-switch="reset" data-yj-en hidden>Forgot password?</a>
      </div>
      <div class="yb-auth-divider">
        <span data-yj-da>Har du ikke en konto?</span>
        <span data-yj-en hidden>Don't have an account?</span>
        <a href="#" data-yb-auth-switch="register" data-yj-da>Opret konto</a>
        <a href="#" data-yb-auth-switch="register" data-yj-en hidden>Create account</a>
      </div>
    </div>

    <!-- REGISTER VIEW -->
    <div id="yb-auth-register" class="yb-auth-view" hidden>
      <div class="yb-auth-modal__header">
        <h2 class="yb-auth-modal__title" data-yj-da>Opret konto</h2>
        <h2 class="yb-auth-modal__title" data-yj-en hidden>Create account</h2>
        <p class="yb-auth-modal__subtitle" data-yj-da>Det tager kun et minut</p>
        <p class="yb-auth-modal__subtitle" data-yj-en hidden>It only takes a minute</p>
      </div>

      <form id="yb-auth-register-form" class="yb-auth-form" novalidate>
        <div class="yb-auth-row">
          <div class="yb-auth-field">
            <label for="yb-register-firstname" data-yj-da>Fornavn</label>
            <label for="yb-register-firstname" data-yj-en hidden>First name</label>
            <input type="text" id="yb-register-firstname" required autocomplete="given-name" placeholder="Fornavn">
          </div>
          <div class="yb-auth-field">
            <label for="yb-register-lastname" data-yj-da>Efternavn</label>
            <label for="yb-register-lastname" data-yj-en hidden>Last name</label>
            <input type="text" id="yb-register-lastname" required autocomplete="family-name" placeholder="Efternavn">
          </div>
        </div>
        <div class="yb-auth-field">
          <label for="yb-register-email" data-yj-da>Email</label>
          <label for="yb-register-email" data-yj-en hidden>Email</label>
          <input type="email" id="yb-register-email" required autocomplete="email" placeholder="din@email.dk">
        </div>
        <div class="yb-auth-field">
          <label for="yb-register-password" data-yj-da>Adgangskode</label>
          <label for="yb-register-password" data-yj-en hidden>Password</label>
          <input type="password" id="yb-register-password" required autocomplete="new-password" placeholder="Mindst 6 tegn">
        </div>
        <div class="yb-auth-consent">
          <label class="yb-auth-consent__item">
            <input type="checkbox" id="yb-register-terms" required>
            <span data-yj-da>Jeg accepterer <a href="/terms-conditions/" target="_blank" rel="noopener">Handelsbetingelser</a> og <a href="/privacy-policy/" target="_blank" rel="noopener">Privatlivspolitik</a></span>
            <span data-yj-en hidden>I agree to the <a href="/en/terms-conditions/" target="_blank" rel="noopener">Terms &amp; Conditions</a> and <a href="/en/privacy-policy/" target="_blank" rel="noopener">Privacy Policy</a></span>
          </label>
          <label class="yb-auth-consent__item">
            <input type="checkbox" id="yb-register-conduct" required>
            <span data-yj-da>Jeg accepterer <a href="/code-of-conduct/" target="_blank" rel="noopener">Code of Conduct</a></span>
            <span data-yj-en hidden>I agree to the <a href="/en/code-of-conduct/" target="_blank" rel="noopener">Code of Conduct</a></span>
          </label>
        </div>
        <div class="yb-auth-error" id="yb-register-error" hidden role="alert"></div>
        <button type="submit" class="yb-auth-submit" data-yj-da>Opret konto</button>
        <button type="submit" class="yb-auth-submit" data-yj-en hidden>Create account</button>
      </form>

      <div class="yb-auth-divider">
        <span data-yj-da>Har du allerede en konto?</span>
        <span data-yj-en hidden>Already have an account?</span>
        <a href="#" data-yb-auth-switch="login" data-yj-da>Log ind</a>
        <a href="#" data-yb-auth-switch="login" data-yj-en hidden>Sign in</a>
      </div>
    </div>

    <!-- RESET PASSWORD VIEW -->
    <div id="yb-auth-reset" class="yb-auth-view" hidden>
      <div class="yb-auth-modal__header">
        <div class="yb-auth-modal__logo">
          <img src="/assets/images/brand/logo-orange-on-transparent.png" alt="Yoga Bible" loading="lazy" />
        </div>
        <h2 class="yb-auth-modal__title" data-yj-da>Nulstil adgangskode</h2>
        <h2 class="yb-auth-modal__title" data-yj-en hidden>Reset password</h2>
        <p class="yb-auth-modal__subtitle" data-yj-da>Indtast din email, s&aring; sender vi dig et link</p>
        <p class="yb-auth-modal__subtitle" data-yj-en hidden>Enter your email and we'll send you a reset link</p>
      </div>

      <form id="yb-auth-reset-form" class="yb-auth-form" novalidate>
        <div class="yb-auth-field">
          <label for="yb-reset-email" data-yj-da>Email</label>
          <label for="yb-reset-email" data-yj-en hidden>Email</label>
          <input type="email" id="yb-reset-email" required autocomplete="email" placeholder="din@email.dk">
        </div>
        <div class="yb-auth-error" id="yb-reset-error" hidden role="alert"></div>
        <div class="yb-auth-success" id="yb-reset-success" hidden role="status"></div>
        <button type="submit" class="yb-auth-submit" data-yj-da>Send nulstillingslink</button>
        <button type="submit" class="yb-auth-submit" data-yj-en hidden>Send reset link</button>
      </form>

      <div class="yb-auth-divider">
        <a href="#" data-yb-auth-switch="login" data-yj-da>&larr; Tilbage til log ind</a>
        <a href="#" data-yb-auth-switch="login" data-yj-en hidden>&larr; Back to sign in</a>
      </div>
    </div>
  </div>
</div>
