<script>
/* ===== Yoga Bible — COURSES (modal + submit) — ybC namespace ===== */
(function(){
  if (window.__ybC_Booted) return;
  window.__ybC_Booted = true;

  const GAS_URL = '/.netlify/functions/lead';

  const modal = document.getElementById('ybC-modal');
  const box   = document.getElementById('ybC-box');
  if(!modal || !box){ console.warn('[ybC] modal pieces missing'); return; }

  try{ if (modal.parentElement !== document.body) document.body.appendChild(modal); }catch(e){}

  const viewForm    = document.getElementById('ybC-view-form');
  const viewSuccess = document.getElementById('ybC-view-success');
  const errBox      = document.getElementById('ybCError');
  const errDetail   = document.getElementById('ybCErrorDetail');
  const submitBtn   = document.getElementById('ybCSubmit');
  const form        = document.getElementById('ybC-form');

  function closeModal() {
    modal.setAttribute('aria-hidden', 'true');
    document.documentElement.style.overflow = '';
    document.body.style.overflow = '';
  }

  function openModal() {
    modal.setAttribute('aria-hidden', 'false');
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
  }

  function fillMonths(select, pillsWrap){
    // Available course months (update each season)
    const courseMonths = ['Juni 2026', 'Juli 2026'];
    const months = ['Ikke sikker endnu', ...courseMonths];

    if(select){
      select.innerHTML = '';
      months.forEach((m,i)=>{
        const o = document.createElement('option');
        o.value = (i===0 ? 'Not sure yet' : m);
        o.textContent = m;
        if(i===0) o.selected = true;
        select.appendChild(o);
      });
    }
    if(pillsWrap){
      pillsWrap.innerHTML = '';
      courseMonths.forEach(m=>{
        const label = document.createElement('label');
        label.className = 'yb-modal-courses__pill';
        label.innerHTML = `<input type="checkbox" name="months" value="${m}"><span>${m.split(' ')[0]}</span>`;
        pillsWrap.appendChild(label);
      });
    }
  }

  function setupHousingToggle(){
    const sel        = document.getElementById('ybC-housing');
    const originWrap = document.getElementById('ybC-originWrap');
    const monthsWrap = document.getElementById('ybC-monthsWrap');
    const originInput= originWrap ? originWrap.querySelector('input[name="origin"]') : null;

    const toggle = ()=>{
      const yes = sel && sel.value === 'Yes';
      if(originWrap && originInput){
        originWrap.hidden = !yes;
        originInput.required = !!yes;
        if(!yes) originInput.value = '';
      }
      if(monthsWrap){
        monthsWrap.hidden = !yes;
        if(!yes) monthsWrap.querySelectorAll('input[name="months"]').forEach(cb=>cb.checked=false);
      }
    };

    if(sel) {
      sel.removeEventListener('change', sel._ybcToggle);
      sel._ybcToggle = toggle;
      sel.addEventListener('change', toggle);
    }
    toggle();
  }

  function resetView(){
    try { form && form.reset(); } catch(e) {}

    if (viewForm) viewForm.hidden = false;
    if (viewSuccess) viewSuccess.hidden = true;

    if (errBox) errBox.hidden = true;
    if (errDetail) errDetail.textContent = '';

    if (submitBtn) {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Send & få brochure';
    }

    const originWrap = document.getElementById('ybC-originWrap');
    const monthsWrap = document.getElementById('ybC-monthsWrap');
    if (originWrap) originWrap.hidden = true;
    if (monthsWrap) monthsWrap.hidden = true;

    setupHousingToggle();
  }

  function setLoading(is){
    if(!form) return;
    try{
      form.querySelectorAll('input,select,button,textarea').forEach(el=> el.disabled = is);
      if(submitBtn){
        if(is){ submitBtn.dataset.label = submitBtn.textContent; submitBtn.textContent='Sender…'; }
        else { submitBtn.textContent = submitBtn.dataset.label || 'Send & få brochure'; }
      }
      form.setAttribute('aria-busy', is ? 'true' : 'false');
    }catch(e){}
  }

  function showError(msg) {
    if (errBox) errBox.hidden = false;
    if (errDetail) errDetail.textContent = msg ? msg : '';
  }

  function showThanks(){
    if (viewForm) viewForm.hidden = true;
    if (viewSuccess) viewSuccess.hidden = false;
  }

  function applyOpenerMeta(openerEl){
    const srcInput = document.getElementById('ybC-source');
    const source = openerEl && openerEl.getAttribute('data-ybc-source');
    if (srcInput) srcInput.value = source || 'Courses – landing page';

    const course = openerEl && openerEl.getAttribute('data-ybc-course');
    if (course){
      const wanted = course.split(',').map(s=>s.trim()).filter(Boolean);
      document.querySelectorAll('#ybC-form input[name="courses"]').forEach(cb=>{
        cb.checked = wanted.includes(cb.value);
      });
    }
  }

  async function handleSubmit(e){
    e.preventDefault();

    if(!form) return;

    const fd     = new FormData(form);
    const source = (document.getElementById('ybC-source')?.value) || 'Courses – landing page';

    if (errBox) errBox.hidden = true;
    if (errDetail) errDetail.textContent = '';

    const chosen = [];
    form.querySelectorAll('input[name="courses"]:checked').forEach(cb=> chosen.push(cb.value));
    if(!chosen.length){
      alert('Vælg mindst ét kursus.');
      return;
    }

    if(!fd.get('consent')){
      alert('Du skal give samtykke for at modtage brochure og info.');
      return;
    }

    const needs = (fd.get('housing') === 'Yes');
    let months = [];
    if(needs){
      form.querySelectorAll('input[name="months"]:checked').forEach(cb=> months.push(cb.value));
      if(!months.length){
        alert('Vælg mindst én måned for bolig.');
        return;
      }
    }

    // Honeypot check
    if (fd.get('ybu_hp')) { showThanks(); return; }

    const params = new URLSearchParams();
    params.set('action',      'lead_courses');
    params.set('firstName',   fd.get('firstName') || '');
    params.set('lastName',    fd.get('lastName')  || '');
    params.set('email',       fd.get('email')     || '');
    params.set('phone',       fd.get('phone')     || '');
    params.set('courses',     chosen.join(', '));
    params.set('preferredMonth', fd.get('preferredMonth') || 'Not sure yet');
    params.set('accommodation', needs ? 'Yes' : 'No');
    params.set('cityCountry', fd.get('origin') || '');
    params.set('housingMonths', months.join(', '));
    params.set('consent', fd.get('consent') ? 'true' : 'false');
    params.set('source', source);

    // Attach attribution data (UTM, referrer, channel)
    if (typeof window.ybAttribution === 'function') {
      var attr = window.ybAttribution();
      if (attr.channel) params.set('channel', attr.channel);
      if (attr.utm_source) params.set('utm_source', attr.utm_source);
      if (attr.utm_medium) params.set('utm_medium', attr.utm_medium);
      if (attr.utm_campaign) params.set('utm_campaign', attr.utm_campaign);
      if (attr.gclid) params.set('gclid', attr.gclid);
      if (attr.fbclid) params.set('fbclid', attr.fbclid);
      if (attr.referrer) params.set('referrer', attr.referrer);
      if (attr.landing_page) params.set('landing_page', attr.landing_page);
    }

    setLoading(true);
    try{
      await fetch(GAS_URL, { method:'POST', headers:{'Content-Type':'application/x-www-form-urlencoded'}, body:params.toString() });
      setLoading(false);
      showThanks();
    }catch(err){
      setLoading(false);
      console.error('[ybC] submit error:', err);
      showError('Noget gik galt. Prøv igen.');
    }
  }

  // ══════════════════════════════════════════════════════════════
  // INITIALIZATION - Only runs ONCE
  // ══════════════════════════════════════════════════════════════

  fillMonths(document.getElementById('ybC-month'), document.getElementById('ybC-housingMonths'));

  if(form) {
    form.addEventListener('submit', handleSubmit);
  }

  document.addEventListener('click', (e)=>{
    const opener = e.target.closest('#ybC-openModal, [data-ybc-open="brochure"]');
    if (opener){
      e.preventDefault();
      resetView();
      applyOpenerMeta(opener);
      openModal();
      return;
    }

    const closer = e.target.closest('[data-ybc-close]');
    if (closer && modal.getAttribute('aria-hidden') === 'false'){
      e.preventDefault();
      closeModal();
      return;
    }
  });

  document.addEventListener('keydown', (e)=>{
    if (e.key === 'Escape' && modal.getAttribute('aria-hidden') === 'false') closeModal();
  });

  closeModal();
})();
</script>
