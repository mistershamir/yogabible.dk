<!-- ═══════════════════════════════════════════════════════════════════════════════
     COURSES MODAL (ybC) - FIXED VERSION
     Inversions / Splits / Backbends Brochure Requests

     Triggers: #ybC-openModal, data-ybc-open="brochure"
═══════════════════════════════════════════════════════════════════════════════ -->

<section class="yb-modals-courses">
  <div class="yb-modal-courses" id="ybC-modal" aria-hidden="true">
    <div class="yb-modal-courses__overlay" data-ybc-close></div>

    <div id="ybC-box" class="yb-modal-courses__box" role="dialog" aria-modal="true" aria-labelledby="ybCTitle">
      <button class="yb-modal-courses__close" type="button" data-ybc-close aria-label="Luk">×</button>

      <!-- Form View -->
      <div id="ybC-view-form">
        <h3 id="ybCTitle">Få brochure på e-mail</h3>
        <p class="yb-modal-courses__lead">Vælg de kurser du er interesseret i — vi sender praktisk info til din e-mail.</p>

        <p id="ybCError" class="yb-modal-courses__error" hidden>
          Kunne ikke sende lige nu. Prøv igen — eller skriv til
          <a href="mailto:info@yogabible.dk">info@yogabible.dk</a>.
          <span id="ybCErrorDetail" class="yb-modal-courses__error-detail"></span>
        </p>

        <form id="ybC-form" class="yb-modal-courses__form" novalidate>
          <input type="hidden" id="ybC-source" value="Courses – landing page">
          <input class="yb-modal-courses__hp" type="text" name="ybu_hp" tabindex="-1" autocomplete="off" aria-hidden="true">

          <div class="yb-modal-courses__grid">
            <label class="yb-modal-courses__field">
              <span>Fornavn *</span>
              <input type="text" name="firstName" autocomplete="given-name" required>
            </label>

            <label class="yb-modal-courses__field">
              <span>Efternavn *</span>
              <input type="text" name="lastName" autocomplete="family-name" required>
            </label>

            <label class="yb-modal-courses__field">
              <span>E-mail *</span>
              <input type="email" name="email" autocomplete="email" required>
            </label>

            <label class="yb-modal-courses__field">
              <span>Telefonnummer *</span>
              <input type="tel" name="phone" autocomplete="tel" required>
            </label>

            <div class="yb-modal-courses__field yb-modal-courses__field--full">
              <span>Hvilke kurser vil du have info om? *</span>
              <div class="yb-modal-courses__courses" role="group" aria-label="Vælg kurser">
                <label class="yb-modal-courses__course">
                  <input type="checkbox" name="courses" value="Inversions">
                  <span class="yb-checkbox"></span>
                  <span class="yb-checkbox-label">Inversions</span>
                </label>

                <label class="yb-modal-courses__course">
                  <input type="checkbox" name="courses" value="Splits">
                  <span class="yb-checkbox"></span>
                  <span class="yb-checkbox-label">Splits</span>
                </label>

                <label class="yb-modal-courses__course">
                  <input type="checkbox" name="courses" value="Backbends">
                  <span class="yb-checkbox"></span>
                  <span class="yb-checkbox-label">Backbends</span>
                </label>
              </div>
            </div>

            <label class="yb-modal-courses__field yb-modal-courses__field--full">
              <span>Hvilken måned passer dig bedst? *</span>
              <select id="ybC-month" name="preferredMonth" required></select>
            </label>

            <label class="yb-modal-courses__field yb-modal-courses__field--full">
              <span>Har du brug for overnatning? *</span>
              <select id="ybC-housing" name="housing" required>
                <option value="No" selected>Nej</option>
                <option value="Yes">Ja</option>
              </select>
            </label>

            <label id="ybC-originWrap" class="yb-modal-courses__field yb-modal-courses__field--full" hidden>
              <span>Fra hvilken by/land kommer du? *</span>
              <input type="text" name="origin" placeholder="Fx Berlin, Tyskland" autocomplete="off">
            </label>

            <div id="ybC-monthsWrap" class="yb-modal-courses__months" hidden>
              <p class="yb-modal-courses__months-label">Vælg de måneder du har brug for bolig:</p>
              <div id="ybC-housingMonths" class="yb-modal-courses__month-pills" aria-label="Vælg måneder"></div>
              <p class="yb-modal-courses__months-note">Vælg én eller flere måneder (kun hvis du har brug for bolig).</p>
            </div>
          </div>

          <label class="yb-modal-courses__consent">
            <input type="checkbox" name="consent" value="Yes" required>
            <span class="yb-checkbox"></span>
            <span class="yb-checkbox-text">Jeg giver samtykke til at modtage e-mails om de valgte kurser (du kan altid afmelde dig).</span>
          </label>

          <button id="ybCSubmit" class="yb-btn yb-btn--cta" type="submit">
            Send & få brochure
          </button>

          <p class="yb-modal-courses__fine">Ved at sende accepterer du, at vi må kontakte dig om din forespørgsel.</p>
        </form>
      </div>

      <!-- Success View -->
      <div id="ybC-view-success" class="yb-modal-courses__success" hidden role="status" aria-live="polite">
        <div class="yb-modal-courses__success-icon">✓</div>
        <h3>Tak for din tilmelding!</h3>
        <p>Vi sender info og praktisk materiale til din e-mail om et øjeblik.</p>
        <button class="yb-btn yb-btn--outline" type="button" data-ybc-close>Luk</button>
      </div>
    </div>
  </div>
</section>

<style>
