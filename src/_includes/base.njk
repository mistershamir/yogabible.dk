<!DOCTYPE html>
<html lang="{% if lang == 'en' %}en{% else %}da-DK{% endif %}">
<head>
  {% include "head.njk" %}
</head>

<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
  <!-- GTM noscript — injected by consent manager when accepted -->
  <noscript id="yb-gtm-noscript"></noscript>

  <!-- Embed detection: hide page chrome when loaded in iframe or via ?embed=1 -->
  <script>
    if (window.self !== window.top || new URLSearchParams(window.location.search).has('embed')) {
      document.documentElement.classList.add('yb-embed');
    }
  </script>
  <style>
    .yb-embed .yb-header,
    .yb-embed .yb-footer,
    .yb-embed .yb-cookie,
    .yb-embed #yb-cookie-banner,
    .yb-embed .yb-profile__hero,
    .yb-embed .yb-profile__tabs,
    .yb-embed .yb-profile__guest,
    .yb-embed .yb-tab-locked-toast { display: none !important; }
    .yb-embed .yb-profile { padding-top: 0 !important; }
    .yb-embed .yb-profile__wrap { padding-top: 1rem !important; }
    .yb-embed body { background: var(--yb-warm-white, #FFFCF9) !important; }
    .yb-embed main { min-height: auto !important; }
  </style>

  {% include "header.njk" %}

  <!-- Main Content -->
  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

  {% if includeScheduleModal %}
    {% include "modal-schedule.njk" %}
  {% endif %}

  {% if includeScheduleModal300 %}
    {% include "modal-schedule-300.njk" %}
  {% endif %}

  {% if includeStoreCSS %}
    <link rel="stylesheet" href="/css/store.css">
  {% endif %}

  {% if includeAdminCSS %}
    <link rel="stylesheet" href="/css/admin.css">
  {% endif %}

  {% if includeP300Styles %}
    <link rel="stylesheet" href="/css/p300.css">
    <script src="/js/p300.js" defer></script>
  {% endif %}

  {% if includeP18Styles %}
    <link rel="stylesheet" href="/css/p18.css">
  {% endif %}

  {% if includeOm200Styles %}
    <link rel="stylesheet" href="/css/om200.css">
    <script src="/js/om200.js" defer></script>
  {% endif %}

  {% if includeCBStyles %}
    <link rel="stylesheet" href="/css/cb.css">
    <script src="/js/cb.js" defer></script>
  {% endif %}

  {% if includeCoursesModal %}
    {% include "modal-courses.njk" %}
  {% endif %}

  <!-- Auth Modal -->
  {% include "modal-auth.njk" %}

  <!-- Checkout Modal -->
  {% include "modal-checkout.njk" %}

  <!-- Checkout Flow Modal (multi-step) -->
  {% include "modal-checkout-flow.njk" %}

  <!-- Appointment Booking Modal (Calendly replacement) -->
  {% include "modal-appointment.njk" %}

  <!-- Photo Session Request Modal -->
  {% if includePhotoBooking %}
    {% include "modal-photo-booking.njk" %}
  {% endif %}

  <!-- Workshop Browser Modal -->
  {% include "modal-workshops.njk" %}

  <!-- Video Tutorial Widget (per-page, opt-in via front matter) -->
  {% if videoTutorial %}
    {% include "widget-video-tutorial.njk" %}
  {% endif %}

  <!-- Cookie Consent -->
  {% include "cookies.njk" %}
  <script src="/js/cookies.js" defer></script>

  <!-- Critical scripts: layout & navigation -->
  <script src="/js/header.js" defer></script>
  <script src="/js/main.js" defer></script>
  <script src="/js/footer.js" defer></script>

  <!-- Firebase + auth: lazy-loaded after idle for mobile performance -->
  <script>
  (function(){
    var loaded=false;
    function loadFirebase(){
      if(loaded)return;loaded=true;
      var s=['https://www.gstatic.com/firebasejs/12.10.0/firebase-app-compat.js',
             'https://www.gstatic.com/firebasejs/12.10.0/firebase-auth-compat.js',
             'https://www.gstatic.com/firebasejs/12.10.0/firebase-firestore-compat.js'];
      var chain=Promise.resolve();
      s.forEach(function(u){chain=chain.then(function(){return new Promise(function(r){
        var e=document.createElement('script');e.src=u;e.onload=r;document.body.appendChild(e);
      })})});
      chain.then(function(){
        ['/js/roles-permissions.js','/js/firebase-auth.js','/js/mindbody.js'
        {% if includeAppointmentJS !== false %},'/js/appointment-booking.js'{% endif %}
        {% if includePhotoBooking %},'/js/photo-booking.js'{% endif %}
        ,'/js/ytt-funnel.js','/js/checkout-flow.js','/js/workshop-browser.js'
        ].forEach(function(u){var e=document.createElement('script');e.src=u;document.body.appendChild(e)});
      });
    }
    if('requestIdleCallback' in window){requestIdleCallback(loadFirebase,{timeout:3500})}
    else{setTimeout(loadFirebase,2000)}
    document.addEventListener('click',loadFirebase,{once:true});
  })();
  </script>
  {% if includeScheduleModal %}
    <script src="/js/modal-200ytt.js" defer></script>
  {% endif %}
  {% if includeScheduleModal300 %}
    <script src="/js/modal-300ytt.js" defer></script>
  {% endif %}
  {% if includeCourseJS %}
    <script src="/js/course.js" defer></script>
  {% endif %}
  {% if videoTutorial %}
    <script src="/js/video-tutorial.js" defer></script>
  {% endif %}
</body>
</html>
