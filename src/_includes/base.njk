<!DOCTYPE html>
<html lang="{% if lang == 'en' %}en{% else %}da-DK{% endif %}">
<head>
  {% include "head.njk" %}
</head>

<body{% if bodyClass %} class="{{ bodyClass }}"{% endif %}>
  <!-- Embed detection: hide chrome when loaded inside an iframe -->
  <script>(function(){if(window.self!==window.top){document.documentElement.classList.add('yb-embed');var p=new URLSearchParams(window.location.search);if(p.get('minimal')==='1')document.documentElement.classList.add('yb-embed-minimal');}})();</script>
  <style>
    html.yb-embed .yb-header,html.yb-embed .yb-footer,html.yb-embed .yb-cookie,html.yb-embed #yb-cookie-banner{display:none!important}
    html.yb-embed-minimal .yb-profile__hero,html.yb-embed-minimal .yb-profile__tabs{display:none!important}
    html.yb-embed-minimal .yb-profile__guest{display:none!important}
  </style>

  <!-- GTM noscript — injected by consent manager when accepted -->
  <noscript id="yb-gtm-noscript"></noscript>

  {% include "header.njk" %}

  <!-- Main Content -->
  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

  {% if includeScheduleModal %}
    {% include "modal-schedule.njk" %}
  {% endif %}

  {% if includeP18Styles %}
    <link rel="stylesheet" href="/css/p18.css">
  {% endif %}

  {% if includeOm200Styles %}
    <link rel="stylesheet" href="/css/om200.css">
    <script src="/js/om200.js" defer></script>
  {% endif %}

  {% if includeCoursesModal %}
    {% include "modal-courses.njk" %}
  {% endif %}

  <!-- Auth Modal -->
  {% include "modal-auth.njk" %}

  <!-- Checkout Modal -->
  {% include "modal-checkout.njk" %}

  <!-- Netlify Identity redirect (for CMS login flow) -->
  <script>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", function(user) {
        if (!user) {
          window.netlifyIdentity.on("login", function() {
            document.location.href = "/decap-cms/";
          });
        }
      });
    }
  </script>

  <!-- Cookie Consent -->
  {% include "cookies.njk" %}
  <script src="/js/cookies.js"></script>

  <!-- Firebase SDK (compat for broad browser support) -->
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-auth-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/10.14.1/firebase-firestore-compat.js"></script>

  <!-- Scripts -->
  <script src="/js/header.js"></script>
  <script src="/js/main.js"></script>
  <script src="/js/footer.js"></script>
  <script src="/js/roles-permissions.js"></script>
  <script src="/js/firebase-auth.js"></script>
  <script src="/js/mindbody.js"></script>
  {% if includeScheduleModal %}
    <script src="/js/modal.js"></script>
  {% endif %}
</body>
</html>
