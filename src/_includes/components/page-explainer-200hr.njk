  </div>
</div>

<!-- Scene 3 — Formats -->
<div class="pe2-scene" id="pe2-s3">
  <p class="pe2-label">VÆLG DIT FORMAT</p>
  <div class="pe2-cards">
    <div class="pe2-card"><p class="pe2-card__title">4 uger</p><p class="pe2-card__sub">Intensiv</p></div>
    <div class="pe2-card"><p class="pe2-card__title">8 uger</p><p class="pe2-card__sub">Semi-intensiv</p></div>
    <div class="pe2-card"><p class="pe2-card__title">18 uger</p><p class="pe2-card__sub">Fleksibel</p></div>
  </div>
  <p class="pe2-sub-note">Samme certificering · Samme undervisere · Samme pensum</p>
</div>

<!-- Scene 4 — Numbers -->
<div class="pe2-scene" id="pe2-s4">
  <p class="pe2-label">YOGA BIBLE I TAL</p>
  <div class="pe2-counters">
    <div class="pe2-counter"><p class="pe2-counter__num" data-pe2-count="200">0</p><p class="pe2-counter__txt">timer</p></div>
    <div class="pe2-counter"><p class="pe2-counter__num" data-pe2-count="500" data-pe2-suffix="+">0</p><p class="pe2-counter__txt">certificerede</p></div>
    <div class="pe2-counter"><p class="pe2-counter__num" data-pe2-count="2014" data-pe2-raw>0</p><p class="pe2-counter__txt">siden</p></div>
  </div>
</div>

<!-- Scene 5 — Price -->
<div class="pe2-scene" id="pe2-s5">
  <p class="pe2-label">DIN INVESTERING</p>
  <p class="pe2-price">23.750 kr · Alt inkluderet</p>
  <p class="pe2-price-sub">Start med forberedelsesfasen: 3.750 kr</p>
  <div class="pe2-checks">
    <span class="pe2-check">60 yogaklasser</span>
    <span class="pe2-check">Alle workshops</span>
    <span class="pe2-check">Livslang adgang</span>
    <span class="pe2-check">Yoga Alliance certificering</span>
  </div>
</div>

<!-- Scene 6 — Yoga Alliance -->
<div class="pe2-scene" id="pe2-s6">
  <p class="pe2-label">INTERNATIONALT ANERKENDT</p>
  <p class="pe2-headline"><span class="pe2-underline">Yoga Alliance RYT-200</span></p>
  <p class="pe2-subtitle">Undervis overalt i verden</p>
  <div class="pe2-creds">
    <span class="pe2-cred">RYT 200</span>
    <span class="pe2-cred">E-RYT 500</span>
    <span class="pe2-cred">YACEP</span>
  </div>
</div>

<!-- Scene 7 — CTA -->
<div class="pe2-scene" id="pe2-s7">
  <p class="pe2-headline"><span class="pe2-underline">Klar til at starte?</span></p>
  <p class="pe2-subtitle">Få dit skema i dag</p>
  <a class="pe2-cta" href="{% if lang == 'en' %}/en/apply{% else %}/apply{% endif %}">yogabible.dk/apply →</a>
</div>

<!-- Progress bar -->
<div class="pe2-progress" id="pe2-bar" style="width:0"></div>

<!-- Replay -->
<button class="pe2-replay" id="pe2-replay" type="button" aria-label="Afspil igen" title="Afspil igen">↺</button>

<script>
(function(){
  var SCENES = [
    { id:'pe2-s1', dur:5000 },
    { id:'pe2-s2', dur:6000 },
    { id:'pe2-s3', dur:6000 },
    { id:'pe2-s4', dur:5000 },
    { id:'pe2-s5', dur:5000 },
    { id:'pe2-s6', dur:4000 },
    { id:'pe2-s7', dur:0 }           // holds forever
  ];
  var totalDur = SCENES.reduce(function(s,c){return s+c.dur},0);
  var elapsed = 0;
  var current = -1;
  var timer = null;
  var bar = document.getElementById('pe2-bar');
  var replay = document.getElementById('pe2-replay');
  var wrap = document.getElementById('pe2-wrap');

  /* ── animate children into view ── */
  function animateIn(el){
    var children = el.querySelectorAll('.pe2-label,.pe2-headline,.pe2-subtitle,.pe2-sub-note,.pe2-badge,.pe2-card,.pe2-counter,.pe2-price,.pe2-price-sub,.pe2-check,.pe2-cred,.pe2-cta');
    var stagger = Math.min(180, 800 / Math.max(children.length,1));
    for(var i=0;i<children.length;i++){
      children[i].classList.remove('pe2-in');
    }
    /* force reflow */
    void el.offsetWidth;
    for(var j=0;j<children.length;j++){
      (function(c,d){ setTimeout(function(){ c.classList.add('pe2-in'); c.style.transition='opacity .45s ease '+d+'ms, transform .45s ease '+d+'ms'; },10); })(children[j], j*stagger);
    }
  }

  /* ── count-up for Scene 4 ── */
  function runCounters(sceneEl){
    var nums = sceneEl.querySelectorAll('[data-pe2-count]');
    for(var i=0;i<nums.length;i++){
      (function(el){
        var target = parseInt(el.getAttribute('data-pe2-count'),10);
        var suffix = el.getAttribute('data-pe2-suffix')||'';
        var raw = el.hasAttribute('data-pe2-raw');
        var start = raw ? 2000 : 0;
        var duration = 1800;
        var t0 = null;
        function step(ts){
          if(!t0) t0=ts;
          var p = Math.min((ts-t0)/duration,1);
          /* ease out cubic */
          var ep = 1 - Math.pow(1-p,3);
          var v = Math.round(start + (target-start)*ep);
          el.textContent = raw ? v : v.toLocaleString('da-DK') + suffix;
          if(p<1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      })(nums[i]);
    }
  }

  /* ── progress bar tick ── */
  var barRAF = null;
  var barStart = 0;
  var barBase = 0;
  function tickBar(){
    var now = performance.now();
    var e = barBase + (now - barStart);
    var pct = Math.min(e/totalDur*100,100);
    bar.style.width = pct+'%';
    if(pct<100) barRAF = requestAnimationFrame(tickBar);
  }
  function startBarSegment(){
    barStart = performance.now();
    barBase = elapsed;
    if(barRAF) cancelAnimationFrame(barRAF);
    barRAF = requestAnimationFrame(tickBar);
  }

  /* ── show scene ── */
  function show(idx){
    if(idx === current) return;
    /* hide previous */
    if(current >= 0){
      var prev = document.getElementById(SCENES[current].id);
      prev.classList.remove('pe2-scene--active');
      /* reset children for potential replay */
      var ch = prev.querySelectorAll('.pe2-in');
      for(var k=0;k<ch.length;k++) ch[k].classList.remove('pe2-in');
    }
    current = idx;
    var el = document.getElementById(SCENES[idx].id);
    el.classList.add('pe2-scene--active');
    animateIn(el);
    if(idx === 3) setTimeout(function(){ runCounters(el); },250);
    /* schedule next scene or finish */
    if(SCENES[idx].dur > 0){
      timer = setTimeout(function(){
        elapsed += SCENES[idx].dur;
        show(idx+1);
      }, SCENES[idx].dur);
      startBarSegment();
    } else {
      /* final scene — fill bar, show replay */
      bar.style.width='100%';
      if(barRAF) cancelAnimationFrame(barRAF);
      replay.classList.add('pe2-replay--visible');
    }
  }

  /* ── start / restart ── */
  function start(){
    clearTimeout(timer);
    if(barRAF) cancelAnimationFrame(barRAF);
    elapsed=0; current=-1;
    bar.style.width='0';
    replay.classList.remove('pe2-replay--visible');
    /* reset all scenes */
    for(var i=0;i<SCENES.length;i++){
      var s=document.getElementById(SCENES[i].id);
      s.classList.remove('pe2-scene--active');
      var ch=s.querySelectorAll('.pe2-in');
      for(var j=0;j<ch.length;j++){ch[j].classList.remove('pe2-in');ch[j].style.transition='';}
    }
    show(0);
  }

  replay.addEventListener('click',function(e){e.stopPropagation();start();});

  /* auto-start when widget becomes visible */
  if(typeof IntersectionObserver !== 'undefined'){
    var obs = new IntersectionObserver(function(entries){
      if(entries[0].isIntersecting){obs.disconnect();start();}
    },{threshold:0.3});
    obs.observe(wrap);
  } else {
    start();
  }
})();
</script>
</div>
