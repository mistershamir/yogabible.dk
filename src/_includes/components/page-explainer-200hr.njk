{# ═══════════════════════════════════════════════════════════
   PAGE EXPLAINER — 200hr YTT animated scenes
   Self-contained HTML + CSS + vanilla JS, no dependencies
   Plays 7 scenes once, then holds on final CTA with replay button
   480×270 (16:9), dark cinematic style
   ═══════════════════════════════════════════════════════════ #}
<div class="pe2-wrap" id="pe2-wrap" role="img" aria-label="200-timers yogalæreruddannelse — animeret overblik">
<style>
/* ── Container ── */
.pe2-wrap{position:relative;width:480px;max-width:100%;aspect-ratio:16/9;background:#141414;overflow:hidden;border-radius:12px;font-family:'Abacaxi',"Helvetica Neue",Helvetica,Arial,system-ui,sans-serif;-webkit-font-smoothing:antialiased;user-select:none}

/* ── Wordmark ── */
.pe2-wm{position:absolute;top:14px;left:16px;font-size:.55rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(245,237,214,.18);z-index:5;pointer-events:none}

/* ── Scenes ── */
.pe2-scene{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:24px 28px;opacity:0;visibility:hidden;transition:opacity .5s ease,visibility .5s ease;z-index:1}
.pe2-scene--active{opacity:1;visibility:visible;z-index:2}

/* ── Typography ── */
.pe2-label{font-size:.55rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:#E8561E;margin:0 0 10px;opacity:0;transform:translateY(12px)}
.pe2-headline{font-size:1.35rem;font-weight:700;color:#F5EDD6;text-align:center;margin:0 0 6px;line-height:1.2;opacity:0;transform:translateY(20px);position:relative;display:inline-block}
.pe2-subtitle{font-size:.7rem;color:rgba(245,237,214,.55);text-align:center;margin:0;letter-spacing:.04em;opacity:0;transform:translateY(16px)}
.pe2-sub-note{font-size:.52rem;color:rgba(245,237,214,.35);text-align:center;margin:8px 0 0;letter-spacing:.02em;opacity:0;transform:translateY(12px)}

/* ── Animated underline ── */
.pe2-underline{position:relative;display:inline-block}
.pe2-underline::after{content:'';position:absolute;left:0;bottom:-3px;width:0;height:2px;background:#E8561E;border-radius:1px;transition:width .6s cubic-bezier(.25,.46,.45,.94) .3s}
.pe2-scene--active .pe2-underline::after{width:100%}

/* ── Badges / Pills ── */
.pe2-badges{display:flex;flex-wrap:wrap;gap:6px;justify-content:center;margin:8px 0 0}
.pe2-badge{display:inline-block;padding:4px 12px;border-radius:20px;font-size:.56rem;font-weight:700;letter-spacing:.06em;color:#F5EDD6;border:1px solid rgba(232,86,30,.5);background:rgba(232,86,30,.08);opacity:0;transform:translateY(14px) scale(.92)}

/* ── Format cards ── */
.pe2-cards{display:flex;gap:8px;margin:8px 0 0;justify-content:center}
.pe2-card{padding:10px 14px;border-radius:10px;background:rgba(245,237,214,.06);border:1px solid rgba(245,237,214,.1);text-align:center;min-width:100px;opacity:0;transform:translateY(16px)}
.pe2-card__title{font-size:.65rem;font-weight:700;color:#E8561E;margin:0 0 2px}
.pe2-card__sub{font-size:.5rem;color:rgba(245,237,214,.5);margin:0}

/* ── Counters ── */
.pe2-counters{display:flex;gap:24px;justify-content:center;margin:6px 0 0}
.pe2-counter{text-align:center;opacity:0;transform:translateY(16px)}
.pe2-counter__num{font-size:1.6rem;font-weight:700;color:#E8561E;margin:0;line-height:1;font-variant-numeric:tabular-nums}
.pe2-counter__txt{font-size:.48rem;color:rgba(245,237,214,.5);margin:2px 0 0;letter-spacing:.06em;text-transform:uppercase}

/* ── Checklist ── */
.pe2-checks{display:grid;grid-template-columns:1fr 1fr;gap:3px 16px;margin:6px 0 0}
.pe2-check{font-size:.5rem;color:rgba(245,237,214,.65);opacity:0;transform:translateX(-10px);white-space:nowrap}
.pe2-check::before{content:'✓ ';color:#E8561E;font-weight:700}

/* ── Price ── */
.pe2-price{font-size:1.15rem;font-weight:700;color:#F5EDD6;margin:0 0 2px;opacity:0;transform:translateY(16px)}
.pe2-price-sub{font-size:.56rem;color:rgba(245,237,214,.45);margin:0 0 6px;opacity:0;transform:translateY(12px)}

/* ── Credential pills ── */
.pe2-creds{display:flex;gap:8px;justify-content:center;margin:8px 0 0}
.pe2-cred{display:inline-block;padding:5px 14px;border-radius:20px;font-size:.58rem;font-weight:700;letter-spacing:.08em;color:#E8561E;border:1.5px solid #E8561E;background:transparent;opacity:0;transform:scale(.85)}

/* ── CTA button ── */
.pe2-cta{display:inline-block;padding:8px 22px;border-radius:24px;background:#E8561E;color:#F5EDD6;font-size:.62rem;font-weight:700;letter-spacing:.04em;text-decoration:none;margin:10px 0 0;opacity:0;transform:translateY(14px);cursor:pointer;border:none;transition:background .2s}
.pe2-cta:hover{background:#d94f02}

/* ── Progress bar ── */
.pe2-progress{position:absolute;bottom:0;left:0;height:2.5px;background:#E8561E;z-index:10;border-radius:0 2px 0 0;transition:width .15s linear}

/* ── Replay button ── */
.pe2-replay{position:absolute;bottom:8px;right:10px;z-index:15;background:rgba(245,237,214,.08);border:1px solid rgba(245,237,214,.12);color:rgba(245,237,214,.4);width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.7rem;cursor:pointer;opacity:0;visibility:hidden;transition:opacity .4s,visibility .4s,color .2s,border-color .2s}
.pe2-replay--visible{opacity:1;visibility:visible}
.pe2-replay:hover{color:#E8561E;border-color:rgba(232,86,30,.4)}

/* ── Entrance animation helper ── */
.pe2-in{opacity:1!important;transform:translateY(0) translateX(0) scale(1)!important}
</style>

<!-- Wordmark -->
<span class="pe2-wm">YOGA BIBLE</span>

<!-- Scene 1 — Hook -->
<div class="pe2-scene" id="pe2-s1">
  <p class="pe2-headline"><span class="pe2-underline">Din rejse mod at blive yogalærer</span></p>
  <p class="pe2-subtitle">200-timers Yogalæreruddannelse · Yoga Bible København</p>
</div>

<!-- Scene 2 — What you learn -->
<div class="pe2-scene" id="pe2-s2">
  <p class="pe2-label">DU LÆRER</p>
  <div class="pe2-badges">
    <span class="pe2-badge">Hatha</span>
    <span class="pe2-badge">Vinyasa</span>
    <span class="pe2-badge">Yin Yoga</span>
    <span class="pe2-badge">Hot Yoga</span>
    <span class="pe2-badge">Anatomi</span>
