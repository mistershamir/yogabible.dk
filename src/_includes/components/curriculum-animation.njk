{# ═══════════════════════════════════════════════════════════
   CURRICULUM ANIMATION — Self-contained looping topic reveal
   Pure HTML + CSS + vanilla JS, no dependencies
   ═══════════════════════════════════════════════════════════ #}
<div class="ca-wrap" aria-label="Curriculum topics animation" role="marquee">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600&display=swap" rel="stylesheet">
  <style>
    .ca-wrap {
      width: 100%;
      min-height: 220px;
      flex: 1 1 auto;
      background: #141414;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      position: relative;
      border-radius: 16px;
      margin-top: 24px;
      border: 1px solid #E8E4E0;
      box-shadow: 0 8px 24px rgba(0,0,0,0.06);
    }

    .ca-stage {
      text-align: center;
      position: relative;
      padding: 0 24px;
    }

    .ca-label {
      font-family: 'Abacaxi', "Helvetica Neue", Helvetica, Arial, system-ui, sans-serif;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: #E8561E;
      margin: 0 0 12px;
      opacity: 0;
      transition: opacity 0.4s ease-out;
    }

    .ca-label.ca--visible {
      opacity: 1;
    }

    .ca-topic {
      font-family: 'Cormorant Garamond', 'Georgia', serif;
      font-size: clamp(1.8rem, 4vw, 3.4rem);
      font-weight: 600;
      color: #F5EDD6;
      line-height: 1.15;
      margin: 0;
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.5s ease-out, transform 0.5s ease-out;
    }

    .ca-topic.ca--visible {
      opacity: 1;
      transform: translateY(0);
    }

    .ca-topic.ca--exit {
      opacity: 0;
      transform: translateY(0);
      transition: opacity 0.4s ease-in;
    }

    .ca-line {
      display: block;
      width: 0;
      height: 2px;
      background: #E8561E;
      margin: 14px auto 0;
      border-radius: 1px;
      transition: width 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }

    .ca-line.ca--visible {
      width: 100%;
    }

    /* ── Mobile: fixed comfortable height ── */
    @media (max-width: 899px) {
      .ca-wrap {
        min-height: 180px;
        margin-top: 20px;
      }
      .ca-topic {
        font-size: clamp(1.5rem, 6vw, 2.2rem);
      }
      .ca-stage {
        padding: 0 16px;
      }
    }

  </style>

  <div class="ca-stage">
    <p class="ca-label" data-ca-label>YOU WILL LEARN</p>
    <p class="ca-topic" data-ca-topic></p>
    <span class="ca-line" data-ca-line></span>
  </div>

  <script>
    (function () {
      var topics = [
        'Hatha Yoga', 'Vinyasa', 'Yin Yoga', 'Hot Yoga',
        'Meditation', 'Yoga Anatomy', 'Yoga Philosophy',
        'Yoga History', 'Business of Yoga', 'Class Management',
        'Confidence Building', 'Voice Training', 'Class Psychology',
        'Creative Sequencing', 'Teaching Practice'
      ];

      var wrap = document.currentScript.closest('.ca-wrap');
      var label = wrap.querySelector('[data-ca-label]');
      var topic = wrap.querySelector('[data-ca-topic]');
      var line  = wrap.querySelector('[data-ca-line]');
      var idx   = 0;
      var timer = null;

      function show() {
        topic.textContent = topics[idx];
        topic.className = 'ca-topic';
        label.className = 'ca-label';
        line.className  = 'ca-line';

        void topic.offsetWidth;

        label.classList.add('ca--visible');
        topic.classList.add('ca--visible');

        setTimeout(function () {
          line.classList.add('ca--visible');
        }, 150);

        setTimeout(hide, 2500);
      }

      function hide() {
        topic.classList.remove('ca--visible');
        topic.classList.add('ca--exit');
        label.classList.remove('ca--visible');
        line.classList.remove('ca--visible');

        setTimeout(function () {
          idx = (idx + 1) % topics.length;
          show();
        }, 500);
      }

      /* IntersectionObserver: only animate when visible */
      if ('IntersectionObserver' in window) {
        var obs = new IntersectionObserver(function (entries) {
          if (entries[0].isIntersecting) {
            if (!timer) { show(); timer = 1; }
          }
        }, { threshold: 0.3 });
        obs.observe(wrap);
      } else {
        show();
      }
    })();
  </script>
</div>
