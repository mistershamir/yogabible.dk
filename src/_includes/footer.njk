{% set tc = i18n.common[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

<footer class="yb-footer" role="contentinfo">
  <div class="yb-footer-inner">
    <!-- TOP: COLUMNS / CARDS -->
    <div class="yb-footer-top">
      <nav class="yb-columns" aria-label="Footer navigation">
        <!-- CARD 1: YOGA BIBLE SITES -->
        <section class="yb-col">
          <button class="yb-col-header" type="button">
            <span class="yb-col-title">{{ tc.footer_col1_title }}</span>
            <span class="yb-col-toggle" aria-hidden="true">▾</span>
          </button>
          <div class="yb-col-body">
            <div class="yb-site-block">
              <a class="yb-footer-link" href="https://www.yogabible.dk{{ lp }}/">{{ tc.footer_dk_name }}</a>
              <div class="yb-site-sub">{{ tc.footer_dk_sub }}</div>
              <a class="yb-site-email" href="mailto:info@yogabible.dk">INFO@YOGABIBLE.DK</a>
            </div>
            <div class="yb-site-block">
              <a class="yb-footer-link" href="https://www.yogabible.com" target="_blank" rel="noopener">{{ tc.footer_int_name }}</a>
              <div class="yb-site-sub">{{ tc.footer_int_sub }}</div>
              <a class="yb-site-email" href="mailto:info@yogabible.com">INFO@YOGABIBLE.COM</a>
            </div>
          </div>
        </section>

        <!-- CARD 2: YOGA BIBLE - DK -->
        <section class="yb-col">
          <button class="yb-col-header" type="button">
            <span class="yb-col-title">{{ tc.footer_col2_title }}</span>
            <span class="yb-col-toggle" aria-hidden="true">▾</span>
          </button>
          <div class="yb-col-body">
            <a class="yb-footer-link" href="{{ lp }}/yoga-bible-historie">{{ tc.footer_about }}</a>
            <a class="yb-footer-link" href="{{ lp }}/about-copenhagen">{{ tc.footer_copenhagen }}</a>
            <a class="yb-footer-link" href="{{ lp }}/accommodation">{{ tc.footer_accommodation }}</a>
            <a class="yb-footer-link" href="{{ lp }}/weekly-schedule">{{ tc.footer_schedule }}</a>
            <a class="yb-footer-link" href="{{ lp }}/careers">{{ tc.footer_careers }}</a>
            <a class="yb-footer-link" href="{{ lp }}/terms-conditions">{{ tc.footer_terms }}</a>
            <a class="yb-footer-link" href="{{ lp }}/privacy-policy">{{ tc.footer_privacy }}</a>
            <a class="yb-footer-link" href="#" data-yb-cookie-settings>{{ tc.footer_cookies }}</a>
            <a class="yb-footer-link" href="{{ lp }}/code-of-conduct">{{ tc.footer_conduct }}</a>
            <a class="yb-footer-link" href="{{ lp }}/kontakt">{{ tc.footer_contact }}</a>
            <div class="yb-contact-meta">
              <a class="yb-contact-link" href="https://www.google.com/maps/search/?api=1&amp;query=Torvegade%2066%2C%201400%20K%C3%B8benhavn%20K" target="_blank" rel="noopener">TORVEGADE 66, 1400 KØBENHAVN K</a>
              <a class="yb-contact-link" href="tel:+4553881209">+45 53 88 12 09</a>
              <div class="yb-app-icons" aria-label="Download Yoga Bible DK app">
                <a class="yb-app-icon" href="https://apps.apple.com/us/app/yoga-bible-dk/id1089612518?itscg=30200&amp;itsct=apps_box_link&amp;mttnsubad=1089612518" target="_blank" rel="noopener"><img src="https://www.yogabible.dk/s/Yoga_Bible_App_Store.svg" alt="Download Yoga Bible DK i App Store" class="yb-app-icon-img" loading="lazy"></a>
                <a class="yb-app-icon" href="https://play.google.com/store/apps/details?id=com.fitnessmobileapps.hotyogacopenhagen&amp;hl=en_US&amp;gl=US" target="_blank" rel="noopener"><img src="https://www.yogabible.dk/s/Yoga_Bible_App_Google_Play.svg" alt="Download Yoga Bible DK på Google Play" class="yb-app-icon-img" loading="lazy"></a>
              </div>
            </div>
          </div>
        </section>

        <!-- CARD 3: EDUCATIONS & COURSES -->
        <section class="yb-col">
          <button class="yb-col-header" type="button">
            <span class="yb-col-title">{{ tc.footer_col3_title }}</span>
            <span class="yb-col-toggle" aria-hidden="true">▾</span>
          </button>
          <div class="yb-col-body">
            <a class="yb-footer-link" href="{{ lp }}/200-hours-18-weeks-flexible-programs">{{ tc.footer_18week }}</a>
            <a class="yb-footer-link" href="{{ lp }}/200-hours-4-weeks-intensive-programs">{{ tc.footer_4week }}</a>
            <a class="yb-footer-link" href="{{ lp }}/om-200hrs-yogalreruddannelser">{{ tc.footer_about200 }}</a>
            <a class="yb-footer-link" href="{{ lp }}/inversions">{{ tc.footer_inversions }}</a>
            <a class="yb-footer-link" href="{{ lp }}/splits">{{ tc.footer_splits }}</a>
            <a class="yb-footer-link" href="{{ lp }}/backbends">{{ tc.footer_backbends }}</a>
            <a class="yb-footer-link" href="{{ lp }}/course-bundles">{{ tc.footer_bundles }}</a>
          </div>
        </section>

        <!-- CARD 4: MORE FROM YOGA BIBLE -->
        <section class="yb-col">
          <button class="yb-col-header" type="button">
            <span class="yb-col-title">{{ tc.footer_col4_title }}</span>
            <span class="yb-col-toggle" aria-hidden="true">▾</span>
          </button>
          <div class="yb-col-body">
            <a class="yb-footer-link" href="{{ lp }}/yogaphotography">{{ tc.footer_photo }}</a>
            <a class="yb-footer-link" href="{{ lp }}/yogamusic">{{ tc.footer_music }}</a>
            <a class="yb-footer-link" href="{{ lp }}/mentorship-private-training">{{ tc.footer_mentorship }}</a>
            <a class="yb-footer-link" href="{{ lp }}/yoga-glossary">{{ tc.footer_glossary }}</a>
            <a class="yb-footer-link" href="{{ lp }}/yoga-journal">{{ tc.footer_journal }}</a>
          </div>
        </section>

        <!-- CARD 5: BRANDS & SOCIALS -->
        <section class="yb-col">
          <button class="yb-col-header" type="button">
            <span class="yb-col-title">{{ tc.footer_col5_title }}</span>
            <span class="yb-col-toggle" aria-hidden="true">▾</span>
          </button>
          <div class="yb-col-body">
            <a class="yb-footer-link" href="https://www.hotyogacph.dk" target="_blank" rel="noopener">HOT YOGA COPENHAGEN</a>
            <a class="yb-footer-link" href="https://www.vibroyoga.dk" target="_blank" rel="noopener">VIBRO YOGA</a>
            <a class="yb-footer-link" href="https://www.namastestudios.com" target="_blank" rel="noopener">NAMASTÉ STUDIOS</a>
            <a class="yb-footer-link" href="https://www.namasteonline.com" target="_blank" rel="noopener">NAMASTÉ ONLINE</a>
            <a class="yb-footer-link" href="https://www.instagram.com/yoga_bible" target="_blank" rel="noopener">INSTAGRAM</a>
            <a class="yb-footer-link" href="https://soundcloud.com/yogabible" target="_blank" rel="noopener">SOUNDCLOUD</a>
          </div>
        </section>
      </nav>
    </div>

    <!-- BOTTOM: META + BIG LOGO -->
    <div class="yb-footer-bottom">
      <div class="yb-footer-meta">
        <span class="yb-meta-item">{{ tc.footer_copyright }}</span>
        <div class="yb-footer-lang" role="navigation" aria-label="Language selector">
          <a class="yb-footer-lang__btn{% if lang != 'en' %} is-active{% endif %}" data-lang="da" href="/" aria-label="Dansk" title="Dansk">🇩🇰 {{ tc.footer_lang_da }}</a>
          <span class="yb-footer-lang__sep" aria-hidden="true">·</span>
          <a class="yb-footer-lang__btn{% if lang == 'en' %} is-active{% endif %}" data-lang="en" href="/en/" aria-label="English" title="English">🇬🇧 {{ tc.footer_lang_en }}</a>
        </div>
      </div>
      <div class="yb-footer-mark">
        <img src="https://www.yogabible.dk/s/YOGA-BIBLE-FOOTER-2000-x-350-7ndy.svg" alt="YOGA BIBLE" class="yb-footer-logo" loading="lazy">
      </div>
    </div>
  </div>
</footer>
