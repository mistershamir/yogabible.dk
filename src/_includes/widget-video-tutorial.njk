{% if videoTutorial %}
<!-- Video Tutorial Widget — floats bottom-right, shown on pages with videoTutorial front matter -->
<div id="yvt-widget" class="yvt-widget{% if videoTutorial.explainer %} yvt-widget--explainer{% endif %}" role="complementary" aria-label="Video guide" hidden>

  {% if videoTutorial.explainer %}
  {# ── EXPLAINER MODE: skip preview, go straight to expanded player with component ── #}
  <div class="yvt-player" id="yvt-player">
    <div class="yvt-player__video-wrap">
      {% include "components/page-explainer-200hr.njk" %}
    </div>
    <div class="yvt-player__bar">
      <span class="yvt-player__title" data-yj-da>{{ videoTutorial.title_da }}</span>
      <span class="yvt-player__title" data-yj-en hidden>{{ videoTutorial.title_en }}</span>
      <div class="yvt-player__controls">
        <button class="yvt-player__close" id="yvt-player-close" type="button" aria-label="Luk">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
            <line x1="1" y1="1" x2="9" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="9" y1="1" x2="1" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
  {% else %}
  <!-- ── PREVIEW (resting: thumbnail fills top, title bar underneath) ── -->
  <div class="yvt-preview" id="yvt-preview">
    <button class="yvt-preview__thumb" id="yvt-thumb" type="button" aria-label="Afspil video guide">
      <img
        src="https://res.cloudinary.com/ddcynsa30/video/upload/so_1,w_496,h_280,c_fill,f_auto,q_auto/{{ videoTutorial.cloudinaryId }}.jpg"
        alt=""
        width="248"
        height="140"
        loading="lazy"
      />
    </button>
    <div class="yvt-preview__bar">
      <p class="yvt-preview__title" data-yj-da>{{ videoTutorial.title_da }}</p>
      <p class="yvt-preview__title" data-yj-en hidden>{{ videoTutorial.title_en }}</p>
    </div>
    <button class="yvt-dismiss" id="yvt-dismiss" type="button" aria-label="Luk">
      <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
        <line x1="1" y1="1" x2="9" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        <line x1="9" y1="1" x2="1" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
      </svg>
    </button>
  </div>

  <!-- ── PLAYER (expanded: video above, title + controls bar underneath) ── -->
  <div class="yvt-player" id="yvt-player" hidden>
    <div class="yvt-player__video-wrap">
      <video
        id="yvt-video"
        class="yvt-player__video"
        controls
        playsinline
        preload="none"
        poster="https://res.cloudinary.com/ddcynsa30/video/upload/so_1,w_640,h_360,c_fill,f_auto,q_auto/{{ videoTutorial.cloudinaryId }}.jpg"
      ></video>
    </div>
    <div class="yvt-player__bar">
      <span class="yvt-player__title" data-yj-da>{{ videoTutorial.title_da }}</span>
      <span class="yvt-player__title" data-yj-en hidden>{{ videoTutorial.title_en }}</span>
      <div class="yvt-player__controls">
        <button class="yvt-player__minimize" id="yvt-minimize" type="button" aria-label="Minimer">
          <svg width="12" height="2" viewBox="0 0 12 2" fill="none"><line x1="1" y1="1" x2="11" y2="1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <button class="yvt-player__close" id="yvt-player-close" type="button" aria-label="Luk">
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none">
            <line x1="1" y1="1" x2="9" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <line x1="9" y1="1" x2="1" y2="9" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
  {% endif %}

</div>

{% if not videoTutorial.explainer %}
<script>
  window.__yvt = {
    src: 'https://res.cloudinary.com/ddcynsa30/video/upload/f_auto,q_auto/{{ videoTutorial.cloudinaryId }}.mp4',
    delay: {{ videoTutorial.delay or 3000 }}
  };
</script>
{% else %}
<script>
  window.__yvt = { explainer: true, delay: {{ videoTutorial.delay or 3000 }} };
</script>
{% endif %}
{% endif %}
