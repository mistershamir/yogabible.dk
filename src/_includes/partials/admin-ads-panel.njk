{# ══════════════════════════════════════════════════════
   Meta Ads Manager Panel — Campaign management for YB + HYC
   ══════════════════════════════════════════════════════ #}

<div class="yb-ads__header">
  <div class="yb-admin__view-head">
    <h2>{{ t.ads_title or "Meta Ads Manager" }}</h2>
    <div class="yb-ads__toolbar">
      <select class="yb-admin__select yb-ads__account-select" id="yb-ads-account">
        <option value="">{{ t.ads_loading_accounts or "Loading…" }}</option>
      </select>
      <select class="yb-admin__select yb-ads__range-select" id="yb-ads-range">
        <option value="1">{{ t.ads_today or "I dag" }}</option>
        <option value="7" selected>{{ t.ads_last_7d or "Sidste 7 dage" }}</option>
        <option value="14">{{ t.ads_last_14d or "Sidste 14 dage" }}</option>
        <option value="28">{{ t.ads_last_28d or "Sidste 28 dage" }}</option>
        <option value="30">{{ t.ads_last_30d or "Sidste 30 dage" }}</option>
        <option value="90">{{ t.ads_last_90d or "Sidste 90 dage" }}</option>
      </select>
      <button class="yb-btn yb-btn--outline yb-ads__refresh-btn" type="button" id="yb-ads-refresh">
        ↻ {{ t.ads_refresh or "Opdater" }}
      </button>
    </div>
  </div>
  <div class="yb-admin__section-divider"></div>
</div>

{# Breadcrumb #}
<div class="yb-ads__breadcrumb" id="yb-ads-breadcrumb"></div>

{# Dynamic content area — rendered by ads-admin.js #}
<div id="yb-ads-content">
  <p class="yb-admin__muted">{{ t.ads_select_account or "Vælg en konto for at begynde" }}</p>
</div>
