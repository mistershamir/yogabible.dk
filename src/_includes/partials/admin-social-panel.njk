  {# Highlights section #}
  <div class="yb-social__stories-section">
    <h3>{{ t.social_story_highlights or "Story Highlights" }}</h3>
    <p class="yb-admin__muted">{{ t.social_story_highlights_desc or "Organize published stories into permanent highlight groups." }}</p>
    <div id="yb-social-story-highlights-list"></div>
  </div>
</div>

<div class="yb-social__composer-modal" id="yb-social-composer" hidden>
  <div class="yb-social__composer-overlay" data-action="social-composer-close"></div>
  <div class="yb-social__composer-box">

    {# Header #}
    <div class="yb-social__composer-header">
      <h3 id="yb-social-composer-title">{{ t.social_composer_new or "New Post" }}</h3>
      <button type="button" data-action="social-composer-close">&times;</button>
    </div>

    {# Body: Editor + Preview #}
    <div class="yb-social__composer-body">

      {# Left: Editor #}
      <div class="yb-social__composer-editor">

        {# Platform toggles #}
        <div class="yb-social__composer-platforms" id="yb-social-composer-platforms">
          <label class="yb-social__platform-toggle">
            <input type="checkbox" name="platform" value="instagram" id="yb-social-p-ig">
            <span class="yb-social__platform-label">IG</span>
          </label>
          <label class="yb-social__platform-toggle">
            <input type="checkbox" name="platform" value="facebook" id="yb-social-p-fb">
            <span class="yb-social__platform-label">FB</span>
          </label>
          <label class="yb-social__platform-toggle">
            <input type="checkbox" name="platform" value="tiktok" id="yb-social-p-tt">
            <span class="yb-social__platform-label">TT</span>
          </label>
          <label class="yb-social__platform-toggle">
            <input type="checkbox" name="platform" value="linkedin" id="yb-social-p-li">
            <span class="yb-social__platform-label">LI</span>
          </label>
          <label class="yb-social__platform-toggle">
            <input type="checkbox" name="platform" value="youtube" id="yb-social-p-yt">
            <span class="yb-social__platform-label">YT</span>
          </label>
          <label class="yb-social__platform-toggle">
            <input type="checkbox" name="platform" value="pinterest" id="yb-social-p-pin">
            <span class="yb-social__platform-label">PIN</span>
          </label>
        </div>

        {# Caption #}
        <div class="yb-admin__field">
          <label for="yb-social-caption">{{ t.social_caption or "Caption" }}</label>
          <textarea id="yb-social-caption" rows="6" placeholder="{{ t.social_caption_placeholder or 'Write your caption...' }}"></textarea>
          <span class="yb-social__char-count" id="yb-social-char-count">0 / 2200</span>
        </div>

        {# Media #}
        <div class="yb-social__media-section">
          <label>{{ t.social_media or "Media" }}</label>
          <div class="yb-social__media-drop" id="yb-social-media-drop">
            <p>{{ t.social_media_drag or "Drag & drop files here or" }}</p>
            <div class="yb-social__media-btns">
              <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-browse-media">{{ t.social_browse_library or "Browse Library" }}</button>
              <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-upload-media">{{ t.social_upload or "Upload" }}</button>
              <button type="button" class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-canva-composer" title="Design with Canva AI">🎨 {{ t.social_design_canva or "Design with Canva" }}</button>
              <input type="file" id="yb-social-file-input" multiple accept="image/*,video/*" hidden>
            </div>
          </div>
          <div class="yb-social__media-preview" id="yb-social-media-preview"></div>
          <p class="yb-social__carousel-hint" id="yb-social-carousel-hint" hidden>
            ↕ {{ t.social_carousel_hint or "Drag to reorder slides" }}
          </p>
          <div class="yb-social__media-type-row" id="yb-social-media-type-row" hidden>
            <label>{{ t.social_media_type or "Post Type" }}</label>
            <div class="yb-social__media-type-options">
              <label class="yb-social__media-type-opt"><input type="radio" name="social-media-type" value="auto" checked> {{ t.social_type_auto or "Auto" }}</label>
              <label class="yb-social__media-type-opt"><input type="radio" name="social-media-type" value="reels"> {{ t.social_type_reels or "Reel" }}</label>
              <label class="yb-social__media-type-opt"><input type="radio" name="social-media-type" value="stories"> {{ t.social_type_stories or "Story" }}</label>
            </div>
          </div>
        </div>

        {# Hashtags #}
        <div class="yb-admin__field">
          <label for="yb-social-hashtags">{{ t.social_hashtags_label or "Hashtags" }}</label>
          <div class="yb-social__hashtag-input-row">
            <textarea id="yb-social-hashtags" rows="2" placeholder="#yoga #yogateacher"></textarea>
            <select id="yb-social-hashtag-set-select" class="yb-admin__select">
              <option value="">{{ t.social_load_set or "Load set..." }}</option>
            </select>
          </div>
          <div class="yb-social__hashtag-suggest" id="yb-social-hashtag-suggest" hidden></div>
        </div>

        {# First Comment (IG only) #}
        <div class="yb-admin__field" id="yb-social-first-comment-field" hidden>
          <label for="yb-social-first-comment">{{ t.social_first_comment or "First Comment (Instagram)" }}</label>
          <textarea id="yb-social-first-comment" rows="2" placeholder="{{ t.social_first_comment_placeholder or 'Additional hashtags or engagement prompt...' }}"></textarea>
        </div>

        {# Location #}
        <div class="yb-admin__field">
          <label for="yb-social-location">{{ t.social_location or "Location" }}</label>
          <input type="text" id="yb-social-location" placeholder="{{ t.social_location_placeholder or 'Yoga Bible, Copenhagen' }}">
        </div>

        {# Content Pillar #}
        <div class="yb-admin__field">
          <label for="yb-social-pillar">{{ t.social_content_pillar or "Content Pillar" }}</label>
          <select id="yb-social-pillar">
            <option value="">{{ t.social_pillar_none or "— Select —" }}</option>
            <option value="educational">📚 {{ t.social_pillar_educational or "Educational" }}</option>
            <option value="social_proof">🌟 {{ t.social_pillar_social_proof or "Social Proof" }}</option>
            <option value="lifestyle">🌿 {{ t.social_pillar_lifestyle or "Lifestyle" }}</option>
            <option value="promotional">🎯 {{ t.social_pillar_promotional or "Promotional" }}</option>
            <option value="behind_scenes">🎬 {{ t.social_pillar_behind_scenes or "Behind the Scenes" }}</option>
            <option value="community">🤝 {{ t.social_pillar_community or "Community" }}</option>
          </select>
        </div>

        {# UTM Builder #}
        <details class="yb-social__utm-builder">
          <summary>{{ t.social_utm_builder or "🔗 UTM Link Builder" }}</summary>
          <div class="yb-social__utm-fields">
            <div class="yb-admin__field">
              <label for="yb-social-utm-url">URL</label>
              <input type="text" id="yb-social-utm-url" placeholder="https://yogabible.dk/..." value="https://yogabible.dk">
            </div>
            <div class="yb-social__utm-grid">
              <div class="yb-admin__field">
                <label for="yb-social-utm-source">Source</label>
                <select id="yb-social-utm-source" class="yb-admin__select">
                  <option value="instagram">instagram</option>
                  <option value="facebook">facebook</option>
                  <option value="tiktok">tiktok</option>
                  <option value="linkedin">linkedin</option>
                </select>
              </div>
              <div class="yb-admin__field">
                <label for="yb-social-utm-medium">Medium</label>
                <input type="text" id="yb-social-utm-medium" value="social" placeholder="social">
              </div>
              <div class="yb-admin__field">
                <label for="yb-social-utm-campaign">Campaign</label>
                <input type="text" id="yb-social-utm-campaign" placeholder="e.g. july-cohort-2026">
              </div>
            </div>
            <div class="yb-social__utm-result">
              <input type="text" id="yb-social-utm-result" readonly placeholder="{{ t.social_utm_result or 'Generated URL will appear here' }}">
              <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-utm-copy">{{ t.social_copy or "Copy" }}</button>
              <button type="button" class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-utm-insert">{{ t.social_utm_insert or "Insert in Caption" }}</button>
            </div>
          </div>
        </details>

        {# Schedule #}
        <div class="yb-social__schedule-section">
          <label>{{ t.social_when or "When to post" }}</label>
          <div class="yb-social__schedule-options">
            <label class="yb-social__schedule-radio">
              <input type="radio" name="social-schedule" value="now" checked> {{ t.social_post_now or "Post Now" }}
            </label>
            <label class="yb-social__schedule-radio">
              <input type="radio" name="social-schedule" value="schedule"> {{ t.social_schedule or "Schedule" }}
            </label>
            <label class="yb-social__schedule-radio">
              <input type="radio" name="social-schedule" value="queue"> {{ t.social_queue or "Queue" }}
              <span class="yb-social__queue-hint">{{ t.social_queue_hint or "(next best slot)" }}</span>
            </label>
          </div>
          <div class="yb-social__schedule-picker" id="yb-social-schedule-picker" hidden>
            <input type="date" id="yb-social-schedule-date">
            <input type="time" id="yb-social-schedule-time" value="10:00">
            <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-best-time" title="{{ t.social_best_time_title or 'Suggest best time' }}">&#9200; {{ t.social_best_time or "Best Time" }}</button>
            <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-smart-schedule" title="{{ t.social_smart_schedule_title or 'Auto-pick optimal slot' }}">&#9889; {{ t.social_smart_schedule or "Smart Schedule" }}</button>
          </div>
        </div>

        {# AI Assistant #}
        <div class="yb-social__ai-section">
          <button type="button" class="yb-btn yb-btn--outline" data-action="social-ai-toggle">&#129302; {{ t.social_ai_assistant or "AI Assistant" }}</button>
          <div class="yb-social__ai-panel" id="yb-social-ai-panel" hidden>
            <div class="yb-admin__field">
              <label for="yb-social-ai-topic">{{ t.social_ai_topic or "Topic / Prompt" }}</label>
              <input type="text" id="yb-social-ai-topic" placeholder="{{ t.social_ai_topic_placeholder or 'e.g., Benefits of morning yoga practice' }}">
            </div>
            <div class="yb-social__ai-btns">
              <button type="button" class="yb-btn yb-btn--sm yb-btn--outline" data-action="social-ai-caption">Generate Caption</button>
              <button type="button" class="yb-btn yb-btn--sm yb-btn--outline" data-action="social-ai-hashtags">Generate Hashtags</button>
              <button type="button" class="yb-btn yb-btn--sm yb-btn--outline" data-action="social-ai-improve">Improve Caption</button>
            </div>
            <div class="yb-social__ai-btns" style="margin-top:6px">
              <button type="button" class="yb-btn yb-btn--sm yb-btn--outline" data-action="social-ai-bilingual">DA + EN Bilingual</button>
              <button type="button" class="yb-btn yb-btn--sm yb-btn--outline" data-action="social-ai-adapt-tone">Adapt Per Platform</button>
              <button type="button" class="yb-btn yb-btn--sm yb-btn--outline" data-action="social-ai-translate">Translate DA/EN</button>
            </div>
            <div class="yb-social__ai-btns" style="margin-top:6px">
              <button type="button" class="yb-btn yb-btn--sm yb-btn--primary" data-action="social-ai-repurpose">Repurpose Blog Post</button>
            </div>
            {# Blog content input for repurpose (hidden until clicked) #}
            <div class="yb-admin__field" id="yb-social-ai-blog-field" hidden style="margin-top:10px">
              <label for="yb-social-ai-blog-content">Blog / Article Content</label>
              <textarea id="yb-social-ai-blog-content" rows="4" placeholder="Paste your blog post or article text here..."></textarea>
              <div style="margin-top:8px">
                <button type="button" class="yb-btn yb-btn--sm yb-btn--primary" data-action="social-ai-repurpose-go">Generate 5 Posts</button>
              </div>
            </div>
            <div class="yb-social__ai-results" id="yb-social-ai-results"></div>
          </div>
        </div>

        {# Per-Platform Captions #}
        <div class="yb-social__platform-captions-section">
          <button type="button" class="yb-btn yb-btn--outline" data-action="social-platform-captions-toggle">&#128221; {{ t.social_platform_captions or "Per-Platform Captions" }}</button>
          <div class="yb-social__platform-captions-panel" id="yb-social-platform-captions" hidden>
            <div class="yb-social__platform-captions-head">
              <span class="yb-admin__muted">{{ t.social_platform_captions_desc or "Override the main caption for specific platforms" }}</span>
              <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-platform-cap-ai-all">&#129302; {{ t.social_ai_adapt_all or "AI Adapt All" }}</button>
            </div>
            <div class="yb-social__platform-caption-tabs" id="yb-social-platform-caption-tabs"></div>
            <div class="yb-social__platform-caption-body" id="yb-social-platform-caption-body"></div>
          </div>
        </div>

      </div>{# /composer-editor #}

      {# Right: Preview with platform tabs #}
      <div class="yb-social__composer-preview">
        <div class="yb-social__preview-tabs" id="yb-social-preview-tabs">
          <button type="button" class="yb-social__preview-tab is-active" data-action="social-preview-tab" data-platform="instagram">IG</button>
          <button type="button" class="yb-social__preview-tab" data-action="social-preview-tab" data-platform="facebook">FB</button>
          <button type="button" class="yb-social__preview-tab" data-action="social-preview-tab" data-platform="tiktok">TT</button>
          <button type="button" class="yb-social__preview-tab" data-action="social-preview-tab" data-platform="linkedin">LI</button>
        </div>
        <div class="yb-social__preview-device" id="yb-social-preview-device" data-preview-platform="instagram">
          <div class="yb-social__preview-header" id="yb-social-preview-header">
            <span class="yb-social__preview-avatar">YB</span>
            <span class="yb-social__preview-username">yogabible</span>
          </div>
          <div class="yb-social__preview-media" id="yb-social-preview-media">
            <p class="yb-admin__muted">{{ t.social_no_media or "No media selected" }}</p>
          </div>
          <div class="yb-social__preview-caption" id="yb-social-preview-caption">
            <strong>yogabible</strong> <span>{{ t.social_preview_placeholder or "Your caption will appear here..." }}</span>
          </div>
          <div class="yb-social__preview-char-info" id="yb-social-preview-char-info"></div>
        </div>
      </div>

    </div>{# /composer-body #}

    {# Footer #}
    <div class="yb-social__composer-footer">
      <input type="hidden" id="yb-social-post-id">
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-save-as-template" title="{{ t.social_save_as_template or 'Save as Template' }}">&#9734; {{ t.social_save_as_template or "Save as Template" }}</button>
      <button type="button" class="yb-btn yb-btn--outline" data-action="social-save-draft">{{ t.social_save_draft or "Save Draft" }}</button>
      <button type="button" class="yb-btn yb-btn--primary" data-action="social-publish-post" id="yb-social-publish-btn">{{ t.social_post_now or "Post Now" }}</button>
    </div>

  </div>{# /composer-box #}
</div>{# /composer-modal #}

{# ════════════════════════════════════════════════════════════════════════════ #}
{# MEDIA BROWSER MODAL                                                        #}
{# ════════════════════════════════════════════════════════════════════════════ #}
<div class="yb-social__media-modal" id="yb-social-media-browser" hidden>
  <div class="yb-social__media-modal-overlay" data-action="social-media-browser-close"></div>
  <div class="yb-social__media-modal-box">

    <div class="yb-social__media-modal-header">
      <h3>{{ t.social_media_library or "Media Library" }}</h3>
      <button type="button" data-action="social-media-browser-close">&times;</button>
    </div>

    <div class="yb-social__media-modal-nav" id="yb-social-media-breadcrumb">
      <button type="button" data-action="social-media-nav-root">social</button>
    </div>

    <div class="yb-social__media-modal-grid" id="yb-social-media-grid">
      {# Rendered by JS: folders + image/video thumbnails #}
    </div>

    <div class="yb-social__media-modal-footer">
      <span id="yb-social-media-selected-count">{{ t.social_selected_count or "0 selected" }}</span>
      <button type="button" class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-media-confirm">{{ t.social_add_selected or "Add Selected" }}</button>
    </div>

  </div>
</div>
