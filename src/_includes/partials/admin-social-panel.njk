{# ── Social Media Management Admin Panel ── #}

{# Sub-Navigation Bar #}
<div class="yb-social__nav" id="yb-social-nav">
  <button class="yb-social__nav-btn is-active" type="button" data-action="social-nav-accounts">{{ t.social_nav_accounts or "Accounts" }}</button>
  <button class="yb-social__nav-btn" type="button" data-action="social-nav-calendar">{{ t.social_nav_calendar or "Calendar" }}</button>
  <button class="yb-social__nav-btn" type="button" data-action="social-nav-posts">{{ t.social_nav_posts or "Posts" }}</button>
  <button class="yb-social__nav-btn" type="button" data-action="social-nav-analytics">{{ t.social_nav_analytics or "Analytics" }}</button>
  <button class="yb-social__nav-btn" type="button" data-action="social-nav-inbox">{{ t.social_nav_inbox or "Inbox" }} <span class="yb-social__inbox-badge" id="yb-social-inbox-badge" hidden>0</span></button>
  <button class="yb-social__nav-btn" type="button" data-action="social-nav-hashtags">{{ t.social_nav_hashtags or "Hashtags" }}</button>
  <button class="yb-social__nav-btn" type="button" data-action="social-nav-templates">{{ t.social_nav_templates or "Templates" }}</button>
  <button class="yb-social__nav-btn" type="button" data-action="social-nav-competitors">{{ t.social_nav_competitors or "Competitors" }}</button>
  <button class="yb-social__nav-btn" type="button" data-action="social-nav-abtesting">{{ t.social_nav_abtesting or "A/B Tests" }}</button>
  <button class="yb-social__nav-btn" type="button" data-action="social-nav-library">{{ t.social_nav_library or "Library" }}</button>
  <button class="yb-social__nav-btn" type="button" data-action="social-nav-stories">{{ t.social_nav_stories or "Stories" }}</button>
</div>

{# ════════════════════════════════════════════════════════════════════════════ #}
{# VIEW: Accounts                                                             #}
{# ════════════════════════════════════════════════════════════════════════════ #}
<div id="yb-social-v-accounts">
  <div class="yb-admin__view-head">
    <h2>{{ t.social_accounts_title or "Connected Accounts" }}</h2>
    <div style="display:flex;gap:8px">
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-init-cdn-folders" title="{{ t.social_init_folders or 'Create CDN folder structure' }}">📁 {{ t.social_init_folders or "Init CDN" }}</button>
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-refresh-accounts">&#8635; {{ t.social_refresh or "Refresh" }}</button>
    </div>
  </div>

  <div class="yb-social__accounts-grid" id="yb-social-accounts-grid">

    {# Instagram #}
    <div class="yb-social__account-card" data-platform="instagram">
      <div class="yb-social__account-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
      </div>
      <div class="yb-social__account-info">
        <h3 class="yb-social__account-name">Instagram</h3>
        <p class="yb-social__account-handle" id="yb-social-ig-handle">{{ t.social_not_connected or "Not connected" }}</p>
        <p class="yb-social__account-followers" id="yb-social-ig-followers"></p>
      </div>
      <div class="yb-social__account-actions">
        <button class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-connect" data-platform="instagram">{{ t.social_connect or "Connect" }}</button>
        <button class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-disconnect" data-platform="instagram" hidden>{{ t.social_disconnect or "Disconnect" }}</button>
      </div>
      <span class="yb-social__account-status" id="yb-social-ig-status">&#9679;</span>
    </div>

    {# Facebook #}
    <div class="yb-social__account-card" data-platform="facebook">
      <div class="yb-social__account-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
        </svg>
      </div>
      <div class="yb-social__account-info">
        <h3 class="yb-social__account-name">Facebook</h3>
        <p class="yb-social__account-handle" id="yb-social-fb-handle">{{ t.social_not_connected or "Not connected" }}</p>
        <p class="yb-social__account-followers" id="yb-social-fb-followers"></p>
      </div>
      <div class="yb-social__account-actions">
        <button class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-connect" data-platform="facebook">{{ t.social_connect or "Connect" }}</button>
        <button class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-disconnect" data-platform="facebook" hidden>{{ t.social_disconnect or "Disconnect" }}</button>
      </div>
      <span class="yb-social__account-status" id="yb-social-fb-status">&#9679;</span>
    </div>

    {# TikTok #}
    <div class="yb-social__account-card" data-platform="tiktok">
      <div class="yb-social__account-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
        </svg>
      </div>
      <div class="yb-social__account-info">
        <h3 class="yb-social__account-name">TikTok</h3>
        <p class="yb-social__account-handle" id="yb-social-tt-handle">{{ t.social_not_connected or "Not connected" }}</p>
        <p class="yb-social__account-followers" id="yb-social-tt-followers"></p>
      </div>
      <div class="yb-social__account-actions">
        <button class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-connect" data-platform="tiktok">{{ t.social_connect or "Connect" }}</button>
        <button class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-disconnect" data-platform="tiktok" hidden>{{ t.social_disconnect or "Disconnect" }}</button>
      </div>
      <span class="yb-social__account-status" id="yb-social-tt-status">&#9679;</span>
    </div>

    {# LinkedIn #}
    <div class="yb-social__account-card" data-platform="linkedin">
      <div class="yb-social__account-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="2" ry="2"/>
          <line x1="8" y1="11" x2="8" y2="16"/>
          <line x1="8" y1="8" x2="8.01" y2="8"/>
          <path d="M12 16v-5a2 2 0 0 1 4 0v5"/>
        </svg>
      </div>
      <div class="yb-social__account-info">
        <h3 class="yb-social__account-name">LinkedIn</h3>
        <p class="yb-social__account-handle" id="yb-social-li-handle">{{ t.social_not_connected or "Not connected" }}</p>
        <p class="yb-social__account-followers" id="yb-social-li-followers"></p>
      </div>
      <div class="yb-social__account-actions">
        <button class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-connect" data-platform="linkedin">{{ t.social_connect or "Connect" }}</button>
        <button class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-disconnect" data-platform="linkedin" hidden>{{ t.social_disconnect or "Disconnect" }}</button>
      </div>
      <span class="yb-social__account-status" id="yb-social-li-status">&#9679;</span>
    </div>

    {# YouTube #}
    <div class="yb-social__account-card" data-platform="youtube">
      <div class="yb-social__account-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19.13C5.12 19.56 12 19.56 12 19.56s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.43z"/>
          <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"/>
        </svg>
      </div>
      <div class="yb-social__account-info">
        <h3 class="yb-social__account-name">YouTube</h3>
        <p class="yb-social__account-handle" id="yb-social-yt-handle">{{ t.social_not_connected or "Not connected" }}</p>
        <p class="yb-social__account-followers" id="yb-social-yt-followers"></p>
      </div>
      <div class="yb-social__account-actions">
        <button class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-connect" data-platform="youtube">{{ t.social_connect or "Connect" }}</button>
        <button class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-disconnect" data-platform="youtube" hidden>{{ t.social_disconnect or "Disconnect" }}</button>
      </div>
      <span class="yb-social__account-status" id="yb-social-yt-status">&#9679;</span>
    </div>

    {# Pinterest #}
    <div class="yb-social__account-card" data-platform="pinterest">
      <div class="yb-social__account-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="12" y1="17" x2="12" y2="22"/>
          <path d="M5 12V7a7 7 0 0 1 14 0v5a5 5 0 0 1-10 0V7a3 3 0 0 1 6 0v5"/>
        </svg>
      </div>
      <div class="yb-social__account-info">
        <h3 class="yb-social__account-name">Pinterest</h3>
        <p class="yb-social__account-handle" id="yb-social-pin-handle">{{ t.social_not_connected or "Not connected" }}</p>
        <p class="yb-social__account-followers" id="yb-social-pin-followers"></p>
      </div>
      <div class="yb-social__account-actions">
        <button class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-connect" data-platform="pinterest">{{ t.social_connect or "Connect" }}</button>
        <button class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-disconnect" data-platform="pinterest" hidden>{{ t.social_disconnect or "Disconnect" }}</button>
      </div>
      <span class="yb-social__account-status" id="yb-social-pin-status">&#9679;</span>
    </div>

  </div>
</div>

{# ════════════════════════════════════════════════════════════════════════════ #}
{# VIEW: Calendar                                                             #}
{# ════════════════════════════════════════════════════════════════════════════ #}
<div id="yb-social-v-calendar" hidden>
  <div class="yb-social__calendar-header">
    <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-cal-prev">&larr;</button>
    <h2 id="yb-social-cal-month">{{ t.social_calendar_loading or "March 2026" }}</h2>
    <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-cal-next">&rarr;</button>
    <button type="button" class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-new-post">+ {{ t.social_new_post or "New Post" }}</button>
    <button type="button" class="yb-btn yb-btn--outline yb-btn--sm yb-social__ai-plan-btn" data-action="social-ai-plan">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
      {{ t.social_ai_plan or "AI Plan" }}
    </button>
    <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-cal-ai-toggle">
      &#128197; {{ t.social_cal_ai or "AI Calendar" }}
    </button>
  </div>

  {# AI Calendar Generator Panel #}
  <div class="yb-social__cal-ai-panel" id="yb-social-cal-ai-panel" hidden>
    <div class="yb-social__cal-ai-head">
      <h3>{{ t.social_cal_ai_title or "AI Content Calendar" }}</h3>
      <p class="yb-admin__muted">{{ t.social_cal_ai_desc or "Auto-generate a week of post ideas with bilingual captions" }}</p>
    </div>
    <div style="display:flex;gap:10px;align-items:end;margin:10px 0">
      <div class="yb-admin__field" style="flex:0 0 80px">
        <label>{{ t.social_cal_ai_days or "Days" }}</label>
        <input type="number" id="yb-social-cal-ai-days" value="7" min="3" max="14">
      </div>
      <div class="yb-admin__field" style="flex:1">
        <label>{{ t.social_cal_ai_notes or "Focus / Notes (optional)" }}</label>
        <input type="text" id="yb-social-cal-ai-notes" placeholder="{{ t.social_cal_ai_notes_ph or 'e.g., July cohort launch, summer vibes...' }}">
      </div>
      <button type="button" class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-cal-ai-generate">{{ t.social_generate or "Generate" }}</button>
    </div>
    <div id="yb-social-cal-ai-results"></div>
  </div>

  {# AI Content Plan Modal #}
  <div class="yb-social__ai-plan-modal" id="yb-social-ai-plan-modal" hidden>
    <div class="yb-social__ai-plan-overlay" data-action="social-ai-plan-close"></div>
    <div class="yb-social__ai-plan-box">
      <h3>{{ t.social_ai_plan_title or "AI Content Planner" }}</h3>
      <p class="yb-admin__muted">{{ t.social_ai_plan_desc or "Claude will generate a content plan based on your goals and themes." }}</p>
      <div class="yb-admin__field">
        <label for="yb-social-ai-plan-days">{{ t.social_ai_plan_days or "Days to plan" }}</label>
        <select id="yb-social-ai-plan-days">
          <option value="7">7 {{ t.social_days or "days" }}</option>
          <option value="14" selected>14 {{ t.social_days or "days" }}</option>
          <option value="30">30 {{ t.social_days or "days" }}</option>
        </select>
      </div>
      <div class="yb-admin__field">
        <label for="yb-social-ai-plan-themes">{{ t.social_ai_plan_themes or "Focus themes (optional)" }}</label>
        <input type="text" id="yb-social-ai-plan-themes" placeholder="{{ t.social_ai_plan_themes_placeholder or 'e.g., July cohort, summer yoga, Copenhagen' }}">
      </div>
      <div class="yb-admin__field">
        <label for="yb-social-ai-plan-goals">{{ t.social_ai_plan_goals or "Campaign goals (optional)" }}</label>
        <input type="text" id="yb-social-ai-plan-goals" placeholder="{{ t.social_ai_plan_goals_placeholder or 'e.g., Drive July enrollment, increase engagement' }}">
      </div>
      <div class="yb-social__ai-plan-results" id="yb-social-ai-plan-results" hidden></div>
      <div class="yb-social__ai-plan-actions">
        <button type="button" class="yb-btn yb-btn--outline" data-action="social-ai-plan-close">{{ t.social_cancel or "Cancel" }}</button>
        <button type="button" class="yb-btn yb-btn--primary" data-action="social-ai-plan-generate" id="yb-social-ai-plan-generate-btn">{{ t.social_ai_plan_generate or "Generate Plan" }}</button>
      </div>
    </div>
  </div>

  <div class="yb-social__calendar-weekdays">
    <span>{{ t.social_cal_mon or "Mon" }}</span>
    <span>{{ t.social_cal_tue or "Tue" }}</span>
    <span>{{ t.social_cal_wed or "Wed" }}</span>
    <span>{{ t.social_cal_thu or "Thu" }}</span>
    <span>{{ t.social_cal_fri or "Fri" }}</span>
    <span>{{ t.social_cal_sat or "Sat" }}</span>
    <span>{{ t.social_cal_sun or "Sun" }}</span>
  </div>

  <div class="yb-social__calendar-grid" id="yb-social-cal-grid">
    {# Days rendered by JS #}
  </div>

  <div class="yb-social__calendar-sidebar" id="yb-social-cal-sidebar" hidden>
    <h3 id="yb-social-cal-sidebar-title">{{ t.social_cal_posts_for or "Posts for" }}</h3>
    <div id="yb-social-cal-sidebar-posts"></div>
  </div>
</div>

{# ════════════════════════════════════════════════════════════════════════════ #}
{# VIEW: Posts List                                                            #}
{# ════════════════════════════════════════════════════════════════════════════ #}
<div id="yb-social-v-posts" hidden>
  <div class="yb-admin__view-head">
    <h2>{{ t.social_posts_title or "Posts" }}</h2>
    <div class="yb-social__posts-toolbar">
      <button type="button" class="yb-btn yb-btn--primary yb-btn--sm" data-action="social-new-post">+ {{ t.social_new_post or "New Post" }}</button>
    </div>
  </div>

  {# Status filter tabs #}
  <div class="yb-social__filter-bar" id="yb-social-status-filter">
    <button class="yb-social__filter-btn is-active" type="button" data-action="social-filter-status" data-status="all">{{ t.social_filter_all or "All" }}</button>
    <button class="yb-social__filter-btn" type="button" data-action="social-filter-status" data-status="draft">{{ t.social_filter_draft or "Drafts" }}</button>
    <button class="yb-social__filter-btn" type="button" data-action="social-filter-status" data-status="pending_review">{{ t.social_filter_pending or "Pending" }}</button>
    <button class="yb-social__filter-btn" type="button" data-action="social-filter-status" data-status="approved">{{ t.social_filter_approved or "Approved" }}</button>
    <button class="yb-social__filter-btn" type="button" data-action="social-filter-status" data-status="scheduled">{{ t.social_filter_scheduled or "Scheduled" }}</button>
    <button class="yb-social__filter-btn" type="button" data-action="social-filter-status" data-status="published">{{ t.social_filter_published or "Published" }}</button>
    <button class="yb-social__filter-btn" type="button" data-action="social-filter-status" data-status="failed">{{ t.social_filter_failed or "Failed" }}</button>
  </div>

  {# Bulk actions bar — shown when posts are selected #}
  <div class="yb-social__bulk-bar" id="yb-social-bulk-bar" hidden>
    <label class="yb-social__bulk-select-all">
      <input type="checkbox" id="yb-social-select-all"> {{ t.social_select_all or "Select all" }}
    </label>
    <span class="yb-social__bulk-count" id="yb-social-bulk-count">0 {{ t.social_selected or "selected" }}</span>
    <div class="yb-social__bulk-actions">
      <button type="button" class="yb-btn yb-btn--sm" data-action="social-bulk-schedule">📅 {{ t.social_bulk_schedule or "Schedule" }}</button>
      <button type="button" class="yb-btn yb-btn--sm" data-action="social-bulk-approve">✓ {{ t.social_bulk_approve or "Approve" }}</button>
      <button type="button" class="yb-btn yb-btn--sm" data-action="social-bulk-duplicate">📋 {{ t.social_bulk_duplicate or "Duplicate" }}</button>
      <button type="button" class="yb-btn yb-btn--sm" data-action="social-bulk-smart-schedule">⚡ {{ t.social_smart_schedule or "Smart Schedule" }}</button>
      <button type="button" class="yb-btn yb-btn--sm yb-btn--danger" data-action="social-bulk-delete">🗑 {{ t.social_bulk_delete or "Delete" }}</button>
    </div>
    <button type="button" class="yb-social__bulk-clear" data-action="social-bulk-clear">✕</button>
  </div>

  <div class="yb-social__posts-count" id="yb-social-posts-count"></div>

  <div class="yb-social__posts-grid" id="yb-social-posts-grid">
    {# Post cards rendered by JS #}
  </div>
</div>

{# ════════════════════════════════════════════════════════════════════════════ #}
{# VIEW: Analytics                                                             #}
{# ════════════════════════════════════════════════════════════════════════════ #}
<div id="yb-social-v-analytics" hidden>
  <div class="yb-admin__view-head">
    <h2>{{ t.social_analytics_title or "Analytics" }}</h2>
    <div style="display:flex;gap:8px;align-items:center">
      <select class="yb-admin__select" id="yb-social-analytics-range">
        <option value="7">{{ t.social_range_7d or "Last 7 days" }}</option>
        <option value="30" selected>{{ t.social_range_30d or "Last 30 days" }}</option>
        <option value="90">{{ t.social_range_90d or "Last 90 days" }}</option>
      </select>
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="social-sync-metrics">&#8635; {{ t.social_sync or "Sync" }}</button>
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm yb-social__ai-plan-btn" data-action="social-ai-insights">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
        {{ t.social_ai_insights or "AI Insights" }}
      </button>
    </div>
  </div>
  <div class="yb-social__last-sync" id="yb-social-last-sync" hidden></div>
  <div class="yb-social__ai-insights-panel" id="yb-social-ai-insights-panel" hidden>
    <div class="yb-social__ai-insights-header">
      <h3>{{ t.social_ai_insights_title or "AI Performance Insights" }}</h3>
      <button type="button" data-action="social-ai-insights-close" class="yb-btn yb-btn--outline yb-btn--sm">✕</button>
    </div>
    <div id="yb-social-ai-insights-body"><p class="yb-admin__muted">{{ t.social_ai_analyzing or "Analyzing your metrics..." }}</p></div>
  </div>

  {# Stat cards #}
  <div class="yb-admin__stats-grid">
    <div class="yb-admin__stat-card">
      <span class="yb-admin__stat-value" id="yb-social-stat-followers">&mdash;</span>
      <span class="yb-admin__stat-label">{{ t.social_stat_followers or "Total Followers" }}</span>
    </div>
    <div class="yb-admin__stat-card">
      <span class="yb-admin__stat-value" id="yb-social-stat-posts">&mdash;</span>
      <span class="yb-admin__stat-label">{{ t.social_stat_posts or "Posts" }}</span>
    </div>
    <div class="yb-admin__stat-card">
      <span class="yb-admin__stat-value" id="yb-social-stat-engagement">&mdash;</span>
      <span class="yb-admin__stat-label">{{ t.social_stat_engagement or "Avg Engagement" }}</span>
    </div>
    <div class="yb-admin__stat-card">
