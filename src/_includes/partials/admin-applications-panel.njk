{# ── Application List View ── #}
<div id="yb-admin-v-app-list">
  <div class="yb-admin__view-head">
    <h2>{{ t.apps_title }}</h2>
    <div class="yb-lead__toolbar-right">
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="app-bulk-email">&#9993;&#65039; {{ t.apps_bulk_email }}</button>
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="app-bulk-sms">&#128241; {{ t.apps_bulk_sms }}</button>
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" id="yb-app-archive-toggle" data-action="toggle-show-archived-apps">&#128230; {{ t.apps_show_archived }}</button>
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="apps-export-csv">&#128229; {{ t.apps_export }}</button>
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="apps-refresh">&#8635; {{ t.leads_refresh }}</button>
    </div>
  </div>

  {# Stats #}
  <div class="yb-lead__stats-grid" id="yb-app-stats"></div>

  {# Search + Filters #}
  <div class="yb-lead__filter-bar">
    <form id="yb-app-search-form" class="yb-lead__search-form">
      <input type="text" id="yb-app-search-input" placeholder="{{ t.apps_search_placeholder }}" class="yb-lead__search-input">
    </form>
    <select id="yb-app-status-filter" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.leads_all_statuses }}</option>
      <option value="Pending">&#9203; Pending</option>
      <option value="Under Review">&#128269; Under Review</option>
      <option value="Approved">&#9989; Approved</option>
      <option value="Enrolled">&#127891; Enrolled</option>
      <option value="Waitlisted">&#128203; Waitlisted</option>
      <option value="Rejected">&#10060; Rejected</option>
      <option value="Withdrawn">&#8617;&#65039; Withdrawn</option>
      <option value="Completed">&#127942; Completed</option>
    </select>
    <select id="yb-app-type-filter" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.leads_all_types }}</option>
      <option value="ytt">YTT</option>
      <option value="course">Course</option>
      <option value="bundle">Bundle</option>
      <option value="mentorship">Mentorship</option>
    </select>
    <select id="yb-app-track-filter" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.apps_all_tracks }}</option>
      <option value="weekday">Weekday</option>
      <option value="weekend">Weekend</option>
    </select>
    <select id="yb-app-cohort-filter" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.apps_all_cohorts }}</option>
    </select>
  </div>

  {# Result count #}
  <div class="yb-lead__result-bar">
    <span id="yb-app-count" class="yb-lead__count-text"></span>
  </div>

  {# Bulk actions bar (hidden until selections) #}
  <div id="yb-app-bulk-bar" class="yb-lead__bulk-bar" hidden>
    <span id="yb-app-bulk-count" class="yb-lead__bulk-count-text"></span>
    <button class="yb-btn yb-btn--sm yb-btn--outline" data-action="app-bulk-status">&#9881;&#65039; {{ t.apps_bulk_status }}</button>
    <button class="yb-btn yb-btn--sm yb-btn--outline yb-admin__icon-btn--danger" data-action="app-bulk-archive">&#128451; {{ t.apps_bulk_archive }}</button>
    <button class="yb-btn yb-btn--sm yb-btn--outline" data-action="app-deselect-all">&#10006; {{ t.apps_deselect }}</button>
  </div>

  {# Applications table #}
  <div class="yb-admin__table-wrap yb-lead__table-wrap">
    <table class="yb-admin__table yb-lead__table" id="yb-app-table">
      <thead>
        <tr>
          <th class="yb-lead__th-cb"><input type="checkbox" id="yb-app-select-all" title="{{ t.apps_select_all }}"></th>
          <th>{{ t.apps_col_app_id }}</th>
          <th>{{ t.users_col_name }}</th>
          <th>{{ t.users_col_email }}</th>
          <th>{{ t.apps_col_program }}</th>
          <th>{{ t.apps_col_course }}</th>
          <th>{{ t.apps_col_track }}</th>
          <th>{{ t.apps_col_payment }}</th>
          <th>{{ t.apps_col_status }}</th>
          <th>{{ t.leads_col_date }}</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="yb-app-table-body"></tbody>
    </table>
  </div>
</div>

{# ── Application Detail View ── #}
<div id="yb-admin-v-app-detail" hidden>
  <div class="yb-admin__view-head">
    <button class="yb-admin__back-btn" data-action="back-apps">&larr; {{ t.back }}</button>
    <h2 id="yb-app-detail-heading">{{ t.apps_detail_title }}</h2>
  </div>

  {# Application detail cards #}
  <div id="yb-app-detail-card"></div>

  {# Invoice status #}
  <div class="yb-admin__section-divider"></div>
  <div id="yb-app-invoice-status"></div>

  {# Quick actions #}
  <div class="yb-admin__section-divider"></div>
  <h3 class="yb-lead__section-title">{{ t.apps_quick_actions }}</h3>
  <div id="yb-app-actions" class="yb-lead__actions"></div>

  {# Billing quick action #}
  <div style="margin-top:0.5rem">
    <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="billing-from-app" id="yb-app-bill-btn">&#128176; {{ t.billing_bill_applicant }}</button>
    <button type="button" class="yb-btn yb-btn--primary yb-btn--sm" data-action="app-activate-user" id="yb-app-activate-btn" style="margin-left:0.5rem">&#128100; {{ t.apps_activate_user }}</button>
  </div>

  {# Invoice quick view modal #}
  <div id="yb-app-invoice-modal" class="yb-billing__modal-overlay" hidden>
    <div class="yb-billing__modal yb-app-invoice__modal">
      <div class="yb-billing__modal-header">
        <h3 id="yb-app-invoice-modal-title">Invoice</h3>
        <button type="button" class="yb-billing__modal-close" data-action="app-invoice-modal-close">&times;</button>
      </div>
      <div id="yb-app-invoice-modal-body" class="yb-billing__modal-body"></div>
    </div>
  </div>

  {# SMS Conversation #}
  <div class="yb-admin__section-divider"></div>
  <h3 class="yb-lead__section-title">{{ t.apps_sms_conversation }}</h3>
  <div id="yb-app-sms-conversation" class="yb-lead__sms-conversation">
    <p class="yb-lead__empty-text">{{ t.apps_no_messages }}</p>
  </div>

  {# Edit Fields #}
  <div class="yb-admin__section-divider"></div>
  <h3 class="yb-lead__section-title">{{ t.apps_edit_fields }}</h3>
  <form id="yb-app-edit-form" class="yb-admin__form">
    <div class="yb-lead__status-grid">
      <div class="yb-admin__field">
        <label for="yb-app-edit-first-name">{{ t.users_col_name }} ({{ t.apps_personal_info }})</label>
        <input type="text" id="yb-app-edit-first-name" class="yb-admin__select" placeholder="First name">
      </div>
      <div class="yb-admin__field">
        <label for="yb-app-edit-last-name">Last name</label>
        <input type="text" id="yb-app-edit-last-name" class="yb-admin__select" placeholder="Last name">
      </div>
      <div class="yb-admin__field">
        <label for="yb-app-edit-email">{{ t.users_col_email }}</label>
        <input type="email" id="yb-app-edit-email" class="yb-admin__select" placeholder="Email">
      </div>
      <div class="yb-admin__field">
        <label for="yb-app-edit-phone">{{ t.apps_col_phone }}</label>
        <input type="text" id="yb-app-edit-phone" class="yb-admin__select" placeholder="Phone">
      </div>
      <div class="yb-admin__field">
        <label for="yb-app-edit-program-type">{{ t.apps_col_program }}</label>
        <select id="yb-app-edit-program-type" class="yb-admin__select">
          <option value="">--</option>
          <option value="ytt">YTT</option>
          <option value="course">Course</option>
          <option value="bundle">Bundle</option>
          <option value="mentorship">Mentorship</option>
        </select>
      </div>
      <div class="yb-admin__field">
        <label for="yb-app-edit-course-id">Program</label>
        <select id="yb-app-edit-course-id" class="yb-admin__select">
          <option value="">---</option>
        </select>
        <small style="color:#6F6A66;font-size:0.7rem">Catalogue-driven. Stored as course_id.</small>
      </div>
      <div class="yb-admin__field">
        <label for="yb-app-edit-method-display">Method</label>
        <input type="text" id="yb-app-edit-method-display" class="yb-admin__select" readonly placeholder="—" style="background:#F5F3F0;color:#6F6A66">
      </div>
      <div class="yb-admin__field">
        <label for="yb-app-edit-cohort-id">Cohort</label>
        <select id="yb-app-edit-cohort-id" class="yb-admin__select" disabled>
          <option value="">Select a program first</option>
        </select>
      </div>
      <div class="yb-admin__field">
        <label for="yb-app-edit-format">Format</label>
        <input type="text" id="yb-app-edit-format" class="yb-admin__select" readonly placeholder="—" style="background:#F5F3F0;color:#6F6A66">
      </div>
      <div class="yb-admin__field" id="yb-app-edit-schedule-track-wrap" style="display:none">
        <label for="yb-app-edit-schedule-track">Schedule Track</label>
        <select id="yb-app-edit-schedule-track" class="yb-admin__select">
          <option value="">---</option>
          <option value="weekday">Weekday</option>
          <option value="weekend">Weekend</option>
        </select>
        <small style="color:#6F6A66;font-size:0.7rem">18-week Flexible only — stored as <code>track</code>.</small>
      </div>
    </div>
    <div class="yb-admin__form-actions">
      <button type="submit" class="yb-btn yb-btn--primary">{{ t.apps_save_fields }}</button>
    </div>
  </form>

  {# Status update #}
  <div class="yb-admin__section-divider"></div>
  <h3 class="yb-lead__section-title">{{ t.leads_update_status }}</h3>
  <form id="yb-app-status-form" class="yb-admin__form">
    <div style="display:flex;gap:0.75rem;align-items:flex-end;flex-wrap:wrap">
      <div class="yb-admin__field">
        <label for="yb-app-status-select">{{ t.leads_col_status }}</label>
        <select id="yb-app-status-select" class="yb-admin__select">
          <option value="Pending">&#9203; Pending</option>
          <option value="Under Review">&#128269; Under Review</option>
          <option value="Approved">&#9989; Approved</option>
          <option value="Enrolled">&#127891; Enrolled</option>
          <option value="Waitlisted">&#128203; Waitlisted</option>
          <option value="Rejected">&#10060; Rejected</option>
          <option value="Withdrawn">&#8617;&#65039; Withdrawn</option>
          <option value="Completed">&#127942; Completed</option>
        </select>
      </div>
      <button type="submit" class="yb-btn yb-btn--primary">{{ t.save }}</button>
    </div>
  </form>

  {# Notes #}
  <div class="yb-admin__section-divider"></div>
  <h3 class="yb-lead__section-title">{{ t.leads_notes }}</h3>
  <form id="yb-app-note-form" class="yb-lead__note-form">
    <input type="text" id="yb-app-note-input" placeholder="{{ t.leads_note_placeholder }}" class="yb-lead__note-input">
    <button type="submit" class="yb-btn yb-btn--primary yb-btn--sm">{{ t.leads_add_note_btn }}</button>
  </form>
  <div id="yb-app-notes-timeline" class="yb-lead__notes-timeline"></div>
</div>
