{# ══════════════════════════════════════
   ADMIN: Training Documents Panel
   Full CRUD for the Firestore 'documents' collection.
   ══════════════════════════════════════ #}

{# ── List View ── #}
<div class="yb-admin__view" id="yb-doc-v-list">

  {# ── Header ── #}
  <div class="yb-doc__header">
    <h2 class="yb-doc__list-title">{{ t.doc_title }}</h2>
    <button class="yb-btn yb-btn--primary yb-btn--small" data-action="new-doc">+ {{ t.doc_new }}</button>
  </div>

  {# ── Seed box ── #}
  <div class="yb-doc__seed-section">
    {# Header row #}
    <div class="yb-doc__seed-header">
      <div class="yb-doc__seed-title-wrap">
        <p class="yb-doc__seed-title">{{ t.doc_seed_title }}</p>
        <p class="yb-doc__seed-hint">{{ t.doc_seed_hint }}</p>
      </div>
      <div class="yb-doc__seed-actions">
        <button class="yb-btn yb-btn--outline yb-btn--small" id="yb-doc-seed-preview-btn" type="button">
          {{ t.doc_seed_preview }}
        </button>
        <button class="yb-btn yb-btn--primary yb-btn--small" id="yb-doc-seed-btn" type="button" disabled>
          {{ t.doc_seed_btn }}
        </button>
      </div>
    </div>
    {# Preview table — shown after "Check status" #}
    <div id="yb-doc-seed-preview" class="yb-doc__seed-preview">
      <div id="yb-doc-seed-table"></div>
      <div id="yb-doc-seed-status" class="yb-doc__seed-status"></div>
    </div>
  </div>

  {# ── Search + Filters ── #}
  <div class="yb-doc__filter-bar">
    <div class="yb-doc__search-wrap">
      <svg class="yb-doc__search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="yb-doc-search" class="yb-doc__search-input" placeholder="{{ t.doc_search }}">
    </div>
    <div id="yb-doc-filter-cats" class="yb-doc__filter-cats">
      <button class="yb-doc-filter-chip is-active" data-filter-cat="all">{{ t.doc_filter_all }}</button>
      <button class="yb-doc-filter-chip" data-filter-cat="manual">{{ t.doc_cat_manual }}</button>
      <button class="yb-doc-filter-chip" data-filter-cat="workbook">{{ t.doc_cat_workbook }}</button>
      <button class="yb-doc-filter-chip" data-filter-cat="reference">{{ t.doc_cat_reference }}</button>
      <button class="yb-doc-filter-chip" data-filter-cat="schedule">{{ t.doc_cat_schedule }}</button>
    </div>
    <select id="yb-doc-filter-perm" class="yb-doc__permission-select">
      <option value="all">{{ t.doc_filter_all_prog }}</option>
      <option value="materials:100h">100h</option>
      <option value="materials:200h">200h</option>
      <option value="materials:300h">300h</option>
      <option value="materials:500h">500h</option>
      <option value="method:triangle">Triangle</option>
      <option value="method:vinyasa">Vinyasa</option>
    </select>
  </div>

  {# ── Result count ── #}
  <p id="yb-doc-count" class="yb-doc__result-count"></p>

  {# ── List ── #}
  <div id="yb-doc-list-container"></div>
</div>

{# ── Form View (create / edit) ── #}
<div class="yb-admin__view" id="yb-doc-v-form" hidden>
  <div class="yb-doc__back-wrap">
    <a href="#" data-action="back-docs" class="yb-doc__back-link">&larr; {{ t.back }}</a>
  </div>

  <form id="yb-doc-form" autocomplete="off">
    <input type="hidden" id="yb-doc-id">

    {# Active toggle ── top of form #}
    <div class="yb-doc__active-toggle">
      <label class="yb-toggle">
        <input type="checkbox" id="yb-doc-active" checked>
        <span class="yb-toggle__track"></span>
      </label>
      <div>
        <p class="yb-doc__active-label">{{ t.doc_field_active }}</p>
        <p class="yb-doc__active-hint">{{ t.doc_field_active_hint }}</p>
      </div>
    </div>

    {# Title DA / EN #}
    <div class="yb-doc__form-grid">
      <div>
        <label class="yb-doc__form-label">{{ t.doc_field_title_da }}</label>
        <input type="text" id="yb-doc-title-da" class="yb-doc__form-input" required>
      </div>
      <div>
        <label class="yb-doc__form-label">{{ t.doc_field_title_en }}</label>
        <input type="text" id="yb-doc-title-en" class="yb-doc__form-input" required>
      </div>
    </div>

    {# Description DA / EN #}
    <div class="yb-doc__form-grid">
      <div>
        <label class="yb-doc__form-label">{{ t.doc_field_desc_da }}</label>
        <textarea id="yb-doc-desc-da" class="yb-doc__form-textarea" rows="2"></textarea>
      </div>
      <div>
        <label class="yb-doc__form-label">{{ t.doc_field_desc_en }}</label>
        <textarea id="yb-doc-desc-en" class="yb-doc__form-textarea" rows="2"></textarea>
      </div>
    </div>

    {# Document URL — accepts Google Drive or Cloudinary #}
    <div class="yb-doc__url-section">
      <label class="yb-doc__form-label">{{ t.doc_field_url }}</label>
      <div class="yb-doc__url-row">
        <input type="url" id="yb-doc-url" class="yb-doc__url-input" required placeholder="https://drive.google.com/file/d/... or https://yogabible.b-cdn.net/...">
        <button type="button" class="yb-btn yb-btn--outline yb-btn--small yb-doc__browse-btn" data-action="toggle-browser">
          <svg class="yb-doc__btn-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          {{ t.doc_browse }}
        </button>
      </div>
      <span class="yb-doc__url-hint">{{ t.doc_field_url_hint }}</span>
      <div id="yb-doc-gdrive-hint" class="yb-doc__gdrive-hint">
        <strong>Google Drive:</strong> {{ t.doc_gdrive_reminder }}
      </div>
    </div>

    {# Cloudinary File Browser (inline, collapsible) #}
    <div id="yb-doc-browser" class="yb-doc-browser" hidden>
      <div class="yb-doc-browser__breadcrumb" id="yb-doc-breadcrumb"></div>
      <div class="yb-doc-browser__toolbar">
        <input type="text" id="yb-doc-browser-search" class="yb-doc-browser__search"
               placeholder="{{ t.doc_browser_search }}">
        <label class="yb-btn yb-btn--primary yb-btn--small yb-doc-browser__upload-btn">
          <svg class="yb-doc__btn-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          {{ t.doc_browser_upload }}
          <input type="file" id="yb-doc-browser-file" accept=".pdf" hidden>
        </label>
      </div>
      <div class="yb-doc-browser__list" id="yb-doc-browser-list"></div>
      <div class="yb-doc-browser__upload-progress" id="yb-doc-upload-progress" hidden>
        <div class="yb-doc-browser__progress-bar">
          <div class="yb-doc-browser__progress-fill" id="yb-doc-progress-fill"></div>
        </div>
        <span id="yb-doc-progress-text" class="yb-doc__progress-text"></span>
      </div>
    </div>

    {# Category + Order row #}
    <div class="yb-doc__form-grid">
      <div>
        <label class="yb-doc__form-label">{{ t.doc_field_category }}</label>
        <select id="yb-doc-category" class="yb-doc__form-select">
          <option value="manual">{{ t.doc_cat_manual }}</option>
          <option value="workbook">{{ t.doc_cat_workbook }}</option>
          <option value="reference">{{ t.doc_cat_reference }}</option>
          <option value="schedule">{{ t.doc_cat_schedule }}</option>
        </select>
      </div>
      <div>
        <label class="yb-doc__form-label">{{ t.doc_field_order }}</label>
        <input type="number" id="yb-doc-order" class="yb-doc__form-input" value="1" min="0">
      </div>
    </div>

    {# Permissions — Program + Method checkboxes #}
    <div class="yb-doc__perm-section">
      <label class="yb-doc__form-label yb-doc__perm-label">{{ t.doc_field_permissions }}</label>
      <div class="yb-doc__perm-grid">
        <fieldset class="yb-doc__fieldset">
          <legend class="yb-doc__legend">{{ t.doc_perm_program }}</legend>
          <label class="yb-doc__checkbox-label">
            <input type="checkbox" id="yb-doc-perm-100h" value="materials:100h"> 100-Hour
          </label>
          <label class="yb-doc__checkbox-label">
            <input type="checkbox" id="yb-doc-perm-200h" value="materials:200h"> 200-Hour
          </label>
          <label class="yb-doc__checkbox-label">
            <input type="checkbox" id="yb-doc-perm-300h" value="materials:300h"> 300-Hour
          </label>
          <label class="yb-doc__checkbox-label">
            <input type="checkbox" id="yb-doc-perm-500h" value="materials:500h"> 500-Hour
          </label>
        </fieldset>
        <fieldset class="yb-doc__fieldset">
          <legend class="yb-doc__legend">{{ t.doc_perm_method }}</legend>
          <label class="yb-doc__checkbox-label">
            <input type="checkbox" id="yb-doc-perm-triangle" value="method:triangle"> Triangle Method
          </label>
          <label class="yb-doc__checkbox-label">
            <input type="checkbox" id="yb-doc-perm-vinyasa" value="method:vinyasa"> Vinyasa Plus
          </label>
        </fieldset>
      </div>
      <p class="yb-doc__perm-hint">
        {{ t.doc_perm_none }}
      </p>
    </div>

    {# Save / Cancel #}
    <div class="yb-doc__form-actions">
      <button type="submit" class="yb-btn yb-btn--primary">{{ t.save }}</button>
      <button type="button" class="yb-btn yb-btn--outline" data-action="back-docs">{{ t.cancel }}</button>
    </div>
  </form>
</div>
