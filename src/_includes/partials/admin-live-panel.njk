{# ── List View ── #}
<div id="yb-live-admin-v-list">
  <div class="yb-admin__view-head">
    <h2>{{ t.live_title }}</h2>
    <div class="yb-lead__toolbar-right">
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="live-backfill-ai">AI Backfill</button>
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="live-import-mb">{{ t.live_import_mb }}</button>
      <button type="button" class="yb-btn yb-btn--primary yb-btn--sm" data-action="live-new">+ {{ t.live_new }}</button>
    </div>
  </div>

  {# Filters #}
  <div class="yb-lead__filter-bar">
    <select id="yb-live-admin-filter" class="yb-admin__select yb-lead__filter">
      <option value="all">{{ t.live_filter_all }}</option>
      <option value="upcoming" selected>{{ t.live_filter_upcoming }}</option>
      <option value="past">{{ t.live_filter_past }}</option>
    </select>
    <select id="yb-live-admin-source-filter" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.live_filter_all }} ({{ t.live_field_source }})</option>
      <option value="manual">{{ t.live_source_manual }}</option>
      <option value="mindbody">{{ t.live_source_mindbody }}</option>
    </select>
  </div>

  <div class="yb-lead__result-bar">
    <span id="yb-live-admin-count" class="yb-lead__count-text"></span>
  </div>

  {# Bulk actions bar (hidden until selections) #}
  <div id="yb-live-bulk-bar" class="yb-lead__bulk-bar" hidden>
    <span id="yb-live-bulk-count" class="yb-lead__bulk-count-text"></span>
    <button class="yb-btn yb-btn--primary yb-btn--sm" data-action="live-bulk-access">&#128274; {{ t.live_bulk_set_access }}</button>
    <button class="yb-btn yb-btn--ghost yb-btn--sm" data-action="live-bulk-not-recorded">&#127909; {{ t.live_bulk_mark_not_recorded }}</button>
    <button class="yb-btn yb-btn--outline yb-btn--sm yb-admin__icon-btn--danger" data-action="live-bulk-delete">&#128465; {{ t.live_bulk_delete }}</button>
    <button class="yb-btn yb-btn--outline yb-btn--sm" data-action="live-bulk-deselect">&#10006; {{ t.live_bulk_deselect }}</button>
  </div>

  {# Bulk access settings panel (hidden until "Set Access" clicked) #}
  <div id="yb-live-bulk-access-panel" class="yb-admin__form yb-live__bulk-access" hidden>
    <div class="yb-live__bulk-access-header">
      <strong class="yb-la__bulk-title">{{ t.live_bulk_set_access }}</strong>
      <button type="button" class="yb-admin__icon-btn" data-action="live-bulk-access-close" title="Close">&times;</button>
    </div>

    {# Bulk — Role pills #}
    <div class="yb-admin__field yb-la__field--md">
      <label class="yb-la__field-label">{{ t.live_field_access_roles }}</label>
      <div class="yb-la__pill-row yb-la__pill-row--bulk-roles">
        <button type="button" class="yb-la-role-pill" data-value="member">Member</button>
        <button type="button" class="yb-la-role-pill yb-la-pill--active" data-value="trainee">Trainee</button>
        <button type="button" class="yb-la-role-pill" data-value="student">Student</button>
        <button type="button" class="yb-la-role-pill yb-la-pill--active" data-value="teacher">Teacher</button>
        <button type="button" class="yb-la-role-pill yb-la-pill--active" data-value="admin">Admin</button>
      </div>
    </div>

    {# Bulk — Permission pills #}
    <div class="yb-admin__field yb-la__field--md">
      <label class="yb-la__field-label">{{ t.live_field_access_perms }}</label>
      <div class="yb-la__perm-wrap">
        <div class="yb-la__perm-section">
          <span class="yb-la__group-label">{{ t.live_perm_group_base }}</span>
          <div class="yb-la__pill-row">
            <button type="button" class="yb-la-perm-pill yb-la-pill--active" data-value="live-streaming">Live Streaming</button>
            <button type="button" class="yb-la-perm-pill" data-value="recordings">Recordings</button>
            <button type="button" class="yb-la-perm-pill" data-value="gated-content">Gated Content</button>
          </div>
        </div>
        <div class="yb-la__perm-section">
          <span class="yb-la__group-label">{{ t.live_perm_group_courses }}</span>
          <div class="yb-la__pill-row">
            <button type="button" class="yb-la-perm-pill" data-value="course:inversions">Inversions</button>
            <button type="button" class="yb-la-perm-pill" data-value="course:splits">Splits</button>
            <button type="button" class="yb-la-perm-pill" data-value="course:backbends">Backbends</button>
            <button type="button" class="yb-la-perm-pill" data-value="course:handstands">Handstands</button>
            <button type="button" class="yb-la-perm-pill" data-value="course:armbalances">Arm Balances</button>
            <button type="button" class="yb-la-perm-pill" data-value="course:prenatal">Prenatal</button>
          </div>
        </div>
        <div class="yb-la__perm-section yb-la__teacher-section" hidden>
          <span class="yb-la__group-label">{{ t.live_perm_group_teacher }}</span>
          <div class="yb-la__pill-row">
            <button type="button" class="yb-la-perm-pill" data-value="teacher:vinyasa">Vinyasa</button>
            <button type="button" class="yb-la-perm-pill" data-value="teacher:yin">Yin</button>
            <button type="button" class="yb-la-perm-pill" data-value="teacher:hot">Hot Yoga</button>
            <button type="button" class="yb-la-perm-pill" data-value="teacher:ashtanga">Ashtanga</button>
            <button type="button" class="yb-la-perm-pill" data-value="teacher:hatha">Hatha</button>
            <button type="button" class="yb-la-perm-pill" data-value="teacher:kids">Kids</button>
            <button type="button" class="yb-la-perm-pill" data-value="teacher:restorative">Restorative</button>
            <button type="button" class="yb-la-perm-pill" data-value="teacher:prenatal">Prenatal</button>
            <button type="button" class="yb-la-perm-pill" data-value="teacher:meditation">Meditation</button>
          </div>
        </div>
        <div class="yb-la__perm-section">
          <span class="yb-la__group-label">{{ t.live_perm_group_other }}</span>
          <div class="yb-la__pill-row">
            <button type="button" class="yb-la-perm-pill" data-value="mentorship">Mentorship</button>
          </div>
        </div>
      </div>
    </div>

    {# Bulk — Programs #}
    <div class="yb-admin__field yb-la__field--sm">
      <label class="yb-la__field-label">{{ t.live_field_programs or "Programs" }}</label>
      <div id="yb-la-bulk-programs-container" class="yb-la-pill-container">
        <span class="yb-la__loading-text">Loading catalogue…</span>
      </div>
    </div>

    {# Bulk — Cohorts #}
    <div class="yb-admin__field yb-la__field--sm">
      <label class="yb-la__field-label">{{ t.live_field_cohorts or "Cohorts" }}</label>
      <div id="yb-la-bulk-cohorts-container" class="yb-la-pill-container">
        <span class="yb-la__loading-text">Select a program first</span>
      </div>
    </div>

    {# Bulk access summary #}
    <div id="yb-la-bulk-access-summary" class="yb-la__access-summary yb-la__access-summary--spaced">
      Visible to: everyone (no restrictions)
    </div>

    <button type="button" class="yb-btn yb-btn--primary yb-btn--sm" data-action="live-bulk-access-apply">&#10003; {{ t.live_bulk_apply }}</button>
  </div>

  <div class="yb-admin__table-wrap">
    <table class="yb-admin__table" id="yb-live-admin-table">
      <thead>
        <tr>
          <th class="yb-lead__th-cb"><input type="checkbox" id="yb-live-select-all" title="{{ t.live_bulk_select_all }}"></th>
          <th>{{ t.live_col_status }}</th>
          <th>{{ t.live_col_title }}</th>
          <th>{{ t.live_col_datetime }}</th>
          <th>{{ t.live_col_source }}</th>
          <th>{{ t.live_col_instructor }}</th>
          <th>{{ t.live_col_access }}</th>
          <th>{{ t.live_col_actions }}</th>
        </tr>
      </thead>
      <tbody id="yb-live-admin-table-body"></tbody>
    </table>
  </div>
  <p id="yb-live-admin-empty" class="yb-admin__empty" hidden>{{ t.live_no_events }}</p>
</div>

{# ── Form View (create / edit) ── #}
<div id="yb-live-admin-v-form" hidden>
  <div class="yb-admin__view-head">
    <button class="yb-admin__back-btn" data-action="live-cancel">&larr; {{ t.back }}</button>
    <h2 id="yb-live-admin-form-title">{{ t.live_form_title }}</h2>
  </div>

  <form id="yb-live-admin-form" class="yb-admin__form" autocomplete="off">
    <input type="hidden" id="yb-la-id">
    <div id="yb-la-id-display" class="yb-la__id-display">
      Session ID: <code id="yb-la-id-text" class="yb-la__id-code"></code>
    </div>

    {# Source selector #}
    <div class="yb-admin__form-row">
      <div class="yb-admin__field">
        <label for="yb-la-source">{{ t.live_field_source }}</label>
        <select id="yb-la-source" class="yb-admin__select">
          <option value="manual">{{ t.live_source_manual }}</option>
          <option value="mindbody">{{ t.live_source_mindbody }}</option>
        </select>
      </div>
      <div class="yb-admin__field">
        <label for="yb-la-status">{{ t.live_field_status }}</label>
        <select id="yb-la-status" class="yb-admin__select">
          <option value="scheduled">{{ t.live_status_scheduled }}</option>
          <option value="live">{{ t.live_status_live }}</option>
          <option value="ended">{{ t.live_status_ended }}</option>
          <option value="cancelled">{{ t.live_status_cancelled }}</option>
        </select>
      </div>
    </div>

    {# MB class picker (shown when source = mindbody) #}
    <div class="yb-admin__field" id="yb-la-mb-wrap" hidden>
      <label for="yb-la-mb-class">{{ t.live_field_mb_class }}</label>
      <select id="yb-la-mb-class" class="yb-admin__select">
        <option value="">{{ t.live_field_mb_select }}</option>
      </select>
    </div>

    {# Title #}
    <div class="yb-admin__form-row">
      <div class="yb-admin__field">
        <label for="yb-la-title-da">{{ t.live_field_title_da }}</label>
        <input type="text" id="yb-la-title-da" required>
      </div>
      <div class="yb-admin__field">
        <label for="yb-la-title-en">{{ t.live_field_title_en }}</label>
        <input type="text" id="yb-la-title-en">
      </div>
    </div>

    {# Description #}
    <div class="yb-admin__form-row">
      <div class="yb-admin__field">
        <label for="yb-la-desc-da">{{ t.live_field_desc_da }}</label>
        <textarea id="yb-la-desc-da" rows="3"></textarea>
      </div>
      <div class="yb-admin__field">
        <label for="yb-la-desc-en">{{ t.live_field_desc_en }}</label>
        <textarea id="yb-la-desc-en" rows="3"></textarea>
      </div>
    </div>

    {# Instructor + Teacher Email #}
    <div class="yb-admin__form-row">
      <div class="yb-admin__field">
        <label for="yb-la-instructor">{{ t.live_field_instructor }}</label>
        <input type="text" id="yb-la-instructor">
      </div>
      <div class="yb-admin__field">
        <label for="yb-la-teacher-email">{{ t.live_field_teacher_email }}</label>
        <input type="email" id="yb-la-teacher-email" placeholder="eva@yogabible.dk">
      </div>
    </div>

    <div class="yb-admin__form-row">
      <div class="yb-admin__field">
        <label for="yb-la-start">{{ t.live_field_start }}</label>
        <input type="datetime-local" id="yb-la-start" required>
      </div>
      <div class="yb-admin__field">
        <label for="yb-la-end">{{ t.live_field_end }}</label>
        <input type="datetime-local" id="yb-la-end">
      </div>
    </div>

    {# Recurrence (manual only) #}
    <div id="yb-la-recurrence-wrap">
      <div class="yb-admin__form-row">
        <div class="yb-admin__field">
          <label for="yb-la-recurrence">{{ t.live_field_recurrence }}</label>
          <select id="yb-la-recurrence" class="yb-admin__select">
            <option value="none">{{ t.live_recurrence_none }}</option>
            <option value="weekly">{{ t.live_recurrence_weekly }}</option>
            <option value="biweekly">{{ t.live_recurrence_biweekly }}</option>
            <option value="every3weeks">{{ t.live_recurrence_every3weeks }}</option>
            <option value="every4weeks">{{ t.live_recurrence_every4weeks }}</option>
          </select>
        </div>
        <div class="yb-admin__field" id="yb-la-recurrence-end-wrap" hidden>
          <label for="yb-la-recurrence-end">{{ t.live_field_recurrence_end }}</label>
          <input type="date" id="yb-la-recurrence-end">
        </div>
      </div>
    </div>

    {# Link existing recording toggle (creation only) #}
    <div class="yb-admin__field yb-la__link-existing" id="yb-la-link-existing-wrap" hidden>
      <label class="yb-admin__checkbox-label">
        <input type="checkbox" id="yb-la-link-existing-toggle">
        <span>Link existing Mux recording</span>
      </label>
    </div>

    {# Not-recorded toggle — only for ended sessions without a recording #}
    <div class="yb-admin__field yb-la__not-recorded-wrap" id="yb-la-not-recorded-wrap" hidden>
      <label class="yb-admin__checkbox-label">
        <input type="checkbox" id="yb-la-not-recorded-toggle">
        <span>{{ t.live_field_not_recorded }}</span>
      </label>
      <p class="yb-la__not-recorded-note" id="yb-la-not-recorded-note" hidden>{{ t.live_field_not_recorded_note }}</p>
    </div>

    {# Mux IDs #}
    <div class="yb-admin__form-row" id="yb-la-mux-ids-row">
      <div class="yb-admin__field">
        <label for="yb-la-mux-playback">{{ t.live_field_mux_playback }}</label>
        <input type="text" id="yb-la-mux-playback" placeholder="{{ t.live_field_mux_playback_hint }}">
      </div>
      <div class="yb-admin__field">
        <label for="yb-la-recording-id">{{ t.live_field_recording_id }}</label>
        <div class="yb-la__input-with-action">
          <input type="text" id="yb-la-recording-id" placeholder="{{ t.live_field_recording_hint }}">
          <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="live-rec-preview" id="yb-la-rec-preview-btn" hidden>Preview</button>
          <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="live-browse-mux">Browse Mux Assets</button>
        </div>
        <input type="hidden" id="yb-la-recording-asset-id">
        <div class="yb-la__rec-preview-slot" id="yb-la-rec-preview-slot" hidden></div>
      </div>
    </div>

    {# Program restriction (catalogue-driven pills) #}
    <div class="yb-admin__field">
      <label>{{ t.live_field_programs or "Program Restriction" }}</label>
      <p class="yb-la__help-text">{{ t.live_programs_help or "Select which programs can access this session. Leave empty for no program restriction." }}</p>
      <div id="yb-la-programs-container" class="yb-la-pill-container">
        <span class="yb-la__loading-text">Loading catalogue…</span>
      </div>
    </div>

    {# Cohort restriction (catalogue-driven pills, shown after program selection) #}
    <div class="yb-admin__field">
      <label>{{ t.live_field_cohorts or "Cohort Restriction" }}</label>
      <p class="yb-la__help-text">{{ t.live_cohorts_help_new or "Select specific cohorts. Only shown after picking a program. Leave empty to allow all cohorts of the selected programs." }}</p>
      <div id="yb-la-cohorts-container" class="yb-la-pill-container">
        <span class="yb-la__loading-text">Select a program first</span>
      </div>
    </div>

    {# Access summary preview #}
    <div class="yb-admin__field">
      <div id="yb-la-access-summary" class="yb-la__access-summary">
        Visible to: everyone (no restrictions)
      </div>
    </div>

    {# Legacy hidden cohorts field for backwards compat #}
    <input type="hidden" id="yb-la-cohorts" value="">

    {# Stream Type #}
    <div class="yb-admin__field">
      <label for="yb-la-stream-type">{{ t.live_field_stream_type or "Stream Type" }}</label>
      <select id="yb-la-stream-type" class="yb-admin__input">
        <option value="broadcast">{{ t.live_stream_broadcast or "Broadcast — teacher streams, students watch" }}</option>
        <option value="interactive">{{ t.live_stream_interactive or "Interactive — students join with camera & mic" }}</option>
        <option value="meet">{{ t.live_stream_meet or "Google Meet — external video meeting" }}</option>
        <option value="panel">{{ t.live_stream_panel or "Panel — multiple teachers stream together" }}</option>
      </select>
      <p class="yb-la__form-hint">{{ t.live_stream_type_help or "Defines who can publish video/audio in this session" }}</p>
    </div>

    {# Meeting URL (for Google Meet / external meeting links) #}
    <div class="yb-admin__field yb-la__hidden-field" id="yb-la-meeting-url-field">
      <label for="yb-la-meeting-url">{{ t.live_field_meeting_url or "Meeting URL" }}</label>
      <input type="url" id="yb-la-meeting-url" placeholder="https://meet.google.com/abc-defg-hij">
      <p class="yb-la__form-hint">{{ t.live_meeting_url_help or "Paste your Google Meet, Zoom, or other meeting link here" }}</p>
    </div>

    {# Co-teachers (only for panel sessions) #}
    <div class="yb-admin__field yb-la__hidden-field" id="yb-la-coteachers-field">
      <label for="yb-la-coteachers">{{ t.live_field_coteachers or "Co-teachers (emails)" }}</label>
      <input type="text" id="yb-la-coteachers" placeholder="{{ t.live_coteachers_hint or "teacher1@yogabible.dk, teacher2@yogabible.dk" }}">
      <p class="yb-la__form-hint">{{ t.live_coteachers_help or "Comma-separated emails. These teachers can also Go Live for this session." }}</p>
    </div>

    {# Access: Roles — pill buttons #}
    <div class="yb-admin__field">
      <label>{{ t.live_field_access_roles }}</label>
      <p class="yb-la__help-text">{{ t.live_access_hint_roles }}</p>
      <div class="yb-la__pill-row yb-la__pill-row--roles">
        <button type="button" class="yb-la-role-pill" data-value="member">Member</button>
        <button type="button" class="yb-la-role-pill yb-la-pill--active" data-value="trainee">Trainee</button>
        <button type="button" class="yb-la-role-pill" data-value="student">Student</button>
        <button type="button" class="yb-la-role-pill yb-la-pill--active" data-value="teacher">Teacher</button>
        <button type="button" class="yb-la-role-pill yb-la-pill--active" data-value="admin">Admin</button>
      </div>
    </div>

    {# Access: Permissions — pill groups #}
    <div class="yb-admin__field">
      <label>{{ t.live_field_access_perms }}</label>
      <p class="yb-la__help-text">{{ t.live_access_hint_perms }}</p>

      {# Base Access #}
      <div class="yb-la__perm-section">
        <span class="yb-la__group-label">{{ t.live_perm_group_base }}</span>
        <div class="yb-la__pill-row">
          <button type="button" class="yb-la-perm-pill yb-la-pill--active" data-value="live-streaming">Live Streaming</button>
          <button type="button" class="yb-la-perm-pill" data-value="recordings">Recordings</button>
          <button type="button" class="yb-la-perm-pill" data-value="gated-content">Gated Content</button>
        </div>
      </div>

      {# Courses #}
      <div class="yb-la__perm-section">
        <span class="yb-la__group-label">{{ t.live_perm_group_courses }}</span>
        <div class="yb-la__pill-row">
          <button type="button" class="yb-la-perm-pill" data-value="course:inversions">Inversions</button>
          <button type="button" class="yb-la-perm-pill" data-value="course:splits">Splits</button>
          <button type="button" class="yb-la-perm-pill" data-value="course:backbends">Backbends</button>
          <button type="button" class="yb-la-perm-pill" data-value="course:handstands">Handstands</button>
          <button type="button" class="yb-la-perm-pill" data-value="course:armbalances">Arm Balances</button>
          <button type="button" class="yb-la-perm-pill" data-value="course:prenatal">Prenatal</button>
        </div>
      </div>

      {# Teacher Type — only visible when Teacher role is active #}
      <div class="yb-la__perm-section yb-la__teacher-section" hidden>
        <span class="yb-la__group-label">{{ t.live_perm_group_teacher }}</span>
        <div class="yb-la__pill-row">
          <button type="button" class="yb-la-perm-pill" data-value="teacher:vinyasa">Vinyasa</button>
          <button type="button" class="yb-la-perm-pill" data-value="teacher:yin">Yin</button>
          <button type="button" class="yb-la-perm-pill" data-value="teacher:hot">Hot Yoga</button>
          <button type="button" class="yb-la-perm-pill" data-value="teacher:ashtanga">Ashtanga</button>
          <button type="button" class="yb-la-perm-pill" data-value="teacher:hatha">Hatha</button>
          <button type="button" class="yb-la-perm-pill" data-value="teacher:kids">Kids</button>
          <button type="button" class="yb-la-perm-pill" data-value="teacher:restorative">Restorative</button>
          <button type="button" class="yb-la-perm-pill" data-value="teacher:prenatal">Prenatal</button>
          <button type="button" class="yb-la-perm-pill" data-value="teacher:meditation">Meditation</button>
        </div>
      </div>

      {# Mentorship #}
      <div class="yb-la__perm-section">
        <span class="yb-la__group-label">{{ t.live_perm_group_other }}</span>
        <div class="yb-la__pill-row">
          <button type="button" class="yb-la-perm-pill" data-value="mentorship">Mentorship</button>
        </div>
      </div>
    </div>

    {# ── AI Content (summary + quiz) — shown only for ended sessions with recordings ── #}
    <div id="yb-la-ai-section" hidden>
      <hr class="yb-la__ai-divider">
      <h3 class="yb-la__ai-heading">AI-genereret indhold</h3>
      <p class="yb-la__ai-desc">Rediger summary og quiz genereret af AI. Ændringer gemmes når du trykker Gem.</p>

      {# AI Status indicator #}
      <div class="yb-admin__form-row yb-la__ai-status-row">
        <div class="yb-admin__field yb-la__ai-status-field">
          <label>AI Status</label>
          <span id="yb-la-ai-status" class="yb-la__ai-status">—</span>
        </div>
        <div class="yb-admin__field yb-la__ai-status-field--end">
          <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" id="yb-la-ai-reprocess-btn" title="Re-run AI on this session's transcript">
            ↻ Reprocess AI
          </button>
        </div>
      </div>

      {# Language tabs for AI content #}
      <div class="yb-la__lang-tabs">
        <button type="button" id="yb-la-ai-tab-da" class="yb-btn yb-btn--sm yb-la__lang-tab yb-la__lang-tab--left" data-action="live-ai-lang" data-lang="da">DA</button>
        <button type="button" id="yb-la-ai-tab-en" class="yb-btn yb-btn--outline yb-btn--sm yb-la__lang-tab yb-la__lang-tab--right" data-action="live-ai-lang" data-lang="en">EN</button>
      </div>

      {# Summary DA #}
      <div class="yb-admin__field yb-la-ai-lang-da">
        <label for="yb-la-ai-summary-da">Summary DA (HTML)</label>
        <textarea id="yb-la-ai-summary-da" rows="10" class="yb-la__mono-block" placeholder="<p>AI-genereret opsummering...</p>"></textarea>
      </div>
      {# Summary EN #}
      <div class="yb-admin__field yb-la-ai-lang-en" hidden>
        <label for="yb-la-ai-summary-en">Summary EN (HTML)</label>
        <textarea id="yb-la-ai-summary-en" rows="10" class="yb-la__mono-block" placeholder="<p>AI-generated summary...</p>"></textarea>
      </div>

      {# Summary preview toggle #}
      <div class="yb-la__preview-wrap">
        <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" id="yb-la-ai-preview-btn">Preview summary</button>
        <div id="yb-la-ai-preview" hidden class="yb-la__preview-box"></div>
      </div>

      {# Quiz DA #}
      <div class="yb-admin__field yb-la-ai-lang-da">
        <label for="yb-la-ai-quiz-da">Quiz DA (JSON array)</label>
        <textarea id="yb-la-ai-quiz-da" rows="12" class="yb-la__mono-block" placeholder='[{"question":"...","type":"multiple","options":["A","B","C","D"],"correct":0,"explanation":"..."}]'></textarea>
      </div>
      {# Quiz EN #}
      <div class="yb-admin__field yb-la-ai-lang-en" hidden>
        <label for="yb-la-ai-quiz-en">Quiz EN (JSON array)</label>
        <textarea id="yb-la-ai-quiz-en" rows="12" class="yb-la__mono-block" placeholder='[{"question":"...","type":"multiple","options":["A","B","C","D"],"correct":0,"explanation":"..."}]'></textarea>
      </div>

      {# Quiz validation #}
      <div id="yb-la-ai-quiz-error" class="yb-la__error-text" hidden></div>

      {# Hidden legacy fields for backward compat #}
      <textarea id="yb-la-ai-summary" hidden></textarea>
      <textarea id="yb-la-ai-quiz" hidden></textarea>
    </div>

    <div class="yb-admin__form-actions">
      <button type="submit" class="yb-btn yb-btn--primary">{{ t.save }}</button>
      <button type="button" class="yb-btn yb-btn--outline" data-action="live-cancel">{{ t.cancel }}</button>
    </div>
  </form>
</div>

{# ── MindBody Import View ── #}
<div id="yb-live-admin-v-mb" hidden>
  <div class="yb-admin__view-head">
    <button class="yb-admin__back-btn" data-action="live-cancel">&larr; {{ t.back }}</button>
    <h2>{{ t.live_import_mb }}</h2>
  </div>

  {# Date range + fetch #}
  <div class="yb-admin__form-row yb-la__import-row">
    <div class="yb-admin__field">
      <label for="yb-la-mb-start">{{ t.live_field_start }}</label>
      <input type="date" id="yb-la-mb-start">
    </div>
    <div class="yb-admin__field">
      <label for="yb-la-mb-end">{{ t.live_field_end }}</label>
      <input type="date" id="yb-la-mb-end">
    </div>
    <div class="yb-admin__field yb-la__import-action">
      <button type="button" class="yb-btn yb-btn--primary yb-btn--sm" data-action="live-mb-fetch" id="yb-la-mb-fetch-btn">{{ t.live_mb_fetch_btn }}</button>
    </div>
  </div>

  {# Search + Filters (populated dynamically after fetch) #}
  <div class="yb-lead__filter-bar" id="yb-la-mb-filters" hidden>
    <input type="text" id="yb-la-mb-search" placeholder="{{ t.live_mb_search }}" class="yb-lead__search-input yb-la__import-search">
    <select id="yb-la-mb-filter-program" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.live_mb_filter_program }}</option>
    </select>
    <select id="yb-la-mb-filter-instructor" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.live_mb_filter_instructor }}</option>
    </select>
    <select id="yb-la-mb-filter-session-type" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.live_mb_filter_session_type }}</option>
    </select>
    <select id="yb-la-mb-filter-day" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.live_mb_filter_day }}</option>
    </select>
  </div>

  {# Result count #}
  <div class="yb-lead__result-bar" id="yb-la-mb-result-bar" hidden>
    <span id="yb-la-mb-count" class="yb-lead__count-text"></span>
  </div>

  {# Bulk actions bar (hidden until selections) #}
  <div id="yb-la-mb-bulk-bar" class="yb-lead__bulk-bar" hidden>
    <span id="yb-la-mb-bulk-count" class="yb-lead__bulk-count-text"></span>
    <button class="yb-btn yb-btn--primary yb-btn--sm" data-action="live-mb-bulk-import">&#128229; {{ t.live_mb_bulk_import }}</button>
    <button class="yb-btn yb-btn--outline yb-btn--sm" data-action="live-mb-deselect">&#10006; {{ t.live_mb_deselect }}</button>
  </div>

  {# Table #}
  <div class="yb-admin__table-wrap">
    <table class="yb-admin__table" id="yb-live-mb-table">
      <thead>
        <tr>
          <th class="yb-lead__th-cb"><input type="checkbox" id="yb-la-mb-select-all" title="{{ t.live_mb_select_all }}"></th>
          <th>{{ t.live_col_title }}</th>
          <th>{{ t.live_col_datetime }}</th>
          <th>{{ t.live_col_instructor }}</th>
          <th>{{ t.live_mb_col_program }}</th>
          <th>{{ t.live_mb_col_session_type }}</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="yb-live-mb-table-body"></tbody>
    </table>
  </div>
  <p id="yb-live-mb-empty" class="yb-admin__empty" hidden>{{ t.live_field_mb_none }}</p>
</div>

{# ── AI Backfill Modal ── #}
<div id="yb-la-backfill-modal" class="yb-la__mux-modal" hidden>
  <div class="yb-la__mux-modal-overlay" data-action="live-backfill-close"></div>
  <div class="yb-la__mux-modal-dialog" role="dialog" aria-label="AI Backfill">
    <div class="yb-la__mux-modal-head">
      <h3 class="yb-la__mux-modal-title">AI Backfill</h3>
      <button type="button" class="yb-admin__icon-btn" data-action="live-backfill-close" title="Close">&times;</button>
    </div>
    <div class="yb-la__mux-modal-body">
      <div class="yb-la__bf-section">
        <h4 class="yb-la__bf-heading">Bulk reprocess sessions</h4>
        <p class="yb-la__help-text">Re-trigger the AI pipeline (Deepgram → Claude) on past ended sessions with recordings. Triggers are staggered by 5 seconds.</p>

        <div class="yb-la__bf-filter-row">
          <label class="yb-la__bf-filter-label">Filter:</label>
          <div class="yb-la__pill-row">
            <button type="button" class="yb-la-perm-pill yb-la-pill--active yb-la-bf-status-pill" data-value="missing">Missing AI content</button>
            <button type="button" class="yb-la-perm-pill yb-la-bf-status-pill" data-value="failed">Failed AI</button>
            <button type="button" class="yb-la-perm-pill yb-la-bf-status-pill" data-value="all">All ended sessions</button>
            <button type="button" class="yb-la-perm-pill yb-la-bf-status-pill" data-value="generate-captions">Generate Mux Captions</button>
          </div>
        </div>

        <div class="yb-la__bf-controls">
          <label class="yb-la__bf-limit-label">
            Limit
            <input type="number" id="yb-la-bf-limit" class="yb-la__bf-limit-input" min="1" max="50" value="10">
          </label>
          <label class="yb-admin__checkbox-label">
            <input type="checkbox" id="yb-la-bf-dry-run" checked>
            <span>Dry run first</span>
          </label>
          <button type="button" class="yb-btn yb-btn--primary yb-btn--sm" id="yb-la-bf-start-btn" data-action="live-backfill-start">Start backfill</button>
        </div>

        <div id="yb-la-bf-results" class="yb-la__bf-results" hidden></div>
      </div>

      <hr class="yb-la__bf-divider">

      <div class="yb-la__bf-section">
        <h4 class="yb-la__bf-heading">Orphan Mux Assets</h4>
        <p class="yb-la__help-text">Ready Mux recordings that aren't attached to any session. Create a backdated session from any of them.</p>
        <div class="yb-la__bf-controls">
          <label class="yb-la__bf-limit-label">
            Days back
            <input type="number" id="yb-la-bf-orphan-days" class="yb-la__bf-limit-input" min="1" max="365" value="60">
          </label>
          <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="live-backfill-scan-orphans">Scan Mux for unattached recordings</button>
        </div>
        <div id="yb-la-bf-orphans" class="yb-la__bf-orphans"></div>
      </div>
    </div>
  </div>
</div>

{# ── Mux Asset Browser Modal ── #}
<div id="yb-la-mux-modal" class="yb-la__mux-modal" hidden>
  <div class="yb-la__mux-modal-overlay" data-action="live-mux-close"></div>
  <div class="yb-la__mux-modal-dialog" role="dialog" aria-label="Browse Mux recordings">
    <div class="yb-la__mux-modal-head">
      <h3 class="yb-la__mux-modal-title">Browse Mux Recordings</h3>
      <div class="yb-la__mux-modal-controls">
        <select id="yb-la-mux-sort" class="yb-admin__select yb-la__mux-sort-select" aria-label="Sort recordings">
          <option value="match">Best match for session</option>
          <option value="recent" selected>Most recent</option>
          <option value="duration-desc">Duration (longest first)</option>
          <option value="duration-asc">Duration (shortest first)</option>
        </select>
        <select id="yb-la-mux-date-filter" class="yb-admin__select">
          <option value="7">Last 7 days</option>
          <option value="30" selected>Last 30 days</option>
          <option value="90">Last 90 days</option>
          <option value="0">All time</option>
        </select>
        <button type="button" class="yb-admin__icon-btn" data-action="live-mux-close" title="Close">&times;</button>
      </div>
    </div>
    <div id="yb-la-mux-modal-body" class="yb-la__mux-modal-body">
      <p class="yb-la__loading-text">Loading assets…</p>
    </div>
    <div class="yb-la__mux-modal-foot">
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" id="yb-la-mux-load-more" hidden>Load more</button>
    </div>
  </div>
</div>
