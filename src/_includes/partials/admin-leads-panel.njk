{# ── Lead List View ── #}
<div id="yb-admin-v-lead-list">
  <div class="yb-admin__view-head">
    <h2>{{ t.leads_title }}</h2>
    <div class="yb-lead__toolbar-right">
      <div class="yb-lead__view-toggle" id="yb-lead-view-toggle">
        <button class="yb-lead__view-btn is-active" data-view="table" type="button">&#128203; {{ t.leads_view_table }}</button>
        <button class="yb-lead__view-btn" data-view="kanban" type="button">&#128202; {{ t.leads_view_board }}</button>
      </div>
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" id="yb-lead-archive-toggle" data-action="toggle-show-archived">&#128230; {{ t.leads_show_archived }}</button>
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="leads-export-csv">&#128229; {{ t.leads_export }}</button>
      <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" data-action="leads-refresh">&#8635; {{ t.leads_refresh }}</button>
    </div>
  </div>

  {# Pipeline Stats (clickable) #}
  <div class="yb-lead__stats-grid" id="yb-lead-stats"></div>

  {# Search + Filters Row #}
  <div class="yb-lead__filter-bar">
    <form id="yb-lead-search-form" class="yb-lead__search-form">
      <input type="text" id="yb-lead-search-input" placeholder="{{ t.leads_search_placeholder }}" class="yb-lead__search-input">
    </form>
    <select id="yb-lead-status-filter" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.leads_all_statuses }}</option>
      <option value="New">&#10024; New</option>
      <option value="Contacted">&#128231; Contacted</option>
      <option value="No Answer">&#128244; No Answer</option>
      <option value="Follow-up">&#128260; Follow-up</option>
      <option value="Engaged">&#128172; Engaged</option>
      <option value="Qualified">&#9989; Qualified</option>
      <option value="Negotiating">&#129309; Negotiating</option>
      <option value="Converted">&#127881; Converted</option>
      <option value="Existing Applicant">&#128196; Existing Applicant</option>
      <option value="On Hold">&#9208;&#65039; On Hold</option>
      <option value="Unsubscribed">&#128683; Unsubscribed</option>
      <option value="Lost">&#128078; Lost</option>
      <option value="Closed">&#10006; Closed</option>
      <option value="Archived">&#128230; Archived</option>
    </select>
    <select id="yb-lead-type-filter" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.leads_all_types }}</option>
      <option value="ytt">YTT</option>
      <option value="course">Course</option>
      <option value="bundle">Bundle</option>
      <option value="mentorship">Mentorship</option>
      <option value="careers">Career</option>
      <option value="contact">Contact</option>
    </select>
    <select id="yb-lead-source-filter" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.leads_all_sources }}</option>
      <option value="200h YTT">200h YTT</option>
      <option value="300h YTT">300h YTT</option>
      <option value="Courses">Courses</option>
      <option value="Mentorship">Mentorship</option>
      <option value="Contact page">Contact page</option>
      <option value="Careers page">Careers page</option>
      <option value="Apply page">Apply page</option>
      <option value="Manual entry">Manual entry</option>
    </select>
    <select id="yb-lead-priority-filter" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.leads_all_priorities }}</option>
      <option value="urgent">&#128308; Urgent</option>
      <option value="high">&#128992; High</option>
      <option value="normal">&#128994; Normal</option>
      <option value="low">&#9898; Low</option>
    </select>
    <select id="yb-lead-temperature-filter" class="yb-admin__select yb-lead__filter">
      <option value="">{{ t.leads_all_temps }}</option>
      <option value="hot">&#128293; Hot</option>
      <option value="warm">&#9728;&#65039; Warm</option>
      <option value="cold">&#10052;&#65039; Cold</option>
    </select>
  </div>

  {# Result count #}
  <div class="yb-lead__result-bar">
    <span id="yb-lead-count" class="yb-lead__count-text"></span>
  </div>

  {# Bulk actions bar (hidden until selections) #}
  <div id="yb-lead-bulk-bar" class="yb-lead__bulk-bar" hidden>
    <span id="yb-lead-bulk-count" class="yb-lead__bulk-count-text"></span>
    <button class="yb-btn yb-btn--sm yb-btn--outline" data-action="bulk-status">&#9881;&#65039; {{ t.leads_bulk_status }}</button>
    <button class="yb-btn yb-btn--sm yb-btn--outline" data-action="bulk-email">&#9993;&#65039; {{ t.leads_bulk_email }}</button>
    <button class="yb-btn yb-btn--sm yb-btn--outline" data-action="bulk-sms">&#128241; {{ t.leads_bulk_sms }}</button>
    <button class="yb-btn yb-btn--sm yb-btn--outline yb-admin__icon-btn--danger" data-action="bulk-archive">&#128451; {{ t.leads_bulk_archive }}</button>
    <button class="yb-btn yb-btn--sm yb-btn--outline" data-action="bulk-deselect">&#10006; {{ t.leads_deselect }}</button>
  </div>

  {# Lead table #}
  <div class="yb-admin__table-wrap yb-lead__table-wrap" id="yb-lead-table-container">
    <table class="yb-admin__table yb-lead__table" id="yb-lead-table">
      <thead>
        <tr>
          <th class="yb-lead__th-chevron"></th>
          <th class="yb-lead__th-cb"><input type="checkbox" id="yb-lead-select-all" title="{{ t.leads_select_all }}"></th>
          <th class="yb-lead__th-date"><button class="yb-lead__sort-btn is-active is-desc" data-sort="created_at">{{ t.leads_col_date }} <span class="yb-lead__sort-icon"></span></button></th>
          <th>{{ t.users_col_name }}</th>
          <th>{{ t.leads_contact }}</th>
          <th>{{ t.leads_col_type }}</th>
          <th class="yb-lead__th-program">{{ t.leads_col_program }}</th>
          <th class="yb-lead__th-source">{{ t.leads_source }}</th>
          <th><button class="yb-lead__sort-btn" data-sort="status">{{ t.leads_col_status }} <span class="yb-lead__sort-icon"></span></button></th>
          <th class="yb-lead__th-followup">{{ t.leads_followup }}</th>
          <th class="yb-lead__th-lastcontact">{{ t.leads_col_lastcontact }}</th>
          <th class="yb-lead__th-temp" title="{{ t.leads_col_temp }}">&#127777;</th>
          <th class="yb-lead__th-notes" title="{{ t.leads_col_notes }}">&#128221;</th>
          <th class="yb-lead__th-app" title="{{ t.leads_has_application }}">App</th>
          <th></th>
        </tr>
      </thead>
      <tbody id="yb-lead-table-body"></tbody>
    </table>
  </div>
  <div id="yb-lead-load-more-wrap" style="text-align:center;margin-top:1rem" hidden>
    <button class="yb-btn yb-btn--outline" data-action="leads-load-more">{{ t.leads_load_more }}</button>
  </div>

  {# Kanban Pipeline Board (hidden by default, toggled by view switch) #}
  <div id="yb-lead-kanban" class="yb-lead__kanban" hidden></div>
</div>

{# ── Lead Detail View ── #}
<div id="yb-admin-v-lead-detail" hidden>
  <div class="yb-admin__view-head">
    <button class="yb-admin__back-btn" data-action="back-leads">&larr; {{ t.back }}</button>
    <h2 id="yb-lead-detail-heading">{{ t.leads_detail_title }}</h2>
  </div>

  {# Lead info card (two-column) #}
  <div id="yb-lead-detail-card"></div>

  {# Quick actions #}
  <div class="yb-admin__section-divider"></div>
  <h3 class="yb-lead__section-title">{{ t.leads_actions }}</h3>
  <div id="yb-lead-actions" class="yb-lead__actions"></div>

  {# SMS Conversation #}
  <div class="yb-admin__section-divider"></div>
  <h3 class="yb-lead__section-title">{{ t.leads_sms_conversation }}</h3>
  <div id="yb-lead-sms-conversation" class="yb-lead__sms-conversation">
    <p class="yb-lead__empty-text">{{ t.leads_no_messages }}</p>
  </div>

  {# Status + Priority + Temperature + Follow-up #}
  <div class="yb-admin__section-divider"></div>
  <h3 class="yb-lead__section-title">{{ t.leads_update_status }}</h3>
  <form id="yb-lead-status-form" class="yb-admin__form">
    <div class="yb-lead__status-grid">
      <div class="yb-admin__field">
        <label for="yb-lead-status-select">{{ t.leads_col_status }}</label>
        <select id="yb-lead-status-select" class="yb-admin__select">
          <option value="New">&#10024; New</option>
          <option value="Contacted">&#128231; Contacted</option>
          <option value="Follow-up">&#128260; Follow-up</option>
          <option value="Engaged">&#128172; Engaged</option>
          <option value="Qualified">&#9989; Qualified</option>
          <option value="Negotiating">&#129309; Negotiating</option>
          <option value="Converted">&#127881; Converted</option>
          <option value="Existing Applicant">&#128196; Existing Applicant</option>
          <option value="On Hold">&#9208;&#65039; On Hold</option>
          <option value="Unsubscribed">&#128683; Unsubscribed</option>
          <option value="Lost">&#128078; Lost</option>
          <option value="Closed">&#10006; Closed</option>
        </select>
      </div>
      <div class="yb-admin__field">
        <label for="yb-lead-sub-status-select">{{ t.leads_sub_status }}</label>
        <select id="yb-lead-sub-status-select" class="yb-admin__select">
          <option value="">--</option>
        </select>
      </div>
      <div class="yb-admin__field">
        <label for="yb-lead-priority-select">{{ t.leads_priority }}</label>
        <select id="yb-lead-priority-select" class="yb-admin__select">
          <option value="">&#8212; None</option>
          <option value="urgent">&#128308; Urgent</option>
          <option value="high">&#128992; High</option>
          <option value="normal">&#128994; Normal</option>
          <option value="low">&#9898; Low</option>
        </select>
      </div>
      <div class="yb-admin__field">
        <label for="yb-lead-temperature-select">{{ t.leads_temperature }}</label>
        <select id="yb-lead-temperature-select" class="yb-admin__select">
          <option value="">&#8212; None</option>
          <option value="hot">&#128293; Hot</option>
          <option value="warm">&#9728;&#65039; Warm</option>
          <option value="cold">&#10052;&#65039; Cold</option>
        </select>
      </div>
      <div class="yb-admin__field">
        <label for="yb-lead-followup-input">{{ t.leads_followup }}</label>
        <input type="date" id="yb-lead-followup-input" class="yb-admin__select">
      </div>
    </div>
    <div class="yb-admin__form-actions">
      <button type="submit" class="yb-btn yb-btn--primary">{{ t.save }}</button>
    </div>
  </form>

  {# Notes timeline #}
  <div class="yb-admin__section-divider"></div>
  <h3 class="yb-lead__section-title">{{ t.leads_notes }}</h3>
  <form id="yb-lead-note-form" class="yb-lead__note-form">
    <input type="text" id="yb-lead-note-input" placeholder="{{ t.leads_note_placeholder }}" class="yb-lead__note-input">
    <button type="submit" class="yb-btn yb-btn--primary yb-btn--sm" data-action="lead-note-submit">{{ t.leads_add_note_btn }}</button>
  </form>
  <div id="yb-lead-notes-timeline" class="yb-lead__notes-timeline"></div>

  {# Activity / communication log #}
  <div class="yb-admin__section-divider"></div>
  <h3 class="yb-lead__section-title">{{ t.leads_activity }}</h3>
  <div id="yb-lead-activity"></div>
</div>

{# Campaign modals moved to admin.njk so they render outside tab panels #}
