<!-- hreflang: Danish is primary, English at /en/ prefix -->
{% if lang == "en" %}
{% set daPath = page.url | replace("/en/", "/") %}
{% set enPath = page.url %}
{% else %}
{% set daPath = page.url %}
{% set enPath = "/en" + page.url %}
{% endif %}
<link rel="alternate" hreflang="da" href="{{ site.url }}{{ daPath }}">
<link rel="alternate" hreflang="en" href="{{ site.url }}{{ enPath }}">
