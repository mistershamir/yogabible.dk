{% if isJournalPost %}
<!-- JSON-LD: Article (individual blog posts, AEO) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": "{{ title }}",
  "description": "{{ description }}",
  "url": "{{ site.url }}{{ page.url }}",
  "datePublished": "{{ journalDate }}",
  "dateModified": "{{ journalDate }}",
  "author": {
