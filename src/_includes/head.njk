<!-- JSON-LD: BreadcrumbList (all pages, AEO) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "{% if lang == 'en' %}Home{% else %}Forside{% endif %}",
      "item": "{{ site.url }}{% if lang == 'en' %}/en/{% else %}/{% endif %}"
    }
    {% if breadcrumb2 %},
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{ breadcrumb2 }}",
      "item": "{{ site.url }}{{ breadcrumb2url }}"
    }
    {% endif %}
    {% if breadcrumb3 %},
    {
      "@type": "ListItem",
      "position": 3,
      "name": "{{ breadcrumb3 }}",
      "item": "{{ site.url }}{{ page.url }}"
    }
    {% endif %}
    {% if not breadcrumb2 and page.url != "/" and page.url != "/en/" %},
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{ title }}",
      "item": "{{ site.url }}{{ page.url }}"
    }
    {% endif %}
  ]
}
</script>

{% if faq %}
<!-- JSON-LD: FAQPage (AEO — pages with FAQ data) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in faq %}
    {% if not loop.first %},{% endif %}
    {
      "@type": "Question",
      "name": "{{ item.q }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ item.a }}"
      }
    }
    {% endfor %}
  ]
}
</script>
{% endif %}

