<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="theme-color" content="#0F0F0F">

{% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}

<!-- SEO Meta Tags -->
<title>{{ title | default("YOGA BIBLE — Yogalæreruddannelse i København | Yoga Teacher Training Copenhagen") }}</title>
<meta name="description" content="{{ description | default("Yoga Bible — professionel yogalæreruddannelse i København siden 2014. Yoga Alliance certificeret (RYS-200). 200-timers & 300-timers uddannelse, hot yoga, kurser og klasser. Professional yoga teacher training in Copenhagen.") }}">
{% if keywords %}<meta name="keywords" content="{{ keywords }}">{% endif %}
<link rel="canonical" href="{{ site.url }}{{ page.url }}">
{% if langAlternateEn %}<link rel="alternate" hreflang="en" href="{{ langAlternateEn }}">{% endif %}
{% if langAlternateDa %}<link rel="alternate" hreflang="da" href="{{ langAlternateDa }}">{% endif %}

<!-- Open Graph -->
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:title" content="{{ ogTitle or title | default("YOGA BIBLE — Yoga Teacher Training Copenhagen") }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:type" content="{{ ogType | default('website') }}">
<meta property="og:description" content="{{ ogDescription or description | default("Yoga Bible — professionel yogalæreruddannelse i København. Yoga Alliance certificeret. Hot yoga, kurser og klasser.") }}">
<meta property="og:image" content="{{ ogImage | default(site.url + '/assets/images/og/og-1200x630.png') }}">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:locale" content="{% if lang == 'en' %}en_US{% else %}da_DK{% endif %}">
<meta property="og:locale:alternate" content="{% if lang == 'en' %}da_DK{% else %}en_US{% endif %}">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ ogTitle or title | default("YOGA BIBLE — Yoga Teacher Training Copenhagen") }}">
<meta name="twitter:description" content="{{ ogDescription or description | default("Yoga Bible — professionel yogalæreruddannelse i København. Yoga Alliance certificeret.") }}">
<meta name="twitter:image" content="{{ ogImage | default(site.url + '/assets/images/og/og-1200x630.png') }}">

<!-- Favicon -->
<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

