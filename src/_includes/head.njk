<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta http-equiv="X-UA-Compatible" content="IE=edge">

{% if noindex %}<meta name="robots" content="noindex, nofollow">{% endif %}

<!-- SEO Meta Tags -->
<title>{{ title | default("YOGA BIBLE - Denmark") }}</title>
<meta name="description" content="{{ description | default("Yoga Bible er din platform for yogalæreruddannelser, fordybelse og professionelle yogaklasser. Uanset om du vil undervise, lære mere eller finde dit fællesskab – vi er her.") }}">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">

<!-- Open Graph -->
<meta property="og:site_name" content="{{ site.name }}">
<meta property="og:title" content="{{ title | default("YOGA BIBLE - Denmark") }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta property="og:type" content="website">
<meta property="og:description" content="{{ description | default("Yoga Bible er din platform for yogalæreruddannelser, fordybelse og professionelle yogaklasser.") }}">
<meta property="og:image" content="{{ site.url }}/assets/images/og/og-1200x630.png">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="{{ title | default("YOGA BIBLE - Denmark") }}">
<meta name="twitter:description" content="{{ description | default("Yoga Bible er din platform for yogalæreruddannelser, fordybelse og professionelle yogaklasser.") }}">
<meta name="twitter:image" content="{{ site.url }}/assets/images/og/og-1200x630.png">

<!-- Favicon -->
<link rel="icon" href="/favicon.ico" sizes="any">
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">

<!-- Google Site Verification -->
<meta name="google-site-verification" content="TwcY-eZVLkyfpXRQVox4jFESZT0sitKW9qkvkJLE0P0">

<!-- Facebook Domain Verification -->
<meta name="facebook-domain-verification" content="uhk5ka193c4bdd16ldrpfhdy92n02g">

<!-- GTM ID — loaded conditionally by cookie consent manager -->
<meta name="yb-gtm-id" content="{{ site.gtmId }}">
<!-- Meta Pixel ID — loaded conditionally by cookie consent manager -->
{% if site.metaPixelId %}<meta name="yb-meta-pixel-id" content="{{ site.metaPixelId }}">{% endif %}
<!-- Clarity ID — loaded conditionally by cookie consent manager -->
{% if site.clarityId %}<meta name="yb-clarity-id" content="{{ site.clarityId }}">{% endif %}
<script>window.dataLayer = window.dataLayer || [];</script>

<!-- hreflang: Danish is primary, English at /en/ prefix -->
{% if lang == "en" %}
{% set daPath = page.url | replace("/en/", "/") %}
{% set enPath = page.url %}
{% else %}
{% set daPath = page.url %}
{% set enPath = "/en" + page.url %}
{% endif %}
<link rel="alternate" hreflang="da" href="{{ site.url }}{{ daPath }}">
<link rel="alternate" hreflang="en" href="{{ site.url }}{{ enPath }}">
<link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ daPath }}">

<!-- JSON-LD: Organization (all pages) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": "Yoga Bible",
  "alternateName": "YOGA BIBLE",
  "url": "{{ site.url }}",
  "logo": "{{ site.url }}/assets/images/og/og-1200x630.png",
  "description": "Yogalæreruddannelser i København. Yoga Alliance certificeret (RYS-200). Hatha, Vinyasa, Yin og Hot Yoga.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Torvegade 66",
    "addressLocality": "København K",
    "postalCode": "1400",
    "addressCountry": "DK"
  },
  "telephone": "{{ site.phone }}",
  "email": "{{ site.email }}",
  "sameAs": [
    "{{ site.instagram }}"
  ],
  "areaServed": {
    "@type": "City",
    "name": "København"
  }
}
</script>

{% if page.url == "/" or page.url == "/en/" %}
<!-- JSON-LD: WebSite with SearchAction (homepage only, AEO) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Yoga Bible",
  "url": "{{ site.url }}",
  "description": "Yogalæreruddannelser, kurser og klasser i København. Yoga Alliance certificeret.",
  "inLanguage": ["da", "en"],
  "publisher": {
    "@type": "EducationalOrganization",
    "name": "Yoga Bible"
  }
}
</script>
{% endif %}

{% set coursePages = ["/om-200hrs-yogalreruddannelser/", "/200-hours-18-weeks-flexible-programs/", "/200-hours-8-weeks-semi-intensive-programs/", "/200-hours-4-weeks-intensive-programs/"] %}
{% set isCourse = page.url in coursePages or page.url | replace("/en/", "/") in coursePages %}
{% if isCourse %}
<!-- JSON-LD: Course (program pages) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "{{ title }}",
  "description": "{{ description }}",
  "url": "{{ site.url }}{{ page.url }}",
  "provider": {
    "@type": "EducationalOrganization",
    "name": "Yoga Bible",
    "url": "{{ site.url }}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Torvegade 66",
      "addressLocality": "København K",
      "postalCode": "1400",
      "addressCountry": "DK"
    }
  },
  "educationalCredentialAwarded": "RYT-200 Yoga Alliance Certification",
  "inLanguage": ["da", "en"],
  "hasCourseInstance": {
    "@type": "CourseInstance",
    "courseMode": "onsite",
    "location": {
      "@type": "Place",
      "name": "Yoga Bible Studio",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Torvegade 66",
        "addressLocality": "København K",
        "postalCode": "1400",
        "addressCountry": "DK"
      }
    }
  },
  "offers": {
    "@type": "Offer",
    "price": "25500",
    "priceCurrency": "DKK",
    "availability": "https://schema.org/InStock",
    "url": "{{ site.url }}/apply"
  }
}
</script>
{% endif %}

{% set specPages = ["/inversions/", "/splits/", "/backbends/"] %}
{% set isSpec = page.url in specPages or page.url | replace("/en/", "/") in specPages %}
{% if isSpec %}
<!-- JSON-LD: Course (specialty courses) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Course",
  "name": "{{ title }}",
  "description": "{{ description }}",
  "url": "{{ site.url }}{{ page.url }}",
  "provider": {
    "@type": "EducationalOrganization",
    "name": "Yoga Bible",
    "url": "{{ site.url }}"
  },
  "offers": {
    "@type": "Offer",
    "price": "2300",
    "priceCurrency": "DKK",
    "availability": "https://schema.org/InStock"
  }
}
</script>
{% endif %}

{% if isJournalListing %}
<!-- JSON-LD: Blog (journal listing page, AEO) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Yoga Journal — YOGA BIBLE",
  "description": "Dybdegående artikler om yogafilosofi, pranayama, asanas, mental sundhed og uddannelse fra Yoga Bible i København.",
  "url": "{{ site.url }}/yoga-journal/",
  "inLanguage": ["da", "en"],
  "publisher": {
    "@type": "EducationalOrganization",
    "name": "Yoga Bible",
    "url": "{{ site.url }}"
  }
}
</script>
{% endif %}

<!-- Netlify Identity (for CMS login) -->
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>

<!-- Font Preloads -->
<link rel="preload" href="/assets/fonts/AbacaxiLatinWeb-Regular.woff2" as="font" type="font/woff2" crossorigin>
<link rel="preload" href="/assets/fonts/AbacaxiLatinWeb-Bold.woff2" as="font" type="font/woff2" crossorigin>

<!-- Stylesheets -->
<link rel="stylesheet" href="/css/main.css">
<link rel="preconnect" href="https://use.typekit.net" crossorigin>
<link rel="preconnect" href="https://p.typekit.net" crossorigin>

