{% set lp = "/en" if lang == "en" else "" %}

<header id="yb-header">
  {# ── Orange utility strip (desktop only, hidden on mobile via CSS) ── #}
  <div class="yb-util">
    <div class="yb-util__wrap">
      <div class="yb-util__left">
        <a href="mailto:{{ site.email }}" data-i18n="util.email">info@yogabible.dk</a>
        <span class="yb-util__dot"></span>
        <a href="tel:{{ site.phone }}" data-i18n="util.phone">+45 53 88 12 09</a>
        <span class="yb-util__dot"></span>
        <span data-i18n="util.address">Torvegade 66, 1400, København K</span>
      </div>
      <div class="yb-util__right">
        <a href="{{ site.instagram }}" target="_blank" rel="noopener">Instagram</a>
        <a href="{{ site.soundcloud }}" target="_blank" rel="noopener">SoundCloud</a>
        <span class="yb-util__dot"></span>
        <a class="yb-util__flag{% if lang != 'en' %} is-active{% endif %}" data-lang="da" href="/">🇩🇰</a>
        <a class="yb-util__flag{% if lang == 'en' %} is-active{% endif %}" data-lang="en" href="/en/">🇬🇧</a>
        <span class="yb-util__dot"></span>
        {# Auth: login link (shown when logged out) #}
        <a id="yb-auth-login-link" class="yb-util__auth" href="#" data-yb-auth-open="login">
          <span data-yj-da>Log ind</span>
          <span data-yj-en hidden>Sign in</span>
        </a>
        {# Auth: user name (shown when logged in) #}
        <span id="yb-auth-user-link" class="yb-util__auth yb-util__auth--user" style="display:none">
          <span id="yb-auth-user-avatar" class="yb-util__avatar">YB</span>
          <span id="yb-auth-user-name" class="yb-util__user-name"></span>
          <a href="#" class="yb-util__logout" data-yb-auth-logout>
            <span data-yj-da>Log ud</span>
            <span data-yj-en hidden>Sign out</span>
          </a>
        </span>
      </div>
    </div>
  </div>

  {# ── Main navigation bar ── #}
  <div class="yb-nav">
    <div class="yb-nav__wrap">
      {# Left nav (desktop) #}
      <nav class="yb-nav__left" aria-label="Primary">
        <div class="yb-dd" data-dd="mega">
          <button class="yb-dd__btn" type="button" aria-haspopup="true" aria-expanded="false">
            <span data-i18n="nav.education">Uddannelser</span>
            <span class="yb-dd__arrow">▾</span>
          </button>
        </div>
        <div class="yb-dd" data-dd>
          <button class="yb-dd__btn" type="button" aria-haspopup="true" aria-expanded="false">
            <span data-i18n="nav.courses">Kurser</span>
            <span class="yb-dd__arrow">▾</span>
          </button>
          <div class="yb-dd__panel" role="menu">
            <a href="{{ lp }}/inversions" data-i18n="courses.inversions">Inversions</a>
            <a href="{{ lp }}/splits" data-i18n="courses.splits">Splits</a>
            <a href="{{ lp }}/backbends" data-i18n="courses.backbends">Backbends</a>
            <a href="{{ lp }}/course-bundles" data-i18n="courses.bundles">Kursus Bundles</a>
          </div>
        </div>
        <a class="yb-dd__btn" href="{{ lp }}/mentorship-private-training" data-i18n="nav.mentorship">Mentorship</a>
      </nav>

      {# Center logo #}
      <a class="yb-nav__logo" href="{{ lp }}/" aria-label="Yoga Bible">
        <img src="/assets/images/brand/logo-orange-on-transparent.png" alt="Yoga Bible" width="180" height="44" />
      </a>

      {# Right nav (desktop) + mobile controls #}
      <div class="yb-nav__right">
        <nav class="yb-nav__links" aria-label="Secondary">
          <div class="yb-dd yb-dd--right" data-dd>
            <button class="yb-dd__btn" type="button" aria-haspopup="true" aria-expanded="false">
              <span data-i18n="nav.more">Mere</span>
              <span class="yb-dd__arrow">▾</span>
            </button>
            <div class="yb-dd__panel yb-dd__panel--right" role="menu">
              <a href="{{ lp }}/yoga-journal" data-i18n="more.journal">Yoga Journal</a>
              <a href="{{ lp }}/yogaphotography" data-i18n="more.photo">Yoga Fotografi</a>
              <a href="{{ lp }}/yogamusic" data-i18n="more.music">Yoga Musik</a>
              <a href="{{ lp }}/yoga-glossary" data-i18n="more.glossary">Yoga Ordbog</a>
            </div>
          </div>
          <div class="yb-dd yb-dd--right" data-dd>
            <button class="yb-dd__btn" type="button" aria-haspopup="true" aria-expanded="false">
              <span data-i18n="nav.yogabible">Yoga Bible</span>
              <span class="yb-dd__arrow">▾</span>
            </button>
            <div class="yb-dd__panel yb-dd__panel--right" role="menu">
              <a href="{{ lp }}/yoga-bible-historie" data-i18n="nav.ourstory">Vores Historie</a>
              <a href="{{ lp }}/about-copenhagen" data-i18n="nav.copenhagen">About Copenhagen</a>
              <a href="{{ lp }}/accommodation" data-i18n="nav.accommodation">Bolig til Kursister</a>
              <a href="{{ lp }}/weekly-schedule" data-i18n="nav.schedule">Ugentligt Klasseskema</a>
              <a href="{{ lp }}/careers" data-i18n="nav.careers">Karriere</a>
              <a href="{{ lp }}/terms-conditions" data-i18n="nav.terms">Handelsbetingelser</a>
              <a href="{{ lp }}/privacy-policy" data-i18n="nav.privacy">Privatlivspolitik</a>
              <a href="{{ lp }}/code-of-conduct" data-i18n="nav.conduct">Code of Conduct</a>
              <a href="{{ lp }}/kontakt" data-i18n="nav.contact">Kontakt</a>
            </div>
          </div>
        </nav>

        <a class="yb-nav__cta" href="{{ lp }}/apply" data-i18n="nav.apply">Ansøg</a>

        {# Mobile: flags + burger #}
        <div class="yb-mob-flags">
          <a class="yb-mob-flag{% if lang != 'en' %} is-active{% endif %}" data-lang="da" href="/">🇩🇰</a>
          <a class="yb-mob-flag{% if lang == 'en' %} is-active{% endif %}" data-lang="en" href="/en/">🇬🇧</a>
        </div>

        <button class="yb-burger" type="button" aria-label="Menu" aria-expanded="false">
          <span></span><span></span><span></span>
        </button>
      </div>
    </div>
  </div>

  {# ── Mega menu panel (Education) ── #}
  <div class="yb-mega" id="yb-mega" hidden>
    <div class="yb-mega__wrap">
      <div class="yb-mega__col">
        <div class="yb-mega__heading" data-i18n="mega.200.title">200 Timer — All Levels</div>
        <a class="yb-mega__link" href="{{ lp }}/om-200hrs-yogalreruddannelser" data-i18n="edu.200.about">Om 200-timers yogalæreruddannelser</a>
        <a class="yb-mega__sub" href="{{ lp }}/200-hours-18-weeks-flexible-programs" data-i18n="edu.200.18">18 uger — fleksibel</a>
        <a class="yb-mega__sub" href="{{ lp }}/200-hours-8-weeks-semi-intensive-programs" data-i18n="edu.200.8">8 uger — semi-intensiv</a>
        <a class="yb-mega__sub" href="{{ lp }}/200-hours-4-weeks-intensive-programs" data-i18n="edu.200.4">4 uger — intensiv</a>
        <a class="yb-mega__link yb-mega__link--mt" href="{{ lp }}/sammenlign-yogalreruddannelser" data-i18n="edu.compare">Sammenlign uddannelser</a>
      </div>
      <div class="yb-mega__col">
        <div class="yb-mega__heading" data-i18n="mega.300.title">300 Timer — Advanced</div>
        <a class="yb-mega__link" href="{{ lp }}/300-hours-advanced-teacher-training" data-i18n="edu.300.about">300-timers avanceret uddannelse</a>
      </div>
    </div>
  </div>

  {# ── Mobile drawer ── #}
  <div class="yb-drawer" id="yb-drawer" hidden>
    <div class="yb-drawer__bg" data-close-drawer></div>
    <div class="yb-drawer__body">
      <div class="yb-drawer__head">
        <a href="{{ lp }}/">
          <img src="/assets/images/brand/logo-orange-on-transparent.png" alt="Yoga Bible" height="34" />
        </a>
        <button class="yb-drawer__close" type="button" data-close-drawer aria-label="Close">✕</button>
      </div>

      {# Auth section (mobile drawer) #}
      <div class="yb-drawer__auth">
        <a id="yb-auth-mobile-login" class="yb-drawer__auth-login" href="#" data-yb-auth-open="login">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <span data-yj-da>Log ind / Opret konto</span>
          <span data-yj-en hidden>Sign in / Create account</span>
        </a>
        <div id="yb-auth-mobile-user" class="yb-drawer__auth-user" style="display:none">
          <span class="yb-drawer__auth-avatar">YB</span>
          <span id="yb-auth-mobile-name" class="yb-drawer__auth-name"></span>
          <a class="yb-drawer__auth-logout" href="#" data-yb-auth-logout>
            <span data-yj-da>Log ud</span>
            <span data-yj-en hidden>Sign out</span>
          </a>
        </div>
      </div>

      <nav class="yb-drawer__list">
        {# Education accordion #}
        <div class="yb-acc" data-acc>
          <button class="yb-acc__toggle" type="button" aria-expanded="false">
            <span data-i18n="nav.education">Uddannelser</span><span class="yb-acc__icon">▾</span>
          </button>
          <div class="yb-acc__content">
            <p class="yb-acc__label" data-i18n="mega.200.title">200 Timer — All Levels</p>
            <a href="{{ lp }}/om-200hrs-yogalreruddannelser" data-i18n="edu.200.about">Om 200-timers uddannelser</a>
            <a href="{{ lp }}/200-hours-18-weeks-flexible-programs" data-i18n="edu.200.18">18 uger — fleksibel</a>
            <a href="{{ lp }}/200-hours-8-weeks-semi-intensive-programs" data-i18n="edu.200.8">8 uger — semi-intensiv</a>
            <a href="{{ lp }}/200-hours-4-weeks-intensive-programs" data-i18n="edu.200.4">4 uger — intensiv</a>
            <a href="{{ lp }}/sammenlign-yogalreruddannelser" data-i18n="edu.compare">Sammenlign uddannelser</a>
            <p class="yb-acc__label" data-i18n="mega.300.title">300 Timer — Advanced</p>
            <a href="{{ lp }}/300-hours-advanced-teacher-training" data-i18n="edu.300.about">300-timers avanceret uddannelse</a>
          </div>
        </div>

        {# Courses accordion #}
        <div class="yb-acc" data-acc>
          <button class="yb-acc__toggle" type="button" aria-expanded="false">
            <span data-i18n="nav.courses">Kurser</span><span class="yb-acc__icon">▾</span>
          </button>
          <div class="yb-acc__content">
            <a href="{{ lp }}/inversions" data-i18n="courses.inversions">Inversions</a>
            <a href="{{ lp }}/splits" data-i18n="courses.splits">Splits</a>
            <a href="{{ lp }}/backbends" data-i18n="courses.backbends">Backbends</a>
            <a href="{{ lp }}/course-bundles" data-i18n="courses.bundles">Kursus Bundles</a>
          </div>
        </div>

        <a class="yb-drawer__link" href="{{ lp }}/mentorship-private-training" data-i18n="nav.mentorship">Mentorship &amp; Privat Træning</a>

        {# More accordion #}
        <div class="yb-acc" data-acc>
          <button class="yb-acc__toggle" type="button" aria-expanded="false">
            <span data-i18n="nav.more">Mere</span><span class="yb-acc__icon">▾</span>
          </button>
          <div class="yb-acc__content">
            <a href="{{ lp }}/yoga-journal" data-i18n="more.journal">Yoga Journal</a>
            <a href="{{ lp }}/yogaphotography" data-i18n="more.photo">Yoga Fotografi</a>
            <a href="{{ lp }}/yogamusic" data-i18n="more.music">Yoga Musik</a>
            <a href="{{ lp }}/yoga-glossary" data-i18n="more.glossary">Yoga Ordbog</a>
          </div>
        </div>

        {# Yoga Bible accordion #}
        <div class="yb-acc" data-acc>
          <button class="yb-acc__toggle" type="button" aria-expanded="false">
            <span data-i18n="nav.yogabible">Yoga Bible</span><span class="yb-acc__icon">▾</span>
          </button>
          <div class="yb-acc__content">
            <a href="{{ lp }}/yoga-bible-historie" data-i18n="nav.ourstory">Vores Historie</a>
            <a href="{{ lp }}/about-copenhagen" data-i18n="nav.copenhagen">About Copenhagen</a>
            <a href="{{ lp }}/accommodation" data-i18n="nav.accommodation">Bolig til Kursister</a>
            <a href="{{ lp }}/weekly-schedule" data-i18n="nav.schedule">Ugentligt Klasseskema</a>
            <a href="{{ lp }}/careers" data-i18n="nav.careers">Karriere</a>
            <a href="{{ lp }}/terms-conditions" data-i18n="nav.terms">Handelsbetingelser</a>
            <a href="{{ lp }}/privacy-policy" data-i18n="nav.privacy">Privatlivspolitik</a>
            <a href="{{ lp }}/code-of-conduct" data-i18n="nav.conduct">Code of Conduct</a>
            <a href="{{ lp }}/kontakt" data-i18n="nav.contact">Kontakt</a>
          </div>
        </div>

        <a class="yb-drawer__cta" href="{{ lp }}/apply" data-i18n="nav.apply">Ansøg</a>
      </nav>

      <div class="yb-drawer__foot">
        <div class="yb-drawer__social">
          <a class="yb-drawer__pill" href="{{ site.instagram }}" target="_blank" rel="noopener">Instagram</a>
          <a class="yb-drawer__pill" href="{{ site.soundcloud }}" target="_blank" rel="noopener">SoundCloud</a>
        </div>
        <div class="yb-drawer__flags">
          <a class="yb-drawer__flag{% if lang != 'en' %} is-active{% endif %}" data-lang="da" href="/">🇩🇰</a>
          <a class="yb-drawer__flag{% if lang == 'en' %} is-active{% endif %}" data-lang="en" href="/en/">🇬🇧</a>
        </div>
        <div class="yb-drawer__apps">
          <a href="{{ site.appStore }}" target="_blank" rel="noopener" aria-label="App Store">
            <img src="https://www.yogabible.dk/s/Yoga_Bible_App_Store.svg" alt="App Store" height="28" />
          </a>
          <a href="{{ site.googlePlay }}" target="_blank" rel="noopener" aria-label="Google Play">
            <img src="https://www.yogabible.dk/s/Yoga_Bible_App_Google_Play.svg" alt="Google Play" height="28" />
          </a>
        </div>
      </div>
    </div>
  </div>
</header>
