      <div class="yb-careers-steps__step"><div class="yb-careers-steps__nr">1</div><h3>{{ t.step1_title | safe }}</h3><p>{{ t.step1_desc }}</p></div>
      <div class="yb-careers-steps__step"><div class="yb-careers-steps__nr">2</div><h3>{{ t.step2_title | safe }}</h3><p>{{ t.step2_desc }}</p></div>
      <div class="yb-careers-steps__step"><div class="yb-careers-steps__nr">3</div><h3>{{ t.step3_title | safe }}</h3><p>{{ t.step3_desc }}</p></div>
    </div>
    <div class="yb-careers-steps__ctaStrip">
      <div><h3>{{ t.steps_cta_title }}</h3><p>{{ t.steps_cta_desc }}</p></div>
      <a class="yb-btn yb-btn--cta" href="#" data-ybcar-open="careers">{{ t.hero_cta_apply }}</a>
    </div>
  </div>
  <style>
    #yb-careers-steps, #yb-careers-steps *{ box-sizing:border-box; }
    #yb-careers-steps{ padding: 52px 20px; background: var(--yb-soft); border-top:1px solid var(--yb-border); border-bottom:1px solid var(--yb-border); }
    #yb-careers-steps .yb-careers-steps__inner{ max-width:1120px; margin:0 auto; }
    #yb-careers-steps .yb-careers-steps__head{ max-width: 760px; }
    #yb-careers-steps h2{ margin:0 0 8px; font-size:28px; letter-spacing:-.01em; }
    #yb-careers-steps p{ margin:0; color:#444; line-height:1.65; }
    #yb-careers-steps .yb-careers-steps__grid{ display:grid; grid-template-columns:1fr; gap:14px; margin-top:18px; }
