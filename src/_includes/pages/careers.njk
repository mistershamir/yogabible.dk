    #yb-careers-need .yb-careers-need__cards{ display: grid; grid-template-columns: 1fr; gap: 16px; }
    @media (min-width: 640px){ #yb-careers-need .yb-careers-need__cards{ grid-template-columns: repeat(2, 1fr); gap: 18px; } }
    @media (min-width: 1000px){ #yb-careers-need .yb-careers-need__cards{ grid-template-columns: repeat(3, 1fr); gap: 20px; } }
    #yb-careers-need .yb-careers-need__card{ position: relative; border: 1px solid var(--yb-border); border-radius: 20px; background: #fff; box-shadow: 0 1px 2px rgba(0,0,0,0.04), 0 8px 24px rgba(0,0,0,0.06); padding: 20px 18px 18px; display: flex; flex-direction: column; min-height: 280px; transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease; }
    #yb-careers-need .yb-careers-need__card:hover{ transform: translateY(-3px); box-shadow: 0 4px 8px rgba(0,0,0,0.04), 0 16px 40px rgba(0,0,0,0.10); border-color: rgba(var(--yb-accent-rgb), 0.25); }
    #yb-careers-need .yb-careers-need__tag{ display: inline-block; align-self: flex-start; font-size: 0.7rem; font-weight: 800; letter-spacing: 0.06em; text-transform: uppercase; padding: 5px 10px; border-radius: 999px; margin-bottom: 12px; background: rgba(var(--yb-accent-rgb), 0.12); color: var(--yb-accent); }
    #yb-careers-need .yb-careers-need__tag--muted{ background: #f3f2f0; color: #666; }
    #yb-careers-need .yb-careers-need__card h3{ margin: 0 0 8px; font-size: 1.15rem; font-weight: 800; letter-spacing: -0.01em; color: var(--yb-text); }
    #yb-careers-need .yb-careers-need__card > p{ margin: 0; color: #555; line-height: 1.55; font-size: 0.95rem; }
    #yb-careers-need .yb-careers-need__card ul{ margin: 14px 0 18px; padding: 0 0 0 18px; color: #444; line-height: 1.55; font-size: 0.9rem; flex: 1; }
    #yb-careers-need .yb-careers-need__card li{ margin: 5px 0; }
    #yb-careers-need .yb-careers-need__card li::marker{ color: rgba(var(--yb-accent-rgb), 0.5); }
    #yb-careers-need .yb-careers-need__card .yb-btn{ margin-top: auto; width: 100%; justify-content: center; text-align: center; }
    #yb-careers-need .yb-careers-need__card--featured{ background: linear-gradient(135deg, rgba(var(--yb-accent-rgb), 0.03) 0%, transparent 60%), #fff; border-color: rgba(var(--yb-accent-rgb), 0.3); box-shadow: 0 1px 2px rgba(0,0,0,0.04), 0 12px 32px rgba(var(--yb-accent-rgb), 0.12); }
    #yb-careers-need .yb-careers-need__card--featured:hover{ border-color: var(--yb-accent); box-shadow: 0 4px 8px rgba(0,0,0,0.04), 0 20px 50px rgba(var(--yb-accent-rgb), 0.18); }
    #yb-careers-need .yb-careers-need__card--featured::before{ content: ''; position: absolute; top: 0; left: 24px; right: 24px; height: 3px; background: linear-gradient(90deg, var(--yb-accent), rgba(var(--yb-accent-rgb), 0.3)); border-radius: 0 0 3px 3px; }
    #yb-careers-need .yb-careers-need__card--cta{ grid-column: 1 / -1; background: radial-gradient(ellipse 60% 100% at 0% 50%, rgba(var(--yb-accent-rgb), 0.08), transparent 50%), radial-gradient(ellipse 40% 80% at 100% 50%, rgba(var(--yb-accent-rgb), 0.05), transparent 50%), linear-gradient(135deg, #FFFCF9 0%, #fff 100%); border: 2px dashed rgba(var(--yb-accent-rgb), 0.35); min-height: auto; padding: clamp(24px, 4vw, 32px) clamp(20px, 4vw, 32px); }
    #yb-careers-need .yb-careers-need__card--cta:hover{ border-color: var(--yb-accent); border-style: solid; transform: translateY(-2px); }
    #yb-careers-need .yb-careers-need__cta-inner{ display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 16px; text-align: center; }
    @media (min-width: 640px){ #yb-careers-need .yb-careers-need__cta-inner{ flex-direction: row; text-align: left; gap: clamp(24px, 4vw, 48px); } }
    #yb-careers-need .yb-careers-need__cta-content{ flex: 1; }
    #yb-careers-need .yb-careers-need__card--cta h3{ margin: 0 0 6px; font-size: clamp(1.1rem, 2.5vw, 1.35rem); }
    #yb-careers-need .yb-careers-need__card--cta p{ margin: 0; max-width: 480px; color: #555; font-size: clamp(0.9rem, 2vw, 1rem); }
    #yb-careers-need .yb-careers-need__card--cta .yb-btn{ width: auto; padding: 0.85rem 2rem; flex-shrink: 0; margin-top: 0; }
    #yb-careers-need .yb-btn{ display: inline-flex; align-items: center; justify-content: center; padding: 0.75rem 1.25rem; border-radius: 999px; font-weight: 750; font-size: 0.92rem; text-decoration: none; border: 2px solid transparent; cursor: pointer; user-select: none; transition: all 0.18s ease; white-space: nowrap; }
    #yb-careers-need .yb-btn--cta{ background: var(--yb-accent) !important; border-color: var(--yb-accent) !important; color: #fff !important; box-shadow: 0 4px 14px rgba(var(--yb-accent-rgb), 0.25); }
    #yb-careers-need .yb-btn--cta:hover{ background: #e05402 !important; border-color: #e05402 !important; box-shadow: 0 6px 20px rgba(var(--yb-accent-rgb), 0.32); transform: translateY(-1px); }
    #yb-careers-need .yb-btn--outline{ background: #fff !important; border-color: rgba(var(--yb-accent-rgb), 0.45) !important; color: var(--yb-accent) !important; }
    #yb-careers-need .yb-btn--outline:hover{ background: var(--yb-accent) !important; border-color: var(--yb-accent) !important; color: #fff !important; box-shadow: 0 4px 14px rgba(var(--yb-accent-rgb), 0.25); transform: translateY(-1px); }
    @media (prefers-reduced-motion: reduce){ #yb-careers-need .yb-careers-need__card, #yb-careers-need .yb-btn{ transition: none; } #yb-careers-need .yb-careers-need__card:hover, #yb-careers-need .yb-btn:hover{ transform: none; } }
  </style>
</section>

<!-- ===================== SECTION 3 — STEPS ===================== -->
<section id="yb-careers-steps" class="yb-careers-scope" aria-label="{{ t.steps_title }}">
