  </style>
  <script>
  (function(){
    var root = document.querySelector('#yb-careers-faq [data-yb-careers-faq]');
    if (!root) return;
    if (root.dataset.init === "1") return;
    root.dataset.init = "1";
    root.addEventListener("click", function(e){
      var btn = e.target.closest(".yb-careers-faq__q");
      if (!btn) return;
      var ans = btn.nextElementSibling;
      var isOpen = btn.getAttribute("aria-expanded") === "true";
      root.querySelectorAll(".yb-careers-faq__q").forEach(function(b){
        b.setAttribute("aria-expanded","false");
        var a = b.nextElementSibling;
        if (a) a.hidden = true;
      });
      btn.setAttribute("aria-expanded", String(!isOpen));
      if (ans) ans.hidden = isOpen ? true : false;
    });
  })();
  </script>
