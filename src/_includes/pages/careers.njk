    #yb-careers-faq .yb-careers-faq__head{ max-width: 760px; }
    #yb-careers-faq h2{ margin:0 0 8px; font-size:28px; letter-spacing:-.01em; }
    #yb-careers-faq p{ margin:0; color:#444; line-height:1.65; }
    #yb-careers-faq .yb-careers-faq__box{ border:1px solid var(--yb-border); border-radius: 20px; background:#fff; overflow:hidden; margin-top: 18px; box-shadow: 0 18px 60px rgba(0,0,0,0.07); }
    #yb-careers-faq .yb-careers-faq__q{ width:100%; text-align:left; padding: 14px 16px; background:#fff; border:0; border-bottom:1px solid var(--yb-border); cursor:pointer; font-weight:800; display:flex; align-items:center; justify-content:space-between; gap:10px; font-family:inherit; color: var(--yb-text); }
