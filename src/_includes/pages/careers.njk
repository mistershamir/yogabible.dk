    #yb-careers-steps .yb-careers-steps__step{ border:1px solid var(--yb-border); border-radius: 20px; background:#fff; padding: 16px; box-shadow: 0 18px 60px rgba(0,0,0,0.07); }
    #yb-careers-steps .yb-careers-steps__nr{ width:32px; height:32px; display:flex; align-items:center; justify-content:center; border-radius:999px; background: var(--yb-accent); color:#fff; font-weight:900; font-size:15px; margin-bottom:10px; }
    #yb-careers-steps .yb-careers-steps__step h3{ margin:0 0 6px; font-size:18px; }
    #yb-careers-steps .yb-careers-steps__step p{ margin:0; color:#444; line-height:1.6; }
    #yb-careers-steps .yb-careers-steps__ctaStrip{ margin-top:18px; border:1px solid var(--yb-border); border-radius:20px; background:#fff; padding:16px; display:flex; align-items:center; justify-content:space-between; gap:14px; flex-wrap:wrap; box-shadow: 0 18px 60px rgba(0,0,0,0.07); }
    #yb-careers-steps .yb-careers-steps__ctaStrip h3{ margin:0 0 6px; font-size:18px; }
    #yb-careers-steps .yb-careers-steps__ctaStrip p{ margin:0; color:#444; line-height:1.6; }
  </style>
</section>

<!-- ===================== SECTION 4 — WHY ===================== -->
<section id="yb-careers-why" class="yb-careers-scope" aria-label="{{ t.why_title }}">
