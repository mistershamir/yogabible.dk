  <style>
    #yb-careers-need, #yb-careers-need *{ box-sizing:border-box; }
    #yb-careers-need{ --yb-accent: #f75c03; --yb-accent-rgb: 247, 92, 3; --yb-border: #EBE7E3; --yb-soft: #FCFBF9; --yb-text: #1A1A1A; --yb-muted: #6B6B6B; padding: clamp(48px, 7vw, 80px) clamp(16px, 4vw, 24px); background: radial-gradient(ellipse 80% 50% at 20% 0%, rgba(247, 92, 3, 0.06), transparent 60%), radial-gradient(ellipse 60% 40% at 90% 100%, rgba(247, 92, 3, 0.04), transparent 50%), linear-gradient(180deg, #FFFCF9 0%, #fff 100%); font-family: "Helvetica Neue", Helvetica, Arial, system-ui, -apple-system, sans-serif; }
    #yb-careers-need .yb-careers-need__inner{ max-width: 1160px; margin: 0 auto; }
    #yb-careers-need .yb-careers-need__head{ max-width: 680px; margin-bottom: clamp(28px, 4vw, 40px); }
