{% set t = i18n.careers[lang or "da"] %}

<!-- ═══════════════════════════════════════════════════════════════
     PRIMARY HERO — Dark Cinematic with Breathing Glow
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title | safe }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_lead }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="#" data-ybcar-open="careers" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta_apply }}</a>
      <a href="#yb-careers-need" class="yb-btn yb-btn--outline-white yb-btn--large">{{ t.hero_cta_options }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

<!-- ===================== SECTION 2 — DETAILED HERO ===================== -->
<section id="yb-careers-hero" class="yb-careers-scope" aria-label="Careers hero">
  <div class="yb-careers-hero__inner">
    <div class="yb-careers-hero__grid">
      <div class="yb-careers-hero__copy">
        <p class="yb-careers-hero__kicker">{{ t.hero_kicker | safe }}</p>
        <h1 class="yb-careers-hero__title">{{ t.hero_title | safe }}</h1>
        <p class="yb-careers-hero__lead">{{ t.hero_lead }}</p>
        <ul class="yb-careers-hero__bullets">
          <li>{{ t.hero_li1 | safe }}</li>
          <li>{{ t.hero_li2 | safe }}</li>
          <li>{{ t.hero_li3 }}</li>
          <li>{{ t.hero_li4 | safe }}</li>
          <li>{{ t.hero_li5 }}</li>
        </ul>
        <div class="yb-careers-hero__ctaRow">
          <a class="yb-btn yb-btn--cta" href="#" data-ybcar-open="careers">{{ t.hero_cta_apply }}</a>
          <a class="yb-btn yb-btn--ghost" href="#yb-careers-need">{{ t.hero_cta_options }}</a>
        </div>
        <p class="yb-careers-hero__fine">{{ t.hero_fine }}</p>
      </div>
      <div class="yb-careers-hero__media" aria-label="Video">
        <div class="yb-careers-hero__frame">
          <video class="yb-careers-hero__video" autoplay muted loop playsinline preload="metadata" poster="https://www.yogabible.dk/s/DSC_8528.jpg">
            <source src="https://www.yogabible.dk/s/careers-vertical.mp4" type="video/mp4">
          </video>
        </div>
        <p class="yb-careers-hero__caption">{{ t.hero_caption }}</p>
      </div>
    </div>
  </div>
  <style>
    #yb-careers-hero, #yb-careers-hero *{ box-sizing:border-box; }
    #yb-careers-hero{ background: linear-gradient(180deg, var(--yb-soft), #fff 70%); border-bottom:1px solid var(--yb-border); padding: 72px 20px 44px; }
    #yb-careers-hero .yb-careers-hero__inner{ max-width:1120px; margin:0 auto; }
    #yb-careers-hero .yb-careers-hero__grid{ display:grid; gap:28px; align-items:center; }
    @media (min-width: 980px){ #yb-careers-hero .yb-careers-hero__grid{ grid-template-columns: 1.12fr .88fr; } }
    #yb-careers-hero .yb-careers-hero__kicker{ margin:0 0 10px; font-size:12px; letter-spacing:.12em; text-transform:uppercase; color:#777; font-weight:800; }
    #yb-careers-hero .yb-careers-hero__title{ margin:0 0 10px; font-size: clamp(32px, 4.2vw, 52px); line-height:1.06; letter-spacing:-.02em; }
    #yb-careers-hero .yb-careers-hero__accent{ color: var(--yb-accent); }
    #yb-careers-hero .yb-careers-hero__lead{ margin:0 0 18px; color:#333; line-height:1.6; font-size:1.02rem; max-width: 56ch; }
    #yb-careers-hero .yb-careers-hero__bullets{ margin:0 0 20px; padding:0 0 0 18px; color:#333; line-height:1.6; }
    #yb-careers-hero .yb-careers-hero__bullets li{ margin:6px 0; }
    #yb-careers-hero .yb-careers-hero__ctaRow{ display:flex; gap:12px; flex-wrap:wrap; margin: 8px 0 10px; }
    #yb-careers-hero .yb-careers-hero__fine{ margin:0; color:var(--yb-muted); font-size:12.8px; line-height:1.55; max-width: 62ch; }
    #yb-careers-hero .yb-careers-hero__frame{ border-radius: 22px; border:1px solid var(--yb-border); background:#fff; box-shadow: 0 18px 60px rgba(0,0,0,0.12); overflow:hidden; aspect-ratio: 9 / 16; }
    #yb-careers-hero .yb-careers-hero__video{ width:100%; height:100%; object-fit:cover; display:block; }
    #yb-careers-hero .yb-careers-hero__caption{ margin:10px 0 0; color:#777; font-size:12.5px; letter-spacing:.02em; text-align:center; }
  </style>
</section>

