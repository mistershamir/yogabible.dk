    @media (min-width: 720px){ .ybcar-upload__row{ grid-template-columns: 1fr 1fr; } }
    .ybcar-upload__label{ display:block; font-size:12px; letter-spacing:.08em; text-transform:uppercase; color:#6b6b6b; font-weight:800; margin-bottom: 7px; }
    .ybcar-upload input[type="file"]{ width:100%; border:1px solid var(--ybcar-border); border-radius:14px; padding: 10px; background:#fff; height:auto; }
    .ybcar-upload__hint{ margin:6px 0 0; color:#777; font-size:12.5px; line-height:1.45; }
    .ybcar-consent{ display:grid; grid-template-columns: 18px 1fr; gap:10px; align-items:flex-start; margin-top: 2px; color:#333; line-height:1.45; font-weight:650; font-size:.92rem; }
    .ybcar-consent input{ margin-top:3px; width:18px; height:18px; accent-color: var(--ybcar-accent); }
    .ybcar-btn{ display:inline-flex; align-items:center; justify-content:center; padding:.7rem 1.1rem; border-radius:999px; font-weight:780; font-size:.95rem; text-decoration:none; border:1px solid transparent; cursor:pointer; user-select:none; transition: filter .16s ease, box-shadow .16s ease, background-color .16s ease, color .16s ease, border-color .16s ease; white-space:nowrap; }
    .ybcar-btn--cta{ background:var(--ybcar-accent); border-color:var(--ybcar-accent); color:#fff; box-shadow: 0 14px 40px rgba(0,0,0,0.10); }
    .ybcar-btn--cta:hover{ filter:brightness(.96); }
    .ybcar-btn--outline{ background:#fff; border-color: rgba(var(--ybcar-accent-rgb), .55); color: var(--ybcar-accent); }
    .ybcar-btn--outline:hover{ border-color: var(--ybcar-accent); filter: brightness(.99); }
    .ybcar-submit{ width: fit-content; }
    .ybcar-submit[disabled]{ opacity:.65; cursor:not-allowed; box-shadow:none; }
    .ybcar-fine{ margin:0; color:var(--ybcar-muted); font-size:12.5px; line-height:1.55; }
    .ybcar-error{ margin:0; font-size:13px; color:#B00020; line-height:1.45; }
    .ybcar-error a{ color: var(--ybcar-accent); text-decoration:none; border-bottom:1px solid rgba(var(--ybcar-accent-rgb), .35); }
    .ybcar-error__detail{ display:block; margin-top:6px; color:#7a1e1e; font-size:12.5px; }
    .ybcar-success{ border:1px solid var(--ybcar-border); border-radius:18px; background: var(--ybcar-soft); padding: 16px; }
    .ybcar-success h3{ margin:.1rem 0 .4rem; font-size:20px; }
    .ybcar-success p{ margin:0 0 .9rem; color:#444; line-height:1.65; }
    @media (max-width: 720px){ .ybcar-grid{ grid-template-columns:1fr; } .ybcar-field--zip{ max-width: none; } .ybcar-submit{ width:100%; } .ybcar-chips{ gap:6px; } .ybcar-chip span{ padding: 8px 12px; font-size:13px; } .ybcar-chips--sub .ybcar-chip span{ padding: 6px 10px; font-size:12px; } }
  </style>
</div>

<!-- ===================== SUBCATS DATA ===================== -->
<script id="ybcar-subcats-data" type="application/json">{{ t.js_subcats | dump | safe }}</script>

<!-- ===================== CAREERS MODAL LOGIC ===================== -->
<script>
(function(){
  var modal = document.getElementById("ybcar-modal");
  if (!modal) return;
  if (modal.dataset.ybcarInit === "1") return;
  modal.dataset.ybcarInit = "1";

  var form       = document.getElementById("ybcarForm");
  var frame      = document.getElementById("ybcarFrame");

  var viewForm    = document.getElementById("ybcar-view-form");
  var viewSuccess = document.getElementById("ybcar-view-success");

  var metaUrl   = document.getElementById("ybcarPageUrl");
  var metaAt    = document.getElementById("ybcarSubmittedAt");
  var payloadEl = document.getElementById("ybcarPayload");

  var errBox    = document.getElementById("ybcarError");
  var errDetail = document.getElementById("ybcarErrorDetail");
  var submitBtn = document.getElementById("ybcarSubmit");

  var categoryChipsWrap = document.getElementById("ybcarCategoryChips");
  var categoryValueEl   = document.getElementById("ybcarCategoryValue");
  var categoryErrorEl   = document.getElementById("ybcarCategoryError");

  var subWrap           = document.getElementById("ybcarSubWrap");
  var subChipsWrap      = document.getElementById("ybcarSubcategoryChips");
  var subValueEl        = document.getElementById("ybcarSubcategoryValue");
  var subErrorEl        = document.getElementById("ybcarSubError");

  var otherWrap = document.getElementById("ybcarOtherWrap");
  var otherInp  = document.getElementById("ybcarOtherTopic");

  var cvInp     = document.getElementById("ybcarCv");
  var extraInp  = document.getElementById("ybcarExtra");

  try{ if (modal.parentElement !== document.body) document.body.appendChild(modal); }catch(e){}

  /* --- Translated JS strings via data attributes --- */
  var MSG_SENDING = form ? (form.getAttribute('data-msg-sending') || 'Sender\u2026') : 'Sender\u2026';
  var MSG_SUBMIT = form ? (form.getAttribute('data-msg-submit') || 'Send foresp\u00f8rgsel') : 'Send foresp\u00f8rgsel';
  var MSG_TOO_MANY = form ? (form.getAttribute('data-msg-too-many') || 'For mange filer.') : 'For mange filer.';
  var MSG_TOO_LARGE_PRE = form ? (form.getAttribute('data-msg-too-large-pre') || 'En fil er for stor. Max ') : 'En fil er for stor. Max ';
  var MSG_TOO_LARGE_SUF = form ? (form.getAttribute('data-msg-too-large-suf') || ' MB pr. fil.') : ' MB pr. fil.';
  var MSG_BAD_TYPE = form ? (form.getAttribute('data-msg-bad-type') || 'Filtype ikke underst\u00f8ttet: ') : 'Filtype ikke underst\u00f8ttet: ';
  var MSG_UNKNOWN = form ? (form.getAttribute('data-msg-unknown') || '(Ukendt fejl)') : '(Ukendt fejl)';
  var MSG_FILEREADER = form ? (form.getAttribute('data-msg-filereader') || '(Kunne ikke l\u00e6se filer.)') : '(Kunne ikke l\u00e6se filer.)';

  /* --- SUBCATS from JSON data element --- */
  var SUBCATS = {};
  try {
    var subcatsEl = document.getElementById("ybcar-subcats-data");
    if (subcatsEl) SUBCATS = JSON.parse(subcatsEl.textContent);
  } catch(e){}

  var awaitingResponse = false;
  var submitStartedAt = 0;
  var fallbackTimer = null;

  function setLoading(is){
    if (!submitBtn) return;
    submitBtn.disabled = !!is;
    submitBtn.textContent = is ? MSG_SENDING : MSG_SUBMIT;
  }

  function showError(msg){
    if (errBox) errBox.hidden = false;
    if (errDetail) errDetail.textContent = msg ? (" " + msg) : "";
  }

  function showSuccessUI(){
    awaitingResponse = false;
    if (fallbackTimer) clearTimeout(fallbackTimer);
    fallbackTimer = null;

    setLoading(false);

    if (viewForm) viewForm.hidden = true;
    if (viewSuccess) viewSuccess.hidden = false;

    try{ form && form.reset(); }catch(e){}
    if (subWrap) subWrap.hidden = true;
    if (otherWrap) otherWrap.hidden = true;
    if (payloadEl) payloadEl.value = "";
    if (categoryValueEl) categoryValueEl.value = "";
    if (subValueEl) subValueEl.value = "";
  }

  function resetViews(){
    if (viewForm) viewForm.hidden = false;
    if (viewSuccess) viewSuccess.hidden = true;
    if (errBox) errBox.hidden = true;
    if (errDetail) errDetail.textContent = "";
    if (categoryErrorEl) categoryErrorEl.hidden = true;
    if (subErrorEl) subErrorEl.hidden = true;
    setLoading(false);

    awaitingResponse = false;
    if (fallbackTimer) clearTimeout(fallbackTimer);
    fallbackTimer = null;
  }

  function getSelectedCategories(){
    if (!categoryChipsWrap) return [];
    var checkboxes = categoryChipsWrap.querySelectorAll('input[type="checkbox"]:checked');
    return Array.from(checkboxes).map(function(cb){ return cb.value; });
  }

  function getSelectedSubcategories(){
    if (!subChipsWrap) return [];
    var checkboxes = subChipsWrap.querySelectorAll('input[type="checkbox"]:checked');
    return Array.from(checkboxes).map(function(cb){ return cb.value; });
  }

  function getMergedSubcategories(selectedCats){
    var merged = [];
    var seen = {};
    selectedCats.forEach(function(cat){
      var subs = SUBCATS[cat] || [];
      subs.forEach(function(sub){
        if (!seen[sub]){
          seen[sub] = true;
          merged.push(sub);
        }
      });
    });
    return merged;
  }

  function updateSubcategoryValue(){
    var selected = getSelectedSubcategories();
    if (subValueEl) subValueEl.value = selected.join(", ");
  }

  function updateCategoryValue(){
    var selected = getSelectedCategories();
    if (categoryValueEl) categoryValueEl.value = selected.join(", ");
  }

  function renderSubcategoryChips(items, preserveSelections){
    if (!subChipsWrap) return;

    var prevSelected = {};
    if (preserveSelections){
      getSelectedSubcategories().forEach(function(s){ prevSelected[s] = true; });
    }

    subChipsWrap.innerHTML = "";

    items.forEach(function(item){
      var label = document.createElement("label");
      label.className = "ybcar-chip";

      var checkbox = document.createElement("input");
      checkbox.type = "checkbox";
      checkbox.name = "subcategoryChip";
      checkbox.value = item;
      if (prevSelected[item]) checkbox.checked = true;

      var span = document.createElement("span");
      span.textContent = item;

      label.appendChild(checkbox);
      label.appendChild(span);
      subChipsWrap.appendChild(label);

      checkbox.addEventListener("change", updateSubcategoryValue);
    });

    updateSubcategoryValue();
  }

  function syncCategoryUI(preserveSubSelections){
    var selectedCats = getSelectedCategories();

    updateCategoryValue();

    var hasAndet = selectedCats.indexOf("Andet samarbejde") !== -1;
    if (otherWrap) otherWrap.hidden = !hasAndet;
    if (otherInp){
      otherInp.required = hasAndet;
      if (!hasAndet) otherInp.value = "";
    }

    var mergedSubs = getMergedSubcategories(selectedCats);
    var hasSubs = mergedSubs.length > 0;

    if (subWrap) subWrap.hidden = !hasSubs;

    if (hasSubs){
      renderSubcategoryChips(mergedSubs, preserveSubSelections);
    } else {
      if (subChipsWrap) subChipsWrap.innerHTML = "";
      if (subValueEl) subValueEl.value = "";
    }

    if (categoryErrorEl) categoryErrorEl.hidden = true;
    if (subErrorEl) subErrorEl.hidden = true;
  }

  function openModal(prefillCategories){
    try{ form && form.reset(); }catch(e){}
    if (metaUrl) metaUrl.value = window.location.href;
    if (metaAt) metaAt.value = "";
    if (payloadEl) payloadEl.value = "";
    if (categoryValueEl) categoryValueEl.value = "";
    if (subValueEl) subValueEl.value = "";

    if (categoryChipsWrap){
      categoryChipsWrap.querySelectorAll('input[type="checkbox"]').forEach(function(cb){ cb.checked = false; });
    }

    if (prefillCategories){
      var prefillArr = Array.isArray(prefillCategories)
        ? prefillCategories
        : prefillCategories.split(",").map(function(s){ return s.trim(); });

      if (categoryChipsWrap){
        prefillArr.forEach(function(cat){
          var cb = categoryChipsWrap.querySelector('input[value="' + cat + '"]');
          if (cb) cb.checked = true;
        });
      }
    }

    syncCategoryUI(false);
    resetViews();

    modal.hidden = false;
    modal.setAttribute("aria-hidden","false");

    var first = form ? form.querySelector('input[name="firstName"]') : null;
    if (first) setTimeout(function(){ first.focus(); }, 30);
  }

  function closeModal(){
    modal.hidden = true;
    modal.setAttribute("aria-hidden","true");
  }

  if (categoryChipsWrap){
    categoryChipsWrap.addEventListener("change", function(){ syncCategoryUI(true); });
  }

  document.addEventListener("click", function(e){
    var opener = e.target.closest('[data-ybcar-open="careers"]');
    if (opener){
      e.preventDefault();
      var prefill = opener.getAttribute("data-ybcar-prefill") || "";
      openModal(prefill);
      return;
    }
    var closer = e.target.closest("[data-ybcar-close]");
    if (closer){
      e.preventDefault();
      closeModal();
      return;
    }
  });

  document.addEventListener("keydown", function(e){
    if (e.key === "Escape" && !modal.hidden) closeModal();
  });

  if (frame){
    frame.addEventListener("load", function(){
      if (!awaitingResponse) return;
      if (Date.now() - submitStartedAt < 250) return;
      showSuccessUI();
    });
  }

  var MAX_MB_PER_FILE = 6;
  var MAX_FILES_TOTAL = 6;
  var ACCEPT_MIME_LIST = [
    "application/pdf","image/jpeg","image/png","image/webp",
    "application/msword","application/vnd.openxmlformats-officedocument.wordprocessingml.document"
  ];

  function fileToBase64(file){
    return new Promise(function(resolve, reject){
      var fr = new FileReader();
      fr.onerror = function(){ reject(new Error("FileReader error")); };
      fr.onload = function(){
        var res = String(fr.result || "");
        var comma = res.indexOf(",");
        var b64 = comma >= 0 ? res.slice(comma+1) : "";
        resolve(b64);
      };
      fr.readAsDataURL(file);
    });
  }

  async function buildPayload(){
    var fd = new FormData(form);
    var fields = {};
    fd.forEach(function(v,k){ fields[k] = String(v); });

    fields.category = categoryValueEl ? categoryValueEl.value : "";
    fields.subcategory = subValueEl ? subValueEl.value : "";

    fields.pageUrl = (metaUrl && metaUrl.value) ? metaUrl.value : window.location.href;
    fields.submittedAt = (metaAt && metaAt.value) ? metaAt.value : new Date().toISOString();
    fields.mode = "careers";

    var files = [];
    var cv = cvInp && cvInp.files && cvInp.files[0] ? cvInp.files[0] : null;
    var extras = extraInp && extraInp.files ? Array.from(extraInp.files) : [];

    var all = [];
    if (cv) all.push({kind:"cv", file:cv});
    extras.forEach(function(f){ all.push({kind:"extra", file:f}); });

    if (all.length > MAX_FILES_TOTAL){
      throw new Error(MSG_TOO_MANY);
    }

    for (var i = 0; i < all.length; i++){
      var item = all[i];
      var f = item.file;

      if (f.size > MAX_MB_PER_FILE * 1024 * 1024){
        throw new Error(MSG_TOO_LARGE_PRE + MAX_MB_PER_FILE + MSG_TOO_LARGE_SUF);
      }
      if (f.type && ACCEPT_MIME_LIST.indexOf(f.type) === -1){
        throw new Error(MSG_BAD_TYPE + (f.type || "unknown"));
      }

      var b64 = await fileToBase64(f);
      files.push({
        kind: item.kind,
        filename: f.name,
        mimeType: f.type || "application/octet-stream",
        base64: b64
      });
    }

    return { fields: fields, files: files };
  }

  function validateChipFields(){
    var valid = true;

    var selectedCats = getSelectedCategories();
    if (selectedCats.length === 0){
      if (categoryErrorEl) categoryErrorEl.hidden = false;
      valid = false;
    } else {
      if (categoryErrorEl) categoryErrorEl.hidden = true;
    }

    var mergedSubs = getMergedSubcategories(selectedCats);
    if (mergedSubs.length > 0){
      var selectedSubs = getSelectedSubcategories();
      if (selectedSubs.length === 0){
        if (subErrorEl) subErrorEl.hidden = false;
        valid = false;
      } else {
        if (subErrorEl) subErrorEl.hidden = true;
      }
    }

    return valid;
  }

  window.addEventListener("message", function(event){
    var origin = String(event.origin || "");
    var okOrigin = origin.indexOf("script.google.com") !== -1 || origin.indexOf("script.googleusercontent.com") !== -1;
    if (!okOrigin) return;

    var data = event.data || {};
    if (!data || typeof data !== "object") return;
    if (data.source !== "yb-careers-webapp") return;

    if (data.ok){
      showSuccessUI();
    } else {
      awaitingResponse = false;
      if (fallbackTimer) clearTimeout(fallbackTimer);
      fallbackTimer = null;
      setLoading(false);
      showError(data.error ? "(" + data.error + ")" : MSG_UNKNOWN);
    }
  });

  if (form){
    form.addEventListener("submit", async function(e){
      e.preventDefault();

      if (errBox) errBox.hidden = true;
      if (errDetail) errDetail.textContent = "";

      syncCategoryUI(true);

      if (!validateChipFields()) return;

      if (metaAt) metaAt.value = new Date().toISOString();
      if (!form.reportValidity()) return;

      try{
        setLoading(true);

        awaitingResponse = true;
        submitStartedAt = Date.now();

        if (fallbackTimer) clearTimeout(fallbackTimer);
        fallbackTimer = setTimeout(function(){
          if (!awaitingResponse) return;
          showSuccessUI();
        }, 9000);

        var payload = await buildPayload();
        if (payloadEl) payloadEl.value = JSON.stringify(payload);

        form.submit();
      } catch(err){
        awaitingResponse = false;
        if (fallbackTimer) clearTimeout(fallbackTimer);
        fallbackTimer = null;

        setLoading(false);
        showError(err && err.message ? "(" + err.message + ")" : MSG_FILEREADER);
      }
    });
  }
})();
</script>
