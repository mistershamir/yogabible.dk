      <h2 style="font-size:1.3rem;font-weight:700;margin-bottom:8px;">{{ t.contactTitle }}</h2>
      <p style="font-size:.92rem;color:#6F6A66;line-height:1.55;margin-bottom:20px;">{{ t.contactDesc }}</p>
      <a href="/en/200-hours-4-weeks-intensive-programs/?booking=consultation" style="display:inline-block;background:#f75c03;color:#fff;padding:14px 28px;border-radius:50px;font-size:.95rem;font-weight:600;text-decoration:none;transition:background .2s;" onmouseenter="this.style.background='#d94f02'" onmouseleave="this.style.background='#f75c03'">{{ t.contactCta }}</a>
      <p style="font-size:.82rem;color:#6F6A66;margin-top:14px;">{{ t.contactEmail }} <a href="mailto:info@yogabible.dk" style="color:#f75c03;">info@yogabible.dk</a></p>
    </div>
  </div>

  {# ── DARK CTA ──────────────────────────────────────── #}
  <div style="background:#0F0F0F;color:#fff;padding:60px 24px;text-align:center;margin-top:48px;">
    <div style="max-width:600px;margin:0 auto;">
      <h2 style="font-size:1.6rem;font-weight:700;margin-bottom:12px;">{{ t.ctaSectionTitle }}</h2>
      <p style="color:rgba(255,255,255,.68);margin-bottom:28px;line-height:1.55;">{{ t.ctaSectionDesc }}</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="/en/200-hours-4-weeks-intensive-programs/?booking=consultation" style="display:inline-flex;align-items:center;background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.5);padding:14px 28px;border-radius:50px;font-size:.95rem;font-weight:600;text-decoration:none;font-family:inherit;transition:all .2s;" onmouseenter="this.style.borderColor='#fff';this.style.background='rgba(255,255,255,.08)'" onmouseleave="this.style.borderColor='rgba(255,255,255,.5)';this.style.background='transparent'">{{ t.ctaBook }}</a>
        <button onclick="startCheckoutFunnel('100211')" style="background:#f75c03;color:#fff;border:none;padding:14px 28px;border-radius:50px;font-size:.95rem;font-weight:600;cursor:pointer;font-family:inherit;transition:background .2s;" onmouseenter="this.style.background='#d94f02'" onmouseleave="this.style.background='#f75c03'">{{ t.ctaStart }}</button>
      </div>
    </div>
  </div>

</section>

<script>
(function() {
  var s4wjpDateCounter = 0;
  var s4wjpFromLabel = '{{ t.conflictDateFrom }}';
  var s4wjpToLabel = '{{ t.conflictDateTo }}';

  window.s4wjpToggleBusyRow = function(cb) {
    var row = cb.closest('.s4wjp-busy-row');
    var times = row.querySelector('.s4wjp-busy-times');
    if (cb.checked) { row.style.background = '#F5F3F0'; times.style.opacity = '1'; times.style.pointerEvents = 'auto'; }
    else { row.style.background = 'transparent'; times.style.opacity = '.3'; times.style.pointerEvents = 'none'; }
  };

  window.s4wjpAddSpecificDate = function() {
    var wrap = document.getElementById('s4wjp-specific-dates');
    if (!wrap) return;
    var row = document.createElement('div');
    row.className = 's4wjp-specific-row';
    row.style.cssText = 'display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:12px;background:#F5F3F0;flex-wrap:wrap;';
    row.innerHTML =
      '<input type="date" class="s4wjp-sd-date" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;flex:1;min-width:130px;">' +
      '<span style="color:#6F6A66;font-size:.75rem;">' + s4wjpFromLabel + '</span>' +
      '<input type="time" value="09:00" class="s4wjp-sd-from" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;width:90px;">' +
      '<span style="color:#6F6A66;font-size:.75rem;">' + s4wjpToLabel + '</span>' +
      '<input type="time" value="17:00" class="s4wjp-sd-to" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;width:90px;">' +
      '<button type="button" onclick="this.parentElement.remove()" style="background:none;border:none;cursor:pointer;padding:4px;color:#6F6A66;font-size:1.1rem;line-height:1;" aria-label="Remove">&times;</button>';
    wrap.appendChild(row);
  };
  s4wjpAddSpecificDate();

  function s4wjpTimeMin(t) { var p = t.split(':'); return parseInt(p[0]) * 60 + parseInt(p[1]); }

  var s4wjpSchedule = [
    {d:'2026-07-06',s:'09:00',e:'15:00'},{d:'2026-07-07',s:'11:00',e:'17:00'},{d:'2026-07-09',s:'11:00',e:'17:00'},{d:'2026-07-11',s:'13:00',e:'18:00'},{d:'2026-07-12',s:'14:00',e:'18:00'},
    {d:'2026-07-13',s:'09:00',e:'15:00'},{d:'2026-07-14',s:'11:00',e:'17:00'},{d:'2026-07-15',s:'10:00',e:'15:00'},{d:'2026-07-16',s:'11:00',e:'17:00'},{d:'2026-07-18',s:'13:00',e:'18:00'},{d:'2026-07-19',s:'13:00',e:'17:00'},
    {d:'2026-07-20',s:'10:00',e:'15:00'},{d:'2026-07-21',s:'09:00',e:'15:00'},{d:'2026-07-23',s:'11:00',e:'15:00'},{d:'2026-07-24',s:'11:00',e:'16:00'},{d:'2026-07-25',s:'13:00',e:'18:00'},{d:'2026-07-26',s:'13:00',e:'17:00'},
    {d:'2026-07-27',s:'10:00',e:'15:00'},{d:'2026-07-29',s:'09:00',e:'15:00'},{d:'2026-07-31',s:'11:00',e:'17:00'},{d:'2026-08-01',s:'13:00',e:'18:00'},{d:'2026-08-02',s:'14:00',e:'17:00'}
  ];
  s4wjpSchedule.forEach(function(item) {
    var dt = new Date(item.d + 'T12:00:00');
    item.dow = dt.getDay();
    item.sMin = s4wjpTimeMin(item.s);
    item.eMin = s4wjpTimeMin(item.e);
    var days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    item.label = days[item.dow] + ' ' + item.d.split('-')[2].replace(/^0/,'') + '/' + item.d.split('-')[1].replace(/^0/,'');
  });

  window.s4wjpCheckConflicts = function() {
    var busySlots = {};
    document.querySelectorAll('.s4wjp-busy-row').forEach(function(row) {
      var cb = row.querySelector('input[name="s4wjp-busy"]');
      if (!cb.checked) return;
      var dow = parseInt(cb.value);
      var from = row.querySelector('.s4wjp-time-from').value || '09:00';
      var to = row.querySelector('.s4wjp-time-to').value || '17:00';
      busySlots[dow] = { s: s4wjpTimeMin(from), e: s4wjpTimeMin(to) };
    });

    var specificDates = [];
    document.querySelectorAll('.s4wjp-specific-row').forEach(function(row) {
      var dateVal = row.querySelector('.s4wjp-sd-date').value;
      if (!dateVal) return;
      var from = row.querySelector('.s4wjp-sd-from').value || '09:00';
      var to = row.querySelector('.s4wjp-sd-to').value || '17:00';
      specificDates.push({ date: dateVal, s: s4wjpTimeMin(from), e: s4wjpTimeMin(to) });
    });

    var conflicts = [];
    s4wjpSchedule.forEach(function(item) {
      var hit = false;
      var slot = busySlots[item.dow];
      if (slot && item.sMin < slot.e && item.eMin > slot.s) hit = true;
      specificDates.forEach(function(sd) {
        if (sd.date === item.d && sd.s < item.eMin && sd.e > item.sMin) hit = true;
      });
      if (hit) conflicts.push(item);
    });

    var el = document.getElementById('s4wjp-conflict-results');
    if (!el) return;
    el.style.display = 'block';
    var total = s4wjpSchedule.length;
    var html = '';
    if (conflicts.length === 0) {
      html += '<div style="background:#f0fff0;border:1px solid #c3e6c3;border-radius:12px;padding:16px;text-align:center;"><p style="font-weight:700;color:#2ecc71;">{{ t.conflictNone }}</p></div>';
    } else {
      html += '<div style="background:#FFF8F3;border:1px solid #FFE5D0;border-radius:12px;padding:16px;">';
      html += '<p style="font-size:.92rem;font-weight:700;margin-bottom:8px;"><span style="color:#f75c03;font-size:1.4rem;">' + conflicts.length + '</span> / ' + total + ' {{ t.conflictSome }}</p>';
      html += '<div style="background:#E8E4E0;border-radius:50px;height:6px;overflow:hidden;margin-bottom:12px;"><div style="background:#2ecc71;height:100%;width:' + Math.round(((total - conflicts.length) / total) * 100) + '%;border-radius:50px;"></div></div>';
      html += '<ul style="margin:0;padding:0 0 0 18px;font-size:.82rem;color:#0F0F0F;">';
      conflicts.forEach(function(c) {
        html += '<li style="margin-bottom:4px;">' + c.label + ' <span style="color:#6F6A66;">(' + c.s + '–' + c.e + ')</span></li>';
      });
      html += '</ul></div>';
    }
    el.innerHTML = html;
  };

  /* Chevron toggle */
  var cfDetails = document.getElementById('s4wjp-conflict-finder');
  if (cfDetails) {
    cfDetails.addEventListener('toggle', function() {
      var chev = cfDetails.querySelector('.s4wjp-cf-chevron');
      if (chev) chev.style.transform = cfDetails.open ? 'rotate(180deg)' : '';
    });
  }

  /* Tokenized visit tracking */
  var params = new URLSearchParams(window.location.search);
  var tid = params.get('tid');
  var tok = params.get('tok');
})();
</script>

