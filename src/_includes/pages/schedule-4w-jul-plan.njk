          { dn: "27", dd_en: "Mon", time: "10:00–15:00", topic_en: "Vinyasa Flow & Creative Sequencing", type: "workshop" },
          { dn: "29", dd_en: "Wed", time: "09:00–15:00", topic_en: "Business of Yoga", type: "workshop" },
          { dn: "31", dd_en: "Fri", time: "11:00–17:00", topic_en: "Hot Yoga & Heated Vinyasa", type: "workshop" },
