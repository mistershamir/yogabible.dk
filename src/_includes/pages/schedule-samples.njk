            {# Content #}
            <div>
              <p style="font-weight:600;font-size:.95rem;">{{ day.topic }}</p>
              <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">{{ day.time }}</p>
            </div>

            {# Type indicator #}
            {% if day.type == "online" %}
            <span style="font-size:.68rem;color:#f75c03;font-weight:600;text-transform:uppercase;letter-spacing:.06em;">Online</span>
            {% elif day.type == "weekend" %}
            <span style="font-size:.68rem;color:#ff9966;font-weight:600;text-transform:uppercase;letter-spacing:.06em;">Weekend</span>
