{# ──────────────────────────────────────────────────────────────
   SCHEDULE DESIGN SAMPLES — 5 distinct visual approaches
   Using the 8-week semi-intensive schedule data as demo content.
   ────────────────────────────────────────────────────────────── #}

{# ── Sample data (first 4 weeks of 8w for demo brevity) ──── #}
{% set demoWeeks = [
  { num: 1, label: "Uge 1 — Introduktion", range: "2–3 maj", days: [
    { date: "2. maj", day: "Fre", time: "13:00–18:00", topic: "Hatha & Class Management — Introduktion", type: "workshop" },
    { date: "3. maj", day: "Lør", time: "14:00–19:00", topic: "Vinyasa & Yin Yoga — Introduktion", type: "weekend" }
  ]},
  { num: 2, label: "Uge 2", range: "7–11 maj", days: [
    { date: "7. maj", day: "Tor", time: "10:00–15:00", topic: "Hatha & Class Management", type: "workshop" },
    { date: "9. maj", day: "Lør", time: "13:00–18:00", topic: "Vinyasa & Yin Yoga", type: "workshop" },
    { date: "10. maj", day: "Søn", time: "14:00–18:00", topic: "Yogafilosofi — Online", type: "online" },
    { date: "11. maj", day: "Man", time: "10:00–15:00", topic: "Vinyasa & Yin Yoga", type: "workshop" }
  ]},
  { num: 3, label: "Uge 3", range: "16–18 maj", days: [
    { date: "16. maj", day: "Lør", time: "13:00–18:00", topic: "Yoga Anatomi", type: "workshop" },
    { date: "17. maj", day: "Søn", time: "14:00–19:00", topic: "Hatha & Class Management", type: "weekend" },
    { date: "18. maj", day: "Man", time: "10:00–15:00", topic: "Vinyasa & Yin Yoga", type: "workshop" }
  ]},
  { num: 4, label: "Uge 4", range: "21–24 maj", days: [
    { date: "21. maj", day: "Ons", time: "10:00–15:00", topic: "Hatha & Class Management", type: "workshop" },
    { date: "23. maj", day: "Fre", time: "13:00–18:00", topic: "Yoga Anatomi", type: "workshop" },
    { date: "24. maj", day: "Lør", time: "14:00–18:00", topic: "Yogafilosofi — Online", type: "online" }
  ]}
] %}

{# ── Page header ─────────────────────────────────────────── #}
<section style="background:#0F0F0F;color:#fff;padding:clamp(80px,12vw,140px) 24px 60px;text-align:center;">
  <div style="max-width:700px;margin:0 auto;">
    <p style="text-transform:uppercase;letter-spacing:.18em;font-size:.78rem;color:#f75c03;margin-bottom:12px;">Design Exploration</p>
    <h1 style="font-size:clamp(2rem,5vw,3.2rem);font-weight:700;line-height:1.15;margin:0 0 16px;">Skema Design Samples</h1>
    <p style="font-size:1.05rem;color:rgba(255,255,255,.72);line-height:1.55;">5 forskellige design-tilgange til YTT uddannelsesskemaet. Samme data, forskellige visuelle udtryk.</p>
  </div>
</section>

{# ── Navigation / jump links ─────────────────────────────── #}
<nav style="background:#F5F3F0;padding:16px 24px;border-bottom:1px solid #E8E4E0;position:sticky;top:0;z-index:100;">
  <div style="max-width:900px;margin:0 auto;display:flex;gap:8px;justify-content:center;flex-wrap:wrap;">
    <a href="#design-1" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:#0F0F0F;color:#fff;">1 · Minimal</a>
    <a href="#design-2" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:rgba(15,15,15,.08);color:#0F0F0F;">2 · Accordion</a>
    <a href="#design-3" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:rgba(15,15,15,.08);color:#0F0F0F;">3 · Timeline</a>
    <a href="#design-4" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:rgba(15,15,15,.08);color:#0F0F0F;">4 · Dark Cinema</a>
    <a href="#design-5" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:rgba(15,15,15,.08);color:#0F0F0F;">5 · Magazine</a>
  </div>
</nav>


{# ════════════════════════════════════════════════════════════
   DESIGN 1: MINIMAL LINEAR
   Ultra-clean, text-focused. No cards, no borders. Like reading
   a beautifully typeset document. Think Apple Notes meets Muji.
   ════════════════════════════════════════════════════════════ #}

<section id="design-1" style="padding:80px 24px 40px;">
  <div style="max-width:640px;margin:0 auto;">

    {# Design label #}
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:48px;">
      <span style="background:#f75c03;color:#fff;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.88rem;">1</span>
      <div>
        <p style="font-weight:700;font-size:1.1rem;">Minimal Linear</p>
        <p style="font-size:.82rem;color:#6F6A66;">Ren typografi. Ingen kort, ingen rammer. Dokument-stil.</p>
      </div>
    </div>

    {# Schedule title #}
    <h2 style="font-size:1.8rem;font-weight:700;letter-spacing:-.02em;margin-bottom:4px;">8 Ugers Semi-Intensiv</h2>
    <p style="font-size:.92rem;color:#6F6A66;margin-bottom:40px;">Maj–Juni 2026 · 200 timer · Yoga Alliance RYT-200</p>

    {% for week in demoWeeks %}
    <div style="margin-bottom:36px;">
      <p style="font-size:.72rem;text-transform:uppercase;letter-spacing:.16em;color:#f75c03;font-weight:700;margin-bottom:12px;">{{ week.label }}</p>

      {% for day in week.days %}
      <div style="display:flex;gap:20px;align-items:baseline;padding:8px 0;{% if not loop.last %}border-bottom:1px solid #F0EDE9;{% endif %}">
        <span style="font-size:.82rem;color:#6F6A66;white-space:nowrap;min-width:52px;">{{ day.date }}</span>
        <span style="font-size:.95rem;font-weight:600;flex:1;">{{ day.topic }}</span>
        <span style="font-size:.78rem;color:#6F6A66;white-space:nowrap;">{{ day.time }}</span>
      </div>
      {% endfor %}
    </div>
    {% endfor %}

  </div>
</section>

<hr style="max-width:900px;margin:0 auto;border:none;border-top:2px dashed #E8E4E0;">


{# ════════════════════════════════════════════════════════════
   DESIGN 2: ACCORDION WEEKS
   Each week is a collapsible accordion item (separate rounded
   items, orange indicator on the right). Compact by default.
   Per design system section 15.
   ════════════════════════════════════════════════════════════ #}

<section id="design-2" style="padding:80px 24px 40px;background:#FFFCF9;">
  <div style="max-width:700px;margin:0 auto;">

    {# Design label #}
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:48px;">
      <span style="background:#f75c03;color:#fff;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.88rem;">2</span>
      <div>
        <p style="font-weight:700;font-size:1.1rem;">Accordion Weeks</p>
        <p style="font-size:.82rem;color:#6F6A66;">Kompakt overblik. Klik for at åbne hver uge. Perfekt til mobil.</p>
      </div>
    </div>

    <h2 style="font-size:1.5rem;font-weight:700;text-align:center;margin-bottom:8px;">Dit uddannelsesskema</h2>
    <p style="text-align:center;font-size:.88rem;color:#6F6A66;margin-bottom:32px;">8 uger · Maj–Juni 2026</p>

    {# Stats row #}
    <div style="display:flex;gap:16px;justify-content:center;margin-bottom:32px;">
      <div style="text-align:center;">
        <span style="font-size:1.5rem;font-weight:700;color:#f75c03;">8</span>
        <p style="font-size:.72rem;color:#6F6A66;">uger</p>
      </div>
      <div style="text-align:center;">
        <span style="font-size:1.5rem;font-weight:700;color:#f75c03;">22</span>
        <p style="font-size:.72rem;color:#6F6A66;">dage</p>
      </div>
      <div style="text-align:center;">
        <span style="font-size:1.5rem;font-weight:700;color:#f75c03;">200+</span>
        <p style="font-size:.72rem;color:#6F6A66;">timer</p>
      </div>
    </div>

    {# Accordion items #}
    {% for week in demoWeeks %}
    <details class="ss-accordion" style="background:#F5F3F0;border-radius:14px;margin-bottom:10px;overflow:hidden;">
      <summary style="display:flex;align-items:center;justify-content:space-between;padding:18px 22px;cursor:pointer;list-style:none;-webkit-appearance:none;">
        <div style="display:flex;align-items:center;gap:14px;">
          <span style="background:#0F0F0F;color:#fff;font-size:.68rem;font-weight:700;padding:4px 10px;border-radius:50px;">UGE {{ week.num }}</span>
          <div>
            <p style="font-weight:600;font-size:.92rem;">{{ week.label | replace("Uge " + week.num + " — ", "") | replace("Uge " + week.num, week.range) }}</p>
            <p style="font-size:.75rem;color:#6F6A66;">{{ week.days | length }} {% if week.days | length == 1 %}dag{% else %}dage{% endif %} · {{ week.range }}</p>
          </div>
        </div>
        <span style="background:#f75c03;color:#fff;width:30px;height:30px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1rem;font-weight:700;transition:transform .25s;" class="ss-acc-icon">+</span>
      </summary>
      <div style="padding:0 22px 18px;">
        {% for day in week.days %}
        <div style="display:flex;align-items:center;gap:12px;padding:10px 0;{% if not loop.last %}border-bottom:1px solid #E8E4E0;{% endif %}">
          <div style="min-width:44px;text-align:center;">
            <span style="font-size:1.1rem;font-weight:700;display:block;line-height:1;">{{ day.date | replace(". maj", "") | replace(". jun", "") }}</span>
            <span style="font-size:.65rem;color:#6F6A66;text-transform:uppercase;">{{ day.day }}</span>
          </div>
          <div style="flex:1;">
            <p style="font-weight:600;font-size:.88rem;">{{ day.topic }}</p>
            <p style="font-size:.75rem;color:#6F6A66;">{{ day.time }}{% if day.type == "online" %} · <span style="color:#f75c03;">Online</span>{% endif %}</p>
          </div>
          {% if day.type == "workshop" %}
          <span style="background:#FFF0E6;color:#f75c03;padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:600;text-transform:uppercase;">Workshop</span>
          {% elif day.type == "weekend" %}
          <span style="background:#FFE5D0;color:#d94f02;padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:600;text-transform:uppercase;">Weekend</span>
          {% elif day.type == "online" %}
          <span style="background:#FFF0E6;color:#f75c03;padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:600;text-transform:uppercase;">Online</span>
          {% endif %}
        </div>
        {% endfor %}
      </div>
    </details>
    {% endfor %}

  </div>
</section>

<hr style="max-width:900px;margin:0 auto;border:none;border-top:2px dashed #E8E4E0;">


{# ════════════════════════════════════════════════════════════
   DESIGN 3: VERTICAL TIMELINE
   A vertical rail runs down the left side. Each day is a node
   on the timeline. Week labels sit as larger dots. Narrative,
   editorial feel — like a journey map.
   ════════════════════════════════════════════════════════════ #}

<section id="design-3" style="padding:80px 24px 40px;">
  <div style="max-width:700px;margin:0 auto;">

    {# Design label #}
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:48px;">
      <span style="background:#f75c03;color:#fff;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.88rem;">3</span>
      <div>
        <p style="font-weight:700;font-size:1.1rem;">Vertical Timeline</p>
        <p style="font-size:.82rem;color:#6F6A66;">Rejsefortælling. Vertikal linje med noder for hver dag. Narrativt flow.</p>
      </div>
    </div>

    <h2 style="font-size:1.5rem;font-weight:700;text-align:center;margin-bottom:8px;">Din rejse starter her</h2>
    <p style="text-align:center;font-size:.88rem;color:#6F6A66;margin-bottom:48px;">8 uger fra introduktion til certificering</p>

    {# Timeline #}
    <div style="position:relative;padding-left:48px;">

      {# The vertical line #}
      <div style="position:absolute;left:18px;top:0;bottom:0;width:2px;background:linear-gradient(to bottom, #f75c03, #ff9966, #E8E4E0);"></div>

      {% for week in demoWeeks %}
      {# Week marker — large dot #}
      <div style="position:relative;margin-bottom:8px;padding-top:{% if loop.first %}0{% else %}20px{% endif %};">
        <div style="position:absolute;left:-42px;top:{% if loop.first %}2px{% else %}22px{% endif %};width:18px;height:18px;background:#f75c03;border-radius:50%;border:3px solid #fff;box-shadow:0 0 0 2px #f75c03;z-index:1;"></div>
        <p style="font-weight:700;font-size:.95rem;color:#f75c03;">{{ week.label }}</p>
        <p style="font-size:.75rem;color:#6F6A66;">{{ week.range }}</p>
      </div>

      {% for day in week.days %}
      {# Day node — small dot #}
      <div style="position:relative;margin-bottom:{% if loop.last and not loop.parent.last %}24px{% else %}12px{% endif %};padding-left:12px;">
        <div style="position:absolute;left:-39px;top:8px;width:10px;height:10px;background:{% if day.type == 'online' %}#fff{% else %}#fff{% endif %};border:2px solid {% if day.type == 'weekend' %}#ff9966{% elif day.type == 'online' %}#f75c03{% else %}#E8E4E0{% endif %};border-radius:50%;z-index:1;"></div>

        <div style="background:#fff;border:1px solid #F0EDE9;border-radius:12px;padding:14px 18px;{% if day.type == 'weekend' %}border-left:3px solid #ff9966;{% elif day.type == 'online' %}border-left:3px solid #f75c03;border-style:dashed;border-left-style:solid;{% else %}border-left:3px solid #E8E4E0;{% endif %}">
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <div>
              <p style="font-weight:600;font-size:.92rem;">{{ day.topic }}</p>
              <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">{{ day.day }} {{ day.date }} · {{ day.time }}{% if day.type == 'online' %} · <span style="color:#f75c03;">Online</span>{% endif %}</p>
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
      {% endfor %}

      {# End node — graduation #}
      <div style="position:relative;padding-top:20px;">
        <div style="position:absolute;left:-44px;top:22px;width:22px;height:22px;background:#2ecc71;border-radius:50%;border:3px solid #fff;box-shadow:0 0 0 2px #2ecc71;z-index:1;display:flex;align-items:center;justify-content:center;">
          <span style="color:#fff;font-size:.65rem;">&#10003;</span>
        </div>
        <p style="font-weight:700;font-size:.95rem;color:#2ecc71;">Graduation — 28. juni 2026</p>
        <p style="font-size:.78rem;color:#6F6A66;">Yoga Alliance RYT-200 certificering</p>
      </div>

    </div>
  </div>
</section>

<hr style="max-width:900px;margin:0 auto;border:none;border-top:2px dashed #E8E4E0;">


{# ════════════════════════════════════════════════════════════
   DESIGN 4: DARK CINEMATIC
   Dark background, dramatic typography, each week as a "chapter"
   with large week numbers. Premium editorial feel. Think Apple
   Keynote presentation slides.
   ════════════════════════════════════════════════════════════ #}

<section id="design-4" style="background:#0F0F0F;color:#fff;padding:80px 24px 40px;">
  <div style="max-width:800px;margin:0 auto;">

    {# Design label #}
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:48px;">
      <span style="background:#f75c03;color:#fff;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.88rem;">4</span>
      <div>
        <p style="font-weight:700;font-size:1.1rem;">Dark Cinematic</p>
        <p style="font-size:.82rem;color:rgba(255,255,255,.55);">Premium, dramatisk. Store ugenumre, filmisk atmosfære. Apple Keynote-stil.</p>
      </div>
    </div>

    {# Title #}
    <div style="text-align:center;margin-bottom:60px;">
      <p style="font-size:clamp(4rem,10vw,7rem);font-weight:700;line-height:.9;background:linear-gradient(135deg,#f75c03,#ff9966);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:12px;">8 Uger.</p>
      <p style="font-size:1.1rem;color:rgba(255,255,255,.55);letter-spacing:.04em;">200 timer der forandrer alt.</p>
    </div>

    {# Weeks #}
    {% for week in demoWeeks %}
    <div style="margin-bottom:48px;padding-bottom:48px;{% if not loop.last %}border-bottom:1px solid rgba(255,255,255,.08);{% endif %}">
      <div style="display:flex;gap:28px;align-items:flex-start;">

        {# Large week number #}
        <div style="min-width:80px;text-align:center;flex-shrink:0;">
          <span style="font-size:3.2rem;font-weight:700;line-height:.9;color:#f75c03;">{{ week.num }}</span>
          <p style="font-size:.65rem;text-transform:uppercase;letter-spacing:.18em;color:rgba(255,255,255,.35);margin-top:4px;">uge</p>
        </div>

        <div style="flex:1;">
          <p style="font-weight:700;font-size:1rem;margin-bottom:4px;">{{ week.label | replace("Uge " + week.num + " — ", "") | replace("Uge " + week.num, "Workshops") }}</p>
          <p style="font-size:.78rem;color:rgba(255,255,255,.4);margin-bottom:16px;">{{ week.range }}</p>

          <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:10px;">
            {% for day in week.days %}
            <div style="background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:12px;padding:16px;transition:all .2s;{% if day.type == 'online' %}border-color:rgba(247,92,3,.3);{% endif %}" onmouseenter="this.style.background='rgba(255,255,255,.08)'" onmouseleave="this.style.background='rgba(255,255,255,.04)'">
              <p style="font-size:.75rem;color:rgba(255,255,255,.35);margin-bottom:6px;">{{ day.day }} {{ day.date }}</p>
              <p style="font-weight:600;font-size:.88rem;line-height:1.3;">{{ day.topic }}</p>
              <div style="display:flex;align-items:center;gap:8px;margin-top:10px;">
                <span style="font-size:.72rem;color:rgba(255,255,255,.4);">{{ day.time }}</span>
                {% if day.type == "online" %}
                <span style="background:rgba(247,92,3,.15);color:#f75c03;padding:2px 8px;border-radius:50px;font-size:.62rem;font-weight:600;">ONLINE</span>
                {% endif %}
              </div>
            </div>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
    {% endfor %}

    {# Graduation callout #}
    <div style="text-align:center;padding:40px 0;">
      <span style="display:inline-block;background:linear-gradient(135deg,#2ecc71,#27ae60);color:#fff;padding:12px 32px;border-radius:50px;font-weight:700;font-size:.92rem;">Graduation — 28. juni 2026</span>
    </div>

  </div>
</section>

<hr style="max-width:900px;margin:0 auto;border:none;border-top:2px dashed #E8E4E0;">


{# ════════════════════════════════════════════════════════════
   DESIGN 5: MAGAZINE / EDITORIAL
   Large month headers, generous whitespace, each week has an
   editorial treatment. Pull-quote style week themes. Big numbers,
   art-directed spacing. Like a coffee-table magazine spread.
   ════════════════════════════════════════════════════════════ #}

<section id="design-5" style="padding:80px 24px 60px;">
  <div style="max-width:780px;margin:0 auto;">

    {# Design label #}
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:48px;">
      <span style="background:#f75c03;color:#fff;width:36px;height:36px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.88rem;">5</span>
      <div>
        <p style="font-weight:700;font-size:1.1rem;">Magazine Editorial</p>
        <p style="font-size:.82rem;color:#6F6A66;">Store overskrifter, generøs whitespace, editorial layout. Coffee-table magasin-stil.</p>
      </div>
    </div>

    {# Magazine header #}
    <div style="text-align:center;margin-bottom:60px;padding-bottom:40px;border-bottom:3px solid #0F0F0F;">
      <p style="font-size:.72rem;text-transform:uppercase;letter-spacing:.22em;color:#f75c03;font-weight:700;margin-bottom:12px;">Yoga Bible Teacher Training</p>
      <h2 style="font-size:clamp(2.4rem,6vw,3.8rem);font-weight:700;letter-spacing:-.03em;line-height:1;margin-bottom:16px;">Dit Skema<br><span style="color:#f75c03;">Dag for Dag</span></h2>
      <p style="font-size:1rem;color:#6F6A66;max-width:460px;margin:0 auto;line-height:1.6;">Otte uger af fordybelse, transformation og certificering. Her er præcis hvad der venter dig.</p>
    </div>

    {# Month header #}
    <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:40px;">
      <span style="font-size:4rem;font-weight:700;line-height:1;color:#0F0F0F;">Maj</span>
      <span style="font-size:1.2rem;color:#6F6A66;">2026</span>
      <div style="flex:1;height:2px;background:#E8E4E0;margin-left:12px;"></div>
    </div>

    {% for week in demoWeeks %}
    <div style="margin-bottom:48px;">

      {# Week as editorial block #}
      <div style="display:grid;grid-template-columns:100px 1fr;gap:24px;{% if week.num == 1 %}{% endif %}">

        {# Left: week number + range #}
        <div style="text-align:right;padding-top:4px;">
          <span style="font-size:2.8rem;font-weight:700;line-height:1;color:#E8E4E0;">{{ week.num }}</span>
          <p style="font-size:.72rem;color:#6F6A66;margin-top:4px;">{{ week.range }}</p>
        </div>

        {# Right: days #}
        <div>
          {% if "—" in week.label %}
          <p style="font-size:.78rem;font-weight:700;color:#f75c03;text-transform:uppercase;letter-spacing:.08em;margin-bottom:14px;">{{ week.label | replace("Uge " + week.num + " — ", "") }}</p>
          {% endif %}

          {% for day in week.days %}
