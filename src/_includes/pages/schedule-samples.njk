      </div>

      {# Decorative separator between weeks #}
      {% if not loop.last %}
      <div style="text-align:center;padding:20px 0;">
        <span style="display:inline-block;width:6px;height:6px;background:#E8E4E0;border-radius:50%;"></span>
      </div>
      {% endif %}
    </div>
    {% endfor %}

    {# Quote / CTA #}
    <blockquote style="border-left:4px solid #f75c03;padding:24px 28px;margin:40px 0;background:#FFFCF9;border-radius:0 14px 14px 0;">
      <p style="font-size:1.1rem;font-weight:600;font-style:italic;line-height:1.5;color:#0F0F0F;">"Den bedste investering, du nogensinde vil gøre, er i din egen transformation."</p>
