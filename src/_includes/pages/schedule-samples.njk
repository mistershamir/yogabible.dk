            {% else %}
            <span class="ss18-route-label" style="font-size:.68rem;color:#f75c03;font-weight:600;white-space:nowrap;">Begge hold</span>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </details>
      {% endif %}

    {% endfor %}
    {% endfor %}

    </div> {# /ss18-view-single #}

