{# ──────────────────────────────────────────────────────────────
   SCHEDULE DESIGN SAMPLES — 5 distinct visual approaches
   Using the 8-week semi-intensive schedule data as demo content.
   ────────────────────────────────────────────────────────────── #}

{# ── Sample data (first 4 weeks of 8w for demo brevity) ──── #}
{% set demoWeeks = [
  { num: 1, label: "Uge 1 — Introduktion", range: "2–3 maj", days: [
    { date: "2. maj", day: "Fre", time: "13:00–18:00", topic: "Hatha & Class Management — Introduktion", type: "workshop" },
    { date: "3. maj", day: "Lør", time: "14:00–19:00", topic: "Vinyasa & Yin Yoga — Introduktion", type: "weekend" }
  ]},
  { num: 2, label: "Uge 2", range: "7–11 maj", days: [
    { date: "7. maj", day: "Tor", time: "10:00–15:00", topic: "Hatha & Class Management", type: "workshop" },
    { date: "9. maj", day: "Lør", time: "13:00–18:00", topic: "Vinyasa & Yin Yoga", type: "workshop" },
    { date: "10. maj", day: "Søn", time: "14:00–18:00", topic: "Yogafilosofi — Online", type: "online" },
    { date: "11. maj", day: "Man", time: "10:00–15:00", topic: "Vinyasa & Yin Yoga", type: "workshop" }
  ]},
  { num: 3, label: "Uge 3", range: "16–18 maj", days: [
    { date: "16. maj", day: "Lør", time: "13:00–18:00", topic: "Yoga Anatomi", type: "workshop" },
    { date: "17. maj", day: "Søn", time: "14:00–19:00", topic: "Hatha & Class Management", type: "weekend" },
    { date: "18. maj", day: "Man", time: "10:00–15:00", topic: "Vinyasa & Yin Yoga", type: "workshop" }
  ]},
  { num: 4, label: "Uge 4", range: "21–24 maj", days: [
    { date: "21. maj", day: "Ons", time: "10:00–15:00", topic: "Hatha & Class Management", type: "workshop" },
    { date: "23. maj", day: "Fre", time: "13:00–18:00", topic: "Yoga Anatomi", type: "workshop" },
    { date: "24. maj", day: "Lør", time: "14:00–18:00", topic: "Yogafilosofi — Online", type: "online" }
  ]}
] %}

{# ── Page header ─────────────────────────────────────────── #}
<section style="background:#0F0F0F;color:#fff;padding:clamp(80px,12vw,140px) 24px 60px;text-align:center;">
  <div style="max-width:700px;margin:0 auto;">
    <p style="text-transform:uppercase;letter-spacing:.18em;font-size:.78rem;color:#f75c03;margin-bottom:12px;">Design Exploration</p>
    <h1 style="font-size:clamp(2rem,5vw,3.2rem);font-weight:700;line-height:1.15;margin:0 0 16px;">Skema Design Samples</h1>
    <p style="font-size:1.05rem;color:rgba(255,255,255,.72);line-height:1.55;">5 forskellige design-tilgange + 1 anbefalet kombination. Samme data, forskellige visuelle udtryk.</p>
  </div>
</section>

{# ── Navigation / jump links ─────────────────────────────── #}
<nav style="background:#F5F3F0;padding:16px 24px;border-bottom:1px solid #E8E4E0;position:sticky;top:0;z-index:100;">
  <div style="max-width:900px;margin:0 auto;display:flex;gap:8px;justify-content:center;flex-wrap:wrap;">
    <a href="#design-combo" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:#f75c03;color:#fff;">&#9733; 8w Combo</a>
    <a href="#design-combo-18w" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:#ff9966;color:#fff;">&#9733; 18w Combo</a>
    <a href="#design-1" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:rgba(15,15,15,.08);color:#0F0F0F;">1 · Minimal</a>
    <a href="#design-2" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:rgba(15,15,15,.08);color:#0F0F0F;">2 · Accordion</a>
    <a href="#design-3" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:rgba(15,15,15,.08);color:#0F0F0F;">3 · Timeline</a>
    <a href="#design-4" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:rgba(15,15,15,.08);color:#0F0F0F;">4 · Dark Cinema</a>
    <a href="#design-5" style="padding:8px 18px;border-radius:50px;font-size:.82rem;font-weight:600;text-decoration:none;background:rgba(15,15,15,.08);color:#0F0F0F;">5 · Magazine</a>
  </div>
</nav>


{# ════════════════════════════════════════════════════════════
   DESIGN 6: THE COMBO (RECOMMENDED)
   Blends the best elements:
   → Dark Cinematic hero (Design 4) — dramatic gradient title
   → Magazine month headers (Design 5) — large month separators
   → Accordion weeks (Design 2) — compact, expandable
   → Minimal day rows (Design 1) — clean typography inside
   → Timeline graduation endpoint (Design 3) — journey's end
   → Magazine blockquote (Design 5) — editorial close
   ════════════════════════════════════════════════════════════ #}

<section id="design-combo">

  {# ── HERO: Minimal Cinematic ───────────────────────────── #}
  <div style="background:#0F0F0F;color:#fff;padding:clamp(100px,14vw,180px) 24px clamp(60px,8vw,100px);text-align:center;">
    <div style="max-width:600px;margin:0 auto;">
      <p style="font-size:clamp(4.5rem,12vw,8rem);font-weight:700;line-height:1.1;padding-top:.1em;background:linear-gradient(135deg,#f75c03,#ff9966);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin-bottom:20px;">8 Uger.</p>
      <p style="font-size:1.05rem;color:rgba(255,255,255,.4);letter-spacing:.06em;">200-timers yogalæreruddannelse · København</p>
    </div>
  </div>

  {# ── STATS BAR + meta chips ────────────────────────────── #}
  <div style="background:#F5F3F0;padding:28px 24px;border-bottom:1px solid #E8E4E0;">
    <div style="max-width:700px;margin:0 auto;">
      <div style="display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin-bottom:20px;">
        <span style="background:#2ecc71;color:#fff;padding:4px 12px;border-radius:50px;font-size:.72rem;font-weight:600;">Yoga Alliance RYT-200</span>
        <span style="background:#0F0F0F;color:#fff;padding:4px 12px;border-radius:50px;font-size:.72rem;font-weight:600;">Max 12 studerende</span>
        <span style="background:#E8E4E0;color:#6F6A66;padding:4px 12px;border-radius:50px;font-size:.72rem;font-weight:600;">Maj–Juni 2026</span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;text-align:center;">
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">8</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">uger</p>
        </div>
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">22</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">uddannelsesdage</p>
        </div>
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">200+</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">kontakttimer</p>
        </div>
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">36</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">fridage</p>
        </div>
      </div>
    </div>
  </div>

  {# ── HOURS BREAKDOWN: Horizontal bars ──────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:32px 24px 0;">
    <p style="font-size:.72rem;text-transform:uppercase;letter-spacing:.14em;color:#6F6A66;font-weight:700;margin-bottom:16px;">Dine 200+ timer fordelt</p>

    {% set hours = [
      { label: "Studietimer i studiet", hours: 60, color: "#f75c03", pct: 28 },
      { label: "Vinyasa & Yin Yoga", hours: 42, color: "#0F0F0F", pct: 20 },
      { label: "Hatha & Class Management", hours: 35, color: "#0F0F0F", pct: 17 },
      { label: "Hjemmearbejde & selvstudie", hours: 25, color: "#E8E4E0", pct: 12 },
      { label: "Yoga Anatomi", hours: 15, color: "#ff9966", pct: 7 },
      { label: "Yogafilosofi", hours: 12, color: "#ff9966", pct: 6 },
      { label: "Business of Yoga", hours: 4, color: "#E8E4E0", pct: 2 },
      { label: "Eksamen & Graduation", hours: 8, color: "#2ecc71", pct: 4 }
    ] %}

    {% for h in hours %}
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
      <span style="font-size:.78rem;color:#6F6A66;min-width:185px;text-align:right;">{{ h.label }}</span>
      <div style="flex:1;background:#F5F3F0;border-radius:50px;height:8px;overflow:hidden;">
        <div style="width:{{ h.pct }}%;height:100%;background:{{ h.color }};border-radius:50px;"></div>
      </div>
      <span style="font-size:.78rem;font-weight:700;color:#0F0F0F;min-width:32px;">{{ h.hours }}t</span>
    </div>
    {% endfor %}

    <p style="font-size:.72rem;color:#6F6A66;text-align:right;margin-top:8px;font-style:italic;">I alt: 201 kontakttimer</p>
  </div>

  {# ── SCHEDULE BODY ────────────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:40px 24px 60px;">

    {# Calendar export — quiet, utility position #}
    <div style="display:flex;justify-content:flex-end;margin-bottom:24px;">
      <button style="display:inline-flex;align-items:center;gap:6px;background:none;color:#6F6A66;border:1.5px solid #E8E4E0;padding:8px 16px;border-radius:50px;font-size:.78rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;" onmouseenter="this.style.borderColor='#f75c03';this.style.color='#f75c03'" onmouseleave="this.style.borderColor='#E8E4E0';this.style.color='#6F6A66'">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Tilføj alle til kalender
      </button>
    </div>

    {# ── MONTH HEADER: Magazine style (from Design 5) ──── #}
    <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:32px;">
      <span style="font-size:3.4rem;font-weight:700;line-height:1;color:#0F0F0F;">Maj</span>
      <span style="font-size:1.1rem;color:#6F6A66;">2026</span>
      <div style="flex:1;height:2px;background:linear-gradient(to right, #E8E4E0, transparent);margin-left:12px;"></div>
    </div>

    {# ── ACCORDION WEEKS with MINIMAL DAY ROWS inside ──── #}
    {% for week in demoWeeks %}
    <details class="ss-combo-accordion" {% if loop.first %}open{% endif %} style="margin-bottom:10px;">
      <summary class="ss-combo-summary" style="
        display:flex;
        align-items:center;
        justify-content:space-between;
        padding:18px 22px;
        cursor:pointer;
        list-style:none;
        -webkit-appearance:none;
        background:#fff;
        border:1px solid #E8E4E0;
        border-radius:14px;
        transition:all .2s;
      ">
        <div style="display:flex;align-items:center;gap:14px;">
          <span style="background:#f75c03;color:#fff;font-size:.68rem;font-weight:700;padding:5px 12px;border-radius:50px;letter-spacing:.06em;">UGE {{ week.num }}</span>
          <div>
            <p style="font-weight:700;font-size:.92rem;color:#0F0F0F;">{% if "—" in week.label %}{{ week.label | replace("Uge " + week.num + " — ", "") }}{% else %}{{ week.range }}{% endif %}</p>
            <p style="font-size:.75rem;color:#6F6A66;">{{ week.days | length }} {% if week.days | length == 1 %}dag{% else %}dage{% endif %} · {{ week.range }}</p>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
          <span style="font-size:.72rem;color:#6F6A66;font-weight:500;">{% for day in week.days %}{{ day.day }}{% if not loop.last %} · {% endif %}{% endfor %}</span>
          <span class="ss-combo-icon" style="background:#f75c03;color:#fff;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.88rem;font-weight:700;transition:transform .25s;flex-shrink:0;">+</span>
        </div>
      </summary>

      {# Expanded content: Minimal day rows (from Design 1) #}
      <div style="padding:6px 22px 18px;background:#fff;border:1px solid #E8E4E0;border-top:none;border-radius:0 0 14px 14px;margin-top:-1px;">
        {% for day in week.days %}
        <div style="display:flex;gap:16px;align-items:center;padding:12px 0;{% if not loop.last %}border-bottom:1px solid #F0EDE9;{% endif %}">

          {# Date tile: Magazine style (from Design 5) #}
          <div style="
            background:{% if day.type == 'workshop' %}#0F0F0F{% elif day.type == 'weekend' %}#ff9966{% elif day.type == 'online' %}#f75c03{% else %}#E8E4E0{% endif %};
            color:#fff;
            width:46px;height:46px;
            border-radius:10px;
            display:flex;flex-direction:column;align-items:center;justify-content:center;
            flex-shrink:0;
            {% if day.type == 'online' %}box-shadow:0 0 0 2px #fff, 0 0 0 3px #f75c03;{% endif %}
          ">
            <span style="font-size:1.1rem;font-weight:700;line-height:1;">{{ day.date | replace(". maj", "") | replace(". jun", "") }}</span>
            <span style="font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;opacity:.75;">{{ day.day }}</span>
          </div>

          {# Content: Minimal linear style (from Design 1) #}
          <div style="flex:1;min-width:0;">
            <p style="font-weight:600;font-size:.92rem;color:#0F0F0F;">{{ day.topic }}</p>
            <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">{{ day.time }}{% if day.type == 'online' %} · <span style="color:#f75c03;font-weight:600;">Online</span>{% endif %}</p>
          </div>

          {# Calendar icon button #}
          <button style="background:none;border:1.5px solid #E8E4E0;border-radius:8px;padding:6px 8px;cursor:pointer;color:#6F6A66;display:flex;align-items:center;justify-content:center;transition:all .2s;flex-shrink:0;" onmouseenter="this.style.borderColor='#f75c03';this.style.color='#f75c03'" onmouseleave="this.style.borderColor='#E8E4E0';this.style.color='#6F6A66'">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="12" y1="14" x2="12" y2="18"/><line x1="10" y1="16" x2="14" y2="16"/></svg>
          </button>
        </div>
        {% endfor %}
      </div>
    </details>
    {% endfor %}

    {# ── (More weeks would continue here: Uge 5–7) ───── #}
    <div style="text-align:center;padding:20px 0;">
      <span style="font-size:.82rem;color:#6F6A66;font-style:italic;">… Uge 5–7 fortsætter …</span>
    </div>

    {# ── JUNE MONTH HEADER ─────────────────────────────── #}
    <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:32px;">
      <span style="font-size:3.4rem;font-weight:700;line-height:1;color:#0F0F0F;">Juni</span>
      <span style="font-size:1.1rem;color:#6F6A66;">2026</span>
      <div style="flex:1;height:2px;background:linear-gradient(to right, #E8E4E0, transparent);margin-left:12px;"></div>
    </div>

    {# ── FINAL WEEK: Eksamen & Graduation ──────────────── #}
    <details class="ss-combo-accordion" open style="margin-bottom:10px;">
      <summary class="ss-combo-summary" style="
        display:flex;
        align-items:center;
        justify-content:space-between;
        padding:18px 22px;
        cursor:pointer;
        list-style:none;
        -webkit-appearance:none;
        background:linear-gradient(135deg, #f0fff0, #e8f5e8);
        border:1.5px solid #2ecc71;
        border-radius:14px;
        transition:all .2s;
      ">
        <div style="display:flex;align-items:center;gap:14px;">
          <span style="background:#2ecc71;color:#fff;font-size:.68rem;font-weight:700;padding:5px 12px;border-radius:50px;letter-spacing:.06em;">UGE 8</span>
          <div>
            <p style="font-weight:700;font-size:.92rem;color:#0F0F0F;">Business & Eksamen</p>
            <p style="font-size:.75rem;color:#6F6A66;">4 dage · 18–28 juni</p>
          </div>
        </div>
        <div style="display:flex;align-items:center;gap:12px;">
          <span style="background:#d4edda;color:#155724;padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:700;text-transform:uppercase;">Graduation</span>
          <span class="ss-combo-icon" style="background:#2ecc71;color:#fff;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.88rem;font-weight:700;transition:transform .25s;flex-shrink:0;">+</span>
        </div>
      </summary>
      <div style="padding:6px 22px 18px;background:#fff;border:1.5px solid #2ecc71;border-top:none;border-radius:0 0 14px 14px;margin-top:-1px;">

        {# Exam day 1 #}
        <div style="display:flex;gap:16px;align-items:center;padding:12px 0;border-bottom:1px solid #F0EDE9;">
          <div style="background:#0F0F0F;color:#fff;width:46px;height:46px;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;">
            <span style="font-size:1.1rem;font-weight:700;line-height:1;">27</span>
            <span style="font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;opacity:.75;">Lør</span>
          </div>
          <div style="flex:1;">
            <p style="font-weight:600;font-size:.92rem;color:#0F0F0F;">Vinyasa & Yin Yoga — Eksamen</p>
            <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">13:00–18:00</p>
          </div>
          <span style="background:#FFF0E6;color:#f75c03;padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:600;text-transform:uppercase;">Eksamen</span>
        </div>

        {# Graduation day #}
        <div style="display:flex;gap:16px;align-items:center;padding:12px 0;">
          <div style="background:#2ecc71;color:#fff;width:46px;height:46px;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;">
            <span style="font-size:1.1rem;font-weight:700;line-height:1;">28</span>
            <span style="font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;opacity:.75;">Søn</span>
          </div>
          <div style="flex:1;">
            <p style="font-weight:600;font-size:.92rem;color:#0F0F0F;">Hatha & Class Management — Eksamen + Graduation &#127891;</p>
            <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">14:00–17:00</p>
          </div>
          <span style="background:#d4edda;color:#155724;padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:600;text-transform:uppercase;">Graduation</span>
        </div>
      </div>
    </details>

    {# ── TIMELINE ENDPOINT: Graduation (from Design 3) ── #}
    <div style="position:relative;padding-left:48px;margin-top:40px;">
      <div style="position:absolute;left:18px;top:0;bottom:50%;width:2px;background:linear-gradient(to bottom, #E8E4E0, #2ecc71);"></div>
      <div style="position:relative;">
        <div style="position:absolute;left:-42px;top:4px;width:22px;height:22px;background:#2ecc71;border-radius:50%;border:3px solid #fff;box-shadow:0 0 0 2px #2ecc71, 0 0 20px rgba(46,204,113,.25);z-index:1;display:flex;align-items:center;justify-content:center;">
          <span style="color:#fff;font-size:.7rem;">&#10003;</span>
        </div>
        <div>
          <p style="font-weight:700;font-size:1.05rem;color:#2ecc71;">Certificeret Yogalærer</p>
          <p style="font-size:.82rem;color:#6F6A66;line-height:1.5;margin-top:4px;">28. juni 2026 · Yoga Alliance RYT-200</p>
        </div>
      </div>
    </div>

    {# ── INFO CARDS ─────────────────────────────────────── #}
    <div style="margin-top:32px;display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div style="background:#FFF8F3;border:1px solid #FFE5D0;border-radius:12px;padding:18px;">
        <p style="font-weight:700;font-size:.85rem;margin-bottom:4px;">60 studietimer påkrævet</p>
        <p style="font-size:.78rem;color:#6F6A66;">Senest 30. september 2026</p>
      </div>
      <div style="background:#f0fff0;border:1px solid #c3e6c3;border-radius:12px;padding:18px;">
        <p style="font-weight:700;font-size:.85rem;margin-bottom:4px;">Certificering</p>
        <p style="font-size:.78rem;color:#6F6A66;">Graduation: 28. juni 2026</p>
      </div>
    </div>

    {# ── BLOCKQUOTE: Editorial close (from Design 5) ──── #}
    <blockquote style="border-left:4px solid #f75c03;padding:24px 28px;margin:40px 0 0;background:#FFFCF9;border-radius:0 14px 14px 0;">
      <p style="font-size:1.05rem;font-weight:600;font-style:italic;line-height:1.5;color:#0F0F0F;">"Den bedste investering, du nogensinde vil gøre, er i din egen transformation."</p>
      <p style="font-size:.82rem;color:#6F6A66;margin-top:8px;">— Yoga Bible</p>
    </blockquote>

  </div>

  {# ── DARK CTA (from current design) ──────────────────── #}
  <div style="background:#0F0F0F;color:#fff;padding:60px 24px;text-align:center;">
    <div style="max-width:600px;margin:0 auto;">
      <h2 style="font-size:1.6rem;font-weight:700;margin-bottom:12px;">Klar til at starte?</h2>
