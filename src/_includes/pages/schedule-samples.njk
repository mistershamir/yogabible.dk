        {# Right: days #}
        <div>
          {% if "—" in week.label %}
          <p style="font-size:.78rem;font-weight:700;color:#f75c03;text-transform:uppercase;letter-spacing:.08em;margin-bottom:14px;">{{ week.label | replace("Uge " + week.num + " — ", "") }}</p>
          {% endif %}

          {% for day in week.days %}
          <div style="padding:14px 0;{% if not loop.last %}border-bottom:1px solid #F0EDE9;{% endif %}display:grid;grid-template-columns:auto 1fr auto;gap:16px;align-items:center;">

            {# Date block #}
            <div style="background:{% if day.type == 'workshop' %}#0F0F0F{% elif day.type == 'weekend' %}#ff9966{% elif day.type == 'online' %}#f75c03{% else %}#E8E4E0{% endif %};color:#fff;width:48px;height:48px;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;{% if day.type == 'online' %}border:2px dashed rgba(255,255,255,.4);{% endif %}">
