            <span style="background:#2ecc71;color:#fff;font-size:.68rem;font-weight:700;padding:5px 12px;border-radius:50px;letter-spacing:.06em;">UGE {{ week.num }}</span>
            <div>
              <p style="font-weight:700;font-size:.92rem;color:#0F0F0F;">{{ week.label }}</p>
              <p style="font-size:.75rem;color:#6F6A66;">{{ week.days | length }} dage · {{ week.range }}</p>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <span style="background:#d4edda;color:#155724;padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:700;text-transform:uppercase;">Graduation</span>
            <span class="ss-combo-icon" style="background:#2ecc71;color:#fff;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.88rem;font-weight:700;transition:transform .25s;flex-shrink:0;">+</span>
          </div>
        </summary>
        <div style="padding:6px 22px 18px;background:#fff;border:1.5px solid #2ecc71;border-top:none;border-radius:0 0 14px 14px;margin-top:-1px;">
          {% for day in week.days %}
          <div class="ss18-day" data-ss18-route="shared" style="display:flex;gap:16px;align-items:center;padding:12px 0;{% if not loop.last %}border-bottom:1px solid #F0EDE9;{% endif %}">
            <div style="background:{% if day.type == 'graduation' %}#2ecc71{% else %}#0F0F0F{% endif %};color:#fff;width:46px;height:46px;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;">
              <span style="font-size:1.1rem;font-weight:700;line-height:1;">{{ day.dn }}</span>
              <span style="font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;opacity:.75;">{{ day.dd }}</span>
            </div>
            <div style="flex:1;">
              <p style="font-weight:600;font-size:.92rem;color:#0F0F0F;">{{ day.topic }}</p>
              <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">{{ day.time }}</p>
            </div>
            <span style="background:{% if day.type == 'graduation' %}#d4edda{% else %}#FFF0E6{% endif %};color:{% if day.type == 'graduation' %}#155724{% else %}#f75c03{% endif %};padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:600;text-transform:uppercase;">{% if day.type == 'graduation' %}Graduation{% else %}Eksamen{% endif %}</span>
          </div>
          {% endfor %}
        </div>
