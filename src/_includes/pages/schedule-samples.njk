              {% if day.type == 'online' %}box-shadow:0 0 0 2px #fff, 0 0 0 3px #f75c03;{% endif %}
            ">
              <span style="font-size:1.1rem;font-weight:700;line-height:1;">{{ day.dn }}</span>
              <span style="font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;opacity:.75;">{{ day.dd }}</span>
            </div>

            {# Topic & time #}
            <div style="flex:1;min-width:0;">
              <p style="font-weight:600;font-size:.92rem;color:#0F0F0F;">{{ day.topic }}</p>
              <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">{{ day.time }}{% if day.type == 'online' %} · <span style="color:#f75c03;font-weight:600;">Online</span>{% endif %}</p>
            </div>

            {# Route label #}
            {% if day.route == 'weekday' %}
            <span class="ss18-route-label" style="font-size:.68rem;color:#6F6A66;font-weight:500;white-space:nowrap;">Hverdag</span>
            {% elif day.route == 'weekend' %}
