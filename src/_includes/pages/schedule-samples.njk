{# ────────────────────────────────────────────────────────────────
   18-WEEK SCHEDULE DESIGN — Active development
   ──────────────────────────────────────────────────────────────── #}



{# ════════════════════════════════════════════════════════════
   18-WEEK COMBO — Flexible Program (Feb–June 2026)
   Same visual approach as 8-week combo, adapted for the
   18-week flexible format with dual tracks (weekday/weekend).
   ════════════════════════════════════════════════════════════ #}

<section id="design-combo-18w">

  {# ── HERO: "18 Uger." ───────────────────────────────── #}
  <div style="background:#0F0F0F;color:#fff;padding:clamp(80px,12vw,160px) 24px clamp(60px,8vw,100px);text-align:center;">
    <div style="max-width:640px;margin:0 auto;">
      <p style="font-size:clamp(5rem,16vw,10rem);font-weight:700;line-height:1.05;padding-bottom:0.12em;background:linear-gradient(135deg,#f75c03,#ff9966);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin:0 0 16px;">18 Uger.</p>
      <p style="font-size:clamp(1.25rem,3.5vw,1.8rem);font-weight:700;color:#fff;letter-spacing:-.015em;line-height:1.2;margin:0 0 12px;">Komplet Yogalæreruddannelse</p>
      <p style="font-size:.95rem;color:rgba(255,255,255,.4);letter-spacing:.04em;">Fleksibelt 200-timers program &middot; Feb–Juni 2026</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:28px;">
        <button onclick="openBookingModal('info-session')" style="background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.5);padding:13px 24px;border-radius:50px;font-size:.92rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;" onmouseenter="this.style.borderColor='#fff';this.style.background='rgba(255,255,255,.08)'" onmouseleave="this.style.borderColor='rgba(255,255,255,.5)';this.style.background='transparent'">Book infomøde</button>
        <button onclick="startCheckoutFunnel('100078')" style="background:#f75c03;color:#fff;border:none;padding:13px 24px;border-radius:50px;font-size:.92rem;font-weight:600;cursor:pointer;font-family:inherit;transition:background .2s;" onmouseenter="this.style.background='#d94f02'" onmouseleave="this.style.background='#f75c03'">Start Forberedelsesfasen</button>
      </div>
    </div>
  </div>

  {# ── STATS BAR + meta chips ────────────────────────────── #}
  <div style="background:#F5F3F0;padding:28px 24px;border-bottom:1px solid #E8E4E0;">
    <div style="max-width:700px;margin:0 auto;">
      <div style="display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:20px;">
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">Yoga Alliance RYT-200</span>
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">Max 12 studerende</span>
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">Hverdagshold · Weekendhold</span>
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">Feb–Juni 2026</span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;text-align:center;">
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">18</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">uger</p>
        </div>
        <div>
          <span id="ss18-stat-days" style="font-size:1.8rem;font-weight:700;color:#f75c03;">25</span>
          <p id="ss18-stat-days-label" style="font-size:.82rem;color:#6F6A66;margin-top:4px;">dage pr. hold</p>
        </div>
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">200+</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">kontakttimer</p>
        </div>
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">4</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">fri uger</p>
        </div>
      </div>
    </div>
  </div>

  {# ── HOURS BREAKDOWN ───────────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:32px 24px 0;">
    <p style="font-size:.72rem;text-transform:uppercase;letter-spacing:.14em;color:#6F6A66;font-weight:700;margin-bottom:16px;">Dine 200+ timer fordelt</p>

    {% set hours18 = [
      { label: "Studietimer i studiet", hours: 60, color: "#f75c03", pct: 30 },
      { label: "Online & andre studier", hours: 10, color: "#ff9966", pct: 5 },
      { label: "Vinyasa Yoga", hours: 30, color: "#0F0F0F", pct: 15 },
      { label: "Yin Yoga", hours: 20, color: "#0F0F0F", pct: 10 },
      { label: "Hatha Yoga", hours: 17, color: "#0F0F0F", pct: 8.5 },
      { label: "Class Management", hours: 12, color: "#6F6A66", pct: 6 },
      { label: "Yoga Anatomi", hours: 16, color: "#ff9966", pct: 8 },
      { label: "Yogafilosofi", hours: 12, color: "#ff9966", pct: 6 },
      { label: "Selvstudie & hjemmearbejde", hours: 20, color: "#E8E4E0", pct: 10 },
      { label: "Business of Yoga", hours: 3, color: "#E8E4E0", pct: 1.5 }
    ] %}

    {% for h in hours18 %}
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:8px;">
      <span style="font-size:.78rem;color:#6F6A66;min-width:185px;text-align:right;">{{ h.label }}</span>
      <div style="flex:1;background:#F5F3F0;border-radius:50px;height:8px;overflow:hidden;">
        <div style="width:{{ h.pct }}%;height:100%;background:{{ h.color }};border-radius:50px;"></div>
      </div>
      <span style="font-size:.78rem;font-weight:700;color:#0F0F0F;min-width:32px;">{{ h.hours }}t</span>
    </div>
    {% endfor %}

    <p style="font-size:.72rem;color:#6F6A66;text-align:right;margin-top:8px;font-style:italic;">I alt: 200 timer</p>
  </div>

  {# ── BUSY DAYS FINDER (collapsible) ───────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:24px 24px 0;">
    <details id="ss18-conflict-finder" style="background:#fff;border:1.5px solid #E8E4E0;border-radius:16px;overflow:hidden;">
      <summary style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;cursor:pointer;list-style:none;-webkit-appearance:none;">
        <div style="display:flex;align-items:center;gap:12px;">
          <span style="background:#FFF0E6;color:#f75c03;width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;">&#128197;</span>
          <div>
            <p style="font-weight:700;font-size:.92rem;">Hvornår er du optaget?</p>
            <p style="font-size:.78rem;color:#6F6A66;">Marker dine optagede dage — arbejde, familie, aftaler — så finder vi det bedste hold for dig.</p>
          </div>
        </div>
        <svg class="ss18-cf-chevron" style="flex-shrink:0;transition:transform .25s;" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div style="padding:0 20px 20px;border-top:1px solid #E8E4E0;">
        <p style="font-size:.8rem;color:#6F6A66;padding:14px 0 10px;margin:0;">Klik på en dag for at markere den som optaget, og juster tiderne for hver dag.</p>
        {# Per-day rows with individual time slots #}
        <div style="display:flex;flex-direction:column;gap:6px;" id="ss18-busy-days">
          {% set busyDays = [
            { val: "1", label: "Mandag", abbr: "Man", checked: true, start: "09:00", end: "17:00" },
            { val: "2", label: "Tirsdag", abbr: "Tir", checked: true, start: "09:00", end: "17:00" },
            { val: "3", label: "Onsdag", abbr: "Ons", checked: true, start: "09:00", end: "17:00" },
            { val: "4", label: "Torsdag", abbr: "Tor", checked: true, start: "09:00", end: "17:00" },
            { val: "5", label: "Fredag", abbr: "Fre", checked: true, start: "09:00", end: "17:00" },
            { val: "6", label: "Lørdag", abbr: "Lør", checked: false, start: "10:00", end: "14:00" },
            { val: "0", label: "Søndag", abbr: "Søn", checked: false, start: "10:00", end: "14:00" }
          ] %}
          {% for d in busyDays %}
          <div class="ss18-busy-row" style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:12px;background:{% if d.checked %}#F5F3F0{% else %}transparent{% endif %};transition:background .2s;">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;min-width:110px;">
              <input type="checkbox" name="ss18-busy" value="{{ d.val }}" {% if d.checked %}checked{% endif %} onchange="ss18ToggleBusyRow(this)" style="accent-color:#f75c03;width:16px;height:16px;">
              <span style="font-size:.85rem;font-weight:600;">{{ d.label }}</span>
            </label>
            <div class="ss18-busy-times" style="display:flex;align-items:center;gap:6px;{% if not d.checked %}opacity:.3;pointer-events:none;{% endif %}">
              <input type="time" value="{{ d.start }}" class="ss18-time-from" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;width:100px;">
              <span style="color:#6F6A66;font-size:.75rem;">til</span>
              <input type="time" value="{{ d.end }}" class="ss18-time-to" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;width:100px;">
            </div>
          </div>
          {% endfor %}
        </div>
        <button onclick="ss18CheckConflicts()" style="margin-top:16px;background:#f75c03;color:#fff;border:none;padding:12px 24px;border-radius:50px;font-size:.88rem;font-weight:600;cursor:pointer;font-family:inherit;transition:background .2s;" onmouseenter="this.style.background='#d94f02'" onmouseleave="this.style.background='#f75c03'">Tjek konflikter</button>
        <div id="ss18-conflict-results" style="display:none;margin-top:16px;"></div>
      </div>
    </details>
  </div>

  {# ── ROUTE TOGGLE (3 tabs) ──────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:24px 24px 0;">
    <div id="ss18-route-toggle" style="display:flex;gap:0;background:rgba(15,15,15,.06);border-radius:16px;padding:4px;max-width:480px;margin:0 auto;">
      <button onclick="ss18SetRoute('both')" data-ss18-tab="both" style="flex:1;padding:12px 14px;border-radius:12px;border:none;cursor:pointer;font-family:inherit;text-align:center;transition:all .25s;background:#f75c03;color:#fff;box-shadow:0 4px 12px rgba(247,92,3,.3);">
        <span style="display:block;font-weight:700;font-size:.85rem;">Samlet overblik</span>
        <span style="display:block;font-size:.68rem;margin-top:2px;opacity:.8;">Se begge hold</span>
      </button>
      <button onclick="ss18SetRoute('weekday')" data-ss18-tab="weekday" style="flex:1;padding:12px 14px;border-radius:12px;border:none;cursor:pointer;font-family:inherit;text-align:center;transition:all .25s;background:transparent;color:#6F6A66;">
        <span style="display:block;font-weight:700;font-size:.85rem;">Hverdagshold</span>
        <span style="display:block;font-size:.68rem;margin-top:2px;opacity:.8;">Man & Ons</span>
      </button>
      <button onclick="ss18SetRoute('weekend')" data-ss18-tab="weekend" style="flex:1;padding:12px 14px;border-radius:12px;border:none;cursor:pointer;font-family:inherit;text-align:center;transition:all .25s;background:transparent;color:#6F6A66;">
        <span style="display:block;font-weight:700;font-size:.85rem;">Weekendhold</span>
        <span style="display:block;font-size:.68rem;margin-top:2px;opacity:.8;">Lør & Søn</span>
      </button>
    </div>
  </div>

  {# ── SCHEDULE BODY ─────────────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:40px 24px 0;">

    {# Calendar export #}
    <div style="display:flex;justify-content:flex-end;margin-bottom:24px;">
      <button style="display:inline-flex;align-items:center;gap:6px;background:none;color:#6F6A66;border:1.5px solid #E8E4E0;padding:8px 16px;border-radius:50px;font-size:.78rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;" onmouseenter="this.style.borderColor='#f75c03';this.style.color='#f75c03'" onmouseleave="this.style.borderColor='#E8E4E0';this.style.color='#6F6A66'">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        Tilføj alle til kalender
      </button>
    </div>

    {# ══════════════════════════════════════════════════════
       VIEW A: "BOTH" — Paired ELLER cards
       ══════════════════════════════════════════════════════ #}
    <div id="ss18-view-both">

    {% set months18wPairs = [
      { name: "Februar", year: "2026", weeks: [
        { num: 1, label: "Introduktion", pairs: [
          { topic: "Hatha & Class Management — Introduktion",
            wd: { date: "Mandag 23. februar", time: "10:00–15:00" },
            we: { date: "Lørdag 28. februar", time: "13:00–18:00" } },
          { topic: "Vinyasa & Yin Yoga — Introduktion",
            wd: { date: "Onsdag 25. februar", time: "10:00–15:00" },
            we: { date: "Søndag 1. marts", time: "14:00–19:00" } }
        ]}
      ]},
      { name: "Marts", year: "2026", weeks: [
        { num: 2, label: "Anatomi & Filosofi", shared: [
          { topic: "Yoga Anatomi 01", date: "Lørdag 7. marts", time: "13:00–17:00" },
          { topic: "Yogafilosofi 01 — Online", date: "Søndag 8. marts", time: "14:00–17:00", online: true }
        ]},
        { num: 3, off: true, offLabel: "Fri uge" },
        { num: 4, pairs: [
          { topic: "Vinyasa & Yin Yoga 02",
            wd: { date: "Mandag 16. marts", time: "10:00–15:00" },
            we: { date: "Lørdag 21. marts", time: "13:00–18:00" } }
        ]},
        { num: 5, pairs: [
          { topic: "Hatha & Class Management 02",
            wd: { date: "Mandag 23. marts", time: "10:00–15:00" },
            we: { date: "Lørdag 28. marts", time: "13:00–18:00" } },
          { topic: "Vinyasa & Yin Yoga 03",
            wd: { date: "Onsdag 25. marts", time: "10:00–15:00" },
            we: { date: "Søndag 29. marts", time: "14:00–19:00" } }
        ]}
      ]},
      { name: "April", year: "2026", weeks: [
        { num: 6, off: true, offLabel: "Påskeferie" },
        { num: 7, label: "Anatomi & Filosofi", shared: [
          { topic: "Yoga Anatomi 02", date: "Lørdag 11. april", time: "13:00–17:00" },
          { topic: "Yogafilosofi 02 — Online", date: "Søndag 12. april", time: "14:00–17:00", online: true }
        ]},
        { num: 8, pairs: [
          { topic: "Vinyasa & Yin Yoga 04",
            wd: { date: "Mandag 13. april", time: "10:00–15:00" },
            we: { date: "Lørdag 18. april", time: "13:00–18:00" } },
          { topic: "Hatha & Class Management 03",
            wd: { date: "Onsdag 15. april", time: "10:00–15:00" },
            we: { date: "Søndag 19. april", time: "14:00–19:00" } }
        ]},
        { num: 9, off: true, offLabel: "Fri uge" },
        { num: 10, pairs: [
          { topic: "Vinyasa & Yin Yoga 05",
            wd: { date: "Mandag 27. april", time: "10:00–15:00" },
            we: { date: "Lørdag 2. maj", time: "13:00–18:00" } },
          { topic: "Hatha & Class Management 04",
            wd: { date: "Onsdag 29. april", time: "10:00–15:00" },
            we: { date: "Søndag 3. maj", time: "14:00–19:00" } }
        ]}
      ]},
      { name: "Maj", year: "2026", weeks: [
        { num: 11, label: "Anatomi & Filosofi", shared: [
          { topic: "Yoga Anatomi 03", date: "Lørdag 9. maj", time: "13:00–17:00" },
          { topic: "Yogafilosofi 03 — Online", date: "Søndag 10. maj", time: "14:00–17:00", online: true }
        ]},
        { num: 12, pairs: [
          { topic: "Vinyasa & Yin Yoga 06",
            wd: { date: "Mandag 11. maj", time: "10:00–15:00" },
            we: { date: "Lørdag 16. maj", time: "13:00–18:00" } }
        ]},
        { num: 13, pairs: [
          { topic: "Vinyasa & Yin Yoga 07",
            wd: { date: "Mandag 18. maj", time: "10:00–15:00" },
            we: { date: "Lørdag 23. maj", time: "13:00–18:00" } }
        ]},
        { num: 14, label: "Anatomi & Filosofi", shared: [
          { topic: "Yoga Anatomi 04", date: "Lørdag 30. maj", time: "13:00–17:00" },
          { topic: "Yogafilosofi 04 — Online", date: "Søndag 31. maj", time: "14:00–17:00", online: true }
        ]}
      ]},
      { name: "Juni", year: "2026", weeks: [
        { num: 15, pairs: [
          { topic: "Vinyasa & Yin Yoga 08",
            wd: { date: "Mandag 1. juni", time: "10:00–15:00" },
            we: { date: "Lørdag 6. juni", time: "13:00–18:00" } },
          { topic: "Hatha & Class Management 05",
            wd: { date: "Onsdag 3. juni", time: "10:00–14:00" },
            we: { date: "Søndag 7. juni", time: "14:00–18:00" } }
        ]},
        { num: 16, label: "Business of Yoga", pairs: [
          { topic: "Vinyasa & Yin Yoga 09",
            wd: { date: "Mandag 8. juni", time: "10:00–15:00" },
            we: { date: "Lørdag 13. juni", time: "13:00–18:00" } },
          { topic: "Business of Yoga — Foredrag",
            wd: { date: "Onsdag 10. juni", time: "11:00–14:00" },
            we: { date: "Søndag 14. juni", time: "14:00–17:00" } }
        ]},
        { num: 17, off: true, offLabel: "Fri uge — forbered dig til eksamen" },
        { num: 18, label: "Eksamen & Graduation", graduation: true, shared: [
          { topic: "Vinyasa & Yin Yoga — Eksamen", date: "Lørdag 27. juni", time: "13:00–18:00" },
          { topic: "Hatha & CM — Eksamen + Graduation &#127891;", date: "Søndag 28. juni", time: "14:00–17:00", grad: true }
        ]}
      ]}
    ] %}

    {# ── Render paired view ──────────────────────────────── #}
    {% for month in months18wPairs %}
    <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:24px;{% if not loop.first %}margin-top:40px;{% endif %}">
      <span style="font-size:3.4rem;font-weight:700;line-height:1;color:#0F0F0F;">{{ month.name }}</span>
      <span style="font-size:1.1rem;color:#6F6A66;">{{ month.year }}</span>
      <div style="flex:1;height:2px;background:linear-gradient(to right, #E8E4E0, transparent);margin-left:12px;"></div>
    </div>

    {% for week in month.weeks %}
      {% if week.off %}
      <div style="margin-bottom:12px;padding:14px 22px;background:#FAFAFA;border:1px dashed #E8E4E0;border-radius:14px;display:flex;align-items:center;gap:14px;">
        <span style="background:#E8E4E0;color:#6F6A66;font-size:.68rem;font-weight:700;padding:5px 12px;border-radius:50px;letter-spacing:.06em;">UGE {{ week.num }}</span>
        <p style="font-size:.85rem;color:#6F6A66;font-style:italic;">{{ week.offLabel }}</p>
      </div>

      {% elif week.shared %}
      {# Week label #}
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;{% if not loop.first %}margin-top:8px;{% endif %}">
        <span style="background:{% if week.graduation %}#2ecc71{% else %}#0F0F0F{% endif %};color:#fff;font-size:.65rem;font-weight:700;padding:5px 12px;border-radius:50px;letter-spacing:.06em;white-space:nowrap;">UGE {{ week.num }}</span>
        {% if week.label %}<span style="font-size:.82rem;font-weight:600;color:#6F6A66;">{{ week.label }}</span>{% endif %}
      </div>
      {# Shared session cards #}
      {% for s in week.shared %}
      <div style="border:1px solid {% if week.graduation %}#c3e6c3{% else %}#E8E4E0{% endif %};border-radius:14px;padding:16px 20px;margin-bottom:10px;{% if week.graduation %}background:linear-gradient(135deg, #f9fff9, #f0fff0);{% endif %}">
        <div style="border-left:3px solid {% if s.grad %}#2ecc71{% elif week.graduation %}#f75c03{% else %}#f75c03{% endif %};padding-left:14px;">
          <p style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:{% if s.grad %}#2ecc71{% else %}#f75c03{% endif %};margin-bottom:4px;">{% if s.grad %}Graduation{% else %}Begge hold{% endif %}</p>
          <p style="font-weight:600;font-size:.92rem;color:#0F0F0F;">{{ s.topic }}</p>
          <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">{{ s.date }} · {{ s.time }}{% if s.online %} · <span style="color:#f75c03;font-weight:600;">Online</span>{% endif %}</p>
        </div>
      </div>
      {% endfor %}

      {% elif week.pairs %}
      {# Week label #}
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;{% if not loop.first %}margin-top:8px;{% endif %}">
        <span style="background:#f75c03;color:#fff;font-size:.65rem;font-weight:700;padding:5px 12px;border-radius:50px;letter-spacing:.06em;white-space:nowrap;">UGE {{ week.num }}</span>
