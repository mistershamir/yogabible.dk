</section>




{# ── Accordion toggle script ─────────────────────────────── #}
<script>
(function() {
  /* ── 18-week route toggle ─────────────────── */
  window.ss18SetRoute = function(route) {
    /* Update tab styles */
    var tabs = document.querySelectorAll('[data-ss18-tab]');
    tabs.forEach(function(btn) {
      if (btn.dataset.ss18Tab === route) {
        btn.style.background = '#f75c03';
        btn.style.color = '#fff';
        btn.style.boxShadow = '0 4px 12px rgba(247,92,3,.3)';
      } else {
        btn.style.background = 'transparent';
        btn.style.color = '#6F6A66';
        btn.style.boxShadow = 'none';
      }
    });

    var viewBoth = document.getElementById('ss18-view-both');
    var viewSingle = document.getElementById('ss18-view-single');

    if (route === 'both') {
      /* Show paired ELLER view, hide accordion */
      if (viewBoth) viewBoth.style.display = '';
      if (viewSingle) viewSingle.style.display = 'none';
    } else {
      /* Show accordion view, hide paired */
      if (viewBoth) viewBoth.style.display = 'none';
      if (viewSingle) viewSingle.style.display = '';

      /* Filter day rows in accordion */
      var days = document.querySelectorAll('.ss18-day');
      days.forEach(function(row) {
        var dayRoute = row.dataset.ss18Route;
        row.style.display = (dayRoute === 'shared' || dayRoute === route) ? 'flex' : 'none';
      });

      /* Hide route labels (redundant when filtered) */
      document.querySelectorAll('.ss18-route-label').forEach(function(lbl) {
        lbl.style.display = 'none';
      });

      /* Hide accordion weeks with zero visible days */
      document.querySelectorAll('.ss18-week').forEach(function(wk) {
        if (wk.dataset.ss18Route === 'shared') { wk.style.display = ''; return; }
        var vis = wk.querySelectorAll('.ss18-day');
        if (!vis.length) { wk.style.display = ''; return; }
        var any = false;
        vis.forEach(function(d) { if (d.style.display !== 'none') any = true; });
        wk.style.display = any ? '' : 'none';
      });

      /* Fix border-bottom on last-visible day rows */
      document.querySelectorAll('#design-combo-18w .ss-combo-accordion').forEach(function(acc) {
        var rows = acc.querySelectorAll('.ss18-day');
        var last = null;
        rows.forEach(function(r) {
          if (r.style.display !== 'none') { r.style.borderBottom = '1px solid #F0EDE9'; last = r; }
        });
        if (last) last.style.borderBottom = 'none';
      });
    }

    /* Update stats */
    var statDays = document.getElementById('ss18-stat-days');
    var statLabel = document.getElementById('ss18-stat-days-label');
    if (statDays && statLabel) {
      if (route === 'both') {
        statDays.textContent = '25';
        statLabel.textContent = 'dage pr. hold';
      } else {
        var count = 0;
        document.querySelectorAll('.ss18-day').forEach(function(d) { if (d.style.display !== 'none') count++; });
        statDays.textContent = count;
        statLabel.textContent = 'uddannelsesdage';
      }
    }
  };

  /* ── Busy-day row toggle ────────────────────── */
  window.ss18ToggleBusyRow = function(cb) {
    var row = cb.closest('.ss18-busy-row');
    var times = row.querySelector('.ss18-busy-times');
    if (cb.checked) {
      row.style.background = '#F5F3F0';
      times.style.opacity = '1';
      times.style.pointerEvents = '';
    } else {
      row.style.background = 'transparent';
      times.style.opacity = '.3';
      times.style.pointerEvents = 'none';
    }
  };

  /* ── 18-week conflict checker (per-day times) ─ */
  var ss18Schedule = [
    {dow:1,s:'10:00',e:'15:00',r:'weekday'},{dow:3,s:'10:00',e:'15:00',r:'weekday'},
    {dow:6,s:'13:00',e:'18:00',r:'weekend'},{dow:0,s:'14:00',e:'19:00',r:'weekend'},
    {dow:6,s:'13:00',e:'17:00',r:'shared'},{dow:0,s:'14:00',e:'17:00',r:'shared'}
  ];
  function ss18TimeMin(t){var p=t.split(':');return parseInt(p[0])*60+parseInt(p[1]);}

  function ss18GetBusySlots() {
    var slots = {};
    var rows = document.querySelectorAll('.ss18-busy-row');
    rows.forEach(function(row) {
      var cb = row.querySelector('input[name="ss18-busy"]');
      if (!cb.checked) return;
      var dow = parseInt(cb.value);
      var from = row.querySelector('.ss18-time-from').value || '09:00';
      var to = row.querySelector('.ss18-time-to').value || '17:00';
      slots[dow] = { s: ss18TimeMin(from), e: ss18TimeMin(to) };
    });
    return slots;
  }

  function ss18Count(route, busySlots) {
    var days = ss18Schedule.filter(function(d) { return d.r === route || d.r === 'shared'; });
    var c = 0;
    days.forEach(function(d) {
      var slot = busySlots[d.dow];
      if (!slot) return;
      var sessS = ss18TimeMin(d.s), sessE = ss18TimeMin(d.e);
      if (sessS < slot.e && sessE > slot.s) c++;
    });
    return { total: days.length, conflicts: c, clear: days.length - c };
  }

  window.ss18CheckConflicts = function() {
    var busySlots = ss18GetBusySlots();
    var el = document.getElementById('ss18-conflict-results');
    if (!el) return;
    el.style.display = 'block';
    var wd = ss18Count('weekday', busySlots);
    var wec = ss18Count('weekend', busySlots);
    var wdPct = Math.round((wd.clear / wd.total) * 100);
    var wePct = Math.round((wec.clear / wec.total) * 100);
    var wdBest = wd.conflicts < wec.conflicts;
    var weBest = wec.conflicts < wd.conflicts;
    var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">';
    html += '<div style="background:' + (wdBest ? '#f0fff0' : '#fff') + ';border:2px solid ' + (wdBest ? '#2ecc71' : '#E8E4E0') + ';border-radius:12px;padding:16px;text-align:center;position:relative;">';
    if (wdBest) html += '<span style="position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:#2ecc71;color:#fff;padding:3px 12px;border-radius:50px;font-size:.68rem;font-weight:700;">Bedste match</span>';
    html += '<p style="font-weight:700;font-size:.85rem;margin-bottom:4px;">Hverdagshold</p>';
    html += '<p style="font-size:2.2rem;font-weight:700;' + (wd.conflicts === 0 ? 'color:#2ecc71;' : 'color:#0F0F0F;') + '">' + wd.conflicts + '</p>';
    html += '<p style="font-size:.75rem;color:#6F6A66;">konflikter af ' + wd.total + '</p>';
    html += '<div style="background:#E8E4E0;border-radius:50px;height:6px;overflow:hidden;margin-top:10px;"><div style="background:#2ecc71;height:100%;width:' + wdPct + '%;border-radius:50px;"></div></div></div>';
    html += '<div style="background:' + (weBest ? '#f0fff0' : '#fff') + ';border:2px solid ' + (weBest ? '#2ecc71' : '#E8E4E0') + ';border-radius:12px;padding:16px;text-align:center;position:relative;">';
    if (weBest) html += '<span style="position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:#2ecc71;color:#fff;padding:3px 12px;border-radius:50px;font-size:.68rem;font-weight:700;">Bedste match</span>';
    html += '<p style="font-weight:700;font-size:.85rem;margin-bottom:4px;">Weekendhold</p>';
    html += '<p style="font-size:2.2rem;font-weight:700;' + (wec.conflicts === 0 ? 'color:#2ecc71;' : 'color:#0F0F0F;') + '">' + wec.conflicts + '</p>';
    html += '<p style="font-size:.75rem;color:#6F6A66;">konflikter af ' + wec.total + '</p>';
    html += '<div style="background:#E8E4E0;border-radius:50px;height:6px;overflow:hidden;margin-top:10px;"><div style="background:#2ecc71;height:100%;width:' + wePct + '%;border-radius:50px;"></div></div></div>';
    html += '</div>';
    if (wd.conflicts === 0 && wec.conflicts === 0) {
      html += '<div style="background:#f0fff0;border:1px solid #c3e6c3;border-radius:12px;padding:16px;text-align:center;margin-top:12px;"><p style="font-weight:700;color:#2ecc71;">Begge hold passer perfekt!</p></div>';
    } else {
      var bestName = wdBest ? 'Hverdagshold' : 'Weekendhold';
      var bestCount = Math.min(wd.conflicts, wec.conflicts);
      html += '<div style="background:#FFF8F3;border:1px solid #FFE5D0;border-radius:12px;padding:16px;margin-top:12px;"><p style="font-size:.88rem;"><strong>Anbefaling:</strong> Brug ' + bestName + ' som base' + (bestCount > 0 ? ' og byt de ' + bestCount + ' konfliktuger til det andet hold' : '') + '.</p></div>';
    }
    el.innerHTML = html;
  };

  /* ── Conflict finder chevron ──────────────── */
  var cfDetails = document.getElementById('ss18-conflict-finder');
  if (cfDetails) {
    cfDetails.addEventListener('toggle', function() {
      var chev = cfDetails.querySelector('.ss18-cf-chevron');
      if (chev) chev.style.transform = cfDetails.open ? 'rotate(180deg)' : '';
    });
  }

})();
</script>

<style>
  /* Combo accordion styles */
  .ss-combo-accordion summary::-webkit-details-marker { display: none; }
  .ss-combo-accordion summary::marker { display: none; content: ''; }
  .ss-combo-summary:hover { box-shadow: 0 4px 16px rgba(0,0,0,.06); transform: translateY(-1px); }
  .ss-combo-accordion[open] .ss-combo-summary {
    border-radius: 14px 14px 0 0 !important;
    border-bottom-color: transparent !important;
  }
  .ss-combo-accordion[open] .ss-combo-icon {
    transform: rotate(45deg);
  }

  /* 18w route filter transitions */
  .ss18-day { transition: opacity .2s; }
  .ss18-week { transition: opacity .2s; }

  /* Smooth scroll */
  html { scroll-behavior: smooth; }

  /* Responsive — hide day abbreviations on small screens */
  @media (max-width: 700px) {
    #design-combo-18w .ss-combo-summary [style*="gap:12px"]:last-child > span:first-child {
      display: none !important;
    }
  }
</style>
