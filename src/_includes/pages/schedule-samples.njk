        </summary>

        <div style="padding:6px 22px 18px;background:#fff;border:1px solid #E8E4E0;border-top:none;border-radius:0 0 14px 14px;margin-top:-1px;">
          {% for day in week.days %}
          <div class="ss18-day" data-ss18-route="{{ day.route }}" style="display:flex;gap:16px;align-items:center;padding:12px 0;{% if not loop.last %}border-bottom:1px solid #F0EDE9;{% endif %}">

            {# Date tile — color by route #}
            <div style="
              background:{% if day.route == 'shared' %}#f75c03{% elif day.route == 'weekend' %}#ff9966{% else %}#0F0F0F{% endif %};
              color:#fff;
              width:46px;height:46px;
