{# ── Accordion toggle script ─────────────────────────────── #}
<script>
(function() {
  // Rotate accordion icons on open/close
  document.querySelectorAll('.ss-accordion').forEach(function(d) {
    d.addEventListener('toggle', function() {
      var icon = d.querySelector('.ss-acc-icon');
      if (!icon) return;
      if (d.open) {
        icon.textContent = '−';
        icon.style.transform = 'rotate(0deg)';
        icon.style.background = '#d94f02';
      } else {
        icon.textContent = '+';
        icon.style.transform = 'rotate(0deg)';
        icon.style.background = '#f75c03';
      }
    });
  });

  /* ── 18-week route toggle ─────────────────── */
  window.ss18SetRoute = function(route) {
    /* Update tab styles */
    var tabs = document.querySelectorAll('[data-ss18-tab]');
    tabs.forEach(function(btn) {
      if (btn.dataset.ss18Tab === route) {
        btn.style.background = '#f75c03';
        btn.style.color = '#fff';
        btn.style.boxShadow = '0 4px 12px rgba(247,92,3,.3)';
      } else {
        btn.style.background = 'transparent';
        btn.style.color = '#6F6A66';
        btn.style.boxShadow = 'none';
      }
    });

    /* Show/hide legend (only in "both" view) */
    var legend = document.getElementById('ss18-legend');
    if (legend) legend.style.display = route === 'both' ? 'flex' : 'none';

    /* Filter day rows */
    var days = document.querySelectorAll('.ss18-day');
    days.forEach(function(row) {
      var dayRoute = row.dataset.ss18Route;
      if (route === 'both') {
        row.style.display = 'flex';
      } else if (dayRoute === 'shared' || dayRoute === route) {
        row.style.display = 'flex';
      } else {
        row.style.display = 'none';
      }
    });

    /* Hide route labels when filtered to a single track */
    var labels = document.querySelectorAll('.ss18-route-label');
    labels.forEach(function(lbl) {
      lbl.style.display = route === 'both' ? '' : 'none';
    });

    /* Hide accordion weeks that have zero visible days */
    var weeks = document.querySelectorAll('.ss18-week');
    weeks.forEach(function(wk) {
      var wkRoute = wk.dataset.ss18Route;
      /* Off weeks & graduation (shared) always show */
      if (wkRoute === 'shared') { wk.style.display = ''; return; }
      /* Check if any child days are visible */
      var visibleDays = wk.querySelectorAll('.ss18-day');
      if (visibleDays.length === 0) { wk.style.display = ''; return; }
      var anyVisible = false;
      visibleDays.forEach(function(d) {
        if (d.style.display !== 'none') anyVisible = true;
      });
      wk.style.display = anyVisible ? '' : 'none';
    });

    /* Update the day count in stats bar */
    var statDays = document.getElementById('ss18-stat-days');
    var statLabel = document.getElementById('ss18-stat-days-label');
    if (statDays && statLabel) {
      if (route === 'both') {
        statDays.textContent = '25';
        statLabel.textContent = 'dage pr. hold';
      } else {
        /* Count visible days for this route */
        var count = 0;
        days.forEach(function(d) { if (d.style.display !== 'none') count++; });
        statDays.textContent = count;
        statLabel.textContent = 'uddannelsesdage';
      }
    }

    /* Fix border-bottom on last-visible day rows within each accordion */
    var containers = document.querySelectorAll('#design-combo-18w .ss-combo-accordion');
    containers.forEach(function(acc) {
      var rows = acc.querySelectorAll('.ss18-day');
      var lastVisible = null;
      rows.forEach(function(r) {
        if (r.style.display !== 'none') {
          r.style.borderBottom = '1px solid #F0EDE9';
          lastVisible = r;
        }
      });
      if (lastVisible) lastVisible.style.borderBottom = 'none';
    });
  };

  // Sticky nav highlight
  var navLinks = document.querySelectorAll('nav a[href^="#design-"]');
  var sections = [];
  navLinks.forEach(function(link) {
    var id = link.getAttribute('href').substring(1);
    var el = document.getElementById(id);
    if (el) sections.push({ el: el, link: link });
  });
  if (sections.length > 0) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        var match = sections.find(function(s) { return s.el === entry.target; });
        if (!match) return;
        if (entry.isIntersecting) {
          navLinks.forEach(function(l) {
            l.style.background = 'rgba(15,15,15,.08)';
            l.style.color = '#0F0F0F';
          });
          match.link.style.background = '#0F0F0F';
          match.link.style.color = '#fff';
        }
      });
    }, { threshold: 0.3 });
    sections.forEach(function(s) { observer.observe(s.el); });
  }
})();
</script>

