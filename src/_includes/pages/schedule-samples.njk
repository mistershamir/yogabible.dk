          display:flex;
          align-items:center;
          justify-content:space-between;
          padding:18px 22px;
          cursor:pointer;
          list-style:none;
          -webkit-appearance:none;
          background:#fff;
          border:1px solid #E8E4E0;
          border-radius:14px;
          transition:all .2s;
        ">
          <div style="display:flex;align-items:center;gap:14px;">
            <span style="background:#f75c03;color:#fff;font-size:.68rem;font-weight:700;padding:5px 12px;border-radius:50px;letter-spacing:.06em;">UGE {{ week.num }}</span>
