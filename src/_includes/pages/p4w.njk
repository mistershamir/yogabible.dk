        <div class="yb-more-card__body">
          <h3 id="ybProgramTitle" class="yb-more-card__title">200 timer – 18 ugers fleksibelt program</h3>

          <div class="yb-more-card__pills" role="tablist" aria-label="Vælg program">
            <button class="yb-pill is-active" role="tab" aria-selected="true" data-program="18w">18 Weeks Flexible</button>
            <button class="yb-pill" role="tab" aria-selected="false" data-program="8w">8 Weeks Semi-Intensive</button>
