      <!-- Programs Card (18w / 8w with pill switching) -->
      <article class="yb-more-card">
        <figure class="yb-more-card__image">
          <img id="ybProgramImg"
               src="https://www.yogabible.dk/s/200timer-Yoga-Education-Kbenhavn.png?format=1500w"
