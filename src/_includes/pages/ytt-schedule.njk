{% set t = i18n.ytt_schedule[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

{# ── Hero ──────────────────────────────────────────── #}
<section id="yts-hero" style="
  background: #0F0F0F;
  color: #fff;
  padding: clamp(80px, 12vw, 140px) 24px 60px;
  text-align: center;
">
  <div style="max-width: 700px; margin: 0 auto;">
    <p style="
      text-transform: uppercase;
      letter-spacing: .18em;
      font-size: .78rem;
      color: #f75c03;
      margin-bottom: 12px;
    ">{{ t.hero_eyebrow }}</p>

    {# Program selector — populated by JS #}
    <div id="yts-program-selector" style="margin-bottom: 16px;"></div>

    <h1 id="yts-program-title" style="
      font-size: clamp(2rem, 5vw, 3.2rem);
      font-weight: 700;
      line-height: 1.15;
      margin: 0 0 16px;
    ">{{ t.hero_title }}</h1>

    <p id="yts-program-subtitle" style="
      font-size: 1.05rem;
      color: rgba(255,255,255,.72);
      line-height: 1.55;
      margin-bottom: 24px;
    ">{{ t.hero_subtitle }}</p>

    <div id="yts-program-meta" style="
      display: flex;
      gap: 10px;
      justify-content: center;
      flex-wrap: wrap;
      margin-bottom: 28px;
    "></div>

    <button id="yts-add-all-btn" onclick="ytsAddAllToCalendar()" style="
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: #f75c03;
      color: #fff;
      border: none;
      padding: 14px 28px;
      border-radius: 50px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: background .2s;
    ">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      {{ t.add_all }}
    </button>

    <p style="margin-top: 16px; font-size: .85rem; color: rgba(255,255,255,.45);">{{ t.hero_tip }}</p>

    {# Route toggle — populated by JS for multi-route programs #}
    <div id="yts-route-toggle" style="margin-top: 24px;"></div>
  </div>
</section>

{# ── Quick stats bar ──────────────────────────────── #}
<section id="yts-stats" style="
  background: #F5F3F0;
  padding: 28px 24px;
  border-bottom: 1px solid #E8E4E0;
">
  <div style="
    max-width: 800px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    text-align: center;
  ">
    <div>
      <span id="yts-stat-weeks" style="font-size: 1.8rem; font-weight: 700; color: #f75c03;">8</span>
      <p style="font-size: .82rem; color: #6F6A66; margin-top: 4px;">{{ t.overview_weeks }}</p>
    </div>
    <div>
      <span id="yts-stat-days" style="font-size: 1.8rem; font-weight: 700; color: #f75c03;">—</span>
      <p style="font-size: .82rem; color: #6F6A66; margin-top: 4px;">{{ t.overview_days }}</p>
    </div>
    <div>
      <span style="font-size: 1.8rem; font-weight: 700; color: #f75c03;">200+</span>
      <p style="font-size: .82rem; color: #6F6A66; margin-top: 4px;">{{ t.overview_hours }}</p>
    </div>
    <div>
      <span id="yts-stat-free" style="font-size: 1.8rem; font-weight: 700; color: #f75c03;">—</span>
      <p style="font-size: .82rem; color: #6F6A66; margin-top: 4px;">{{ t.overview_free }}</p>
    </div>
  </div>
</section>

{# ── Legend ────────────────────────────────────────── #}
<section style="
  max-width: 800px;
  margin: 0 auto;
  padding: 24px 24px 0;
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  font-size: .82rem;
  color: #6F6A66;
">
  <span style="display:flex;align-items:center;gap:6px;">
    <span style="width:14px;height:14px;border-radius:4px;background:#f75c03;display:inline-block;"></span>
    {{ t.legend_workshop }}
  </span>
  <span style="display:flex;align-items:center;gap:6px;">
    <span style="width:14px;height:14px;border-radius:4px;background:#E8E4E0;display:inline-block;"></span>
    {{ t.legend_free }}
  </span>
  <span style="display:flex;align-items:center;gap:6px;">
    <span style="width:14px;height:14px;border-radius:4px;background:#ff9966;display:inline-block;"></span>
    {{ t.legend_weekend }}
  </span>
  <span style="display:flex;align-items:center;gap:6px;">
    <span style="width:14px;height:14px;border-radius:4px;background:#2ecc71;display:inline-block;"></span>
    {{ t.legend_graduation }}
  </span>
  <span id="yts-legend-shared" style="display:none;align-items:center;gap:6px;">
    <span style="width:14px;height:14px;border-radius:4px;background:#3498db;display:inline-block;"></span>
    {{ t.legend_shared }}
  </span>
  <span id="yts-legend-off" style="display:none;align-items:center;gap:6px;">
    <span style="width:14px;height:14px;border-radius:4px;background:#c9c5c0;display:inline-block;"></span>
    {{ t.legend_off }}
  </span>
</section>

{# ── Schedule grid — populated by JS ─────────────── #}
<section id="yts-schedule" style="
  max-width: 800px;
  margin: 0 auto;
  padding: 32px 24px 60px;
">
  <div id="yts-weeks-container"></div>
</section>

{# ── Typical week visual ─────────────────────────── #}
<section id="yts-typical-section" style="
  background: #F5F3F0;
  padding: 60px 24px;
">
  <div style="max-width: 800px; margin: 0 auto;">
    <div id="yts-typical-inner">
    <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 24px; text-align: center;">{{ t.typical_title }}</h2>
    <div style="
      display: grid;
      grid-template-columns: repeat(7, 1fr);
      gap: 8px;
    " id="yts-typical-week">
      {% set days = [
        { "name": t.typical_mon, "desc": t.typical_mon_desc, "time": t.typical_time_weekday, "type": "workshop" },
        { "name": t.typical_tue, "desc": t.typical_tue_desc, "time": t.typical_time_weekday, "type": "workshop" },
        { "name": t.typical_wed, "desc": t.typical_wed_desc, "time": "", "type": "free" },
        { "name": t.typical_thu, "desc": t.typical_thu_desc, "time": t.typical_time_weekday, "type": "workshop" },
        { "name": t.typical_fri, "desc": t.typical_fri_desc, "time": t.typical_time_weekday, "type": "workshop" },
        { "name": t.typical_sat, "desc": t.typical_sat_desc, "time": t.typical_time_weekend, "type": "weekend" },
        { "name": t.typical_sun, "desc": t.typical_sun_desc, "time": "", "type": "free" }
      ] %}
      {% for d in days %}
      <div style="
        background: {% if d.type == 'workshop' %}#fff{% elif d.type == 'weekend' %}#fff{% else %}#FFFCF9{% endif %};
        border: 1px solid {% if d.type == 'workshop' %}#f75c03{% elif d.type == 'weekend' %}#ff9966{% else %}#E8E4E0{% endif %};
        border-radius: 12px;
        padding: 14px 10px;
        text-align: center;
        min-height: 120px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      ">
        <p style="font-weight: 700; font-size: .78rem; text-transform: uppercase; letter-spacing: .08em; color: {% if d.type == 'workshop' %}#f75c03{% elif d.type == 'weekend' %}#ff9966{% else %}#6F6A66{% endif %}; margin-bottom: 8px;">{{ d.name }}</p>
        <p style="font-size: .72rem; color: #333; line-height: 1.4; flex: 1;">{{ d.desc }}</p>
        {% if d.time %}
        <p style="font-size: .68rem; color: #6F6A66; margin-top: 8px;">{{ d.time }}</p>
        {% endif %}
      </div>
      {% endfor %}
    </div>
    </div>{# /yts-typical-inner #}
  </div>
</section>

{# ── CTA section ──────────────────────────────────── #}
<section style="
  background: #0F0F0F;
  color: #fff;
  padding: 60px 24px;
  text-align: center;
">
  <div style="max-width: 600px; margin: 0 auto;">
    <h2 style="font-size: 1.6rem; font-weight: 700; margin-bottom: 12px;">{{ t.next_title }}</h2>
    <p style="color: rgba(255,255,255,.68); margin-bottom: 28px; line-height: 1.55;">{{ t.next_text }}</p>
    <div style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap;">
      <a href="{% if lang == 'en' %}/en{% endif %}/?booking=1" style="
        display: inline-block;
        background: transparent;
        color: #fff;
        border: 1.5px solid #fff;
        padding: 14px 28px;
        border-radius: 50px;
        font-size: .95rem;
        font-weight: 600;
        text-decoration: none;
        transition: all .2s;
      ">{{ t.next_cta_meeting }}</a>
      <button id="yts-prep-cta" style="
        display: inline-block;
        background: #f75c03;
        color: #fff;
        border: none;
        padding: 14px 28px;
        border-radius: 50px;
        font-size: .95rem;
        font-weight: 600;
        cursor: pointer;
        font-family: inherit;
        transition: background .2s;
      ">{{ t.next_cta_prep }}</button>
    </div>
  </div>
</section>

<p style="text-align: center; font-size: .78rem; color: #6F6A66; padding: 20px 24px; max-width: 600px; margin: 0 auto;">
  {{ t.footer_note }}
</p>

{# ── Schedule data passed to JS via hidden script ── #}
<script>
  window.YTS_LANG = '{{ lang or "da" }}';
</script>
<script src="/js/ytt-schedule.js" defer></script>

<style>
  /* ── YTT Schedule page styles (yts- prefix) ───── */
  #yts-hero button:hover { background: #d94f02 !important; }
  #yts-prep-cta:hover { background: #d94f02 !important; }

  .yts-week {
    margin-bottom: 32px;
  }
  .yts-week__header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 14px;
    padding-bottom: 10px;
    border-bottom: 2px solid #E8E4E0;
  }
  .yts-week__number {
    background: #0F0F0F;
    color: #fff;
    font-size: .72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .1em;
    padding: 5px 12px;
    border-radius: 50px;
  }
  .yts-week__range {
    font-size: .88rem;
    color: #6F6A66;
  }
  .yts-week__theme {
    font-size: .82rem;
    font-weight: 600;
    color: #333;
    margin-left: auto;
  }

  .yts-day {
    display: grid;
    grid-template-columns: 50px 1fr auto;
    gap: 14px;
    align-items: center;
    padding: 12px 16px;
    border-radius: 10px;
    margin-bottom: 6px;
    transition: transform .15s, box-shadow .15s;
  }
  .yts-day:hover {
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(0,0,0,.06);
  }
  .yts-day--workshop {
    background: #fff;
    border: 1px solid #E8E4E0;
  }
  .yts-day--free {
    background: #FAFAF8;
    border: 1px solid #F0EDE9;
  }
  .yts-day--weekend {
    background: #FFF8F3;
    border: 1px solid #FFE5D0;
  }
  .yts-day--graduation {
    background: linear-gradient(135deg, #f0fff0, #e8f5e8);
    border: 1.5px solid #2ecc71;
  }

  .yts-day__date {
    text-align: center;
  }
  .yts-day__date-num {
    font-size: 1.3rem;
    font-weight: 700;
    line-height: 1;
    color: #0F0F0F;
  }
  .yts-day__date-day {
    font-size: .68rem;
    color: #6F6A66;
    text-transform: uppercase;
    letter-spacing: .06em;
  }

  .yts-day__info {
    min-width: 0;
  }
  .yts-day__topic {
    font-weight: 600;
    font-size: .92rem;
    color: #0F0F0F;
  }
  .yts-day__time {
    font-size: .78rem;
    color: #6F6A66;
    margin-top: 2px;
  }
  .yts-day__badge {
    font-size: .68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .06em;
    padding: 4px 10px;
    border-radius: 50px;
    white-space: nowrap;
  }
  .yts-day__badge--workshop { background: #FFF0E6; color: #f75c03; }
  .yts-day__badge--free { background: #F0EDE9; color: #6F6A66; }
  .yts-day__badge--weekend { background: #FFE5D0; color: #d94f02; }
  .yts-day__badge--graduation { background: #d4edda; color: #155724; }

  .yts-day__cal-btn {
    background: none;
    border: 1.5px solid #E8E4E0;
    border-radius: 8px;
    padding: 6px 8px;
    cursor: pointer;
    color: #6F6A66;
    transition: all .2s;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .yts-day__cal-btn:hover {
    border-color: #f75c03;
    color: #f75c03;
    background: #FFF8F3;
  }

  /* Month separator */
  .yts-month-sep {
    font-size: 1.2rem;
    font-weight: 700;
    color: #f75c03;
    padding: 20px 0 8px;
    margin-top: 12px;
    border-top: 2px solid #f75c03;
  }

  /* OFF week */
  .yts-week--off {
    margin-bottom: 16px;
  }
  .yts-week__header--off {
    border-bottom-style: dashed;
    border-bottom-color: #c9c5c0;
    opacity: .7;
  }
  .yts-week__number--off {
    background: #c9c5c0;
  }
  .yts-week__off-label {
    font-size: .88rem;
    color: #6F6A66;
    font-style: italic;
  }

  /* Shared session (both groups) */
  .yts-day--shared {
    border-color: #3498db !important;
    background: #EBF5FB !important;
  }
  .yts-shared-pill {
    display: inline-block;
    background: #3498db;
    color: #fff;
    padding: 2px 8px;
    border-radius: 50px;
    font-size: .65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .04em;
    vertical-align: middle;
    margin-left: 6px;
  }

  /* Responsive: stack typical week on mobile */
  @media (max-width: 700px) {
    #yts-typical-week,
    #yts-typical-grid {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    #yts-typical-week > div:last-child,
    #yts-typical-grid > div:last-child {
      grid-column: span 2;
    }
    #yts-stats > div {
      grid-template-columns: repeat(2, 1fr) !important;
    }
    .yts-day {
      grid-template-columns: 44px 1fr auto;
      gap: 10px;
      padding: 10px 12px;
    }
    .yts-day__date-num { font-size: 1.1rem; }
    .yts-day__topic { font-size: .85rem; }
    .yts-week__header { flex-wrap: wrap; }
    .yts-week__theme { margin-left: 0; width: 100%; font-size: .78rem; }
    #yts-route-toggle > div {
      flex-direction: column !important;
      max-width: 100% !important;
    }
  }

  @media (max-width: 480px) {
    #yts-typical-week,
    #yts-typical-grid {
      grid-template-columns: 1fr !important;
    }
    #yts-typical-week > div:last-child,
    #yts-typical-grid > div:last-child {
      grid-column: span 1;
    }
  }
</style>
