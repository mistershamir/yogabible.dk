{% set t = i18n.index[lang or "da"] %}

<!-- ═══════════════════════════════════════════════════════════════
     HERO — Cinematic Dark with Breathing Glow
     Centered layout, optional video/image background
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-hero">
  <div class="yb-hero__bg">
    <video autoplay muted loop playsinline>
      <source src="/assets/video/hero-loop.mp4" type="video/mp4">
    </video>
  </div>
  <div class="yb-hero__glow"></div>

  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_flag }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title | safe }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_lead }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="{% if lang == 'en' %}/en/apply{% else %}/apply{% endif %}" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta1 }}</a>
      <a href="{% if lang == 'en' %}/en/sammenlign-yogalreruddannelser{% else %}/sammenlign-yogalreruddannelser{% endif %}" class="yb-btn yb-btn--outline-white yb-btn--large">{{ t.hero_cta2 }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>

  <div class="yb-hero__scroll">
    <span>{{ t.hero_scroll }}</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════
     UDDANNELSER — Choose Your Path
     Two program cards: 18-week flexible & 4-week intensive
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-programs" id="{% if lang == 'en' %}programs{% else %}uddannelser{% endif %}">
  <div class="yb-programs__inner">
    <header class="yb-programs__header">
      <h2 class="yb-programs__title">{{ t.programs_title }}</h2>
      <p class="yb-programs__subtitle">
        {{ t.programs_subtitle }}
      </p>
    </header>

    <div class="yb-programs__grid">
      <!-- 18-Week Flexible -->
      <article class="yb-program-card">
        <div class="yb-program-card__badge">{{ t.prog18_badge }}</div>
        <h3 class="yb-program-card__title">{{ t.prog18_title }}</h3>
        <p class="yb-program-card__tagline">{{ t.prog18_tagline }}</p>

        <div class="yb-program-card__meta">
          <span class="yb-program-card__date">{{ t.prog18_date }}</span>
        </div>

        <ul class="yb-program-card__points">
          <li>{{ t.prog18_point1 }}</li>
          <li>{{ t.prog18_point2 }}</li>
          <li>{{ t.prog18_point3 }}</li>
          <li>{{ t.prog18_point4 }}</li>
        </ul>

        <div class="yb-program-card__price">
          <span class="yb-program-card__amount">{{ t.prog18_price }}</span>
          <span class="yb-program-card__note">{{ t.prog18_note }}</span>
        </div>

        <a href="{% if lang == 'en' %}/en/200-hours-18-weeks-flexible-programs{% else %}/200-hours-18-weeks-flexible-programs{% endif %}" class="yb-btn yb-btn--primary yb-btn--full">
          {{ t.prog18_cta }}
        </a>
      </article>

      <!-- 4-Week Intensive -->
      <article class="yb-program-card yb-program-card--featured">
        <div class="yb-program-card__badge yb-program-card__badge--orange">{{ t.prog4_badge }}</div>
        <h3 class="yb-program-card__title">{{ t.prog4_title }}</h3>
        <p class="yb-program-card__tagline">{{ t.prog4_tagline }}</p>

        <div class="yb-program-card__meta">
          <span class="yb-program-card__date">{{ t.prog4_date }}</span>
        </div>

        <ul class="yb-program-card__points">
          <li>{{ t.prog4_point1 }}</li>
          <li>{{ t.prog4_point2 }}</li>
          <li>{{ t.prog4_point3 }}</li>
          <li>{{ t.prog4_point4 }}</li>
        </ul>

        <div class="yb-program-card__price">
          <span class="yb-program-card__amount">{{ t.prog4_price }}</span>
          <span class="yb-program-card__note">{{ t.prog4_note }}</span>
        </div>

        <a href="{% if lang == 'en' %}/en/200-hours-4-weeks-intensive-programs{% else %}/200-hours-4-weeks-intensive-programs{% endif %}" class="yb-btn yb-btn--primary yb-btn--full">
          {{ t.prog4_cta }}
        </a>
      </article>
    </div>

    <div class="yb-programs__compare">
      <a href="{% if lang == 'en' %}/en/sammenlign-yogalreruddannelser{% else %}/sammenlign-yogalreruddannelser{% endif %}" class="yb-link-arrow">
        {{ t.programs_compare }}
      </a>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════
     KURSER — 4-Week Specialty Courses (Tabbed Interface)
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-courses" id="{% if lang == 'en' %}courses{% else %}kurser{% endif %}">
  <div class="yb-courses__inner">
    <header class="yb-courses__header">
      <h2 class="yb-courses__title">{{ t.courses_title }}</h2>
      <p class="yb-courses__subtitle">
        {{ t.courses_subtitle }}
      </p>
    </header>

    <!-- Tab Navigation -->
    <div class="yb-courses__tabs" role="tablist">
      <button
        class="yb-courses__tab yb-courses__tab--active"
        role="tab"
        aria-selected="true"
        data-course="inversions"
      >Inversions</button>
      <button
        class="yb-courses__tab"
        role="tab"
        aria-selected="false"
        data-course="splits"
      >Splits</button>
      <button
        class="yb-courses__tab"
        role="tab"
        aria-selected="false"
        data-course="backbends"
      >Backbends</button>
    </div>

    <!-- Tab Panels -->
    <div class="yb-courses__panels">
      <!-- Inversions Panel -->
      <article class="yb-courses__panel yb-courses__panel--active" data-panel="inversions">
        <div class="yb-courses__panel-content">
          <div class="yb-courses__panel-meta">
            <span>{{ t.courses_meta_sessions }}</span>
            <span>{{ t.courses_meta_schedule }}</span>
            <span>{{ t.courses_meta_price }}</span>
          </div>
          <h3 class="yb-courses__panel-title">Inversions</h3>
          <p class="yb-courses__panel-desc">
            {{ t.inv_desc }}
          </p>
          <a href="{% if lang == 'en' %}/en/inversions{% else %}/inversions{% endif %}" class="yb-btn yb-btn--primary">{{ t.inv_cta }}</a>
        </div>
        <div class="yb-courses__panel-media">
          <img
            src="/assets/images/courses/inversions-hero.jpg"
            alt="{{ t.inv_img_alt }}"
            loading="lazy"
          >
        </div>
      </article>

      <!-- Splits Panel -->
      <article class="yb-courses__panel" data-panel="splits" hidden>
        <div class="yb-courses__panel-content">
          <div class="yb-courses__panel-meta">
            <span>{{ t.courses_meta_sessions }}</span>
            <span>{{ t.courses_meta_schedule }}</span>
            <span>{{ t.courses_meta_price }}</span>
          </div>
          <h3 class="yb-courses__panel-title">Splits</h3>
          <p class="yb-courses__panel-desc">
            {{ t.splits_desc }}
          </p>
          <a href="{% if lang == 'en' %}/en/splits{% else %}/splits{% endif %}" class="yb-btn yb-btn--primary">{{ t.splits_cta }}</a>
        </div>
        <div class="yb-courses__panel-media">
          <img
            src="/assets/images/courses/splits-hero.jpg"
            alt="{{ t.splits_img_alt }}"
            loading="lazy"
          >
        </div>
      </article>

      <!-- Backbends Panel -->
      <article class="yb-courses__panel" data-panel="backbends" hidden>
        <div class="yb-courses__panel-content">
          <div class="yb-courses__panel-meta">
            <span>{{ t.courses_meta_sessions }}</span>
            <span>{{ t.courses_meta_schedule }}</span>
            <span>{{ t.courses_meta_price }}</span>
          </div>
          <h3 class="yb-courses__panel-title">Backbends</h3>
          <p class="yb-courses__panel-desc">
            {{ t.back_desc }}
          </p>
          <a href="{% if lang == 'en' %}/en/backbends{% else %}/backbends{% endif %}" class="yb-btn yb-btn--primary">{{ t.back_cta }}</a>
        </div>
        <div class="yb-courses__panel-media">
          <img
            src="/assets/images/courses/backbends-hero.jpg"
            alt="{{ t.back_img_alt }}"
            loading="lazy"
          >
        </div>
      </article>
    </div>

    <div class="yb-courses__bundle">
      <p>{{ t.courses_bundle }}</p>
      <a href="{% if lang == 'en' %}/en/course-bundles{% else %}/course-bundles{% endif %}" class="yb-link-arrow">{{ t.courses_bundle_link }}</a>
    </div>
  </div>
</section>


