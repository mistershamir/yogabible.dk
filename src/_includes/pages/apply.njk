    function getValidationIssues(){
      var issues = [];
      var builderOk = applyForYTT.checked || applyForCourse.checked;
      if(!builderOk) issues.push("{{ t.js_val_select_ytt_or_course }}");

      if(applyForYTT.checked){
        if(!yttProgramSel.value) issues.push("{{ t.js_val_select_ytt_program }}");
        if(!yttPeriodSel.value) issues.push("{{ t.js_val_select_ytt_period }}");
        var trackNeeded = !yttTrackField.classList.contains("is-hidden");
        if(trackNeeded && !yttTrackSel.value) issues.push("{{ t.js_val_select_ytt_track }}");
        var yttPayChoice = (applyForm.querySelector("input[name='ytt_payment_choice']:checked") || {}).value || "";
        if(!yttPayChoice) issues.push("{{ t.js_val_select_ytt_payment }}");
        if(yttPayChoice === "pay_now" && !yttPaidConfirm.checked) issues.push("{{ t.js_val_confirm_ytt_payment }}");
      }

      if(applyForCourse.checked){
        if(isBundleSelected()){
          if(!coursePeriodSel.value) issues.push("{{ t.js_val_select_course_period }}");
          if(!courseBundleType.value) issues.push("{{ t.js_val_select_bundle }}");
        } else {
          if(!courseProgramSel.value) issues.push("Vælg kursus");
          if(!coursePeriodSel.value) issues.push("Vælg kursusperiode");
        }
        var coursePayChoice = (applyForm.querySelector("input[name='course_payment_choice']:checked") || {}).value || "";
        if(!coursePayChoice) issues.push("{{ t.js_val_select_course_payment }}");
        if(coursePayChoice === "pay_now" && !coursePaidConfirm.checked) issues.push("{{ t.js_val_confirm_course_payment }}");
      }

      if(getAccomNeed() === "yes"){
        if(!(accomMonthsValue.value || "").trim()) issues.push("{{ t.js_val_select_accom_months }}");
        var aChoice = (applyForm.querySelector("input[name='accom_payment_choice']:checked") || {}).value || "";
        if(!aChoice) issues.push("{{ t.js_val_select_accom_payment }}");
        if(aChoice === "pay_now" && !accomPaidConfirm.checked) issues.push("{{ t.js_val_confirm_accom_payment }}");
      }

      if(!firstName.value.trim()) issues.push("{{ t.js_val_firstname }}");
      if(!lastName.value.trim()) issues.push("{{ t.js_val_lastname }}");
      if(!email.value.trim()) issues.push("{{ t.js_val_email }}");
      if(!phone.value.trim()) issues.push("{{ t.js_val_phone }}");
      if(!hearAbout.value) issues.push("{{ t.js_val_hearabout }}");
      if(hearAbout.value === "Other" && !hearOther.value.trim()) issues.push("{{ t.js_val_hearother }}");
      if((antiSpam.value || "").trim().toUpperCase() !== "YOGA") issues.push("{{ t.js_val_antispam }}");
      if(!consent.checked) issues.push("{{ t.js_val_consent }}");

      return issues;
    }

    function updateSubmitState(){
      var issues = getValidationIssues();
      var allOk = issues.length === 0;

      formIsValid = allOk;
      submitBtn.classList.toggle("is-disabled", !allOk);

      // Update hint text
      if(allOk){
        submitHint.textContent = "{{ t.js_submit_ready }}";
        submitHint.classList.add("is-ready");
      } else {
        submitHint.textContent = "{{ t.js_submit_hint_default }}";
        submitHint.classList.remove("is-ready");
      }

      // Show/hide validation list if user has tried to submit
      if(userTriedSubmit && !allOk){
        validationList.innerHTML = "";
        issues.forEach(function(issue){
          var li = document.createElement("li");
          li.textContent = issue;
          validationList.appendChild(li);
        });
        validationBox.classList.add("is-visible");
      } else {
        validationBox.classList.remove("is-visible");
      }
    }

    async function loadCatalog(){
      try{
        var data = await getJSON("/.netlify/functions/catalog?v=" + Date.now());
        if(!data || data.ok !== true) throw new Error("catalog not ok");
        catalog = data.catalog || [];
        buildMaps();
        fillProgramSelect(yttProgramSel, "education");
        fillProgramSelect(courseProgramSel, "course");
        if(yttProgramSel.options.length <= 1){
          builderHint.innerHTML = "{{ t.js_catalog_error_ytt }}";
        }
        window.dispatchEvent(new CustomEvent('ybCatalogLoaded'));
      } catch(e){
        console.error("Catalog load error:", e);
        setMsg(applyMsg, "{{ t.js_catalog_load_error }}", "err");
      }
    }

