    applyForYTT.addEventListener("change", updateBuilderUI);
    applyForCourse.addEventListener("change", updateBuilderUI);
    applyForMentorship.addEventListener("change", function(){ updateBuilderHint(); updateSubmitState(); });

    yttProgramSel.addEventListener("change", function(){
      setYttPeriods(yttProgramSel.value);
      onYttPeriodChange();
      updateSubmitState();
    });
    yttPeriodSel.addEventListener("change", function(){
      onYttPeriodChange();
      updateSubmitState();
    });
    yttTrackSel.addEventListener("change", function(){
      updateYttPaymentUI();
      updateSubmitState();
    });

    courseProgramSel.addEventListener("change", function(){
      setCoursePeriods(courseProgramSel.value);
      onCoursePeriodChange();
      updateSubmitState();
    });
    coursePeriodSel.addEventListener("change", function(){ onCoursePeriodChange(); updateSubmitState(); });
    courseBundleType.addEventListener("change", function(){ updateCoursePaymentUI(); updateSubmitState(); });

    applyForm.addEventListener("input", function(e){
      if(e.target && e.target.name === "ytt_payment_choice") updateYttPaymentUI();
      if(e.target && e.target.name === "course_payment_choice") updateCoursePaymentUI();
      if(e.target && e.target.name === "accom_payment_choice") updateAccomPaymentUI();
      if(e.target && e.target.name === "accom_need") updateAccomUI();
      updateSubmitState();
    });

    yttPaidConfirm.addEventListener("change", updateSubmitState);
    coursePaidConfirm.addEventListener("change", updateSubmitState);
    accomPaidConfirm.addEventListener("change", updateSubmitState);

    hearAbout.addEventListener("change", updateHearAboutUI);
    hearOther.addEventListener("input", updateSubmitState);

    antiSpam.addEventListener("input", updateSubmitState);
    consent.addEventListener("change", updateSubmitState);
    [firstName,lastName,email,phone].forEach(function(el){ el.addEventListener("input", updateSubmitState); });

    // Submit handler
    applyForm.addEventListener("submit", async function(e){
      e.preventDefault();
      setMsg(applyMsg, "", null);

      if(!formIsValid){
        userTriedSubmit = true;
        updateSubmitState();
        if(validationBox && validationBox.classList.contains("is-visible")){
          validationBox.scrollIntoView({ behavior: "smooth", block: "center" });
        }
        return;
      }

      var payload = {
        action: "apply_builder",
        source: "{{ t.js_source }}",
        applicant: {
          first_name: firstName.value.trim(),
          last_name: lastName.value.trim(),
          email: email.value.trim(),
          phone: phone.value.trim(),
          hear_about: hearAbout.value,
          hear_about_other: hearOther.value.trim(),
          mentorship_selected: !!applyForMentorship.checked
        },
        selections: {
          ytt: null,
          course: null,
          accommodation: { need: getAccomNeed(), months: [], payment_choice: "" }
        }
      };

      if(applyForYTT.checked){
        var yttRow = getSelectedYttRow();
        var yttOpt = yttPeriodSel.options[yttPeriodSel.selectedIndex];
        payload.selections.ytt = {
          course_id: yttProgramSel.value,
          course_name: (yttRow && yttRow.course_name) || (yttOpt && yttOpt.dataset.course_name) || "",
          cohort_id: yttPeriodSel.value,
          cohort_label: (yttRow && yttRow.cohort_label) || (yttOpt && yttOpt.dataset.cohort_label) || "",
          track: (!yttTrackField.classList.contains("is-hidden") ? (yttTrackSel.value || "") : ((yttRow && yttRow.track) || "")),
          payment_choice: (applyForm.querySelector("input[name='ytt_payment_choice']:checked") || {}).value || ""
        };
      }

      if(applyForCourse.checked){
        if(isBundleSelected()){
          var bundleMonth = coursePeriodSel.value;
          var bundleType = courseBundleType.value;
          var bundlePayUrl = getBundlePayUrl();
          payload.selections.course = {
            course_id: BUNDLE_PROGRAM_ID,
            course_name: "Kursuspakke — " + bundleType,
            cohort_id: bundleMonth,
            cohort_label: bundleMonth,
            bundle_type: bundleType,
            bundle_payment_url: bundlePayUrl,
            payment_choice: (applyForm.querySelector("input[name='course_payment_choice']:checked") || {}).value || ""
          };
        } else {
          var courseRow = getSelectedCourseRow();
          var courseOpt = coursePeriodSel.options[coursePeriodSel.selectedIndex];
          payload.selections.course = {
            course_id: courseProgramSel.value,
            course_name: (courseRow && courseRow.course_name) || (courseOpt && courseOpt.dataset.course_name) || "",
            cohort_id: coursePeriodSel.value,
            cohort_label: (courseRow && courseRow.cohort_label) || (courseOpt && courseOpt.dataset.cohort_label) || "",
            payment_choice: (applyForm.querySelector("input[name='course_payment_choice']:checked") || {}).value || ""
          };
        }
      }

      if(getAccomNeed() === "yes"){
        payload.selections.accommodation.months = (accomMonthsValue.value || "").split(",").map(function(x){ return x.trim(); }).filter(Boolean);
        payload.selections.accommodation.payment_choice = (applyForm.querySelector("input[name='accom_payment_choice']:checked") || {}).value || "";
      }

      try{
        submitBtn.classList.add("is-disabled");
        submitBtn.textContent = "{{ t.js_sending }}";
        var res = await postJSON(payload);

        if(res && res.ok){
          // Show success card, hide form
          var appId = res.application_id || "YB-XXXX";
          successId.textContent = appId;
          successBody.textContent = "{{ t.js_success_body }}";
          applyForm.style.display = "none";
          validationBox.classList.remove("is-visible");
          show(successCard, true);
          successCard.scrollIntoView({ behavior: "smooth", block: "center" });

          // If logged-in user's role was upgraded by the backend, refresh permissions
          if(res.role_upgraded && window.ybReloadUserRole){
            window.ybReloadUserRole();
          }

          // Also set the text msg for screen readers
          setMsg(applyMsg, "{{ t.js_success_msg_prefix }}" + appId + ".", "ok");

          applyForm.reset();
          show(yttBlock, false);
          show(courseBlock, false);
          builderGrid.classList.remove("is-double");

          yttPeriodSel.innerHTML = '<option value="">Vælg program først...</option>';
          yttPeriodSel.disabled = true;
          show(yttTrackField, false);
          yttTrackSel.innerHTML = '<option value="">Vælg...</option>';
          yttTrackSel.value = "";

          coursePeriodSel.innerHTML = '<option value="">Vælg kursus først...</option>';
          coursePeriodSel.disabled = true;

          resetBundleUI();

          show(yttPayBox, false);
          show(coursePayBox, false);
          show(accomPayBox, false);
          show(accomInner, false);
          show(hearOtherField, false);

          accomMonthsWrap.innerHTML = "";
          accomMonthsValue.value = "";

          applyForYTT.checked = false;
          applyForCourse.checked = false;
          applyForMentorship.checked = false;
          userTriedSubmit = false;

        } else {
          setMsg(applyMsg, (res && res.message) || "{{ t.js_submit_error }}", "err");
        }
      } catch(err){
        setMsg(applyMsg, "Kunne ikke sende lige nu. Prøv igen — eller skriv til info@yogabible.dk.", "err");
      } finally {
        submitBtn.textContent = "Send ansøgning";
        updateBuilderUI();
        updateHearAboutUI();
        updateAccomUI();
        updateSubmitState();
      }
    });

    // "Ansøg igen" button — reset and show form
    var applyAgainBtn = $("#ybApplyAgain");
    if(applyAgainBtn){
      applyAgainBtn.addEventListener("click", function(){
        show(successCard, false);
        applyForm.style.display = "";
        applyForm.reset();

        show(yttBlock, false);
        show(courseBlock, false);
        builderGrid.classList.remove("is-double");

        yttPeriodSel.innerHTML = '<option value="">Vælg program først...</option>';
        yttPeriodSel.disabled = true;
        show(yttTrackField, false);
        yttTrackSel.innerHTML = '<option value="">Vælg...</option>';
        yttTrackSel.value = "";

        coursePeriodSel.innerHTML = '<option value="">Vælg kursus først...</option>';
        coursePeriodSel.disabled = true;

        resetBundleUI();

        show(yttPayBox, false);
        show(coursePayBox, false);
        show(accomPayBox, false);
        show(accomInner, false);
        show(hearOtherField, false);

        accomMonthsWrap.innerHTML = "";
        accomMonthsValue.value = "";

        applyForYTT.checked = false;
        applyForCourse.checked = false;
        applyForMentorship.checked = false;
        userTriedSubmit = false;

        validationBox.classList.remove("is-visible");
        setMsg(applyMsg, "", "");

        updateBuilderUI();
        updateHearAboutUI();
        updateAccomUI();
        updateSubmitState();

        // Scroll to form
        document.getElementById("yb-apply-form").scrollIntoView({ behavior: "smooth", block: "start" });
      });
    }

    // Init
    loadCatalog();
    updateBuilderUI();
    updateHearAboutUI();
    updateAccomUI();
    updateSubmitState();
  });
})();
</script>
