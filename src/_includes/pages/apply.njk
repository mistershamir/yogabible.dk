      }
    };

    // ===== DOM =====
    const applyForYTT       = $("#ybApplyYTT");
    const applyForCourse    = $("#ybApplyCourse");
    const applyForMentorship= $("#ybApplyMentorship");
    const builderHint       = $("#ybBuilderHint");
    const builderGrid       = $("#ybBuilderGrid");

    const yttBlock   = $("#ybYttBlock");
    const courseBlock= $("#ybCourseBlock");

    const yttProgramSel = $("#ybYttProgram");
    const yttPeriodSel  = $("#ybYttPeriod");
    const yttPeriodHint = $("#ybYttPeriodHint");
    const yttTrackField = $("#ybYttTrackField");
    const yttTrackSel   = $("#ybYttTrack");
    const yttTrackHint  = $("#ybYttTrackHint");

    const courseProgramSel = $("#ybCourseProgram");
    const coursePeriodSel  = $("#ybCoursePeriod");
    const coursePeriodHint = $("#ybCoursePeriodHint");

    const courseBundleField= $("#ybCourseBundleField");
    const courseBundleType = $("#ybCourseBundleType");
    const courseBundleHint = $("#ybCourseBundleHint");

    const accomMonthsWrap  = $("#ybAccomMonths");
    const accomMonthsValue = $("#ybAccomMonthsValue");
    const accomHint        = $("#ybAccomHint");
    const accomInner       = $("#ybAccomInner");
    const accomPayBox      = $("#ybAccomPayBox");
    const accomPaidConfirm = $("#ybAccomPaidConfirm");

    const yttPayBox        = $("#ybYttPayBox");
    const yttPayLink       = $("#ybYttPayLink");
    const yttPaidConfirm   = $("#ybYttPaidConfirm");

    const coursePayBox     = $("#ybCoursePayBox");
    const coursePayLink    = $("#ybCoursePayLink");
    const coursePaidConfirm= $("#ybCoursePaidConfirm");

    const firstName = $("#ybFirstName");
    const lastName  = $("#ybLastName");
    const email     = $("#ybEmail");
    const phone     = $("#ybPhone");

    const hearAbout     = $("#ybHearAbout");
    const hearOtherField= $("#ybHearOtherField");
    const hearOther     = $("#ybHearOther");

    const antiSpam = $("#ybAntiSpam");
    const consent  = $("#ybConsent");

    const applyForm = $("#ybApplyForm");
    const applyMsg  = $("#ybApplyMsg");
    const submitBtn = $("#ybApplySubmit");
    const validationBox  = $("#ybValidationBox");
    const validationList = $("#ybValidationList");
    const submitHint     = $("#ybSubmitHint");
    const successCard    = $("#ybSuccessCard");
    const successBody    = $("#ybSuccessBody");
    const successId      = $("#ybSuccessId");
    var userTriedSubmit = false;
    var formIsValid = false;

    // ===== Helpers =====
    let catalog = [];
    let byCourse = new Map();

    window.ybCatalog = { catalog: [], byCourse: new Map(), helpers: {} };

    function setMsg(el, text, type){
      if(!el) return;
      el.textContent = text || "";
      el.classList.remove("is-ok","is-err");
      if(type) el.classList.add(type === "ok" ? "is-ok" : "is-err");
    }

    function setHintMailto(el, text){
      if(!el) return;
      el.innerHTML = text + ' <a href="mailto:info@yogabible.dk">info@yogabible.dk</a>.';
    }

    function show(el, on){
      if(!el) return;
      el.classList.toggle("is-hidden", !on);
      el.setAttribute("aria-hidden", on ? "false" : "true");
    }

    function normalize(s){ return String(s||"").trim(); }
    function lower(s){ return normalize(s).toLowerCase(); }
    function catNorm(c){ return String(c||"").trim().toLowerCase(); }

    function isEducationRow(r){
      var c = catNorm(r.category);
      if(["education","ytt","teacher training","teachertraining","teacher-training"].includes(c)) return true;
      var name = catNorm(r.course_name);
      return name.includes("ytt") || name.includes("læreruddannelse") || name.includes("teacher training");
    }

    function isBundleRow(r){
      var c = catNorm(r.category);
      if(c === "bundle") return true;
      var name = catNorm(r.course_name);
      return name.includes("bundle");
    }

    function isCourseRow(r){
      if(isBundleRow(r)) return false;
      var c = catNorm(r.category);
      if(["course","kursus","workshop","courses"].includes(c)) return true;
      var name = catNorm(r.course_name);
      return name.includes("kursus") || name.includes("workshop") || name.includes("inversions course") || name.includes("splits course") || name.includes("backbends course");
    }

    function looksNotOpenYet(openStatus){
      var t = String(openStatus || "").toLowerCase();
      return (
        t.includes("ikke åben") ||
        t.includes("not open") ||
        t.includes("coming soon") ||
        t.includes("åbner snart") ||
        (t.includes("snart") && t.includes("åbn")) ||
        (t.includes("soon") && t.includes("open"))
      );
    }

    async function getJSON(url){
      var res = await fetch(url, { method: "GET", redirect: "follow" });
      var txt = await res.text();
      try { return JSON.parse(txt); }
      catch(e){ throw new Error("Bad JSON from web app"); }
    }

    async function postJSON(payload){
      var res = await fetch(WEB_APP_URL, {
        method: "POST",
        redirect: "follow",
        headers: { "Content-Type": "text/plain;charset=utf-8" },
        body: JSON.stringify(payload)
      });
      var txt = await res.text();
      try { return JSON.parse(txt); }
      catch(e){ throw new Error("Bad JSON from web app"); }
    }

    function looksLikeRawDateLabel(label){
      var t = lower(label);
      if(!t) return false;
      if(t.includes("gmt")) return true;
      if(/central(europe|europ)/i.test(t)) return true;
      if(/\b(mon|tue|wed|thu|fri|sat|sun)\b/i.test(t)) return true;
      return false;
    }

    var MONTH_ALIASES = {
      jan:0, januar:0, january:0,
      feb:1, februar:1, february:1,
      mar:2, marts:2, march:2,
      apr:3, april:3,
      maj:4, may:4,
      jun:5, juni:5, june:5,
      jul:6, juli:6, july:6,
      aug:7, august:7,
      sep:8, sept:8, september:8,
      okt:9, oct:9, oktober:9, october:9,
      nov:10, november:10,
      dec:11, dek:11, december:11
    };

    function parseMonthYear(text){
      var raw = String(text || "").trim();
      if(!raw) return null;
      var t = raw.replace(/[–—-]/g, " ").replace(/[,/]/g, " ").replace(/\s+/g, " ").trim();
      var year = null;
      var y4 = t.match(/\b(20\d{2})\b/);
      if(y4) year = Number(y4[1]);
      if(!year){
        var y2 = t.match(/\b(\d{2})\b/);
        if(y2){
          var yy = Number(y2[1]);
          if(!isNaN(yy)) year = 2000 + yy;
        }
      }
      var tokens = t.toLowerCase().split(" ").map(function(w){ return w.replace(/[^a-zæøå]/g, ""); }).filter(Boolean);
      var month = null;
      for(var i = 0; i < tokens.length; i++){
        if(MONTH_ALIASES.hasOwnProperty(tokens[i])){
          month = MONTH_ALIASES[tokens[i]];
          break;
        }
      }
      if(month === null) return null;
      return { month: month, year: year };
    }

    function sortKeyForRow(row){
      var label = row.cohort_label || row.cohort_id || "";
      var pm = parseMonthYear(label);
      var labelTime = (pm && pm.year) ? new Date(pm.year, pm.month, 1).getTime() : null;
      var sk = (row.sort_key || "").trim();
      var d = sk ? new Date(sk) : null;
      var sortTime = (d && !isNaN(d.getTime())) ? d.getTime() : null;
      if(sortTime && labelTime){
        var diffDays = Math.abs(sortTime - labelTime) / (1000*60*60*24);
        if(diffDays > 200) return labelTime;
        return sortTime;
      }
      if(sortTime) return sortTime;
      if(labelTime) return labelTime;
      return Number.MAX_SAFE_INTEGER;
    }

    function buildMaps(){
      byCourse = new Map();
      (catalog || []).forEach(function(r){
        if(!r.course_id) return;
        if(!byCourse.has(r.course_id)) byCourse.set(r.course_id, []);
        byCourse.get(r.course_id).push(r);
      });
      byCourse.forEach(function(list){ list.sort(function(a,b){ return sortKeyForRow(a) - sortKeyForRow(b); }); });
      window.ybCatalog.catalog = catalog;
      window.ybCatalog.byCourse = byCourse;
      window.ybCatalog.helpers = {
        isEducationRow: isEducationRow,
        isCourseRow: isCourseRow,
        isBundleRow: isBundleRow,
        looksLikeRawDateLabel: looksLikeRawDateLabel,
        looksNotOpenYet: looksNotOpenYet,
        sortKeyForRow: sortKeyForRow,
        groupCohorts: groupCohorts,
        formatPeriodLabel: formatPeriodLabel,
        isCourseRowAllowed: isCourseRowAllowed
      };
    }

    function paymentMetaForRow(row){
      var allowDeposit = String(row.allow_deposit || "").toLowerCase() === "true";
      var dep = row.payment_url_deposit || "";
      var full = row.payment_url_full || "";
      if(isEducationRow(row)){
        if(allowDeposit && dep) return { url: dep, label: "{{ t.js_pay_deposit_ytt }}", kind: "deposit" };
        return { url: full || dep || "", label: "{{ t.js_pay_full_ytt }}", kind: "full" };
      }
      return { url: full || dep || "", label: "{{ t.js_pay_full_course }}", kind: "full" };
    }

    function formatPeriodLabel(row){
      return row.cohort_label || row.cohort_id || "{{ t.js_period_default }}";
    }

    function groupCohorts(list){
      var map = new Map();
      list.forEach(function(r){
        var key = String(r.cohort_id || r.cohort_label || "");
        if(!key) return;
        if(!map.has(key)) map.set(key, []);
        map.get(key).push(r);
      });
      return map;
    }

    function fillProgramSelect(sel, kind){
      sel.innerHTML = '<option value="">Vælg...</option>';
      var seen = new Map();
      (catalog || []).forEach(function(r){
        if(!r.course_id) return;
        var ok = (kind === "education") ? isEducationRow(r) : isCourseRow(r);
        if(!ok) return;
        if(seen.has(r.course_id)) return;
        seen.set(r.course_id, r.course_name || r.course_id);
      });
      Array.from(seen.entries())
        .sort(function(a,b){ return String(a[1]).localeCompare(String(b[1]), "da"); })
        .forEach(function(entry){
          var opt = document.createElement("option");
          opt.value = entry[0];
          opt.textContent = entry[1];
          sel.appendChild(opt);
        });
      if(kind === "course"){
        var bundleOpt = document.createElement("option");
        bundleOpt.value = BUNDLE_PROGRAM_ID;
        bundleOpt.textContent = "{{ t.js_bundle_option }}";
        sel.insertBefore(bundleOpt, sel.options[1] || null);
      }
    }

    function isBundleSelected(){
      return courseProgramSel.value === BUNDLE_PROGRAM_ID;
    }

    // ===== YTT specific =====
    function is200Hr4WeekIntensive(courseId){
      var list = byCourse.get(courseId) || [];
      var name = (list[0] && list[0].course_name || "").toLowerCase();
      return /200/.test(name) && /(4\s*[- ]?(ugers|uger|weeks|week))/.test(name) && /(intensiv|intensive)/.test(name);
    }

    function yttPeriodAllowed(courseId, rep){
      var label = lower(rep.cohort_label || rep.cohort_id || "");
      if(!label) return false;
      if(looksLikeRawDateLabel(label)) return false;
      if(is200Hr4WeekIntensive(courseId)){
        if(!/2026/.test(label)) return false;
        return /(februar|feb)\s*2026|(marts|mar|march)\s*2026|(april|apr)\s*2026/i.test(label);
      }
      return true;
    }

    function setYttPeriods(courseId){
      yttPeriodSel.innerHTML = '<option value="">Vælg...</option>';
      yttPeriodHint.textContent = "";
      yttPeriodSel.disabled = true;
      show(yttTrackField, false);
      yttTrackSel.innerHTML = '<option value="">Vælg...</option>';
      yttTrackSel.value = "";
      yttTrackHint.textContent = "";
      if(!courseId){
        yttPeriodSel.innerHTML = '<option value="">Vælg program først...</option>';
        return;
      }
      var list = (byCourse.get(courseId) || []).filter(isEducationRow);
      if(!list.length){
        yttPeriodSel.innerHTML = '<option value="">{{ t.js_no_periods }}</option>';
        return;
      }
      var groups = groupCohorts(list);
      var reps = Array.from(groups.entries()).map(function(entry){ return { key: entry[0], rep: entry[1][0] }; });
      reps.sort(function(a,b){
        var ka = sortKeyForRow(a.rep);
        var kb = sortKeyForRow(b.rep);
        if(ka !== kb) return ka - kb;
        return String(a.rep.cohort_label||a.rep.cohort_id||"").localeCompare(String(b.rep.cohort_label||b.rep.cohort_id||""), "da");
      });
      reps.forEach(function(item){
        if(!yttPeriodAllowed(courseId, item.rep)) return;
        var opt = document.createElement("option");
        opt.value = item.key;
        opt.textContent = formatPeriodLabel(item.rep);
        var meta = paymentMetaForRow(item.rep);
        opt.dataset.course_id = item.rep.course_id || "";
        opt.dataset.course_name = item.rep.course_name || "";
        opt.dataset.cohort_label = item.rep.cohort_label || "";
        opt.dataset.open_status = item.rep.open_status || "";
        opt.dataset.notes = item.rep.notes || "";
        opt.dataset.pay_url = meta.url || "";
        opt.dataset.pay_label = meta.label || "Betal";
        opt.dataset.pay_kind = meta.kind || "full";
        yttPeriodSel.appendChild(opt);
      });
      yttPeriodSel.disabled = (yttPeriodSel.options.length <= 1);
      if(yttPeriodSel.disabled){
        yttPeriodSel.innerHTML = '<option value="">Ingen perioder lige nu...</option>';
      }
    }

    function is18WeeksProgram(courseId){
      var list = byCourse.get(courseId) || [];
      var name = (list[0] && list[0].course_name || "").toLowerCase();
      return /18\s*(weeks|week|ugers|uger)/i.test(name);
    }

    function getYttRowsForSelection(){
