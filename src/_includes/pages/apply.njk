{% set t = i18n.apply[lang or "da"] %}


<!-- FAQPage Schema (AEO — featured snippets for AI search) -->
<script type="application/ld+json">
{%- set _faqs = [
      [t.faq1_q, t.faq1_a],
      [t.faq2_q, t.faq2_a],
      [t.faq3_q, t.faq3_a],
      [t.faq4_q, t.faq4_a],
      [t.faq5_q, t.faq5_a],
      [t.faq6_q, t.faq6_a]
    ] -%}
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in _faqs %}
    {
      "@type": "Question",
      "name": {{ faq[0] | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq[1] | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

<!-- Hero -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_sub }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="#yb-apply-form" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

<!-- =========================================================
  YogaBible.dk — Apply Page: PART 1 — Intro Section
========================================================= -->
<section id="yb-apply-intro" class="yb-apply-intro" lang="da">
  <div class="yb-apply-intro__wrap yb-font">

    <!-- Page head -->
    <header class="yb-apply-intro__head">
      <p class="yb-apply-intro__eyebrow">{{ t.intro_eyebrow }}</p>
      <h2 class="yb-apply-intro__title">{{ t.intro_title }}</h2>
    </header>

    <!-- Hero (text + image) -->
    <div class="yb-apply-intro__hero">
      <div class="yb-apply-intro__heroCard">
        <div class="yb-apply-intro__heroText">
          <p class="yb-apply-intro__kicker">{{ t.intro_kicker }}</p>

          <p class="yb-apply-intro__heroCopy">{{ t.intro_copy }}</p>

          <ul class="yb-apply-intro__bullets" aria-label="{{ t.intro_bullets_label }}">
            <li>{{ t.intro_bullet1 }}</li>
            <li>{{ t.intro_bullet2 }}</li>
            <li>{{ t.intro_bullet3 }}</li>
          </ul>
        </div>

        <!-- Image frame -->
        <figure class="yb-apply-intro__heroMedia" style="--yb-hero-img:url('https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/mentorship/beth-02.jpg')" aria-label="Yoga Bible">
          <img
            src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/mentorship/beth-02.jpg"
            alt="{{ t.intro_img_alt }}"
            loading="eager"
            decoding="async"
          />
        </figure>
      </div>
    </div>

    <!-- Instruction -->
    <p class="yb-apply-intro__note">{{ t.intro_note | safe }}</p>

  </div>
</section>

<!-- =========================================================
  YogaBible.dk — Apply Page: PART 2 — Application Form
========================================================= -->
<section id="yb-apply-form" class="yb-apply-form" lang="da" aria-label="{{ t.form_title }}">
  <div class="yb-apply-form__wrap yb-font">

    <!-- Form card -->
    <div class="yb-card yb-card--form">
      <header class="yb-card__head">
        <h2 class="yb-card__title">{{ t.form_section_label }}</h2>
        <p class="yb-card__sub">{{ t.form_sub }}</p>
      </header>

      <form id="ybApplyForm" class="yb-form" novalidate>

        <!-- Builder choose -->
        <fieldset class="yb-fieldset">
          <legend class="yb-legend">{{ t.builder_legend }}</legend>

          <label class="yb-check yb-check--builder">
            <input id="ybApplyYTT" type="checkbox" />
            <span>{{ t.ytt_title }}</span>
          </label>

          <label class="yb-check yb-check--builder">
            <input id="ybApplyCourse" type="checkbox" />
            <span>{{ t.course_section_label }}</span>
          </label>

          <label class="yb-check yb-check--builder">
            <input id="ybApplyMentorship" type="checkbox" />
            <span>{{ t.builder_mentorship }}</span>
          </label>

          <div id="ybBuilderHint" class="yb-hint" aria-live="polite"></div>
        </fieldset>

        <!-- BUILDER GRID (YTT + Course blocks) -->
        <div class="yb-builderGrid" id="ybBuilderGrid" aria-label="{{ t.builder_grid_label }}">

          <!-- YTT block -->
          <section id="ybYttBlock" class="yb-subCard is-hidden" aria-label="{{ t.ytt_section_label }}">
            <div class="yb-subHead">
              <div>
                <div class="yb-subTitle">Yoga læreruddannelse (YTT)</div>
                <div class="yb-subSub">{{ t.ytt_sub }}</div>
              </div>
            </div>

            <label class="yb-field">
              <span class="yb-label">{{ t.ytt_program_label }}</span>
              <select id="ybYttProgram" required>
                <option value="">{{ t.select_default }}</option>
              </select>
            </label>

            <label class="yb-field">
              <span class="yb-label">{{ t.ytt_period_label }}</span>
              <select id="ybYttPeriod" required disabled>
                <option value="">{{ t.select_program_first }}</option>
              </select>
              <div id="ybYttPeriodHint" class="yb-hint" aria-live="polite"></div>
            </label>

            <!-- Track under period -->
            <label id="ybYttTrackField" class="yb-field is-hidden">
              <span class="yb-label">{{ t.ytt_track_label }}</span>
              <select id="ybYttTrack">
                <option value="">Vælg...</option>
              </select>
              <div id="ybYttTrackHint" class="yb-hint" aria-live="polite"></div>
            </label>

            <fieldset class="yb-fieldset">
              <legend class="yb-legend">{{ t.ytt_payment_legend }}</legend>

              <div class="yb-radioGroup" role="radiogroup" aria-label="{{ t.ytt_payment_group_label }}">
                <label class="yb-radio">
                  <input type="radio" name="ytt_payment_choice" value="paid_deposit" />
                  <span>{{ t.ytt_paid_deposit_radio }}</span>
                </label>

                <label class="yb-radio">
                  <input type="radio" name="ytt_payment_choice" value="paid_full" />
                  <span>{{ t.ytt_paid_full_radio }}</span>
                </label>

                <label class="yb-radio">
                  <input type="radio" name="ytt_payment_choice" value="pay_now" />
                  <span>{{ t.ytt_paynow_radio }}</span>
                </label>
              </div>

              <div class="yb-payBox is-hidden" id="ybYttPayBox" aria-hidden="true">
                <div class="yb-alert">{{ t.ytt_pay_alert | safe }}</div>

                <div class="yb-payRow">
                  <a id="ybYttPayLink" class="yb-payBtn" href="#" target="_blank" rel="noopener">
                    <span class="yb-payBtn__txt">{{ t.ytt_pay_btn }}</span>
                    <span class="yb-payBtn__icon" aria-hidden="true">&#8599;</span>
                  </a>
                  <span class="yb-payMeta">{{ t.ytt_pay_meta }}</span>
                </div>

                <label class="yb-check yb-check--pay">
                  <input id="ybYttPaidConfirm" type="checkbox" />
                  <span>{{ t.ytt_paid_confirm }}</span>
                </label>
              </div>
            </fieldset>
          </section>

          <!-- Course block -->
          <section id="ybCourseBlock" class="yb-subCard is-hidden" aria-label="{{ t.course_title }}">
            <div class="yb-subHead">
              <div>
                <div class="yb-subTitle">Kursus</div>
                <div class="yb-subSub">{{ t.course_sub }}</div>
              </div>
            </div>

            <label class="yb-field">
              <span class="yb-label">{{ t.course_label }}</span>
              <select id="ybCourseProgram" required>
                <option value="">Vælg...</option>
              </select>
            </label>

            <label class="yb-field">
              <span class="yb-label">{{ t.course_period_label }}</span>
              <select id="ybCoursePeriod" required disabled>
                <option value="">{{ t.select_course_first }}</option>
              </select>
              <div id="ybCoursePeriodHint" class="yb-hint" aria-live="polite"></div>
            </label>

            <!-- Bundle type (shows only when program = Kursuspakke) -->
            <label id="ybCourseBundleField" class="yb-field is-hidden">
              <span class="yb-label">{{ t.course_bundle_label }}</span>
              <select id="ybCourseBundleType" required disabled>
                <option value="">Vælg...</option>
                <option value="{{ t.bundle_opt_inv_back }}">Inversions + Backbends</option>
                <option value="{{ t.bundle_opt_inv_splits }}">Inversions + Splits</option>
                <option value="{{ t.bundle_opt_back_splits }}">Backbends + Splits</option>
                <option value="{{ t.bundle_opt_allin }}">All-in (Inversions + Backbends + Splits)</option>
              </select>
              <div id="ybCourseBundleHint" class="yb-hint" aria-live="polite"></div>
            </label>

            <fieldset class="yb-fieldset">
              <legend class="yb-legend">{{ t.course_payment_legend }}</legend>

              <div class="yb-radioGroup" role="radiogroup" aria-label="{{ t.course_payment_group_label }}">
                <label class="yb-radio">
                  <input type="radio" name="course_payment_choice" value="paid" />
                  <span>{{ t.course_paid_radio }}</span>
                </label>

                <label class="yb-radio">
                  <input type="radio" name="course_payment_choice" value="pay_now" />
                  <span>{{ t.course_paynow_radio }}</span>
                </label>
              </div>

              <div class="yb-payBox is-hidden" id="ybCoursePayBox" aria-hidden="true">
                <div class="yb-alert">{{ t.course_pay_alert | safe }}</div>

                <div class="yb-payRow">
                  <a id="ybCoursePayLink" class="yb-payBtn" href="#" target="_blank" rel="noopener">
                    <span class="yb-payBtn__txt">{{ t.course_pay_btn }}</span>
                    <span class="yb-payBtn__icon" aria-hidden="true">&#8599;</span>
                  </a>
                  <span class="yb-payMeta">{{ t.course_pay_meta }}</span>
                </div>

                <label class="yb-check yb-check--pay">
                  <input id="ybCoursePaidConfirm" type="checkbox" />
                  <span>{{ t.course_paid_confirm }}</span>
                </label>
              </div>
            </fieldset>
          </section>

          <!-- Accommodation block (full width) -->
          <section id="ybAccomBlock" class="yb-subCard yb-subCard--wide" aria-label="{{ t.accom_section_label }}">
            <div class="yb-subHead">
              <div>
                <div class="yb-subTitle">{{ t.accom_title }}</div>
                <div class="yb-subSub">{{ t.accom_sub }}</div>
              </div>
            </div>

            <fieldset class="yb-fieldset">
              <legend class="yb-legend">{{ t.accom_legend }}</legend>

              <div class="yb-radioGroup" role="radiogroup" aria-label="{{ t.accom_group_label }}">
                <label class="yb-radio">
                  <input type="radio" name="accom_need" value="no" checked />
                  <span>{{ t.accom_no }}</span>
                </label>
                <label class="yb-radio">
                  <input type="radio" name="accom_need" value="yes" />
                  <span>{{ t.accom_yes }}</span>
                </label>
              </div>

              <div id="ybAccomInner" class="is-hidden" aria-hidden="true">
                <div id="ybAccomHint" class="yb-hint" style="margin-top:2px;">
                  {{ t.accom_months_hint }}
                </div>

                <div class="yb-months" id="ybAccomMonths" aria-label="{{ t.accom_months_label }}"></div>
                <input id="ybAccomMonthsValue" type="hidden" />

                <fieldset class="yb-fieldset" style="margin-top:10px;">
                  <legend class="yb-legend">{{ t.accom_payment_legend }}</legend>

                  <div class="yb-radioGroup" role="radiogroup" aria-label="{{ t.accom_payment_group_label }}">
                    <label class="yb-radio">
                      <input type="radio" name="accom_payment_choice" value="paid" />
                      <span>{{ t.accom_paid_radio }}</span>
                    </label>

                    <label class="yb-radio">
                      <input type="radio" name="accom_payment_choice" value="pay_now" />
                      <span>{{ t.accom_paynow_radio }}</span>
                    </label>
                  </div>

                  <div class="yb-payBox is-hidden" id="ybAccomPayBox" aria-hidden="true">
                    <div class="yb-alert">
                      {{ t.accom_pay_alert | safe }}
                    </div>

                    <div class="yb-payRow">
                      <a id="ybAccomPayLink" class="yb-payBtn" href="/accommodation" target="_blank" rel="noopener">
                        <span class="yb-payBtn__txt">{{ t.accom_pay_btn }}</span>
                        <span class="yb-payBtn__icon" aria-hidden="true">&#8599;</span>
                      </a>
                      <span class="yb-payMeta">{{ t.accom_pay_meta }}</span>
                    </div>

                    <label class="yb-check yb-check--pay">
                      <input id="ybAccomPaidConfirm" type="checkbox" />
                      <span>{{ t.accom_paid_confirm }}</span>
                    </label>
                  </div>
                </fieldset>
              </div>
            </fieldset>
          </section>

        </div><!-- /builder grid -->

        <!-- User info -->
        <label class="yb-field">
          <span class="yb-label">{{ t.field_firstname }}</span>
          <input id="ybFirstName" name="first_name" type="text" autocomplete="given-name" required />
        </label>

        <label class="yb-field">
          <span class="yb-label">{{ t.field_lastname }}</span>
          <input id="ybLastName" name="last_name" type="text" autocomplete="family-name" required />
        </label>

        <label class="yb-field">
          <span class="yb-label">{{ t.field_email }}</span>
          <input id="ybEmail" name="email" type="email" autocomplete="email" required />
        </label>

        <label class="yb-field">
          <span class="yb-label">{{ t.field_phone }}</span>
          <input id="ybPhone" name="phone" type="tel" autocomplete="tel" required />
        </label>

        <!-- How did you hear about us -->
        <label class="yb-field">
          <span class="yb-label">{{ t.field_hearabout }}</span>
          <select id="ybHearAbout" required>
            <option value="">Vælg...</option>
            <option value="{{ t.hearabout_google }}">Google</option>
            <option value="Social Media">{{ t.hearabout_social }}</option>
            <option value="A Friend">{{ t.hearabout_friend }}</option>
            <option value="Hot Yoga Copenhagen member">{{ t.hearabout_hyc }}</option>
            <option value="AI ChatBots (fx ChatGPT)">{{ t.hearabout_ai }}</option>
            <option value="Not sure yet">{{ t.hearabout_notsure }}</option>
            <option value="Other">{{ t.hearabout_other }}</option>
          </select>
        </label>

        <label id="ybHearOtherField" class="yb-field is-hidden">
          <span class="yb-label">{{ t.hearother_label }}</span>
          <input id="ybHearOther" type="text" placeholder="{{ t.hearother_placeholder }}" />
        </label>

        <label class="yb-field">
          <span class="yb-label">{{ t.antispam_label }}</span>
          <input id="ybAntiSpam" name="anti_spam" type="text" placeholder="{{ t.antispam_placeholder }}" required />
          <span class="yb-hint">{{ t.antispam_hint }}</span>
        </label>

        <label class="yb-check">
          <input id="ybConsent" type="checkbox" required />
          <span>{{ t.consent_text }}</span>
        </label>

        <!-- Validation checklist (shown when form incomplete) -->
        <div id="ybValidationBox" class="yb-validation" aria-live="polite">
          <div class="yb-validation__head">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span>{{ t.validation_head }}</span>
          </div>
          <ul id="ybValidationList" class="yb-validation__list"></ul>
        </div>

        <div class="yb-submitWrap" id="ybSubmitWrap">
          <button id="ybApplySubmit" class="yb-btn yb-btn--primary" type="submit">
            {{ t.submit_btn }}
          </button>
          <p class="yb-submitHint" id="ybSubmitHint">{{ t.submit_hint }}</p>
        </div>

        <p id="ybApplyMsg" class="yb-msg" aria-live="polite"></p>
      </form>

      <!-- Success card (replaces form on success) -->
      <div id="ybSuccessCard" class="yb-successCard is-hidden" role="status" aria-live="polite">
        <div class="yb-successCard__icon">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#166534" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        </div>
        <h3 class="yb-successCard__title">{{ t.success_title }}</h3>
        <p class="yb-successCard__body" id="ybSuccessBody">{{ t.success_body }}</p>
        <div class="yb-successCard__meta">
          <span>{{ t.success_id_label }}</span>
          <strong id="ybSuccessId">-</strong>
        </div>
        <div class="yb-successCard__next">
          <p><strong>{{ t.success_next_title }}</strong></p>
          <ol>
            <li>{{ t.success_step1 }}</li>
            <li>{{ t.success_step2 }}</li>
            <li>{{ t.success_step3 }}</li>
          </ol>
        </div>
        <button id="ybApplyAgain" class="yb-btn yb-btn--outline" type="button">{{ t.success_again }}</button>
        <p class="yb-successCard__contact">{{ t.success_contact }} <a href="mailto:info@yogabible.dk">info@yogabible.dk</a></p>
      </div>
    </div>

  </div>
</section>

<!-- =========================================================
  PART 3 — Process Timeline
========================================================= -->
<section id="yb-apply-process" class="yb-apply-process" lang="da">
  <div class="yb-apply-process__wrap">
    <h2 class="yb-apply-process__title">{{ t.process_title }}</h2>
    <p class="yb-apply-process__sub">{{ t.process_sub }}</p>

    <div class="yb-apply-process__steps">
      <div class="yb-apply-process__step">
        <div class="yb-apply-process__num">1</div>
        <h3>{{ t.process_step1_title }}</h3>
        <p>{{ t.process_step1_text }}</p>
      </div>
      <div class="yb-apply-process__step">
        <div class="yb-apply-process__num">2</div>
        <h3>Betaling</h3>
        <p>{{ t.process_step2_text }}</p>
      </div>
      <div class="yb-apply-process__step">
        <div class="yb-apply-process__num">3</div>
        <h3>{{ t.process_step3_title }}</h3>
        <p>{{ t.process_step3_text }}</p>
      </div>
      <div class="yb-apply-process__step">
        <div class="yb-apply-process__num">4</div>
        <h3>{{ t.process_step4_title }}</h3>
        <p>{{ t.process_step4_text }}</p>
      </div>
    </div>
  </div>
</section>

<!-- =========================================================
  PART 4 — FAQ
========================================================= -->
<section id="yb-apply-faq" class="yb-apply-faq" lang="da">
  <div class="yb-apply-faq__wrap">
    <h2 class="yb-apply-faq__title">{{ t.faq_title }}</h2>

    <div class="yb-apply-faq__list">
      <details class="yb-apply-faq__item">
        <summary>{{ t.faq1_q }}</summary>
        <p>{{ t.faq1_a }}</p>
      </details>

      <details class="yb-apply-faq__item">
        <summary>{{ t.faq2_q }}</summary>
        <p>{{ t.faq2_a }}</p>
      </details>

      <details class="yb-apply-faq__item">
        <summary>{{ t.faq3_q }}</summary>
        <p>{{ t.faq3_a }}</p>
      </details>

      <details class="yb-apply-faq__item">
        <summary>{{ t.faq4_q }}</summary>
        <p>{{ t.faq4_a | safe }}</p>
      </details>

      <details class="yb-apply-faq__item">
        <summary>{{ t.faq5_q }}</summary>
        <p>{{ t.faq5_a }}</p>
      </details>

      <details class="yb-apply-faq__item">
        <summary>{{ t.faq6_q }}</summary>
        <p>{{ t.faq6_a }}</p>
      </details>
    </div>
  </div>
</section>

<!-- =========================================================
  PART 5 — Contact / Trust
========================================================= -->
<section id="yb-apply-contact" class="yb-apply-contact" lang="da">
  <div class="yb-apply-contact__wrap">
    <div class="yb-apply-contact__card">
      <h2 class="yb-apply-contact__title">{{ t.contact_title }}</h2>
      <p class="yb-apply-contact__body">{{ t.contact_body }}</p>
      <div class="yb-apply-contact__links">
        <a href="mailto:info@yogabible.dk" class="yb-apply-contact__link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          info@yogabible.dk
        </a>
        <a href="tel:+4550155915" class="yb-apply-contact__link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          +45 50 15 59 15
        </a>
      </div>
    </div>

    <div class="yb-apply-contact__trust">
      <div class="yb-apply-contact__trustItem">
        <strong>{{ t.trust_ya_title }}</strong>
        <span>{{ t.trust_ya_sub }}</span>
      </div>
      <div class="yb-apply-contact__trustItem">
        <strong>{{ t.trust_loc_title }}</strong>
        <span>{{ t.trust_loc_sub }}</span>
      </div>
      <div class="yb-apply-contact__trustItem">
        <strong>{{ t.trust_since_title }}</strong>
        <span>{{ t.trust_since_sub }}</span>
      </div>
    </div>
  </div>
</section>


<!-- =========================================================
  STYLES: Hero + Intro + Form
========================================================= -->
