    // ===== Course specific =====
    function isCourseRowAllowed(row){
      var label = lower(row.cohort_label || row.cohort_id || "");
      var name  = lower(row.course_name || "");
      if(!label) return false;
      if(looksLikeRawDateLabel(label)) return false;
      if(!/2026/.test(label)) return false;
      var allowedMonthPatterns = [/feb/i, /mar/i, /apr/i, /maj|may/i, /jun/i];
      var hasAllowedMonth = allowedMonthPatterns.some(function(p){ return p.test(label); });
      if(!hasAllowedMonth) return false;
      var is4 = /(^|[^0-9])4\s*[- ]?(ugers|uger|weeks|week)\b/i.test(name) || /4\s*[- ]?ugers/i.test(label) || /4\s*weeks/i.test(label);
      if(is4) return /(feb|mar|apr)/i.test(label);
      var is8 = /(^|[^0-9])8\s*[- ]?(ugers|uger|weeks|week)\b/i.test(name) || /8\s*[- ]?ugers/i.test(label) || /8\s*weeks/i.test(label);
      if(is8) return /(maj|may|jun)/i.test(label);
      return true;
    }

