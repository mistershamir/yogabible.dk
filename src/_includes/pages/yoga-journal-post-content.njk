{% set lp = "/en" if lang == "en" else "" %}

<!-- JSON-LD: BlogPosting -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": "{{ journal.title_da }}",
  "alternativeHeadline": "{{ journal.title_en }}",
  "description": "{{ journal.excerpt_da }}",
  "image": "{% if journal.image.startsWith('http') %}{{ journal.image }}{% else %}{{ site.url }}{{ journal.image }}{% endif %}",
  "url": "{{ site.url }}/yoga-journal/{{ journal.slug }}/",
  "datePublished": "{{ journal.date }}",
  "dateModified": "{{ journal.date }}",
  "author": {
    "@type": "Organization",
    "name": "{{ journal.author }}",
    "url": "{{ site.url }}"
  },
  "publisher": {
    "@type": "EducationalOrganization",
    "name": "Yoga Bible",
    "url": "{{ site.url }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.url }}/assets/images/og/og-1200x630.png"
    }
  },
  "inLanguage": ["da", "en"],
  "isPartOf": {
    "@type": "Blog",
    "name": "Yoga Journal",
    "url": "{{ site.url }}/yoga-journal/"
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.url }}/yoga-journal/{{ journal.slug }}/"
  },
  "keywords": "{{ journal.tags | join(', ') }}"
}
</script>

<!-- Breadcrumb JSON-LD -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Yoga Bible", "item": "{{ site.url }}{{ lp }}/" },
    { "@type": "ListItem", "position": 2, "name": "Yoga Journal", "item": "{{ site.url }}{{ lp }}/yoga-journal/" },
    { "@type": "ListItem", "position": 3, "name": "{{ journal.title_da }}", "item": "{{ site.url }}{{ lp }}/yoga-journal/{{ journal.slug }}/" }
  ]
}
</script>

<!-- Reading Progress Bar -->
<div class="yj-progress" id="yjProgress" aria-hidden="true">
  <div class="yj-progress__bar" id="yjProgressBar"></div>
</div>

<!-- Full-width Hero Image -->
<div class="yj-post-hero-img" style="background-image:url('{{ journal.image }}')">
  <div class="yj-post-hero-img__overlay"></div>
  <div class="yj-post-hero-img__content">
    <div class="container">
      <nav class="yj-breadcrumb yj-breadcrumb--hero" aria-label="Breadcrumb">
        <ol class="yj-breadcrumb__list">
          <li><a href="{{ lp }}/">Yoga Bible</a></li>
          <li><a href="{{ lp }}/yoga-journal/">Yoga Journal</a></li>
          <li aria-current="page">
            <span data-yj-da>{{ journal.title_da }}</span>
            <span data-yj-en hidden>{{ journal.title_en }}</span>
          </li>
        </ol>
      </nav>

      <div class="yj-post-hero__meta yj-post-hero__meta--hero">
        <span class="yj-post-hero__category">{{ journal.category }}</span>
        <span class="yj-post-hero__dot">&middot;</span>
        <time datetime="{{ journal.date }}">{{ journal.date }}</time>
        <span class="yj-post-hero__dot">&middot;</span>
        <span data-yj-da>{{ journal.readTime_da }} læsetid</span>
        <span data-yj-en hidden>{{ journal.readTime_en }} read</span>
      </div>

      <h1 class="yj-post-hero__title yj-post-hero__title--hero">
        <span data-yj-da>{{ journal.title_da }}</span>
        <span data-yj-en hidden>{{ journal.title_en }}</span>
      </h1>

      <p class="yj-post-hero__excerpt yj-post-hero__excerpt--hero">
        <span data-yj-da>{{ journal.excerpt_da }}</span>
        <span data-yj-en hidden>{{ journal.excerpt_en }}</span>
      </p>
    </div>
  </div>
</div>

<!-- Article Toolbar -->
<div class="yj-toolbar">
  <div class="container">
    <div class="yj-toolbar__inner">
      <div class="yj-toolbar__author">
        <div class="yj-toolbar__avatar">YB</div>
        <div class="yj-toolbar__author-info">
          <span class="yj-toolbar__author-name">{{ journal.author }}</span>
          <time class="yj-toolbar__author-date" datetime="{{ journal.date }}">{{ journal.date }}</time>
        </div>
      </div>

      <div class="yj-toolbar__share">
        <span class="yj-toolbar__share-label" data-yj-da>Del:</span>
        <span class="yj-toolbar__share-label" data-yj-en hidden>Share:</span>
        <button class="yj-share-btn" data-yj-share="copy" type="button" aria-label="Copy link" title="Copy link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6.5 9.5L9.5 6.5M7 4L7.5 3.5a3.18 3.18 0 014.5 4.5L11.5 8.5M9 12l-.5.5a3.18 3.18 0 01-4.5-4.5L4.5 7.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <a class="yj-share-btn" href="https://twitter.com/intent/tweet?url={{ site.url }}{{ lp }}/yoga-journal/{{ journal.slug }}/&text={{ journal.title_en }}" target="_blank" rel="noopener" aria-label="Share on X">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </a>
        <a class="yj-share-btn" href="https://www.facebook.com/sharer/sharer.php?u={{ site.url }}{{ lp }}/yoga-journal/{{ journal.slug }}/" target="_blank" rel="noopener" aria-label="Share on Facebook">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
      </div>
    </div>
  </div>
</div>

<!-- Article Content -->
<article class="yj-post-content" {% if journal.gated %}data-yb-gated-post="true"{% endif %}>
  <div class="container">
    <div class="yj-post-content__inner">
      <div class="yj-post-body yj-post-body--dropcap" data-yj-da>
        {{ journal.content_da | renderContent | safe }}
      </div>
      <div class="yj-post-body yj-post-body--dropcap" data-yj-en hidden>
        {{ journal.content_en | renderContent | safe }}
      </div>
    </div>

    {% if journal.gated %}
    <!-- Gate Wall (shown to non-members) -->
    <div id="yb-gate-wall" class="yb-gate-wall" hidden>
      <div class="yb-gate-wall__inner">
        <div class="yb-gate-wall__icon">&#128274;</div>

        <!-- For logged-out users -->
        <div class="yb-gate-login">
          <h3 class="yb-gate-wall__title" data-yj-da>Log ind for at læse denne artikel</h3>
          <h3 class="yb-gate-wall__title" data-yj-en hidden>Sign in to read this article</h3>
          <p class="yb-gate-wall__text" data-yj-da>Denne artikel er kun tilgængelig for Yoga Bible medlemmer. Log ind eller opret en gratis konto.</p>
          <p class="yb-gate-wall__text" data-yj-en hidden>This article is available to Yoga Bible members only. Sign in or create a free account.</p>
          <div class="yb-gate-wall__actions">
            <button class="yb-btn yb-btn--primary" type="button" data-yb-auth-open="login" data-yj-da>Log ind</button>
            <button class="yb-btn yb-btn--primary" type="button" data-yb-auth-open="login" data-yj-en hidden>Sign in</button>
            <button class="yb-btn yb-btn--outline" type="button" data-yb-auth-open="register" data-yj-da>Opret konto</button>
            <button class="yb-btn yb-btn--outline" type="button" data-yb-auth-open="register" data-yj-en hidden>Create account</button>
          </div>
        </div>

        <!-- For logged-in free users -->
        <div class="yb-gate-upgrade" hidden>
          <h3 class="yb-gate-wall__title" data-yj-da>Bliv medlem for at læse denne artikel</h3>
          <h3 class="yb-gate-wall__title" data-yj-en hidden>Become a member to read this article</h3>
          <p class="yb-gate-wall__text" data-yj-da>Denne artikel kræver et aktivt Yoga Bible medlemskab. Opgrader din konto for at få adgang.</p>
          <p class="yb-gate-wall__text" data-yj-en hidden>This article requires an active Yoga Bible membership. Upgrade your account to get access.</p>
          <div class="yb-gate-wall__actions">
            <a class="yb-btn yb-btn--primary" href="{{ lp }}/apply" data-yj-da>Se medlemskaber</a>
            <a class="yb-btn yb-btn--primary" href="{{ lp }}/apply" data-yj-en hidden>View memberships</a>
          </div>
        </div>
      </div>
    </div>
    {% endif %}
  </div>
</article>

<!-- Tags -->
<section class="yj-post-tags">
  <div class="container">
    <div class="yj-post-tags__inner">
      <span class="yj-post-tags__label" data-yj-da>Tags:</span>
      <span class="yj-post-tags__label" data-yj-en hidden>Tags:</span>
      <div class="yj-post-tags__list">
        {%- for tag in journal.tags %}
        <span class="yj-card__tag">{{ tag }}</span>
        {%- endfor %}
      </div>
    </div>
  </div>
</section>

<!-- Author Card -->
<section class="yj-author-card">
  <div class="container">
    <div class="yj-author-card__inner">
      <div class="yj-author-card__avatar">YB</div>
      <div class="yj-author-card__info">
        <h3 class="yj-author-card__name">{{ journal.author }}</h3>
        <p class="yj-author-card__bio" data-yj-da>
          Yoga Bible er en professionel yogaskole i København. Siden 2014 har vi uddannet 500+ yogalærere med Yoga Alliance certificering.
        </p>
        <p class="yj-author-card__bio" data-yj-en hidden>
          Yoga Bible is a professional yoga school in Copenhagen. Since 2014, we've trained 500+ yoga teachers with Yoga Alliance certification.
        </p>
        <a href="{{ lp }}/yoga-bible-historie" class="yj-author-card__link">
          <span data-yj-da>Læs vores historie &rarr;</span>
          <span data-yj-en hidden>Read our story &rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>

<!-- Related Journals -->
<section class="yj-related">
  <div class="container">
    <h2 class="yj-related__title">
      <span data-yj-da>Relaterede Artikler</span>
      <span data-yj-en hidden>Related Articles</span>
    </h2>
    <div class="yj-related__grid" id="yjRelated">
      {%- set currentSlug = journal.slug %}
      {%- set currentTags = journal.tags %}
      {%- set relatedCount = 0 %}
      {%- for other in journals.entries | sort(true, false, 'date') %}
        {%- if other.slug != currentSlug and relatedCount < 3 %}
          {%- set hasMatch = false %}
          {%- for tag in other.tags %}
            {%- if tag in currentTags %}
              {%- set hasMatch = true %}
            {%- endif %}
          {%- endfor %}
          {%- if hasMatch %}
            {%- set relatedCount = relatedCount + 1 %}
            <article class="yj-card yj-card--related">
              <a href="{{ lp }}/yoga-journal/{{ other.slug }}/" class="yj-card__link">
                <div class="yj-card__img-wrap yj-card__img-wrap--sm">
                  <div class="yj-card__img" style="background-image:url('{{ other.image }}')"></div>
                </div>
                <div class="yj-card__body">
                  <div class="yj-card__meta">
                    <time datetime="{{ other.date }}">{{ other.date }}</time>
                    <span class="yj-card__dot">&middot;</span>
                    <span data-yj-da>{{ other.readTime_da }} læsetid</span>
                    <span data-yj-en hidden>{{ other.readTime_en }} read</span>
                  </div>
                  <h3 class="yj-card__title yj-card__title--sm">
                    <span data-yj-da>{{ other.title_da }}</span>
                    <span data-yj-en hidden>{{ other.title_en }}</span>
                  </h3>
                  <span class="yj-card__read-more">
                    <span data-yj-da>Læs mere &rarr;</span>
                    <span data-yj-en hidden>Read more &rarr;</span>
                  </span>
                </div>
              </a>
            </article>
          {%- endif %}
        {%- endif %}
      {%- endfor %}
    </div>
  </div>
</section>

<!-- Back to Journal -->
<section class="yj-back">
  <div class="container">
    <a href="{{ lp }}/yoga-journal/" class="yj-back__link">
      <span data-yj-da>&larr; Tilbage til Yoga Journal</span>
      <span data-yj-en hidden>&larr; Back to Yoga Journal</span>
    </a>
  </div>
</section>

<!-- CTA -->
<section class="yj-post-cta">
  <div class="container">
    <div class="yj-post-cta__inner">
      <h2 class="yj-post-cta__title" data-yj-da>Klar til at gå dybere?</h2>
      <h2 class="yj-post-cta__title" data-yj-en hidden>Ready to go deeper?</h2>
      <p class="yj-post-cta__text" data-yj-da>Alt hvad du læser her, underviser vi i dybden i vores yogalæreruddannelser.</p>
      <p class="yj-post-cta__text" data-yj-en hidden>Everything you read here, we teach in depth in our yoga teacher trainings.</p>
      <div class="yj-post-cta__buttons">
        <a href="{{ lp }}/om-200hrs-yogalreruddannelser" class="yb-btn yb-btn--white" data-yj-da>Se Uddannelser</a>
        <a href="{{ lp }}/om-200hrs-yogalreruddannelser" class="yb-btn yb-btn--white" data-yj-en hidden>View Programs</a>
        <a href="{{ lp }}/apply" class="yb-btn yb-btn--outline-white" data-yj-da>Ansøg Nu</a>
        <a href="{{ lp }}/apply" class="yb-btn yb-btn--outline-white" data-yj-en hidden>Apply Now</a>
      </div>
    </div>
  </div>
</section>

<script src="/js/journal.js"></script>
