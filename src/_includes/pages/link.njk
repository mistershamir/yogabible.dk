{% set t = i18n.link[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

<section class="yb-link">

  {# ── Hero Media (auto-detects image or video) ── #}
  <div class="yb-link__media">
    <video
      class="yb-link__video"
      src="/assets/images/link/hero.mp4"
      autoplay loop muted playsinline
      poster="/assets/images/link/hero.jpg"
    ></video>
    <div class="yb-link__media-overlay"></div>
  </div>

  <div class="yb-link__container">

    {# ── Brand Identity ── #}
    <div class="yb-link__hero yb-link__fade">
      <img
        src="/assets/images/brand/logo-orange-on-transparent.png"
        alt="Yoga Bible"
        class="yb-link__logo"
        width="200"
        height="49"
      />
      <p class="yb-link__social-proof">{{ t.social_proof }}</p>
    </div>

    {# ── Language Toggle ── #}
    <div class="yb-link__lang yb-link__fade">
      <a href="/link/" class="yb-link__lang-btn {% if lang != 'en' %}yb-link__lang-btn--active{% endif %}">DA</a>
      <a href="/en/link/" class="yb-link__lang-btn {% if lang == 'en' %}yb-link__lang-btn--active{% endif %}">EN</a>
    </div>

    {# ── CTA: Apply Now ── #}
    <a href="{{ lp }}/apply" class="yb-link__cta yb-link__fade" data-yb-link="apply-cta">
      {{ t.training_apply }}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>

    {# ── Teacher Trainings ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_trainings }}</p>

      <a href="{{ lp }}/200-hours-4-weeks-intensive-programs" class="yb-link__item yb-link__item--training" data-yb-link="training-4w">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.training_4w }}</span>
          <span class="yb-link__item-sub">{{ t.training_4w_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/200-hours-8-weeks-semi-intensive-programs" class="yb-link__item yb-link__item--training" data-yb-link="training-8w">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.training_8w }}</span>
          <span class="yb-link__item-sub">{{ t.training_8w_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/200-hours-18-weeks-flexible-programs" class="yb-link__item yb-link__item--training" data-yb-link="training-18w">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.training_18w }}</span>
          <span class="yb-link__item-sub">{{ t.training_18w_sub }}</span>
        </span>
        <span class="yb-link__badge">POPULÆR</span>
      </a>

      <a href="{{ lp }}/300-hours-advanced-teacher-training" class="yb-link__item yb-link__item--training" data-yb-link="training-300hr">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.training_300 }}</span>
          <span class="yb-link__item-sub">{{ t.training_300_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/sammenlign-yogalreruddannelser" class="yb-link__item yb-link__item--subtle" data-yb-link="compare-trainings">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.training_compare }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>

    {# ── Courses (3-col grid) ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_courses }}</p>
      <div class="yb-link__course-grid">
        <a href="{{ lp }}/inversions" class="yb-link__course-card" data-yb-link="course-inversions">
          <span class="yb-link__course-name">{{ t.course_inversions }}</span>
        </a>
        <a href="{{ lp }}/backbends" class="yb-link__course-card" data-yb-link="course-backbends">
          <span class="yb-link__course-name">{{ t.course_backbends }}</span>
        </a>
        <a href="{{ lp }}/splits" class="yb-link__course-card" data-yb-link="course-splits">
          <span class="yb-link__course-name">{{ t.course_splits }}</span>
        </a>
      </div>
      <a href="{{ lp }}/course-bundles" class="yb-link__item yb-link__item--subtle" data-yb-link="course-bundles">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.course_bundles }}</span>
          <span class="yb-link__item-sub">{{ t.course_bundles_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>

    {# ── Mentorship ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_mentorship }}</p>
      <a href="{{ lp }}/mentorship-private-training" class="yb-link__item" data-yb-link="mentorship">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.mentorship_title }}</span>
          <span class="yb-link__item-sub">{{ t.mentorship_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>

    {# ── Book Appointment ── #}
    <div class="yb-link__section yb-link__fade" id="booking">
      <p class="yb-link__section-label">{{ t.section_booking }}</p>
      <button class="yb-link__item yb-link__item--booking" data-open-booking="info-session" data-yb-link="booking-studio">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.booking_studio }}</span>
          <span class="yb-link__item-sub">{{ t.booking_studio_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
      <button class="yb-link__item yb-link__item--booking" data-open-booking="consultation" data-yb-link="booking-consultation">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.booking_consultation }}</span>
          <span class="yb-link__item-sub">{{ t.booking_consultation_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
      <button class="yb-link__item yb-link__item--booking" data-open-booking="intro-class" data-yb-link="booking-trial">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.booking_trial }}</span>
          <span class="yb-link__item-sub">{{ t.booking_trial_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>

    {# ── SoundCloud Embed ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_listen }}</p>
      <div class="yb-link__embed">
        <iframe
          width="100%"
          height="166"
          scrolling="no"
          frameborder="no"
          allow="autoplay"
          src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/yogabible&color=%23f75c03&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false"
          loading="lazy"
          title="{{ t.listen_label }}"
        ></iframe>
      </div>
    </div>

    {# ── Explore (2-col grid) ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_explore }}</p>
      <div class="yb-link__explore-grid">
        <a href="{{ lp }}/yoga-journal" class="yb-link__explore-item" data-yb-link="explore-journal">{{ t.explore_journal }}</a>
        <a href="{{ lp }}/weekly-schedule" class="yb-link__explore-item" data-yb-link="explore-schedule">{{ t.explore_schedule }}</a>
        <a href="{{ lp }}/yogaphotography" class="yb-link__explore-item" data-yb-link="explore-photography">{{ t.explore_photo }}</a>
        <a href="{{ lp }}/yogamusic" class="yb-link__explore-item" data-yb-link="explore-music">{{ t.explore_music }}</a>
        <a href="{{ lp }}/yoga-glossary" class="yb-link__explore-item" data-yb-link="explore-glossary">{{ t.explore_glossary }}</a>
        <a href="{{ lp }}/yoga-bible-historie" class="yb-link__explore-item" data-yb-link="explore-about">{{ t.explore_about }}</a>
      </div>
    </div>

    {# ── App Downloads ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_apps }}</p>
      <div class="yb-link__app-grid">
        <a href="{{ site.appStore }}" target="_blank" rel="noopener noreferrer" class="yb-link__app" data-yb-link="app-ios">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#FDFBF7"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span>{{ t.connect_app_ios }}</span>
        </a>
        <a href="{{ site.googlePlay }}" target="_blank" rel="noopener noreferrer" class="yb-link__app" data-yb-link="app-android">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="#FDFBF7"><path d="M3.18 23.73c-.41-.2-.68-.61-.68-1.08V1.35c0-.47.27-.88.68-1.08l11.09 11.73L3.18 23.73zM16.23 14l-2.6-2.74L16.23 8.5l3.63 2.08c.59.34.59.91 0 1.24L16.23 14zm-3.7-2.74L4.68.47l12.1 6.92-4.25 3.87zm0 1.48l4.25 3.87-12.1 6.92 7.85-10.79z"/></svg>
          <span>{{ t.connect_app_android }}</span>
        </a>
      </div>
    </div>

    {# ── Contact (WhatsApp + Email) ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_connect }}</p>
      <div class="yb-link__contact-row">
        <a href="https://wa.me/4553881209" target="_blank" rel="noopener noreferrer" class="yb-link__contact" data-yb-link="contact-whatsapp">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.138.558 4.143 1.534 5.886L.05 23.308l5.567-1.46A11.95 11.95 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.82c-2.04 0-3.93-.613-5.508-1.665l-.395-.235-3.301.866.882-3.22-.258-.41A9.78 9.78 0 0 1 2.18 12c0-5.422 4.398-9.82 9.82-9.82 5.422 0 9.82 4.398 9.82 9.82 0 5.422-4.398 9.82-9.82 9.82z"/></svg>
          {{ t.connect_whatsapp }}
        </a>
        <a href="mailto:{{ site.email }}" class="yb-link__contact" data-yb-link="contact-email">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          {{ t.connect_email }}
        </a>
      </div>
    </div>

    {# ── Share Button ── #}
    <div class="yb-link__fade">
      <button class="yb-link__share" id="yb-link-share" data-label="{{ t.share_button }}" data-copied="{{ t.share_copied }}">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        <span>{{ t.share_button }}</span>
      </button>
    </div>

    {# ── Tagline ── #}
    <p class="yb-link__tagline yb-link__fade">{{ t.footer_tagline }}</p>

  </div>
</section>

<script src="/js/link.js"></script>
