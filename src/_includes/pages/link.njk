{% set t = i18n.link[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

<section class="yb-link">
  <div class="yb-link__container">

    {# ── Hero / Brand Identity ── #}
    <div class="yb-link__hero yb-link__fade">
      <img
        src="/assets/images/brand/logo-orange-on-transparent.png"
        alt="Yoga Bible"
        class="yb-link__logo"
        width="200"
        height="49"
      />
      <p class="yb-link__subtitle">{{ t.subtitle }}</p>
      <p class="yb-link__intro">{{ t.intro }}</p>
      <p class="yb-link__location">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        {{ t.location }}
      </p>
    </div>

    {# ── Language Toggle (top, for international visitors) ── #}
    <div class="yb-link__lang yb-link__fade">
      <a href="/link/" class="yb-link__lang-btn {% if lang != 'en' %}yb-link__lang-btn--active{% endif %}">DA</a>
      <a href="/en/link/" class="yb-link__lang-btn {% if lang == 'en' %}yb-link__lang-btn--active{% endif %}">EN</a>
    </div>

    {# ── CTA: Apply Now ── #}
    <a href="{{ lp }}/apply" class="yb-link__cta yb-link__fade" data-yb-link="apply-cta">
      {{ t.training_apply }}
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
    </a>

    {# ── Teacher Trainings ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_trainings }}</p>

      <a href="{{ lp }}/200-hours-4-weeks-intensive-programs" class="yb-link__item yb-link__item--training" data-yb-link="training-4w">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.training_4w }}</span>
          <span class="yb-link__item-sub">{{ t.training_4w_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/200-hours-8-weeks-semi-intensive-programs" class="yb-link__item yb-link__item--training" data-yb-link="training-8w">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.training_8w }}</span>
          <span class="yb-link__item-sub">{{ t.training_8w_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/200-hours-18-weeks-flexible-programs" class="yb-link__item yb-link__item--training" data-yb-link="training-18w">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.training_18w }}</span>
          <span class="yb-link__item-sub">{{ t.training_18w_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/300-hours-advanced-teacher-training" class="yb-link__item yb-link__item--training" data-yb-link="training-300hr">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.training_300 }}</span>
          <span class="yb-link__item-sub">{{ t.training_300_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/sammenlign-yogalreruddannelser" class="yb-link__item yb-link__item--subtle" data-yb-link="compare-trainings">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.training_compare }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>

    {# ── Courses ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_courses }}</p>

      <a href="{{ lp }}/inversions" class="yb-link__item" data-yb-link="course-inversions">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.course_inversions }}</span>
          <span class="yb-link__item-sub">{{ t.course_inversions_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/backbends" class="yb-link__item" data-yb-link="course-backbends">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.course_backbends }}</span>
          <span class="yb-link__item-sub">{{ t.course_backbends_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/splits" class="yb-link__item" data-yb-link="course-splits">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.course_splits }}</span>
          <span class="yb-link__item-sub">{{ t.course_splits_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/course-bundles" class="yb-link__item yb-link__item--subtle" data-yb-link="course-bundles">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.course_bundles }}</span>
          <span class="yb-link__item-sub">{{ t.course_bundles_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>

    {# ── Mentorship ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_mentorship }}</p>

      <a href="{{ lp }}/mentorship-private-training" class="yb-link__item" data-yb-link="mentorship">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.mentorship_title }}</span>
          <span class="yb-link__item-sub">{{ t.mentorship_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>

    {# ── SoundCloud Embed ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_listen }}</p>
      <div class="yb-link__embed">
        <iframe
          width="100%"
          height="166"
          scrolling="no"
          frameborder="no"
          allow="autoplay"
          src="https://w.soundcloud.com/player/?url=https%3A//soundcloud.com/yogabible&color=%23f75c03&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false"
          loading="lazy"
          title="{{ t.listen_label }}"
        ></iframe>
      </div>
    </div>

    {# ── Explore ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_explore }}</p>

      <a href="{{ lp }}/yoga-journal" class="yb-link__item yb-link__item--compact" data-yb-link="explore-journal">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.explore_journal }}</span>
          <span class="yb-link__item-sub">{{ t.explore_journal_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/weekly-schedule" class="yb-link__item yb-link__item--compact" data-yb-link="explore-schedule">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.explore_schedule }}</span>
          <span class="yb-link__item-sub">{{ t.explore_schedule_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/yogaphotography" class="yb-link__item yb-link__item--compact" data-yb-link="explore-photography">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.explore_photo }}</span>
          <span class="yb-link__item-sub">{{ t.explore_photo_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/yogamusic" class="yb-link__item yb-link__item--compact" data-yb-link="explore-music">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.explore_music }}</span>
          <span class="yb-link__item-sub">{{ t.explore_music_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/yoga-glossary" class="yb-link__item yb-link__item--compact" data-yb-link="explore-glossary">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.explore_glossary }}</span>
          <span class="yb-link__item-sub">{{ t.explore_glossary_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>

      <a href="{{ lp }}/yoga-bible-historie" class="yb-link__item yb-link__item--compact" data-yb-link="explore-about">
        <span class="yb-link__item-text">
          <span class="yb-link__item-title">{{ t.explore_about }}</span>
          <span class="yb-link__item-sub">{{ t.explore_about_sub }}</span>
        </span>
        <svg class="yb-link__arrow" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    </div>

    {# ── Social & Apps ── #}
    <div class="yb-link__section yb-link__fade">
      <p class="yb-link__section-label">{{ t.section_connect }}</p>

      <div class="yb-link__social-grid">
        <a href="{{ site.instagram }}" target="_blank" rel="noopener noreferrer" class="yb-link__social" data-yb-link="social-instagram" aria-label="{{ t.connect_instagram }}">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
          <span>{{ t.connect_instagram }}</span>
        </a>

        <a href="{{ site.soundcloud }}" target="_blank" rel="noopener noreferrer" class="yb-link__social" data-yb-link="social-soundcloud" aria-label="{{ t.connect_soundcloud }}">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M1 18V13h1v5H1zm2.5-7v7h1v-7h-1zM6 9v9h1V9H6zm2.5-1v10h1V8h-1zM11 6v12h1V6h-1zm2.5 2v10h1V8h-1zM16 5v13h1V5h-1zm2.5 3v10h1V8h-1zM21 10v8h1v-8h-1z"/></svg>
          <span>{{ t.connect_soundcloud }}</span>
        </a>

        <a href="{{ site.appStore }}" target="_blank" rel="noopener noreferrer" class="yb-link__social" data-yb-link="app-ios" aria-label="{{ t.connect_app_ios }}">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
          <span>{{ t.connect_app_ios }}</span>
        </a>

        <a href="{{ site.googlePlay }}" target="_blank" rel="noopener noreferrer" class="yb-link__social" data-yb-link="app-android" aria-label="{{ t.connect_app_android }}">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M3.18 23.73c-.41-.2-.68-.61-.68-1.08V1.35c0-.47.27-.88.68-1.08l11.09 11.73L3.18 23.73zM16.23 14l-2.6-2.74L16.23 8.5l3.63 2.08c.59.34.59.91 0 1.24L16.23 14zm-3.7-2.74L4.68.47l12.1 6.92-4.25 3.87zm0 1.48l4.25 3.87-12.1 6.92 7.85-10.79z"/></svg>
          <span>{{ t.connect_app_android }}</span>
        </a>
      </div>

      <div class="yb-link__contact-row">
        <a href="mailto:{{ site.email }}" class="yb-link__contact" data-yb-link="contact-email">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          {{ t.connect_email }}
        </a>
        <a href="tel:+4553881209" class="yb-link__contact" data-yb-link="contact-phone">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          {{ t.connect_phone }}
        </a>
      </div>
    </div>

    {# ── Share Button ── #}
    <div class="yb-link__fade">
      <button class="yb-link__share" id="yb-link-share" data-label="{{ t.share_button }}" data-copied="{{ t.share_copied }}">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
        <span>{{ t.share_button }}</span>
      </button>
    </div>

    {# ── Tagline ── #}
    <p class="yb-link__tagline yb-link__fade">{{ t.footer_tagline }}</p>

  </div>
</section>

<script src="/js/link.js"></script>
