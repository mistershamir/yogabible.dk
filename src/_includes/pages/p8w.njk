{% set t = i18n.p8w[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}


<!-- FAQPage Schema (AEO — featured snippets for AI search) -->
<script type="application/ld+json">
{%- set _faqs = [
      [t.faq1_q, t.faq1_a],
      [t.faq2_q, t.faq2_a],
      [t.faq3_q, t.faq3_a],
      [t.faq4_q, t.faq4_a],
      [t.faq5_q, t.faq5_a],
      [t.faq6_q, t.faq6_a],
      [t.faq7_q, t.faq7_a],
      [t.faq8_q, t.faq8_a],
      [t.faq9_q, t.faq9_a]
    ] -%}
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in _faqs %}
    {
      "@type": "Question",
      "name": {{ faq[0] | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq[1] | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

<!-- ═══════════════════════════════════════
     1. HERO — Primary Cinematic with Breathing Glow
     ═══════════════════════════════════════ -->
<section class="yb-hero">
  <div class="yb-hero__bg">
    <video autoplay muted loop playsinline preload="metadata">
      <source src="https://res.cloudinary.com/ddcynsa30/video/upload/q_auto/v1773250613/8_weeks_hero_compressed_zy0yup.mp4" type="video/mp4">
    </video>
  </div>
  <div class="yb-hero__glow"></div>

  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_eyebrow }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title | safe }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <p class="p8w-hero__styles">{{ t.hero_styles }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="?product=100209" class="yb-btn yb-btn--primary yb-btn--large" data-checkout-product="100209">{{ t.hero_cta_prep }}</a>
      <button onclick="openYBScheduleModal('8w')" class="yb-btn yb-btn--outline-white yb-btn--large">{{ t.hero_cta_schedule }}</button>
    </div>
    <p class="yb-hero__read-more">
      <a href="{{ lp }}/om-200hrs-yogalreruddannelser" class="yb-hero__read-more-link">{{ t.hero_cta_more }}</a>
    </p>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>

  <div class="yb-hero__scroll">
    <span>{{ t.hero_scroll }}</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     2. TRAINEE INTERVIEW — Social Proof First
     ═══════════════════════════════════════ -->
<section class="p18-video-interview">
  <div class="container">
    <span class="p18-eyebrow">{{ t.video_eyebrow }}</span>
    <h2 class="p18-section-title">{{ t.video_title }}</h2>
    <p class="p18-section-sub">{{ t.video_subtitle }}</p>

    <div class="p18-video-interview__wrap">
      <video controls playsinline preload="metadata" style="width:100%;height:100%;border-radius:12px;background:#0F0F0F;"
        poster="{{ "yoga-bible-DK/programs/p18w/yogalaereruddannelse-elev-erfaring-koebenhavn.jpg" | cloudvid("w_1280,c_fill,so_2,q_60") }}">
        <source src="{{ "yoga-bible-DK/programs/p18w/yogalaereruddannelse-elev-erfaring-koebenhavn" | cloudvid("w_1280,q_auto") }}" type="video/mp4">
      </video>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     3. CERTIFICATION — Yoga Alliance RYT-200
     ═══════════════════════════════════════ -->
<section class="p18-certification">
  <div class="container">
    <span class="p18-eyebrow">{{ t.cert_eyebrow }}</span>
    <h2 class="p18-section-title">{{ t.cert_title }}</h2>
    <p class="p18-section-sub">{{ t.cert_subtitle }}</p>

    <div class="p18-cert-grid">

      <!-- Left: Yoga styles you master -->
      <div>
        <h3 class="p18-cert-subtitle">{% if lang == "en" %}Yoga styles you'll master{% else %}Yogastile du mestrer{% endif %}</h3>
        <div class="p18-cert-style-cards">
          {% for i in [1, 2, 3, 4, 5] %}
          <div class="p18-cert-style">
            <div class="p18-cert-style__icon">{{ t["cert_style" + i + "_icon"] }}</div>
            <div class="p18-cert-style__text">
              <h4>{{ t["cert_style" + i + "_title"] }}</h4>
              <p>{{ t["cert_style" + i + "_desc"] }}</p>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>

      <!-- Right: What it opens for you -->
      <div>
        <h3 class="p18-cert-subtitle">{% if lang == "en" %}Career & opportunities{% else %}Karriere & muligheder{% endif %}</h3>
        <ul class="p18-cert-list">
          {% for i in [1, 2, 3, 4, 5] %}
          <li>
            <span class="p18-cert-check" aria-hidden="true">&#x2713;</span>
            <span><strong>{{ t["cert_career" + i + "_bold"] }}</strong> — {{ t["cert_career" + i + "_text"] }}</span>
          </li>
          {% endfor %}
        </ul>
      </div>

    </div>

    <p class="p18-cert-closing">{{ t.cert_closing }}</p>

    <div class="p18-cert-cta">
      <a href="{{ lp }}/om-200hrs-yogalreruddannelser" target="_blank" rel="noopener" class="btn btn--primary btn--large">{{ t.cert_cta_text }}</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     4. CERTIFICATION VALUE — Why RYT-200 Matters
     ═══════════════════════════════════════ -->
<section class="p4w-certval">
  <div class="container">
    <span class="p18-eyebrow">{{ t.certval_eyebrow }}</span>
    <h2 class="p18-section-title">{{ t.certval_title }}</h2>
    <p class="p18-section-sub">{{ t.certval_intro }}</p>

    <div class="p4w-certval__grid">

      <!-- Left: Content with Feature Card -->
      <div class="p4w-certval__content">

        <!-- What You Learn Card -->
        <div class="p4w-certval__card">
          <div class="p4w-certval__card-header">
            <h3 class="p4w-certval__card-title">{{ t.certval_learn_title }}</h3>
          </div>
          <ul class="p4w-certval__list">
            {% for i in [1, 2, 3, 4, 5] %}
            <li>
              <svg class="p4w-certval__check-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{{ t["certval_learn" + i] }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>

        <!-- Additional sections -->
        <div class="p4w-certval__section">
          <h3 class="p4w-certval__heading">{{ t.certval_upgrade_title }}</h3>
          <p class="p4w-certval__text">{{ t.certval_upgrade_text | safe }}</p>
        </div>

        <div class="p4w-certval__section">
          <h3 class="p4w-certval__heading">{{ t.certval_exam_title }}</h3>
          <p class="p4w-certval__text">{{ t.certval_exam_text }}</p>
        </div>

      </div>

      <!-- Right: Certificate image (featured) -->
      <div class="p4w-certval__media">
        <div class="p4w-certval__image-container">
          <div class="p4w-certval__image-wrapper">
            {# CLOUDINARY: Sample_Certificate_jzjtfx — optimized for display #}
            <img
              src="https://res.cloudinary.com/ddcynsa30/image/upload/w_800,q_auto,f_auto/v1771966816/Sample_Certificate_jzjtfx.png"
              alt="{{ t.certval_image_alt }}"
              loading="lazy"
            >
          </div>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     5. WHY COPENHAGEN — Comparison Table + Approach
     ═══════════════════════════════════════ -->
<section class="p18-compare" id="why-copenhagen">
  <div class="container">
    <span class="p18-eyebrow">{{ t.compare_eyebrow }}</span>
    <h2 class="p18-section-title">{{ t.compare_title }}</h2>
    <p class="p18-section-sub">{{ t.compare_subtitle }}</p>

    <!-- Comparison table -->
    <div class="p18-compare__table">
      <div class="p18-compare__header">
        <div></div>
        <div class="p18-compare__col--cph">{{ t.compare_col_cph }}</div>
        <div>{{ t.compare_col_bali }}</div>
        <div>{{ t.compare_col_india }}</div>
      </div>

      {% for i in [1, 2, 3, 4, 5, 6, 7, 8] %}
      <div class="p18-compare__row">
        <div>{{ t["compare_r" + i + "_label"] }}</div>
        <div>{{ t["compare_r" + i + "_cph"] }}</div>
        <div>{{ t["compare_r" + i + "_bali"] }}</div>
        <div>{{ t["compare_r" + i + "_india"] }}</div>
      </div>
      {% endfor %}
    </div>

    <!-- Approach cards -->
    <h3 class="p18-compare__approach-title">{{ t.compare_approach_title }}</h3>
    <div class="p18-compare__cards">
      {% for i in [1, 2, 3, 4, 5, 6, 7, 8] %}
      <div class="p18-compare__card">
        <div class="p18-compare__card-icon">{{ t["approach" + i + "_icon"] }}</div>
        <h4>{{ t["approach" + i + "_title"] }}</h4>
        <p>{{ t["approach" + i + "_desc"] }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     6. COPENHAGEN SHOWCASE — Training Environment & City
     ═══════════════════════════════════════ -->
<section class="p18-cph">
  <div class="container">
    <span class="p18-eyebrow">{{ t.cph_eyebrow }}</span>
    <h2 class="p18-section-title">{{ t.cph_title }}</h2>
    <p class="p18-section-sub">{{ t.cph_subtitle }}</p>

    <!-- Image slider -->
    <div class="p18-cph__slider">
      <div class="p18-cph__viewport">
        <div class="p18-cph__track" id="cph-track">
          <figure class="p18-cph__slide">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/studio/studio-torvegade.jpg" alt="Yoga Bible {% if lang == 'en' %}studio in Christianshavn{% else %}studie i Christianshavn{% endif %}" loading="lazy">
          </figure>
          <figure class="p18-cph__slide">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/copenhagen/christianshavn-location.jpg" alt="Christianshavn {% if lang == 'en' %}canal with colourful houses{% else %}kanal med farverige huse{% endif %}" loading="lazy">
          </figure>
          <figure class="p18-cph__slide">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/copenhagen/metro-station-02.jpeg" alt="Christianshavn Metro — {% if lang == 'en' %}2 min from the studio{% else %}2 min fra studiet{% endif %}" loading="lazy">
          </figure>
          <figure class="p18-cph__slide">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/studio/studio-hot-yoga-01.jpg" alt="Hot Yoga {% if lang == 'en' %}studio in Copenhagen{% else %}studio i København{% endif %}" loading="lazy">
          </figure>
          <figure class="p18-cph__slide">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/studio/studio-training-space.jpg" alt="{% if lang == 'en' %}Training room with daylight and plants{% else %}Træningsrum med dagslys og planter{% endif %}" loading="lazy">
          </figure>
          <figure class="p18-cph__slide">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/copenhagen/metro-station-01.jpeg" alt="{% if lang == 'en' %}Copenhagen by night near the studio{% else %}København by night nær studiet{% endif %}" loading="lazy">
          </figure>
        </div>
      </div>

      <div class="p18-cph__nav">
        <button class="p18-cph__arrow" type="button" aria-label="{% if lang == 'en' %}Previous image{% else %}Forrige billede{% endif %}" data-dir="-1">&#10094;</button>
        <button class="p18-cph__arrow" type="button" aria-label="{% if lang == 'en' %}Next image{% else %}Næste billede{% endif %}" data-dir="1">&#10095;</button>
      </div>
    </div>

    <!-- Feature grid -->
    <div class="p18-cph__features">
      {% for i in [1, 2, 3, 4, 5, 6] %}
      <div class="p18-cph__feature">
        <span class="p18-cph__feature-icon">{{ t["cph_feat" + i + "_icon"] }}</span>
        <h3>{{ t["cph_feat" + i + "_title"] }}</h3>
        <p>{{ t["cph_feat" + i + "_desc"] }}</p>
      </div>
      {% endfor %}
    </div>

    <!-- Studio location -->
    <div class="p18-cph__studio">
      <div class="p18-cph__studio-text">
        <h3>{{ t.cph_studio_title }}</h3>
        <p>{{ t.cph_studio_desc }}</p>
        <ul class="p18-cph__studio-details">
          <li><span>&#x1F687;</span> <span>{{ t.cph_studio_detail1 }}</span></li>
          <li><span>&#x1F333;</span> <span>{{ t.cph_studio_detail2 }}</span></li>
          <li><span>&#x1F9D8;</span> <span>{{ t.cph_studio_detail3 }}</span></li>
          <li><span>&#x1F6D2;</span> <span>{{ t.cph_studio_detail4 }}</span></li>
        </ul>
      </div>
      <div class="p18-cph__studio-img">
        <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/studio/studio-torvegade.jpg" alt="Yoga Bible {% if lang == 'en' %}studio, Torvegade 66, Christianshavn{% else %}studie, Torvegade 66, Christianshavn{% endif %}" loading="lazy">
      </div>
    </div>

    <!-- Experience strip -->
    <div class="p18-cph__strip">
      <span>&#x1F9D6; {% if lang == "en" %}Sauna{% else %}Sauna{% endif %}</span>
      <span>&#x1F3CA; Cold Dips</span>
      <span>&#x2615; Specialty Coffee</span>
      <span>&#x1F6B2; {% if lang == "en" %}Cycling Culture{% else %}Cykelkultur{% endif %}</span>
      <span>&#x1F37D;&#xFE0F; New Nordic</span>
      <span>&#x1F3B6; {% if lang == "en" %}Nightlife{% else %}Natteliv{% endif %}</span>
      <span>&#x1F33F; {% if lang == "en" %}Parks{% else %}Parker{% endif %}</span>
      <span>&#x1F3DB;&#xFE0F; {% if lang == "en" %}Architecture{% else %}Arkitektur{% endif %}</span>
    </div>

    <div class="p18-cph__cta">
      <a href="{{ lp }}/about-copenhagen" target="_blank" rel="noopener" class="yb-btn yb-btn--cta">{{ t.cph_cta_text }}</a>
      <a href="#accommodation" class="yb-btn yb-btn--outline" style="margin-left:12px">{{ t.cph_cta_accommodation }}</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     7. VISIT STUDIO — Gallery + Calendly Booking
     ═══════════════════════════════════════ -->
<section class="yb-visit" id="yb-visit">
  <div class="yb-visit__wrap container">

    <div class="yb-visit__copy">
      <p class="yb-visit__kicker">{{ t.visit_kicker }}</p>
      <h2 class="yb-visit__title">{{ t.visit_title }}</h2>

      <p class="yb-visit__lead">{{ t.visit_lead | safe }}</p>

      <ul class="yb-visit__list" role="list">
        {% for i in [1, 2, 3] %}
        <li>
          <span class="yb-visit__check" aria-hidden="true">&#x2713;</span>
          <span>{{ t["visit_list" + i] }}</span>
        </li>
        {% endfor %}
      </ul>

      <p class="yb-visit__note">{{ t.visit_note | safe }}</p>

      <button class="yb-btn yb-btn--cta" type="button" data-open="visit-modal">
        {{ t.visit_cta_text }}
      </button>
    </div>

    <div class="yb-visit__media">
      <div class="yb-visit__slider">
        <div class="yb-visit__viewport">
          <div class="yb-visit__track" id="visit-track">
            <figure class="yb-visit__slide">
              <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/studio/studio-hot-yoga-01.jpg" alt="{% if lang == 'en' %}Yoga room with warm wooden floor{% else %}Yogasal med varmt trægulv{% endif %}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/studio/studio-training-space.jpg" alt="{% if lang == 'en' %}Bright yoga room and props{% else %}Lyst yogarum og rekvisitter{% endif %}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/studio/studio-torvegade.jpg" alt="{% if lang == 'en' %}Reception and lounge area{% else %}Reception og loungeområde{% endif %}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/studio/studio-shower.jpg" alt="{% if lang == 'en' %}Showers & facilities{% else %}Brus & faciliteter{% endif %}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/copenhagen/christianshavn-location.jpg" alt="{% if lang == 'en' %}Central location in Christianshavn{% else %}Central placering i Christianshavn{% endif %}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/copenhagen/metro-station-02.jpeg" alt="{% if lang == 'en' %}Metro near the studio{% else %}Metro ved studiet{% endif %}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/copenhagen/metro-station-01.jpeg" alt="{% if lang == 'en' %}Metro near the studio{% else %}Metro ved studiet{% endif %}" loading="lazy">
            </figure>
          </div>
        </div>

        <div class="yb-visit__nav">
          <button class="yb-visit__arrow" type="button" aria-label="{% if lang == 'en' %}Previous image{% else %}Forrige billede{% endif %}" data-dir="-1">&#10094;</button>
          <button class="yb-visit__arrow" type="button" aria-label="{% if lang == 'en' %}Next image{% else %}Næste billede{% endif %}" data-dir="1">&#10095;</button>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Calendly Visit Modal -->
<section class="yb-modal-visit" id="visit-modal" aria-hidden="true">
  <div class="yb-modal-visit__overlay" data-close></div>

  <div class="yb-modal-visit__box" role="dialog" aria-modal="true" aria-label="{{ t.visit_modal_title }}">
    <button class="yb-modal-visit__close" type="button" data-close aria-label="{% if lang == 'en' %}Close{% else %}Luk{% endif %}">&#215;</button>

    <div class="yb-modal-visit__header">
      <h3 class="yb-modal-visit__title">{{ t.visit_modal_title }}</h3>
      <p class="yb-modal-visit__subtitle">{{ t.visit_modal_subtitle }}</p>
    </div>

    <div class="yb-modal-visit__booking" style="text-align:center;padding:32px 16px;">
      <p style="font-size:18px;margin-bottom:20px;">{{ t.visit_modal_subtitle }}</p>
      <button class="yb-btn yb-btn--primary" data-open-booking="info-session" data-close style="font-size:16px;padding:14px 32px;">
        &#127963; {% if lang == 'en' %}Book Free Info Session{% else %}Book et gratis infomøde{% endif %}
      </button>
      <div style="margin-top:16px;">
        <button class="yb-btn yb-btn--outline" data-open-booking="consultation" data-close style="font-size:14px;padding:10px 24px;">
          &#128187; {% if lang == 'en' %}Online Consultation{% else %}Online konsultation{% endif %}
        </button>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     8. REVIEWS — Google Reviews Carousel
     ═══════════════════════════════════════ -->
<section class="yb-reviews" id="yb-reviews-section" aria-labelledby="yb-reviews-title">
  <div class="yb-reviews__inner container">
    <p class="yb-reviews__kicker">{{ t.reviews_kicker }}</p>
    <h2 id="yb-reviews-title" class="yb-reviews__title">{{ t.reviews_title }}</h2>

    <p class="yb-reviews__lead">{{ t.reviews_lead | safe }}</p>

    <div class="yb-reviews__carousel">
      <button class="yb-reviews__nav yb-reviews__nav--prev" aria-label="{{ t.reviews_prev }}" data-prev type="button">&#10094;</button>

      <div class="yb-reviews__viewport" data-viewport>
        <div class="yb-reviews__track" data-track></div>
      </div>

      <button class="yb-reviews__nav yb-reviews__nav--next" aria-label="{{ t.reviews_next }}" data-next type="button">&#10095;</button>
    </div>

    <div class="yb-reviews__footer">
      <div class="yb-reviews__rating">
        <span class="yb-reviews__stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
        <span class="yb-reviews__score">{{ t.reviews_rating }}</span>
      </div>
      <a class="yb-reviews__link" target="_blank" rel="noopener"
         href="https://search.google.com/local/reviews?placeid=ChIJpQHE13BTUkYRY6oGEONORHM">
        {{ t.reviews_link_text }}
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     9. DARK CINEMATIC QUOTE
     ═══════════════════════════════════════ -->
<section class="p18-quote-dark">
  <div class="container">
    <p class="p18-quote-dark__quote">{{ t.quote_text }}</p>
    <p class="p18-quote-dark__attribution">
      — <strong>{{ t.quote_attribution }}</strong> {{ t.quote_attribution_suffix }}
    </p>
