    <span class="p18-eyebrow">{{ t.curr_eyebrow }}</span>
    <h2 class="p18-section-title">{{ t.curr_title }}</h2>
    <p class="p18-section-sub">{{ t.curr_subtitle }}</p>

    <div class="p18-curr-grid">
      <div class="p18-curr-card">
        <div class="p18-curr-card__accent"></div>
        <h3>{{ t.curr1_title }}</h3>
        <p>{{ t.curr1_desc }}</p>
      </div>

      <div class="p18-curr-card">
        <div class="p18-curr-card__accent"></div>
        <h3>{{ t.curr2_title }}</h3>
        <p>{{ t.curr2_desc }}</p>
      </div>

      <div class="p18-curr-card">
        <div class="p18-curr-card__accent"></div>
        <h3>{{ t.curr3_title }}</h3>
        <p>{{ t.curr3_desc }}</p>
      </div>

      <div class="p18-curr-card">
        <div class="p18-curr-card__accent"></div>
        <h3>{{ t.curr4_title }}</h3>
        <p>{{ t.curr4_desc }}</p>
      </div>

      <div class="p18-curr-card">
        <div class="p18-curr-card__accent"></div>
        <h3>{{ t.curr5_title }}</h3>
        <p>{{ t.curr5_desc }}</p>
      </div>

      <div class="p18-curr-card">
        <div class="p18-curr-card__accent"></div>
        <h3>{{ t.curr6_title }}</h3>
        <p>{{ t.curr6_desc }}</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     3. TRAINEE INTERVIEW — Video with Sound
     ═══════════════════════════════════════ -->
<section class="p18-video-interview">
  <div class="container">
    <span class="p18-eyebrow">{{ t.video_eyebrow }}</span>
    <h2 class="p18-section-title">{{ t.video_title }}</h2>
    <p class="p18-section-sub">{{ t.video_subtitle }}</p>

    <div class="p18-video-interview__wrap">
      <iframe
        src="https://drive.google.com/file/d/1WWanYni0tZKJ656czw_N2Vf6thCKFwU8/preview?t=10"
        allow="autoplay; encrypted-media"
        allowfullscreen
        loading="lazy"
        style="width:100%;height:100%;border:none;">
      </iframe>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     4. CERTIFICATION — Yoga Alliance RYT-200
     ═══════════════════════════════════════ -->
<section class="p18-certification">
  <div class="container">
    <span class="p18-eyebrow">{{ t.cert_eyebrow }}</span>
    <h2 class="p18-section-title">{{ t.cert_title }}</h2>
    <p class="p18-section-sub">{{ t.cert_subtitle }}</p>

    <div class="p18-cert-grid">

      <!-- Left: Yoga styles you master -->
      <div>
        <h3 class="p18-cert-subtitle">{{ t.cert_styles_title }}</h3>
        <div class="p18-cert-style-cards">
          <div class="p18-cert-style">
            <div class="p18-cert-style__icon">🧘</div>
            <div class="p18-cert-style__text">
              <h4>{{ t.cert_style1_title }}</h4>
              <p>{{ t.cert_style1_desc }}</p>
            </div>
          </div>
          <div class="p18-cert-style">
            <div class="p18-cert-style__icon">🌊</div>
            <div class="p18-cert-style__text">
              <h4>{{ t.cert_style2_title }}</h4>
              <p>{{ t.cert_style2_desc }}</p>
            </div>
          </div>
          <div class="p18-cert-style">
            <div class="p18-cert-style__icon">🌙</div>
            <div class="p18-cert-style__text">
              <h4>{{ t.cert_style3_title }}</h4>
              <p>{{ t.cert_style3_desc }}</p>
            </div>
          </div>
          <div class="p18-cert-style">
            <div class="p18-cert-style__icon">🔥</div>
            <div class="p18-cert-style__text">
              <h4>{{ t.cert_style4_title }}</h4>
              <p>{{ t.cert_style4_desc }}</p>
            </div>
          </div>
          <div class="p18-cert-style">
            <div class="p18-cert-style__icon">🧠</div>
            <div class="p18-cert-style__text">
              <h4>{{ t.cert_style5_title }}</h4>
              <p>{{ t.cert_style5_desc }}</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: What it opens for you -->
      <div>
        <h3 class="p18-cert-subtitle">{{ t.cert_doors_title }}</h3>
        <ul class="p18-cert-list">
          <li>
            <span class="p18-cert-check" aria-hidden="true">✓</span>
            <span>{{ t.cert_door1 | safe }}</span>
          </li>
          <li>
            <span class="p18-cert-check" aria-hidden="true">✓</span>
            <span>{{ t.cert_door2 | safe }}</span>
          </li>
          <li>
            <span class="p18-cert-check" aria-hidden="true">✓</span>
            <span>{{ t.cert_door3 | safe }}</span>
          </li>
          <li>
            <span class="p18-cert-check" aria-hidden="true">✓</span>
            <span>{{ t.cert_door4 | safe }}</span>
          </li>
          <li>
            <span class="p18-cert-check" aria-hidden="true">✓</span>
            <span>{{ t.cert_door5 | safe }}</span>
          </li>
        </ul>
      </div>

    </div>

    <p class="p18-cert-closing">{{ t.cert_closing }}</p>

    <div class="p18-cert-cta">
      <a href="{% if lang == 'en' %}/en/om-200hrs-yogalreruddannelser{% else %}/om-200hrs-yogalreruddannelser{% endif %}" class="btn btn--primary btn--large">{{ t.cert_cta }}</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     5. PROGRAM FORMAT — Semi-Intensive Schedule
     (with scroll-draw vine accent)
     ═══════════════════════════════════════ -->
<section class="p18-flexibility">
  <div class="p18-flexibility__vine" data-p18-scroll-draw>
    <svg viewBox="0 0 120 800" preserveAspectRatio="xMidYMid meet" fill="none">
      <path class="p18-vine-shadow" fill="none"
            d="M 60,0 C 80,80 100,120 80,200 C 60,280 40,300 50,380 C 60,460 90,500 70,580 C 50,660 60,720 60,800"
            stroke="rgba(247,92,3,0.08)" stroke-width="1.5" stroke-linecap="round" />
      <path class="p18-vine-path" fill="none"
            d="M 60,0 C 80,80 100,120 80,200 C 60,280 40,300 50,380 C 60,460 90,500 70,580 C 50,660 60,720 60,800"
            stroke="#f75c03" stroke-width="2" stroke-linecap="round" />
    </svg>
  </div>

  <div class="container">
    <span class="p18-eyebrow">{{ t.flex_eyebrow }}</span>
    <h2 class="p18-section-title">{{ t.flex_title }}</h2>
    <p class="p18-section-sub">{{ t.flex_subtitle }}</p>

    <div class="p18-flex-grid">
      <div class="p18-flex-card">
        <div class="p18-flex-card__icon">📅</div>
        <h3>{{ t.flex1_title }}</h3>
        <p>{{ t.flex1_desc }}</p>
      </div>
      <div class="p18-flex-card">
        <div class="p18-flex-card__icon">🗓</div>
        <h3>{{ t.flex2_title }}</h3>
        <p>{{ t.flex2_desc }}</p>
      </div>
      <div class="p18-flex-card">
        <div class="p18-flex-card__icon">⚖️</div>
        <h3>{{ t.flex3_title }}</h3>
        <p>{{ t.flex3_desc }}</p>
      </div>
    </div>

    <div class="p18-8w-schedule-details">
      <div class="p18-8w-detail-card">
        <div class="p18-8w-detail-card__icon">⏱</div>
        <div class="p18-8w-detail-card__content">
          <h4>{{ t.detail1_title }}</h4>
          <p>{{ t.detail1_desc }}</p>
        </div>
      </div>
      <div class="p18-8w-detail-card">
        <div class="p18-8w-detail-card__icon">📋</div>
        <div class="p18-8w-detail-card__content">
          <h4>{{ t.detail2_title }}</h4>
          <p>{{ t.detail2_desc }}</p>
        </div>
      </div>
      <div class="p18-8w-detail-card">
        <div class="p18-8w-detail-card__icon">🌍</div>
        <div class="p18-8w-detail-card__content">
          <h4>{{ t.detail3_title }}</h4>
          <p>{{ t.detail3_desc | safe }}</p>
        </div>
      </div>
    </div>

    <div style="text-align:center;margin-top:2rem;">
      <button onclick="openYBScheduleModal('8w')" class="yb-btn yb-btn--cta">{{ t.flex_cta }}</button>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     6. VERTICAL VIDEO + GRADUATION QUOTE
     ═══════════════════════════════════════ -->
<section class="p18-testimonial-video">
  <div class="container">
    <div class="p18-testimonial-video__grid">
      <div class="p18-testimonial-video__media">
        <video autoplay muted loop playsinline preload="metadata">
          <source src="/assets/video/yoga-practice-loop.mp4" type="video/mp4">
        </video>
      </div>
      <div class="p18-testimonial-video__content">
        <p class="p18-testimonial-video__quote">{{ t.testimonial_quote }}</p>
        <p class="p18-testimonial-video__attribution">
          <strong>{{ t.testimonial_attribution }}</strong>
        </p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     7. INVESTMENT — 25.500 DKK
     ═══════════════════════════════════════ -->
<section class="p18-investment">
  <div class="container">
    <span class="p18-eyebrow">{{ t.invest_eyebrow }}</span>
    <h2 class="p18-section-title">{{ t.invest_title }}</h2>

    <div class="p18-invest-box">
      <div class="p18-invest-price">
        <span class="p18-invest-price__amount">{{ t.invest_amount }}</span>
        <span class="p18-invest-price__label">{{ t.invest_label }}</span>
      </div>

      <div class="p18-invest-includes">
        <h4>{{ t.invest_incl_title }}</h4>
        <ul>
          <li>{{ t.invest_incl1 }}</li>
          <li>{{ t.invest_incl2 }}</li>
          <li>{{ t.invest_incl3 }}</li>
          <li>{{ t.invest_incl4 }}</li>
          <li>{{ t.invest_incl5 }}</li>
          <li>{{ t.invest_incl6 }}</li>
        </ul>
      </div>

      <div class="p18-invest-divider"></div>

      <div class="p18-invest-payment">
        <h4>{{ t.invest_pay_title }}</h4>
        <p style="font-size:13px;color:#6F6A66;margin:0 0 12px;">{{ t.invest_deposit_note }}</p>
        <div class="p18-invest-options">
          <div class="p18-invest-option">
            <span class="p18-invest-option__label">{{ t.invest_pay1_label }}</span>
            <span class="p18-invest-option__value">{{ t.invest_pay1_value }}</span>
          </div>
          <div class="p18-invest-option">
            <span class="p18-invest-option__label">{{ t.invest_pay2_label }}</span>
            <span class="p18-invest-option__value">{{ t.invest_pay2_value }}</span>
          </div>
          <div class="p18-invest-option">
            <span class="p18-invest-option__label">{{ t.invest_pay3_label }}</span>
            <span class="p18-invest-option__value">{{ t.invest_pay3_value }}</span>
          </div>
        </div>
      </div>

      <button onclick="openYBScheduleModal('8w')" class="btn btn--primary btn--large" style="width:100%;margin-top:1.5rem">{{ t.invest_cta }}</button>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     8. EARLY DEPOSIT — Get Studio Access Now
     ═══════════════════════════════════════ -->
<section class="yb-early" aria-label="{{ t.early_kicker }}">
  <div class="yb-early-wrap container">
    <figure class="yb-early-media">
      <img
        src="https://www.yogabible.dk/s/Start_with_Hot_Yoga_Copenhagen.jpg"
        alt="{{ t.early_img_alt }}"
        loading="lazy"
        decoding="async"
      />
    </figure>

    <div class="yb-early-copy">
      <p class="yb-early-kicker">{{ t.early_kicker }}</p>
      <h2 class="yb-early-title">{{ t.early_title }}</h2>

      <div class="yb-early-meta">
        <span class="yb-meta-item">
          <span class="yb-meta-icon">📍</span>
          {{ t.early_location }}
        </span>
        <span class="yb-meta-divider">•</span>
        <span class="yb-meta-item">{{ t.early_classes }}</span>
      </div>

      <p class="yb-early-styles">{{ t.early_styles }}</p>

      <ul class="yb-early-list" role="list">
        <li>
          <span class="yb-check" aria-hidden="true">✓</span>
          <span>{{ t.early1 }}</span>
        </li>
        <li>
          <span class="yb-check" aria-hidden="true">✓</span>
          <span>{{ t.early2 }}</span>
        </li>
        <li>
          <span class="yb-check" aria-hidden="true">✓</span>
          <span>{{ t.early3 }}</span>
        </li>
        <li>
          <span class="yb-check" aria-hidden="true">✓</span>
          <span>{{ t.early4 }}</span>
        </li>
      </ul>

      <div class="yb-early-cta">
        <a class="yb-btn yb-btn--cta"
           href="https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=41&sTG=46&prodId=100078"
           target="_blank" rel="noopener">{{ t.early_cta }}</a>
        <div class="yb-early-pricing">
          <span class="yb-deposit">{{ t.early_deposit }}</span>
          <span class="yb-installment">{{ t.early_installment }}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     9. REVIEWS — Google Reviews Carousel
     ═══════════════════════════════════════ -->
<section class="yb-reviews" id="yb-reviews-section" aria-labelledby="yb-reviews-title">
  <div class="yb-reviews__inner container">
    <p class="yb-reviews__kicker">{{ t.reviews_kicker }}</p>
    <h2 id="yb-reviews-title" class="yb-reviews__title">{{ t.reviews_title }}</h2>

    <p class="yb-reviews__lead">{{ t.reviews_lead | safe }}</p>

    <div class="yb-reviews__carousel">
      <button class="yb-reviews__nav yb-reviews__nav--prev" aria-label="{{ t.reviews_prev_aria }}" data-prev type="button">❮</button>

      <div class="yb-reviews__viewport" data-viewport>
        <div class="yb-reviews__track" data-track></div>
      </div>

      <button class="yb-reviews__nav yb-reviews__nav--next" aria-label="{{ t.reviews_next_aria }}" data-next type="button">❯</button>
    </div>

    <div class="yb-reviews__footer">
      <div class="yb-reviews__rating">
        <span class="yb-reviews__stars" aria-hidden="true">★★★★★</span>
        <span class="yb-reviews__score">{{ t.reviews_rating }}</span>
      </div>
      <a class="yb-reviews__link" target="_blank" rel="noopener"
         href="https://search.google.com/local/reviews?placeid=ChIJpQHE13BTUkYRY6oGEONORHM">
        {{ t.reviews_link }}
      </a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     10. VISIT STUDIO — Gallery + Calendly Booking
     ═══════════════════════════════════════ -->
<section class="yb-visit" id="yb-visit">
  <div class="yb-visit__wrap container">

    <div class="yb-visit__copy">
      <p class="yb-visit__kicker">{{ t.visit_kicker }}</p>
      <h2 class="yb-visit__title">{{ t.visit_title }}</h2>

      <p class="yb-visit__lead">{{ t.visit_lead | safe }}</p>

      <ul class="yb-visit__list" role="list">
        <li>
          <span class="yb-visit__check" aria-hidden="true">✓</span>
          <span>{{ t.visit1 }}</span>
        </li>
        <li>
          <span class="yb-visit__check" aria-hidden="true">✓</span>
          <span>{{ t.visit2 }}</span>
        </li>
        <li>
          <span class="yb-visit__check" aria-hidden="true">✓</span>
          <span>{{ t.visit3 }}</span>
        </li>
      </ul>

      <p class="yb-visit__note">{{ t.visit_note | safe }}</p>

      <button class="yb-btn yb-btn--cta" type="button" data-open="visit-modal">
        {{ t.visit_cta }}
      </button>
    </div>

    <div class="yb-visit__media">
      <div class="yb-visit__slider">
        <div class="yb-visit__viewport">
          <div class="yb-visit__track" id="visit-track">
            <figure class="yb-visit__slide">
              <img src="https://www.yogabible.dk/s/Yoga_bible_studio_Kbenhavn_Hot_Yoga_Copenhagen01" alt="{{ t.visit_img1_alt }}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://www.yogabible.dk/s/Yoga_bible_studio_Kbenhavn_Hot_Yoga_Copenhagen01_Yoga_Teacher_Training_space02" alt="{{ t.visit_img2_alt }}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://www.yogabible.dk/s/Yoga_Bible_Studio_Torvegade_66_Christianshavn" alt="{{ t.visit_img3_alt }}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://www.yogabible.dk/s/Yoga_bible_shower_facilities" alt="{{ t.visit_img4_alt }}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://www.yogabible.dk/s/Christianshavn_Yoga_Bible_Central_Location.jpg" alt="{{ t.visit_img5_alt }}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://www.yogabible.dk/s/christianshavn_metro_Station_studio_central_Yoga_Bible_Hot_Yoga_Copenhagen_02.jpeg" alt="{{ t.visit_img6_alt }}" loading="lazy">
            </figure>
            <figure class="yb-visit__slide">
              <img src="https://www.yogabible.dk/s/christianshavn_metro_Station_studio_central_Yoga_Bible_Hot_Yoga_Copenhagen.jpeg" alt="{{ t.visit_img7_alt }}" loading="lazy">
            </figure>
          </div>
        </div>

        <div class="yb-visit__nav">
          <button class="yb-visit__arrow" type="button" aria-label="{{ t.visit_prev_aria }}" data-dir="-1">❮</button>
          <button class="yb-visit__arrow" type="button" aria-label="{{ t.visit_next_aria }}" data-dir="1">❯</button>
        </div>
      </div>
    </div>

  </div>
</section>

<!-- Calendly Visit Modal -->
<section class="yb-modal-visit" id="visit-modal" aria-hidden="true">
  <div class="yb-modal-visit__overlay" data-close></div>

  <div class="yb-modal-visit__box" role="dialog" aria-modal="true" aria-label="{{ t.visit_modal_aria }}">
    <button class="yb-modal-visit__close" type="button" data-close aria-label="{{ t.visit_modal_close_aria }}">×</button>

    <div class="yb-modal-visit__header">
      <h3 class="yb-modal-visit__title">{{ t.visit_modal_title }}</h3>
      <p class="yb-modal-visit__subtitle">{{ t.visit_modal_subtitle }}</p>
    </div>

    <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet">
    <div class="calendly-inline-widget"
         data-url="https://calendly.com/yogabible/studio-tour-consultation-yoga-teacher-training"
         style="min-width:320px;height:680px;"></div>
    <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async></script>

    <p class="yb-modal-visit__fallback">{{ t.visit_modal_fallback | safe }}</p>
  </div>
</section>

<!-- ═══════════════════════════════════════
