<!-- Page-specific JS -->
<script>
(function() {
  var isEN = (document.documentElement.lang === 'en') || (window.location.pathname.indexOf('/en/') === 0);

  /* ── Scroll-Draw Vine ── */
  var vineWrap = document.querySelector('[data-p18-scroll-draw]');
  if (vineWrap) {
    var mainPath = vineWrap.querySelector('.p18-vine-path');
    var shadowPath = vineWrap.querySelector('.p18-vine-shadow');
    var allPaths = [mainPath, shadowPath].filter(Boolean);

    allPaths.forEach(function(p) {
      var len = p.getTotalLength();
      p.style.strokeDasharray = len;
      p.style.strokeDashoffset = len;
    });

    function drawVine() {
      var rect = vineWrap.getBoundingClientRect();
      var winH = window.innerHeight;
      var start = winH;
      var end = -rect.height;
      var progress = Math.max(0, Math.min(1, (start - rect.top) / (start - end)));

      allPaths.forEach(function(p) {
        var len = p.getTotalLength();
        p.style.strokeDashoffset = len - (progress * len);
      });
      requestAnimationFrame(drawVine);
    }
    drawVine();
  }

  /* ── Scroll-triggered fade-up ── */
  var fadeEls = document.querySelectorAll('.p18-flex-card');
  if (fadeEls.length && 'IntersectionObserver' in window) {
    var obs = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          e.target.classList.add('p18-visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.15 });
    fadeEls.forEach(function(el) { obs.observe(el); });
  }

  /* ── Copenhagen Slider ── */
  var cphTrack = document.getElementById('cph-track');
  if (cphTrack) {
    var cphSlides = Array.from(cphTrack.children);
    var cphArrows = document.querySelectorAll('.p18-cph__arrow');

    if (cphSlides.length > 1) {
      var cphIdx = 0;
      var cphTotal = cphSlides.length;

      var cphGoTo = function(i) {
        if (i >= cphTotal) cphIdx = 0;
        else if (i < 0) cphIdx = cphTotal - 1;
        else cphIdx = i;
        cphTrack.style.transform = 'translateX(-' + (cphIdx * 100) + '%)';
      };

      var cphAutoInterval = setInterval(function() { cphGoTo(cphIdx + 1); }, 5000);
      var cphResetAuto = function() {
        clearInterval(cphAutoInterval);
        cphAutoInterval = setInterval(function() { cphGoTo(cphIdx + 1); }, 5000);
      };

      cphArrows.forEach(function(btn) {
        btn.addEventListener('click', function() {
          cphGoTo(cphIdx + Number(btn.getAttribute('data-dir')));
          cphResetAuto();
        });
      });

      var cphStartX = 0;
      var cphDeltaX = 0;
      cphTrack.addEventListener('touchstart', function(e) {
        cphStartX = e.touches[0].clientX;
      }, { passive: true });
      cphTrack.addEventListener('touchmove', function(e) {
        cphDeltaX = e.touches[0].clientX - cphStartX;
      }, { passive: true });
      cphTrack.addEventListener('touchend', function() {
        if (Math.abs(cphDeltaX) > 50) {
          cphGoTo(cphIdx + (cphDeltaX < 0 ? 1 : -1));
        }
        cphDeltaX = 0;
        cphResetAuto();
      });
    }
  }

  /* ── Room Gallery Sliders ── */
  var roomTracks = document.querySelectorAll('[data-room-track]');
  roomTracks.forEach(function(track) {
    var imgs = Array.from(track.children);
    if (imgs.length <= 1) return;

    var idx = 0;
    var total = imgs.length;
    var nav = track.parentElement.querySelector('.p18-rooms__gallery-nav');
    if (!nav) return;
    var arrows = nav.querySelectorAll('.p18-rooms__gallery-arrow');

    var goTo = function(i) {
      if (i >= total) idx = 0;
      else if (i < 0) idx = total - 1;
      else idx = i;
      track.style.transform = 'translateX(-' + (idx * 100) + '%)';
    };

    arrows.forEach(function(btn) {
      btn.addEventListener('click', function() {
        goTo(idx + Number(btn.getAttribute('data-dir')));
      });
    });
  });

  /* ── Visit Gallery Slider ── */
  var visitTrack = document.getElementById('visit-track');
  if (visitTrack) {
    var visitSlides = Array.from(visitTrack.children);
    var visitArrows = document.querySelectorAll('.yb-visit__arrow');

    if (visitSlides.length > 1) {
      var visitIdx = 0;
      var visitTotal = visitSlides.length;

      var visitGoTo = function(i) {
        if (i >= visitTotal) visitIdx = 0;
        else if (i < 0) visitIdx = visitTotal - 1;
        else visitIdx = i;
        visitTrack.style.transform = 'translateX(-' + (visitIdx * 100) + '%)';
      };

      var visitAutoInterval = setInterval(function() { visitGoTo(visitIdx + 1); }, 5000);
      var visitResetAuto = function() {
        clearInterval(visitAutoInterval);
        visitAutoInterval = setInterval(function() { visitGoTo(visitIdx + 1); }, 5000);
      };

      visitArrows.forEach(function(btn) {
        btn.addEventListener('click', function() {
          visitGoTo(visitIdx + Number(btn.getAttribute('data-dir')));
          visitResetAuto();
        });
      });

      var visitStartX = 0;
      var visitDeltaX = 0;
      visitTrack.addEventListener('touchstart', function(e) {
        visitStartX = e.touches[0].clientX;
      }, { passive: true });
      visitTrack.addEventListener('touchmove', function(e) {
        visitDeltaX = e.touches[0].clientX - visitStartX;
      }, { passive: true });
      visitTrack.addEventListener('touchend', function() {
        if (Math.abs(visitDeltaX) > 50) {
          visitGoTo(visitIdx + (visitDeltaX < 0 ? 1 : -1));
        }
        visitDeltaX = 0;
        visitResetAuto();
      });
    }
  }

  /* ── Visit Calendly Modal ── */
  var visitModal = document.getElementById('visit-modal');
  if (visitModal) {
    var visitOpeners = document.querySelectorAll('[data-open="visit-modal"]');
    var openVisitModal = function() {
      visitModal.setAttribute('aria-hidden', 'false');
      document.documentElement.style.overflow = 'hidden';
      document.body.style.overflow = 'hidden';
    };
    var closeVisitModal = function() {
      visitModal.setAttribute('aria-hidden', 'true');
      document.documentElement.style.overflow = '';
      document.body.style.overflow = '';
    };
    visitOpeners.forEach(function(btn) { btn.addEventListener('click', openVisitModal); });
    visitModal.addEventListener('click', function(e) {
      if (e.target.hasAttribute('data-close')) closeVisitModal();
    });
    var visitCloseBtn = visitModal.querySelector('.yb-modal-visit__close');
    if (visitCloseBtn) visitCloseBtn.addEventListener('click', closeVisitModal);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && visitModal.getAttribute('aria-hidden') === 'false') {
        closeVisitModal();
      }
    });
  }

  /* ── Reviews Carousel ── */
  var reviewsSection = document.getElementById('yb-reviews-section');
  if (reviewsSection) {
    var REVIEWS = [
      {name:"Tanja E.",when:isEN?"4 months ago":"for 4 mdr. siden",text:isEN?"Warm, friendly environment and competent teachers. Good balance between practice and philosophy – strong understanding of anatomy.":"Varmt, venligt miljø og kompetente lærere. God balance mellem praksis og den filosofiske del – stærk forståelse for anatomi."},
      {name:"Sara Gerlee",when:isEN?"4 months ago":"for 4 mdr. siden",text:isEN?"The 200-hour program was transformative. Knowledgeable and supportive team – the studio feels like a second home, for both new and experienced practitioners.":"200-timers forløb var transformerende. Vidende og støttende team – studiet føles som et andet hjem, for både nye og erfarne."},
      {name:"Clara Aagaard",when:isEN?"5 months ago":"for 5 mdr. siden",text:isEN?"Holistic learning environment with room for questions and practical focus. Skilled teachers and useful tools for class management.":"Holistisk læringsmiljø med plads til spørgsmål og praksisfokus. Dygtige undervisere og anvendelige værktøjer til klasseledelse."},
      {name:"Liza Westh",when:isEN?"9 months ago":"for 9 mdr. siden",text:isEN?"My warmest recommendation. 200 hours of class management, anatomy and practice – I felt optimally prepared as a yoga teacher.":"Min varmeste anbefaling. 200 timer i class management, anatomi og praksis – følte mig optimalt forberedt som yogalærer."},
      {name:"Signe Schmidt",when:isEN?"1 year ago":"for 1 år siden",text:isEN?"Effective 18-week training in anatomy, philosophy and practice (yin, vinyasa, hatha) – in a beautiful room with daylight and green plants.":"Effektiv 18-ugers uddannelse i anatomi, filosofi og praksis (yin, vinyasa, hatha) – i en smuk sal med dagslys og grønne planter."},
      {name:"Meg Ellis",when:isEN?"10 months ago":"for 10 mdr. siden",text:isEN?"Extraordinary studio and teaching team. The 200h program prepares you fully — perfect for both deepening practice and teaching.":"Ekstraordinært studie og lærerteam. 200t forløb forbereder dig fuldt — perfekt til både fordybelse og undervisning."},
      {name:"Kama Krystel",when:isEN?"1 year ago":"for 1 år siden",text:isEN?"Well-structured intensive program that blends theory and practice. Personal feedback and supportive community – highly recommended.":"Velstruktureret intensivt forløb, der blander teori og praksis. Personlig feedback og støttende community – kan varmt anbefales."},
      {name:"Giorgianna G.",when:isEN?"1 year ago":"for 1 år siden",text:isEN?"Challenging and rewarding. Unique focus on class management. Five stars for the skilled teachers and preparation to teach.":"Udfordrende og belønnende. Unikt fokus på class management. Fem stjerner for de dygtige lærere og forberedelse til at undervise."},
      {name:"Helena Bend...",when:isEN?"1 year ago":"for 1 år siden",text:isEN?"Highly recommend the training – 5 educational months. I feel well equipped to continue as a yoga teacher.":"Kan virkelig anbefale uddannelsen – 5 lærerige måneder. Jeg føler mig godt klædt på til at fortsætte som yogalærer."},
      {name:"Tonje Follum",when:isEN?"1 year ago":"for 1 år siden",text:isEN?"Inspiration, great attention to detail and warm environment. Fantastic atmosphere with plants, light and music – my favourite yoga community.":"Inspiration, stor detaljegrad og varmt miljø. Fantastisk atmosfære med planter, lys og musik – mit yndlings-yogafællesskab."},
      {name:"Ping Li",when:isEN?"1 year ago":"for 1 år siden",text:isEN?"Just completed my 200h – great mental & physical development. Deeply professional team. Very happy with my journey here.":"Afsluttede netop min 200t – stor mental & fysisk udvikling. Dybt professionelt team. Meget glad for min rejse her."},
      {name:"Camilla Rend...",when:isEN?"1 year ago":"for 1 år siden",text:isEN?"Newly certified instructor – I feel ready in hatha, vinyasa and yin. Hard work, but worth it. Recommended for both practitioners and aspiring instructors.":"Nyuddannet instruktør – føler mig klar i hatha, vinyasa og yin. Hårdt arbejde, men det værd. Anbefales til både udøvere og kommende instruktører."},
      {name:"Dagmar Eliza...",when:isEN?"1 year ago":"for 1 år siden",text:isEN?"Wide range of classes + opportunity for YTT. Skilled teachers in anatomy & philosophy. Learned a lot and found a strong community.":"Bredt udbud af klasser + mulighed for YTT. Dygtige undervisere i anatomi & filosofi. Lærte meget og fandt et stærkt fællesskab."},
      {name:"Yasmine Olof...",when:isEN?"1 year ago":"for 1 år siden",text:isEN?"Fantastic training! I feel ready to lead my own classes. Warm, professional teachers and cosy studio.":"Fantastisk uddannelse! Føler mig klar til at lede egne klasser. Varme, professionelle undervisere og hyggeligt studie."},
      {name:"Anastasia Se...",when:isEN?"1 year ago":"for 1 år siden",text:isEN?"Wonderful place to practice. The 5-month YTT was informative and professional – the teachers support you all the way.":"Vidunderligt sted at praktisere. 5-måneders YTT var informativt og professionelt – lærerne støtter dig hele vejen."},
      {name:"Maja Pedersen",when:isEN?"10 months ago":"for 10 mdr. siden",text:isEN?"Pragmatic approach – you develop quickly. Super teachers with great experience in Hatha/Vinyasa, anatomy and yoga philosophy.":"Pragmatisk tilgang – man udvikler sig hurtigt. Super undervisere med stor erfaring i Hatha/Vinyasa, anatomi og yogafilosofi."}
    ];

    var revTrack = reviewsSection.querySelector('[data-track]');
    var revViewport = reviewsSection.querySelector('[data-viewport]');
    var revPrev = reviewsSection.querySelector('[data-prev]');
    var revNext = reviewsSection.querySelector('[data-next]');

    if (revTrack && revViewport) {
      REVIEWS.forEach(function(review) {
        var card = document.createElement('article');
        card.className = 'yb-reviews__card';
        card.setAttribute('aria-label', (isEN ? 'Review from ' : 'Anmeldelse fra ') + review.name);
        card.innerHTML =
          '<div class="yb-reviews__card-header">' +
            '<div class="yb-reviews__card-info">' +
              '<h3 class="yb-reviews__name">' + review.name + '</h3>' +
              '<p class="yb-reviews__when">' + review.when + '</p>' +
            '</div>' +
            '<span class="yb-reviews__card-stars" aria-hidden="true">\u2605\u2605\u2605\u2605\u2605</span>' +
          '</div>' +
          '<p class="yb-reviews__text">' + review.text + '</p>';
        revTrack.appendChild(card);
      });

      var getRevScrollAmount = function() {
        var card = revTrack.querySelector('.yb-reviews__card');
        if (!card) return 0;
        var style = window.getComputedStyle(revTrack);
        var gap = parseInt(style.gap) || 16;
        return card.offsetWidth + gap;
      };

      var getRevVisibleCount = function() {
        var w = window.innerWidth;
        if (w >= 900) return 3;
        if (w >= 600) return 2;
        return 1;
      };

      var updateRevButtons = function() {
        if (!revPrev || !revNext) return;
        var scrollLeft = revViewport.scrollLeft;
        var maxScroll = revViewport.scrollWidth - revViewport.clientWidth;
        revPrev.disabled = scrollLeft <= 5;
        revNext.disabled = scrollLeft >= maxScroll - 5;
      };

      var scrollRevByCards = function(direction) {
        var amount = getRevScrollAmount() * getRevVisibleCount();
        revViewport.scrollBy({ left: direction * amount, behavior: 'smooth' });
      };

      if (revPrev) revPrev.addEventListener('click', function() { scrollRevByCards(-1); });
      if (revNext) revNext.addEventListener('click', function() { scrollRevByCards(1); });
      revViewport.addEventListener('scroll', updateRevButtons, { passive: true });
      window.addEventListener('resize', updateRevButtons, { passive: true });
      requestAnimationFrame(function() {
        requestAnimationFrame(updateRevButtons);
      });
    }
  }

  /* ── yb-more: Course pills ── */
  var COURSE_DATA = {
    inv: {
      image: 'https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/courses/inversions-course.jpg',
      blurb: isEN ? 'Learn to work safely with handstands, forearm balances, and headstands – technique, strength, and courage.' : 'Lær at arbejde sikkert med håndstande, underarmsbalancer og hovedstande – teknik, styrke og mod.',
      href: (isEN ? '/en' : '') + '/inversions',
      label: isEN ? 'Learn more about Inversions' : 'Læs mere om Inversions',
      alt: isEN ? 'Inversions course' : 'Inversions kursus'
    },
    spl: {
      image: 'https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/courses/splits-course.jpg',
      blurb: isEN ? 'Flexibility with structure – hip openers, hamstrings, and technique for front & middle splits without forcing the body.' : 'Smidighed med system – hofteåbnere, baglår og teknik til front & middle splits uden at presse kroppen.',
      href: (isEN ? '/en' : '') + '/splits',
      label: isEN ? 'Learn more about Splits' : 'Læs mere om Splits',
      alt: isEN ? 'Splits course' : 'Splits kursus'
    },
    bb: {
      image: 'https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/courses/backbend-training-pro.jpg',
      blurb: isEN ? 'Healthy backbends with focus on breath, stability, and gradual mobility in the thoracic spine and hips.' : 'Sunde bagoverbøjninger med fokus på åndedræt, stabilitet og gradvis mobilitet i brystryg og hofter.',
      href: (isEN ? '/en' : '') + '/backbends',
      label: isEN ? 'Learn more about Backbends' : 'Læs mere om Backbends',
      alt: isEN ? 'Backbends course' : 'Backbends kursus'
    }
  };

  var courseImg = document.getElementById('ybCourseImg');
  var courseBlurb = document.getElementById('ybCourseBlurb');
  var courseCta = document.getElementById('ybCourseCta');
  var coursePills = document.querySelectorAll('.yb-more [data-course]');

  if (courseImg && courseBlurb && courseCta && coursePills.length) {
    var setCourse = function(key) {
      var data = COURSE_DATA[key];
      if (!data) return;
      coursePills.forEach(function(p) {
        var isActive = p.dataset.course === key;
        p.classList.toggle('is-active', isActive);
        p.setAttribute('aria-selected', isActive);
      });
      courseImg.src = data.image;
      courseImg.alt = data.alt;
      courseBlurb.textContent = data.blurb;
      courseCta.href = data.href;
      courseCta.target = '_blank';
      courseCta.rel = 'noopener';
      courseCta.textContent = data.label + ' \u2192';
    };
    coursePills.forEach(function(p) {
      p.addEventListener('click', function() { setCourse(p.dataset.course); });
    });
    setCourse('inv');
  }

  /* ── yb-more: Program pills (18w / 4w) ── */
  var PROGRAM_DATA = {
    '18w': {
      title: isEN ? '200 hours – 18-week flexible program' : '200 timer – 18 ugers fleksibelt program',
      badge: isEN ? 'Flexible' : 'Fleksibelt',
      blurb: isEN ? 'The same <strong>Yoga Alliance-certified</strong> training – spread over <strong>18 weeks</strong> with maximum flexibility. Perfect alongside a job, studies, or family life.' : 'Samme <strong>Yoga Alliance–certificerede</strong> uddannelse – fordelt over <strong>18 uger</strong> med maksimal fleksibilitet. Perfekt ved siden af job, studie eller familieliv.',
      list: isEN ? [
        'Weekday or weekend track — switch freely',
        'Approx. 12 hours per week incl. homework',
        'Can be combined with full-time work'
      ] : [
        'Hverdags- eller weekendforløb — skift frit',
        'Ca. 12 timer om ugen inkl. hjemmeopgaver',
        'Kan kombineres med fuldtidsarbejde'
      ],
      href: (isEN ? '/en' : '') + '/200-hours-18-weeks-flexible-programs',
      ctaLabel: isEN ? 'Go to 18-week flexible training \u2192' : 'Gå til 18-ugers fleksibel uddannelse \u2192',
      alt: isEN ? '200-hour – 18-week flexible program' : '200-timers – 18 ugers fleksibelt program'
    },
    '4w': {
      title: isEN ? '200 hours – 4-week intensive program' : '200 timer – 4 ugers intensivt program',
      badge: isEN ? 'Intensive' : 'Intensivt',
      blurb: isEN ? 'The same <strong>Yoga Alliance-certified</strong> training – compressed into <strong>4 weeks</strong> for those who want to complete quickly and have the time to immerse themselves daily.' : 'Samme <strong>Yoga Alliance–certificerede</strong> uddannelse – komprimeret til <strong>4 uger</strong> for dig, der vil gennemføre hurtigt og har tiden til at fordybe dig hver dag.',
      list: isEN ? [
        'Daily training and theory in a focused program',
        'Strong focus on technique, teaching craft & practice',
        '<strong>Accommodation option</strong> during the program'
      ] : [
        'Daglig træning og teori i et fokuseret forløb',
        'Stærkt fokus på teknik, undervisningshåndværk & praksis',
        '<strong>Mulighed for indkvartering</strong> under forløbet'
      ],
      href: (isEN ? '/en' : '') + '/200-hours-4-weeks-intensive-programs',
      ctaLabel: isEN ? 'Go to 4-week intensive training \u2192' : 'Gå til 4-ugers intensiv uddannelse \u2192',
      alt: isEN ? '200-hour – 4-week intensive program' : '200-timers – 4 ugers intensivt program'
    }
  };

  var programTitle = document.getElementById('ybProgramTitle');
  var programBadge = document.getElementById('ybProgramBadge');
  var programBlurb = document.getElementById('ybProgramBlurb');
  var programList = document.getElementById('ybProgramList');
  var programCta = document.getElementById('ybProgramCta');
  var programImg = document.getElementById('ybProgramImg');
  var programPills = document.querySelectorAll('.yb-more [data-program]');

  if (programTitle && programBlurb && programCta && programPills.length) {
    var setProgram = function(key) {
      var data = PROGRAM_DATA[key];
      if (!data) return;
      programPills.forEach(function(p) {
        var isActive = p.dataset.program === key;
        p.classList.toggle('is-active', isActive);
        p.setAttribute('aria-selected', isActive);
      });
      programTitle.textContent = data.title;
      if (programBadge) programBadge.textContent = data.badge;
      programBlurb.innerHTML = data.blurb;
      if (programImg) programImg.alt = data.alt;
      if (programList) {
        programList.innerHTML = '';
        data.list.forEach(function(item) {
          var li = document.createElement('li');
          li.innerHTML = item;
          programList.appendChild(li);
        });
      }
      programCta.href = data.href;
      programCta.target = '_blank';
      programCta.rel = 'noopener';
      programCta.textContent = data.ctaLabel;
    };
    programPills.forEach(function(p) {
      p.addEventListener('click', function() { setProgram(p.dataset.program); });
    });
    setProgram('18w');
  }
})();
</script>
