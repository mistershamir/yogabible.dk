{% set t = i18n.p8w[lang or "da"] %}

<!-- ═══════════════════════════════════════
     1. HERO — Dark Cinematic
     ═══════════════════════════════════════ -->
<section class="p18-hero">
  <div class="p18-hero__bg">
    <!-- Video slot: add <video> here when ready -->
  </div>
  <div class="p18-hero__overlay"></div>

  <div class="container p18-hero__inner">
    <span class="p18-hero__eyebrow">{{ t.hero_eyebrow }}</span>
    <h1 class="p18-hero__title">{{ t.hero_title | safe }}</h1>
    <p class="p18-hero__subtitle">{{ t.hero_subtitle }}</p>

    <div class="p18-hero__meta">
      <div class="p18-hero__meta-item">
        <strong>{{ t.hero_meta_next_label }}</strong> {{ t.hero_meta_next_val }}
      </div>
      <div class="p18-hero__meta-item">
        <strong>{{ t.hero_meta_format_label }}</strong> {{ t.hero_meta_format_val }}
      </div>
      <div class="p18-hero__meta-item">
        <strong>{{ t.hero_meta_cert_label }}</strong> {{ t.hero_meta_cert_val }}
      </div>
    </div>

    <p class="p18-hero__styles">{{ t.hero_styles }}</p>

    <div class="p18-hero__cta">
      <button onclick="openYBScheduleModal('8w')" class="btn btn--primary btn--large">{{ t.hero_cta_schedule }}</button>
      <a href="/accommodation" class="btn btn--secondary btn--large">{{ t.hero_cta_accommodation }}</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════
     2. WHAT YOU LEARN — Lifting Cards
     ═══════════════════════════════════════ -->
<section class="p18-curriculum" id="program-overview">
