    </div>
  </div>
</section>

{# ── PAGE SCRIPT: filters, bio toggles, photo/video switch ── #}
<script>
(function(){
  /* ── Filter tabs ── */
  var btns = document.querySelectorAll('[data-filter]');
  var cards = document.querySelectorAll('.mt-card');
  btns.forEach(function(btn){
    btn.addEventListener('click', function(){
      btns.forEach(function(b){ b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      var f = btn.getAttribute('data-filter');
      cards.forEach(function(c){
        if(f === 'all' || c.getAttribute('data-category') === f){
          c.style.display = '';
        } else {
          c.style.display = 'none';
        }
      });
    });
  });

  /* ── Bio read-more toggle ── */
  document.querySelectorAll('[data-bio-toggle]').forEach(function(btn){
    btn.addEventListener('click', function(){
      var wrap = btn.previousElementSibling;
      var more = btn.querySelector('.mt-card__toggle-more');
      var less = btn.querySelector('.mt-card__toggle-less');
      var open = wrap.classList.toggle('is-open');
      more.style.display = open ? 'none' : '';
      less.style.display = open ? '' : 'none';
    });
  });

  /* ── Photo / Video toggle ── */
  document.querySelectorAll('.mt-card__media-btn').forEach(function(btn){
    btn.addEventListener('click', function(){
      var media = btn.closest('.mt-card__media');
      var img = media.querySelector('img');
      var vid = media.querySelector('video');
      var sibs = media.querySelectorAll('.mt-card__media-btn');
      sibs.forEach(function(s){ s.classList.remove('is-active'); });
      btn.classList.add('is-active');
      if(btn.getAttribute('data-media') === 'video' && vid){
        img.style.display = 'none';
        vid.style.display = 'block';
        vid.play();
      } else {
        img.style.display = '';
        if(vid){ vid.style.display = 'none'; vid.pause(); }
      }
    });
  });
})();
</script>
