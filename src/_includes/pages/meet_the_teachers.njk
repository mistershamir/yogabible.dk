{% set t = i18n.meet_the_teachers[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

{# ── HERO ── #}
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="{{ lp }}/apply" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta_apply }}</a>
      <a href="#teachers" class="yb-btn yb-btn--outline-white yb-btn--large">{{ t.hero_cta_explore }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

{# ── INTRO ── #}
<section class="program-overview">
  <div class="container">
    <h2 class="section-title">{{ t.intro_title }}</h2>
    <p class="section-subtitle">{{ t.intro_text }}</p>
  </div>
</section>

{# ── FILTER TABS ── #}
<section class="mt-filters" id="teachers">
  <div class="container">
    <div class="mt-filters__bar">
      <button class="mt-filters__btn is-active" data-filter="all">{{ t.filter_all }}</button>
      <button class="mt-filters__btn" data-filter="lead">{{ t.filter_lead }}</button>
      <button class="mt-filters__btn" data-filter="senior">{{ t.filter_senior }}</button>
      <button class="mt-filters__btn" data-filter="specialist">{{ t.filter_specialist }}</button>
      <button class="mt-filters__btn" data-filter="guest">{{ t.filter_guest }}</button>
    </div>
  </div>
</section>

