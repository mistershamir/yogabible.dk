{% set t = i18n.kontakt[lang or "da"] %}

<!-- ═══════════════════════════════════════════════════════════════
     HERO — Dark Cinematic with Breathing Glow
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__trust">
      <span>{{ site.phone }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ site.email }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>Torvegade 66, København K</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════
     INTRO + CONTACT DETAILS — Split Layout (Image + Copy)
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-kontakt-intro">
  <div class="container">
    <div class="yb-kontakt-split">
      <!-- Left: Studio Photo -->
      <figure class="yb-kontakt-photo yb-fade-in">
        <img src="{{ mediaBase }}/yoga-bible-DK/studio/dsc-8528.jpg"
             alt="Yoga Bible studio, Christianshavn"
             loading="lazy" decoding="async"
             width="600" height="800">
      </figure>

      <!-- Right: Intro Copy + Contact Details -->
      <div class="yb-kontakt-copy yb-fade-in">
        <p class="yb-kontakt-eyebrow">{{ t.intro_eyebrow }}</p>
        <h2 class="yb-kontakt-heading">{{ t.intro_heading }}</h2>
        <p class="yb-kontakt-text">{{ t.intro_text | safe }}</p>

        <div class="yb-kontakt-details">
          <div class="yb-kontakt-detail">
            <span class="yb-kontakt-detail__label">{{ t.intro_phone_label }}</span>
            <a href="tel:{{ site.phone | replace(' ', '') }}" class="yb-kontakt-detail__value">{{ site.phone }}</a>
          </div>
          <div class="yb-kontakt-detail">
            <span class="yb-kontakt-detail__label">{{ t.intro_email_label }}</span>
            <a href="mailto:{{ site.email }}" class="yb-kontakt-detail__value">{{ site.email }}</a>
          </div>
          <div class="yb-kontakt-detail">
            <span class="yb-kontakt-detail__label">{{ t.intro_address_label }}</span>
            <a href="{{ t.findus_directions_url }}" target="_blank" rel="noopener" class="yb-kontakt-detail__value">{{ t.intro_address }}</a>
          </div>
          <div class="yb-kontakt-detail">
            <span class="yb-kontakt-detail__label">{{ t.intro_hours_label }}</span>
            <span class="yb-kontakt-detail__value">{{ t.intro_hours }}</span>
          </div>
        </div>

        <hr class="yb-kontakt-sep">

        <p class="yb-kontakt-studio">{{ t.intro_studio | safe }}</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════
     OUR STUDIO — Video + Copy + Feature Cards + Image Gallery
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-kontakt-studio-section">
  <div class="container">
    <p class="yb-kontakt-eyebrow yb-fade-in" style="text-align:center">{{ t.studio_eyebrow }}</p>
    <h2 class="section-title yb-fade-in">{{ t.studio_title }}</h2>
    <p class="section-subtitle yb-fade-in">{{ t.studio_subtitle }}</p>

    <!-- Video + Copy split -->
    <div class="yb-kontakt-studio-split yb-fade-in">
      <div class="yb-kontakt-studio-media">
        <div class="yb-kontakt-studio-video">
          <video autoplay muted loop playsinline preload="metadata"
                 poster="{{ t.studio_video_poster | cdnUrl }}">
            <source src="{{ t.studio_video_src | cdnUrl }}" type="video/mp4">
          </video>
        </div>
      </div>
      <div class="yb-kontakt-studio-copy">
        <p class="yb-kontakt-text">{{ t.studio_text | safe }}</p>
        <div class="yb-kontakt-studio-features">
          <div class="yb-kontakt-studio-feat">
            <span class="yb-kontakt-studio-feat__icon">{{ t.studio_feat1_icon }}</span>
            <div>
              <strong>{{ t.studio_feat1_title }}</strong>
              <span>{{ t.studio_feat1_desc }}</span>
            </div>
          </div>
          <div class="yb-kontakt-studio-feat">
            <span class="yb-kontakt-studio-feat__icon">{{ t.studio_feat2_icon }}</span>
            <div>
              <strong>{{ t.studio_feat2_title }}</strong>
              <span>{{ t.studio_feat2_desc }}</span>
            </div>
          </div>
          <div class="yb-kontakt-studio-feat">
            <span class="yb-kontakt-studio-feat__icon">{{ t.studio_feat3_icon }}</span>
            <div>
              <strong>{{ t.studio_feat3_title }}</strong>
              <span>{{ t.studio_feat3_desc }}</span>
            </div>
          </div>
          <div class="yb-kontakt-studio-feat">
            <span class="yb-kontakt-studio-feat__icon">{{ t.studio_feat4_icon }}</span>
            <div>
              <strong>{{ t.studio_feat4_title }}</strong>
              <span>{{ t.studio_feat4_desc }}</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Horizontal scroll image gallery -->
    <div class="yb-kontakt-gallery yb-fade-in">
      <h3 class="yb-kontakt-gallery__title">{{ t.studio_gallery_title }}</h3>
      <div class="yb-kontakt-gallery__track" id="ybStudioGallery">
        <div class="yb-kontakt-gallery__slide">
          <img src="/assets/images/studio/studio-hot-room.jpg" alt="{{ t.studio_img1_alt }}" loading="lazy" decoding="async">
        </div>
        <div class="yb-kontakt-gallery__slide">
          <img src="/assets/images/studio/studio-main-room.jpg" alt="{{ t.studio_img2_alt }}" loading="lazy" decoding="async">
        </div>
        <div class="yb-kontakt-gallery__slide">
          <img src="/assets/images/copenhagen/christianshavn-canal.jpg" alt="{{ t.studio_img3_alt }}" loading="lazy" decoding="async">
        </div>
        <div class="yb-kontakt-gallery__slide">
          <img src="{{ mediaBase }}/yoga-bible-DK/studio/dsc-8528.jpg" alt="{{ t.studio_img4_alt }}" loading="lazy" decoding="async">
        </div>
        <div class="yb-kontakt-gallery__slide">
          <img src="/assets/images/copenhagen/copenhagen-hero.jpg" alt="{{ t.studio_img5_alt }}" loading="lazy" decoding="async">
        </div>
      </div>
      <!-- Navigation arrows -->
      <div class="yb-kontakt-gallery__nav">
        <button class="yb-kontakt-gallery__arrow yb-kontakt-gallery__arrow--prev" aria-label="Previous" type="button">&#8592;</button>
        <button class="yb-kontakt-gallery__arrow yb-kontakt-gallery__arrow--next" aria-label="Next" type="button">&#8594;</button>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════
     BOOKING NUDGE — Prefer to meet in person?
     ═══════════════════════════════════════════════════════════════ -->
<div style="text-align:center;padding:2.5rem 1rem 0;">
  <p style="color:#6F6A66;font-size:0.95rem;margin-bottom:0.75rem;">
    {% if lang == 'en' %}Prefer to talk in person? Book a free, no-obligation info session at our studio.{% else %}Foretrækker du at tale personligt? Book et gratis og uforpligtende infomøde i vores studie.{% endif %}
  </p>
  <a class="yb-btn yb-btn--primary" href="{% if lang == 'en' %}/en/kontakt?booking=info-session{% else %}/kontakt?booking=info-session{% endif %}" data-open-booking="info-session">
    &#127963; {% if lang == 'en' %}Book a Free Info Session{% else %}Book et Gratis Infomøde{% endif %}
  </a>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     CONTACT FORM
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-kontakt-form-section">
  <div class="container">
    <h2 class="section-title yb-fade-in">{{ t.form_title }}</h2>
    <p class="section-subtitle yb-fade-in">{{ t.form_subtitle }}</p>

    <div class="yb-kontakt-form-card yb-fade-in">
      <form id="ybForm" class="yb-kontakt-form" novalidate
        data-msg-antispam="{{ t.js_antispam_error }}"
        data-msg-wait="{{ t.js_wait_error }}"
        data-msg-sending="{{ t.js_sending }}"
        data-msg-submit="{{ t.submit_btn }}">

        <!-- Honeypot -->
        <input class="yb-kontakt-hp" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true">
        <!-- Timing -->
        <input type="hidden" name="yb_ts" id="ybTs">
        <input type="hidden" name="yb_elapsed" id="ybElapsed">

        <!-- Name row (2-col) -->
        <div class="yb-kontakt-form__grid">
          <label class="yb-kontakt-field">
            <span>{{ t.label_firstname }}</span>
            <input type="text" name="firstName" id="ybFirstName" required>
          </label>
          <label class="yb-kontakt-field">
            <span>{{ t.label_lastname }}</span>
            <input type="text" name="lastName" id="ybLastName" required>
          </label>
        </div>

        <!-- Email + Phone row (2-col) -->
        <div class="yb-kontakt-form__grid">
          <label class="yb-kontakt-field">
            <span>{{ t.label_email }}</span>
            <input type="email" name="email" id="ybEmail" inputmode="email" required>
          </label>
          <label class="yb-kontakt-field">
            <span>{{ t.label_phone }}</span>
            <input type="tel" name="phone" id="ybPhone" inputmode="tel" required>
          </label>
        </div>

        <!-- Topic (full-width) -->
        <label class="yb-kontakt-field">
          <span>{{ t.label_topic }}</span>
          <select name="topic" id="ybTopic" required>
            <option value="">{{ t.topic_placeholder }}</option>
            <option value="generel">{{ t.topic_general }}</option>
            <option value="uddannelse">{{ t.topic_education }}</option>
            <option value="kursus">{{ t.topic_course }}</option>
            <option value="indkvartering">{{ t.topic_accommodation }}</option>
            <option value="job">{{ t.topic_job }}</option>
          </select>
        </label>

        <!-- Anti-spam (full-width) -->
        <label class="yb-kontakt-field">
          <span>{{ t.label_antispam }}</span>
          <input type="text" name="antispam" id="ybAntispam" required autocomplete="off" placeholder="NAMASTE">
        </label>

        <!-- Message (full-width) -->
        <label class="yb-kontakt-field">
          <span>{{ t.label_message }}</span>
          <textarea name="message" id="ybMessage" rows="6" required placeholder="{{ t.message_placeholder }}"></textarea>
        </label>

        <p class="yb-kontakt-fine">{{ t.required_note }}</p>

        <!-- Error -->
        <p id="ybFormError" class="yb-kontakt-error" hidden role="alert" aria-live="polite"></p>

        <!-- Submit -->
        <button id="ybSubmitBtn" class="yb-btn yb-btn--primary yb-btn--full" type="submit">{{ t.submit_btn }}</button>
      </form>

      <!-- Success -->
      <div id="ybFormSuccess" class="yb-kontakt-success" hidden role="status" aria-live="polite">
        <div class="yb-kontakt-success__icon">&#10003;</div>
        <h3>{{ t.success_title }}</h3>
        <p>{{ t.success_message }}</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════
     FIND US — Location Card
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-kontakt-findus">
  <div class="container">
    <h2 class="section-title yb-fade-in">{{ t.findus_title }}</h2>
    <p class="section-subtitle yb-fade-in">{{ t.findus_subtitle }}</p>

    <div class="yb-kontakt-location yb-fade-in">
      <div class="yb-kontakt-location__card">
        <h3 class="yb-kontakt-location__name">{{ t.findus_studio }}</h3>
        <div class="yb-kontakt-location__info">
          <p>
            <strong>{{ t.intro_address_label }}</strong><br>
            {{ t.intro_address }}
          </p>
          <p>
            <strong>{{ t.intro_phone_label }}</strong><br>
            <a href="tel:{{ site.phone | replace(' ', '') }}">{{ site.phone }}</a>
          </p>
          <p>
            <strong>{{ t.intro_email_label }}</strong><br>
            <a href="mailto:{{ site.email }}">{{ site.email }}</a>
          </p>
          <p>
            <strong>{{ t.intro_hours_label }}</strong><br>
            {{ t.intro_hours }}
          </p>
        </div>
        <a href="{{ t.findus_directions_url }}" target="_blank" rel="noopener" class="yb-btn yb-btn--primary">
          {{ t.findus_directions }} →
        </a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════
     KONTAKT FORM JS — Anti-spam, honeypot, time-trap
     ═══════════════════════════════════════════════════════════════ -->
<script>
(function() {
  'use strict';
  var FORM_URL = '/.netlify/functions/lead';
  var form = document.getElementById('ybForm');
  var errBox = document.getElementById('ybFormError');
  var successBox = document.getElementById('ybFormSuccess');
  var submitBtn = document.getElementById('ybSubmitBtn');
  var tsField = document.getElementById('ybTs');
  var elField = document.getElementById('ybElapsed');

  if (!form) return;

  var MSG_ANTISPAM = form.getAttribute('data-msg-antispam') || 'Udfyld venligst anti-spam korrekt (skriv: NAMASTE).';
  var MSG_WAIT = form.getAttribute('data-msg-wait') || 'Vent venligst et \u00f8jeblik og pr\u00f8v igen.';
  var MSG_SENDING = form.getAttribute('data-msg-sending') || 'Sender\u2026';
  var MSG_SUBMIT = form.getAttribute('data-msg-submit') || 'Send henvendelse';

  var loadTime = Date.now();
  if (tsField) tsField.value = loadTime;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    if (errBox) errBox.hidden = true;

    var elapsed = Date.now() - loadTime;
    if (elField) elField.value = elapsed;

    // Anti-spam check
    var antispam = document.getElementById('ybAntispam');
    if (!antispam || antispam.value.trim().toUpperCase() !== 'NAMASTE') {
      errBox.textContent = MSG_ANTISPAM;
      errBox.hidden = false;
      if (antispam) antispam.focus();
      return;
    }

    // Time trap (minimum 3 seconds)
    if (elapsed < 3000) {
      errBox.textContent = MSG_WAIT;
      errBox.hidden = false;
      return;
    }

    // Honeypot check
    var hp = form.querySelector('[name="website"]');
    if (hp && hp.value) return;

    // Native validation
    if (!form.reportValidity()) return;

    submitBtn.disabled = true;
    submitBtn.textContent = MSG_SENDING;

    var fd = new FormData(form);
    var payload = {
      action: 'contact',
      firstName: fd.get('firstName') || '',
      lastName: fd.get('lastName') || '',
      email: fd.get('email') || '',
      phone: fd.get('phone') || '',
      message: fd.get('message') || '',
      source: 'Contact form'
    };

    // Attach attribution data (UTM, referrer, channel)
    if (typeof window.ybAttribution === 'function') {
      var attr = window.ybAttribution();
      if (attr.channel) payload.channel = attr.channel;
      if (attr.utm_source) payload.utm_source = attr.utm_source;
      if (attr.utm_medium) payload.utm_medium = attr.utm_medium;
      if (attr.utm_campaign) payload.utm_campaign = attr.utm_campaign;
      if (attr.gclid) payload.gclid = attr.gclid;
      if (attr.fbclid) payload.fbclid = attr.fbclid;
      if (attr.referrer) payload.referrer = attr.referrer;
      if (attr.landing_page) payload.landing_page = attr.landing_page;
    }

    fetch(FORM_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .finally(function() {
      submitBtn.disabled = false;
      submitBtn.textContent = MSG_SUBMIT;
      form.hidden = true;
      successBox.hidden = false;

      // Reset after 6 seconds
      setTimeout(function() {
        form.reset();
        successBox.hidden = true;
        if (tsField) tsField.value = Date.now();
        form.hidden = false;
      }, 6000);
    });
  });
})();
</script>

<!-- Studio gallery navigation -->
<script>
(function() {
  var track = document.getElementById('ybStudioGallery');
  if (!track) return;
  var prevBtn = track.parentElement.querySelector('.yb-kontakt-gallery__arrow--prev');
  var nextBtn = track.parentElement.querySelector('.yb-kontakt-gallery__arrow--next');
  var scrollAmount = 340;

  if (prevBtn) {
    prevBtn.addEventListener('click', function() {
      track.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });
  }
  if (nextBtn) {
    nextBtn.addEventListener('click', function() {
      track.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  }
})();
</script>

<!-- Scroll-triggered fade-in observer -->
<script>
(function() {
  if (!('IntersectionObserver' in window)) {
    document.querySelectorAll('.yb-fade-in').forEach(function(el) { el.classList.add('yb-visible'); });
    return;
  }
  var fadeObserver = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('yb-visible');
        fadeObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
  document.querySelectorAll('.yb-fade-in').forEach(function(el) {
    fadeObserver.observe(el);
  });
})();
</script>
