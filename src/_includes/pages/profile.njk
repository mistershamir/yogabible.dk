{% set t = i18n.profile[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

<section class="yb-profile">
  <div class="container">

    <!-- Not logged in state -->
    <div id="yb-profile-guest" class="yb-profile__guest">
      <div class="yb-profile__guest-inner">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        <h2 class="yb-profile__guest-title">{{ t.not_logged_in_title }}</h2>
        <p class="yb-profile__guest-text">{{ t.not_logged_in_text }}</p>
        <div class="yb-profile__guest-actions">
          <button class="yb-btn yb-btn--primary" type="button" data-yb-auth-open="login">{{ t.login_btn }}</button>
          <button class="yb-btn yb-btn--outline" type="button" data-yb-auth-open="register">{{ t.register_btn }}</button>
        </div>
      </div>
    </div>

    <!-- Logged in state -->
    <div id="yb-profile-user" style="display:none">
      <div class="yb-profile__wrap">

        <!-- Hero header -->
        <div class="yb-profile__hero">
          <div class="yb-profile__hero-top">
            <span class="yb-profile__hero-logo">YOGA BIBLE</span>
            <div class="yb-profile__hero-actions">
              <div class="yb-profile__hero-lang">
                <button{% if lang != "en" %} class="is-active"{% endif %} onclick="window.location.href='{{ lp }}/profile/'">DA</button>
                <button{% if lang == "en" %} class="is-active"{% endif %} onclick="window.location.href='{% if lang == 'en' %}/profile/{% else %}/en/profile/{% endif %}'">EN</button>
              </div>
              <button class="yb-profile__hero-logout" type="button" data-yb-auth-logout>{{ t.btn_logout }}</button>
            </div>
          </div>
          <div class="yb-profile__hero-user">
            <div class="yb-profile__avatar-wrap">
              <div class="yb-profile__avatar" id="yb-profile-avatar">YB</div>
              <button class="yb-profile__avatar-edit" type="button" id="yb-profile-avatar-btn" title="{{ t.avatar_change }}">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
              </button>
              <input type="file" id="yb-profile-avatar-input" accept="image/*" hidden>
            </div>
            <div>
              <span class="yb-profile__member-name" id="yb-profile-display-name"></span>
              <p class="yb-profile__member-meta">
                <span id="yb-profile-display-email"></span>
                <span class="yb-profile__member-badge" id="yb-profile-tier">&mdash;</span>
                <span class="yb-profile__role-badge" id="yb-profile-role-badge" style="display:none"></span>
              </p>
              {# Member since hidden for now #}
            </div>
          </div>
        </div>

        <!-- Tab navigation -->
        <div class="yb-profile__tabs">
          <button class="yb-profile__tab is-active" type="button" data-yb-tab="profile">{{ t.tab_profile }}</button>
          <button class="yb-profile__tab" type="button" data-yb-tab="schedule">{{ t.tab_schedule }}</button>
          <button class="yb-profile__tab" type="button" data-yb-tab="store">{{ t.tab_store }}</button>
          <button class="yb-profile__tab" type="button" data-yb-tab="visits">{{ t.tab_visits }}</button>
          <button class="yb-profile__tab" type="button" data-yb-tab="passes">{{ t.tab_passes }}</button>
          <button class="yb-profile__tab" type="button" data-yb-tab="applications">{{ t.tab_applications }}</button>
          <button class="yb-profile__tab" type="button" data-yb-tab="receipts">{{ t.tab_receipts }}</button>
          <button class="yb-profile__tab" type="button" data-yb-tab="giftcards">{{ t.tab_giftcards }}</button>
          {# CRM tabs — visible only for marketing and admin roles #}
          <button class="yb-profile__tab yb-profile__tab--crm" type="button" data-yb-tab="crm-leads" data-yb-role="marketing,admin" style="display:none">{{ t.tab_crm_leads }}</button>
          <button class="yb-profile__tab yb-profile__tab--crm" type="button" data-yb-tab="crm-applications" data-yb-role="marketing,admin" style="display:none">{{ t.tab_crm_applications }}</button>
          <button class="yb-profile__tab yb-profile__tab--crm" type="button" data-yb-tab="crm-appointments" data-yb-role="marketing,admin" style="display:none">{{ t.tab_crm_appointments }}</button>
        </div>

        {# ═══════ TAB: Profile ═══════ #}
        <div class="yb-profile__tab-panel is-active" data-yb-panel="profile">
          <div class="yb-profile__content-area">

            <!-- Inline onboarding card (shown until phone+DOB are filled) -->
            <div id="yb-onboarding-inline" class="yb-onboarding-inline" hidden>
              <div class="yb-onboarding-inline__card">
                <div class="yb-onboarding-inline__header">
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  <div>
                    <h3 class="yb-onboarding-inline__title">{{ t.onboarding_title }}</h3>
                    <p class="yb-onboarding-inline__desc">{{ t.onboarding_desc }}</p>
                  </div>
                </div>
                <form id="yb-onboarding-form" class="yb-onboarding-inline__form" novalidate>
                  <div class="yb-profile__form-row">
                    <div class="yb-auth-field">
                      <label for="yb-onboarding-phone">{{ t.label_phone }} <span style="color:#f75c03">*</span></label>
                      <input type="tel" id="yb-onboarding-phone" autocomplete="tel" placeholder="{{ t.placeholder_phone }}" required>
                    </div>
                    <div class="yb-auth-field">
                      <label for="yb-onboarding-dob">{{ t.label_dob }} <span style="color:#f75c03">*</span></label>
                      <input type="date" id="yb-onboarding-dob" required>
                    </div>
                  </div>
                  <div class="yb-auth-error" id="yb-onboarding-error" hidden role="alert"></div>
                  <button type="submit" class="yb-btn yb-btn--primary">{{ t.onboarding_submit }}</button>
                </form>
              </div>
            </div>

            <!-- Onboarding success message (shown after phone+DOB saved) -->
            <div id="yb-onboarding-success" class="yb-onboarding-success" hidden>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <span>{{ t.onboarding_success }}</span>
            </div>

            <!-- Personal details -->
            <div class="yb-profile__card">
              <h2 class="yb-profile__card-title">{{ t.section_personal }}</h2>
              <form id="yb-profile-form" class="yb-profile__form" novalidate>
                <div class="yb-profile__form-row">
                  <div class="yb-auth-field">
                    <label for="yb-profile-firstname">{{ t.label_firstname }}</label>
                    <input type="text" id="yb-profile-firstname" autocomplete="given-name">
                  </div>
                  <div class="yb-auth-field">
                    <label for="yb-profile-lastname">{{ t.label_lastname }}</label>
                    <input type="text" id="yb-profile-lastname" autocomplete="family-name">
                  </div>
                </div>
                <div class="yb-auth-field">
                  <label for="yb-profile-email">{{ t.label_email }}</label>
                  <input type="email" id="yb-profile-email" disabled>
                </div>
                <div class="yb-profile__form-row">
                  <div class="yb-auth-field">
                    <label for="yb-profile-phone">{{ t.label_phone }}</label>
                    <input type="tel" id="yb-profile-phone" autocomplete="tel" placeholder="{{ t.placeholder_phone }}">
                  </div>
                  <div class="yb-auth-field">
                    <label for="yb-profile-dob">{{ t.label_dob }}</label>
                    <input type="date" id="yb-profile-dob">
                  </div>
                </div>
                <div class="yb-profile__form-row">
                  <div class="yb-auth-field">
                    <label for="yb-profile-yoga-level">{{ t.label_yoga_level }}</label>
                    <select id="yb-profile-yoga-level" class="yb-auth-field__select">
                      <option value="">{{ t.yoga_level_placeholder }}</option>
                      <option value="beginner">{{ t.yoga_level_beginner }}</option>
                      <option value="intermediate">{{ t.yoga_level_intermediate }}</option>
                      <option value="advanced">{{ t.yoga_level_advanced }}</option>
                    </select>
                  </div>
                  <div class="yb-auth-field">
                    <label for="yb-profile-practice-freq">{{ t.label_practice_freq }}</label>
                    <select id="yb-profile-practice-freq" class="yb-auth-field__select">
                      <option value="">{{ t.practice_freq_placeholder }}</option>
                      <option value="occasional">{{ t.practice_freq_occasional }}</option>
                      <option value="regular">{{ t.practice_freq_regular }}</option>
                      <option value="dedicated">{{ t.practice_freq_dedicated }}</option>
                    </select>
                  </div>
                </div>
                <!-- Soft reminder for missing phone/DOB -->
                <div class="yb-profile__reminder" id="yb-profile-reminder" hidden>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  <span>{{ t.profile_reminder }}</span>
                </div>
                <div class="yb-auth-error" id="yb-profile-error" hidden role="alert"></div>
                <div class="yb-auth-success" id="yb-profile-success" hidden role="status"></div>
                <button type="submit" class="yb-auth-submit">{{ t.btn_save }}</button>
              </form>
            </div>

            <!-- Change password -->
            <div class="yb-profile__card">
              <h2 class="yb-profile__card-title">{{ t.section_password }}</h2>
              <form id="yb-profile-password-form" class="yb-profile__form" novalidate>
                <div class="yb-profile__form-row">
                  <div class="yb-auth-field">
                    <label for="yb-profile-new-password">{{ t.label_new_password }}</label>
                    <input type="password" id="yb-profile-new-password" autocomplete="new-password" placeholder="{{ t.placeholder_password }}">
                  </div>
                  <div class="yb-auth-field">
                    <label for="yb-profile-confirm-password">{{ t.label_confirm_password }}</label>
                    <input type="password" id="yb-profile-confirm-password" autocomplete="new-password" placeholder="{{ t.placeholder_password }}">
                  </div>
                </div>
                <div class="yb-auth-error" id="yb-profile-pw-error" hidden role="alert"></div>
                <div class="yb-auth-success" id="yb-profile-pw-success" hidden role="status"></div>
                <button type="submit" class="yb-auth-submit">{{ t.btn_change_password }}</button>
              </form>
            </div>

            <!-- Stored Credit Card -->
            <div class="yb-profile__card" id="yb-stored-card-section">
              <h2 class="yb-profile__card-title">{{ t.section_payment }}</h2>
              <div id="yb-stored-card-loading" class="yb-stored-card__loading">
                <div class="yb-mb-spinner" style="width:18px;height:18px"></div>
                <span style="color:#6F6A66;font-size:0.9rem">{{ t.stored_card_loading }}</span>
              </div>
              <div id="yb-stored-card-display" hidden>
                <div class="yb-stored-card">
                  <div class="yb-stored-card__info">
                    <svg class="yb-stored-card__icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                    <div>
                      <span class="yb-stored-card__type" id="yb-stored-card-type"></span>
                      <span class="yb-stored-card__number" id="yb-stored-card-number"></span>
                    </div>
                  </div>
                  <div class="yb-stored-card__meta">
                    <span class="yb-stored-card__holder" id="yb-stored-card-holder"></span>
                    <span class="yb-stored-card__exp" id="yb-stored-card-exp"></span>
                  </div>
                  <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" id="yb-stored-card-change">{{ t.stored_card_change }}</button>
                </div>
              </div>
              <div id="yb-stored-card-empty" hidden>
                <p class="yb-stored-card__empty-text">{{ t.stored_card_empty }}</p>
              </div>
              {# Inline change-card form (hidden by default) #}
              <div id="yb-stored-card-form" class="yb-stored-card__form" hidden>
                <h3 class="yb-stored-card__form-title">{{ t.stored_card_new_title }}</h3>
                <form id="yb-stored-card-form-inner" class="yb-profile__form" novalidate autocomplete="on">
                  <div class="yb-profile__form-grid" style="grid-template-columns:1fr">
                    <div class="yb-profile__field">
                      <label class="yb-profile__label" for="yb-sc-cardholder">{{ t.checkout_card_name }}</label>
                      <input type="text" id="yb-sc-cardholder" class="yb-profile__input" autocomplete="cc-name" required>
                    </div>
                    <div class="yb-profile__field">
                      <label class="yb-profile__label" for="yb-sc-cardnumber">{{ t.checkout_card_number }}</label>
                      <input type="text" id="yb-sc-cardnumber" class="yb-profile__input" inputmode="numeric" autocomplete="cc-number" maxlength="19" required>
                    </div>
                    <div class="yb-profile__form-grid" style="grid-template-columns:1fr 1fr">
                      <div class="yb-profile__field">
                        <label class="yb-profile__label" for="yb-sc-expiry">{{ t.checkout_card_expiry }}</label>
                        <input type="text" id="yb-sc-expiry" class="yb-profile__input" placeholder="MM/YY" inputmode="numeric" autocomplete="cc-exp" maxlength="5" required>
                      </div>
                      <div class="yb-profile__field">
                        <label class="yb-profile__label" for="yb-sc-cvv">{{ t.checkout_card_cvv }}</label>
                        <input type="text" id="yb-sc-cvv" class="yb-profile__input" inputmode="numeric" autocomplete="cc-csc" maxlength="4" required>
                      </div>
                    </div>
                  </div>
                  <div class="yb-auth-error" id="yb-sc-error" hidden></div>
                  <div class="yb-stored-card__form-actions">
                    <button type="submit" class="yb-btn yb-btn--primary yb-btn--sm" id="yb-sc-save-btn">{{ t.stored_card_save }}</button>
                    <button type="button" class="yb-btn yb-btn--outline yb-btn--sm" id="yb-sc-cancel-btn">{{ t.stored_card_cancel_form }}</button>
                  </div>
                </form>
              </div>
            </div>

            <!-- Membership summary (details in My Passes tab) -->
            <div class="yb-profile__card">
              <h2 class="yb-profile__card-title">{{ t.section_membership }}</h2>
              <div class="yb-profile__info-grid">
                <div class="yb-profile__info-item">
                  <span class="yb-profile__info-label">{{ t.label_tier }}</span>
                  <span class="yb-profile__info-value" id="yb-profile-tier-detail">&mdash;</span>
                </div>
                <div class="yb-profile__info-item" id="yb-profile-client-id-wrap" hidden>
                  <span class="yb-profile__info-label">{{ t.label_client_id }}</span>
                  <span class="yb-profile__info-value yb-profile__info-value--muted" id="yb-profile-client-id">&mdash;</span>
                </div>
              </div>
            </div>

          </div>
        </div>

        {# ═══════ TAB: Schedule ═══════ #}
        <div class="yb-profile__tab-panel" data-yb-panel="schedule">
          <div class="yb-profile__content-area">
          <div class="yb-schedule">
          <div class="yb-schedule__header">
            <h2 class="yb-schedule__title">{{ t.schedule_title }}</h2>
            <p class="yb-schedule__subtitle">{{ t.schedule_subtitle }}</p>
          </div>

          <!-- Pass info or no-pass prompt (toggled by JS) -->
          <div id="yb-schedule-pass-info" class="yb-schedule__pass-info" hidden></div>
          <div id="yb-schedule-no-pass" class="yb-schedule__no-pass" hidden>
            <p>{{ t.schedule_no_pass }}</p>
            <button class="yb-btn yb-btn--primary" type="button" id="yb-schedule-buy-pass">{{ t.schedule_buy_pass }}</button>
          </div>

          <div class="yb-schedule__nav">
            <button class="yb-schedule__nav-btn" type="button" id="yb-schedule-prev">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
              <span class="yb-schedule__nav-label">{{ t.schedule_prev_week }}</span>
            </button>
            <span class="yb-schedule__week-label" id="yb-schedule-week-label"></span>
            <button class="yb-schedule__nav-btn" type="button" id="yb-schedule-next">
              <span class="yb-schedule__nav-label">{{ t.schedule_next_week }}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>

          <!-- Schedule list (loaded via JS) -->
          <div id="yb-schedule-list" class="yb-schedule__list">
            <div class="yb-store__loading">
              <div class="yb-mb-spinner"></div>
              <span>{{ t.schedule_loading }}</span>
            </div>
          </div>

          <!-- Toast notification -->
          <div id="yb-schedule-toast" class="yb-schedule__toast" hidden></div>
          </div>
          </div>
        </div>

        {# ═══════ TAB: Store ═══════ #}
        <div class="yb-profile__tab-panel" data-yb-panel="store" data-store-items="{{ t.store_items | join(',') }}">
          <div class="yb-profile__content-area">
          <div class="yb-store">
          <div class="yb-store__header">
            <h2 class="yb-store__title">{{ t.store_title }}</h2>
            <p class="yb-store__subtitle">{{ t.store_subtitle }}</p>
          </div>

          <!-- Services list (loaded via JS) -->
          <div id="yb-store-list" class="yb-store__list">
            <div class="yb-store__loading">
              <div class="yb-mb-spinner"></div>
              <span>{{ t.store_loading }}</span>
            </div>
          </div>

          <!-- Checkout overlay (hidden by default) -->
          <div id="yb-store-checkout" class="yb-store__checkout" hidden>
            <div class="yb-store__checkout-inner">
              <h3 class="yb-store__checkout-title">{{ t.checkout_title }}</h3>

              <!-- Selected service summary -->
              <div class="yb-store__checkout-item" id="yb-store-checkout-item"></div>

              <!-- Start date picker (contracts/memberships only) -->
              <div class="yb-store__checkout-startdate" id="yb-checkout-startdate" hidden>
                <label for="yb-store-start-date">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                  <span id="yb-checkout-startdate-label">Startdato</span>
                </label>
                <input type="date" id="yb-store-start-date">
              </div>

              <!-- Two-column grid: left = waiver/terms, right = payment -->
              <div class="yb-checkout__grid" id="yb-checkout-grid">

                <!-- Left column: Waiver + Contract Terms (unified single signature) -->
                <div class="yb-checkout__col-left" id="yb-checkout-col-left">

                  <!-- Collapsible: Liability waiver (shown if waiver not yet signed) -->
                  <div id="yb-checkout-waiver-section" class="yb-checkout-doc" hidden>
                    <button type="button" class="yb-checkout-doc__toggle" id="yb-checkout-waiver-toggle">
                      <span class="yb-checkout-doc__toggle-title">{{ t.waiver_title }}</span>
                      <svg class="yb-checkout-doc__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div id="yb-checkout-waiver-text" class="yb-checkout-doc__content" hidden></div>
                  </div>

                  <!-- Collapsible: Contract terms (shown for contracts with AgreementTerms) -->
                  <div id="yb-checkout-terms-section" class="yb-checkout-doc" hidden>
                    <button type="button" class="yb-checkout-doc__toggle" id="yb-checkout-terms-toggle">
                      <span class="yb-checkout-doc__toggle-title">{{ t.contract_terms_title }}</span>
                      <svg class="yb-checkout-doc__chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
                    </button>
                    <div id="yb-checkout-terms-text" class="yb-checkout-doc__content" hidden></div>
                  </div>

                  <!-- Unified agreement + single signature -->
                  <div id="yb-checkout-agree-section" class="yb-checkout-agree" hidden>
                    <label class="yb-waiver__agree">
                      <input type="checkbox" id="yb-checkout-agree-check">
                      <span id="yb-checkout-agree-label">{{ t.waiver_agree_label }}</span>
                    </label>
                    <p class="yb-waiver__sign-label">{{ t.checkout_sign_label }}</p>
                    <div class="yb-signature-pad" id="yb-checkout-sigpad">
                      <canvas id="yb-checkout-canvas" width="400" height="160"></canvas>
                      <button type="button" class="yb-signature-pad__clear" id="yb-checkout-sig-clear">{{ t.signature_clear }}</button>
                    </div>
                  </div>

                </div>

                <!-- Right column: Payment form -->
                <div class="yb-checkout__col-right">
                  <h4 class="yb-checkout__payment-title">{{ t.checkout_payment_title }}</h4>
                  <form id="yb-store-checkout-form" class="yb-profile__form" novalidate>
                    <!-- Stored card option (shown when user has a saved card) -->
                    <div id="yb-store-stored-card" class="yb-checkout-stored-card" hidden>
                      <label class="yb-checkout-stored-card__option yb-checkout-stored-card__option--active" id="yb-store-use-stored">
                        <input type="radio" name="yb-store-payment-method" value="stored" checked>
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
                        <span id="yb-store-stored-label"></span>
                      </label>
                      <label class="yb-checkout-stored-card__option" id="yb-store-use-new">
                        <input type="radio" name="yb-store-payment-method" value="new">
                        <span>{{ t.checkout_new_card }}</span>
                      </label>
                    </div>
                    <div id="yb-store-card-fields">
                    <div class="yb-auth-field">
                      <label for="yb-store-cardholder">{{ t.checkout_cardholder }}</label>
                      <input type="text" id="yb-store-cardholder" required autocomplete="cc-name">
                    </div>
                    <div class="yb-auth-field">
                      <label for="yb-store-cardnumber">{{ t.checkout_card_number }}</label>
                      <input type="text" id="yb-store-cardnumber" required autocomplete="cc-number" placeholder="1234 5678 9012 3456" inputmode="numeric" maxlength="19">
                    </div>
                    <div class="yb-profile__form-row yb-profile__form-row--3">
                      <div class="yb-auth-field">
                        <label for="yb-store-expiry">{{ t.checkout_expiry }}</label>
                        <input type="text" id="yb-store-expiry" required placeholder="MM/YY" inputmode="numeric" maxlength="5">
                      </div>
                      <div class="yb-auth-field">
                        <label for="yb-store-cvv">{{ t.checkout_cvv }}</label>
                        <input type="text" id="yb-store-cvv" required autocomplete="cc-csc" placeholder="123" inputmode="numeric" maxlength="4">
                      </div>
                    </div>
                    <div class="yb-auth-field">
                      <label for="yb-store-address">{{ t.checkout_address }}</label>
                      <input type="text" id="yb-store-address" autocomplete="street-address">
                    </div>
                    <div class="yb-profile__form-row">
                      <div class="yb-auth-field">
                        <label for="yb-store-city">{{ t.checkout_city }}</label>
                        <input type="text" id="yb-store-city" autocomplete="address-level2">
                      </div>
                      <div class="yb-auth-field">
                        <label for="yb-store-zip">{{ t.checkout_zip }}</label>
                        <input type="text" id="yb-store-zip" autocomplete="postal-code">
                      </div>
                    </div>

                    <label class="yb-store__save-card">
                      <input type="checkbox" id="yb-store-save-card" checked>
                      <span>{{ t.checkout_save_card }}</span>
                    </label>
                    </div>{# end yb-store-card-fields #}

                    <div class="yb-auth-error" id="yb-store-error" hidden role="alert"></div>

                    <div class="yb-store__checkout-actions">
                      <button type="submit" class="yb-auth-submit" id="yb-store-pay-btn">{{ t.checkout_pay }}</button>
                      <button type="button" class="yb-btn yb-btn--outline" id="yb-store-cancel-btn">{{ t.checkout_cancel }}</button>
                    </div>

                    <div class="yb-store__secure">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                      {{ t.checkout_secure }}
                    </div>
                  </form>
                </div>

              </div>
            </div>
          </div>

          <!-- Success state -->
          <div id="yb-store-success" class="yb-store__success" hidden>
            <div class="yb-store__success-inner">
              <div class="yb-checkout-success__icon">&#10003;</div>
              <h3>{{ t.checkout_success_title }}</h3>
              <p>{{ t.checkout_success_text }}</p>
              <div class="yb-store__success-actions">
                <button class="yb-btn yb-btn--primary" type="button" id="yb-store-success-book">{{ t.checkout_success_book }}</button>
                <button class="yb-btn yb-btn--outline" type="button" id="yb-store-success-close">{{ t.checkout_success_close }}</button>
              </div>
            </div>
          </div>
          </div>
          </div>
        </div>

        {# ═══════ TAB: Visit History ═══════ #}
        <div class="yb-profile__tab-panel" data-yb-panel="visits">
          <div class="yb-profile__content-area">
          <div class="yb-visits">
          <div class="yb-visits__header">
            <h2 class="yb-visits__title">{{ t.visits_title }}</h2>
            <p class="yb-visits__subtitle">{{ t.visits_subtitle }}</p>
          </div>
          <div class="yb-visits__controls">
            <div class="yb-visits__filters">
              <button class="yb-visits__filter is-active" type="button" data-visit-filter="all">{{ t.visits_filter_all }}</button>
              <button class="yb-visits__filter" type="button" data-visit-filter="upcoming">{{ t.visits_filter_upcoming }}</button>
              <button class="yb-visits__filter" type="button" data-visit-filter="attended">{{ t.visits_filter_attended }}</button>
              <button class="yb-visits__filter" type="button" data-visit-filter="lateCancelled">{% if lang == 'en' %}Late Cancel{% else %}Sen afmelding{% endif %}</button>
              <button class="yb-visits__filter" type="button" data-visit-filter="noshow">{{ t.visits_filter_noshow }}</button>
            </div>
            <select class="yb-visits__period" id="yb-visits-period">
              <option value="30">{% if lang == 'en' %}Last 30 days{% else %}Sidste 30 dage{% endif %}</option>
              <option value="90" selected>{% if lang == 'en' %}Last 90 days{% else %}Sidste 90 dage{% endif %}</option>
              <option value="180">{% if lang == 'en' %}Last 6 months{% else %}Sidste 6 måneder{% endif %}</option>
              <option value="365">{% if lang == 'en' %}Last year{% else %}Sidste år{% endif %}</option>
            </select>
          </div>
          <div id="yb-visits-list" class="yb-visits__list">
            <div class="yb-store__loading">
              <div class="yb-mb-spinner"></div>
              <span>{{ t.visits_loading }}</span>
            </div>
          </div>
          </div>
          </div>
        </div>

        {# ═══════ TAB: My Passes ═══════ #}
        <div class="yb-profile__tab-panel" data-yb-panel="passes">
          <div class="yb-profile__content-area">
          <div class="yb-membership-tab">
          <div class="yb-membership-tab__header">
            <h2 class="yb-membership-tab__title">{{ t.tab_passes }}</h2>
          </div>

          <!-- Liability waiver status card -->
          <div id="yb-waiver-card" class="yb-waiver-card" hidden>
            <!-- Collapsed state (when signed) -->
            <div id="yb-waiver-card-signed" class="yb-waiver-card__signed" hidden>
              <div class="yb-waiver-card__signed-row">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                <span class="yb-waiver-card__signed-text">{{ t.waiver_signed_label }}</span>
                <span class="yb-waiver-card__signed-date" id="yb-waiver-signed-date"></span>
                <button type="button" class="yb-waiver-card__toggle" id="yb-waiver-toggle-btn">{{ t.waiver_view_details }}</button>
              </div>
            </div>
            <!-- Expanded state (unsigned or expanded) -->
            <div id="yb-waiver-card-body" class="yb-waiver-card__body" hidden>
              <div class="yb-waiver-card__header-row">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                <div>
                  <h3 class="yb-waiver-card__title">{{ t.waiver_title }}</h3>
                  <p class="yb-waiver-card__desc">{{ t.waiver_desc }}</p>
                </div>
              </div>
              <button type="button" class="yb-waiver__read-toggle" id="yb-waiver-read-toggle">
                <span>{{ t.waiver_read_toggle }}</span>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
              </button>
              <div id="yb-waiver-text" class="yb-waiver__text" hidden>
                <div class="yb-store__loading">
                  <div class="yb-mb-spinner"></div>
                  <span>{{ t.waiver_loading }}</span>
                </div>
              </div>
              <div class="yb-waiver__sign-section" id="yb-waiver-sign-section" hidden>
                <label class="yb-waiver__agree">
                  <input type="checkbox" id="yb-waiver-agree-check">
                  <span>{{ t.waiver_agree_label }}</span>
                </label>
                <p class="yb-waiver__sign-label">{{ t.waiver_sign_label }}</p>
                <div class="yb-signature-pad" id="yb-waiver-sigpad">
                  <canvas id="yb-waiver-canvas" width="360" height="120"></canvas>
                  <button type="button" class="yb-signature-pad__clear" id="yb-waiver-sig-clear">{{ t.signature_clear }}</button>
                </div>
                <div class="yb-auth-error" id="yb-waiver-error" hidden role="alert"></div>
                <button type="button" class="yb-btn yb-btn--primary" id="yb-waiver-submit">{{ t.waiver_submit }}</button>
              </div>
            </div>
          </div>

          <div id="yb-membership-details" class="yb-membership">
            <div class="yb-store__loading yb-membership__loading" id="yb-membership-loading" hidden>
              <div class="yb-mb-spinner"></div>
              <span>{{ t.membership_loading }}</span>
            </div>
            <div id="yb-membership-content"></div>
          </div>
          </div>
          </div>
        </div>

        {# ═══════ TAB: My Applications ═══════ #}
        <div class="yb-profile__tab-panel" data-yb-panel="applications">
          <div class="yb-profile__content-area">
            <div class="yb-applications-tab">
              <div class="yb-applications-tab__header">
                <h2 class="yb-applications-tab__title">{{ t.tab_applications }}</h2>
              </div>
              <div id="yb-my-applications-loading" class="yb-store__loading" hidden>
                <div class="yb-mb-spinner"></div>
                <span id="yb-my-applications-loading-text"></span>
              </div>
              <div id="yb-my-applications-content"></div>
            </div>
          </div>
        </div>

        {# ═══════ TAB: Receipts ═══════ #}
        <div class="yb-profile__tab-panel" data-yb-panel="receipts">
          <div class="yb-profile__content-area">
          <div class="yb-receipts">
          <div class="yb-receipts__header">
            <div>
              <h2 class="yb-receipts__title">{{ t.receipts_title }}</h2>
              <p class="yb-receipts__subtitle">{{ t.receipts_subtitle }}</p>
            </div>
            <select class="yb-receipts__period" id="yb-receipts-period">
              <option value="90">{% if lang == 'en' %}Last 90 days{% else %}Sidste 90 dage{% endif %}</option>
              <option value="180">{% if lang == 'en' %}Last 6 months{% else %}Sidste 6 måneder{% endif %}</option>
              <option value="365">{% if lang == 'en' %}Last year{% else %}Sidste år{% endif %}</option>
              <option value="730" selected>{% if lang == 'en' %}Last 2 years{% else %}Sidste 2 år{% endif %}</option>
            </select>
          </div>
          <div id="yb-receipts-list" class="yb-receipts__list">
            <div class="yb-store__loading">
              <div class="yb-mb-spinner"></div>
              <span>{{ t.receipts_loading }}</span>
            </div>
          </div>
          </div>
          </div>
        </div>

        {# ═══════ TAB: Gift Cards ═══════ #}
        <div class="yb-profile__tab-panel" data-yb-panel="giftcards">
          <div class="yb-profile__content-area">
          <div class="yb-giftcards">
            <div class="yb-giftcards__header">
              <h2 class="yb-giftcards__title">{{ t.giftcards_title }}</h2>
              <p class="yb-giftcards__subtitle">{{ t.giftcards_subtitle }}</p>
            </div>
            <div id="yb-giftcards-list" class="yb-giftcards__list">
              <div class="yb-store__loading">
                <div class="yb-mb-spinner"></div>
                <span>{{ t.giftcards_loading }}</span>
              </div>
            </div>
            {# Purchase form (hidden until a gift card is selected) #}
            <div id="yb-giftcard-form" class="yb-giftcards__form" hidden>
              <div class="yb-giftcards__checkout-grid">
                {# Left: Build gift card #}
                <div class="yb-giftcards__checkout-left">
                  <h3 class="yb-giftcards__form-title">{{ t.giftcard_send_title }}</h3>
                  <div class="yb-giftcards__field">
                    <label class="yb-giftcards__label">{{ t.giftcard_recipient_name }}</label>
                    <input type="text" id="yb-gc-recipient-name" class="yb-giftcards__input" required>
                  </div>
                  <div class="yb-giftcards__field">
                    <label class="yb-giftcards__label">{{ t.giftcard_recipient_email }}</label>
                    <input type="email" id="yb-gc-recipient-email" class="yb-giftcards__input" required>
                  </div>
                  <div class="yb-giftcards__field">
                    <label class="yb-giftcards__label">{{ t.giftcard_title_label }}</label>
                    <input type="text" id="yb-gc-title" class="yb-giftcards__input">
                  </div>
                  <div class="yb-giftcards__field">
                    <label class="yb-giftcards__label">{{ t.giftcard_message }}</label>
                    <textarea id="yb-gc-message" class="yb-giftcards__textarea" rows="3"></textarea>
                  </div>
                  <div class="yb-giftcards__field">
                    <label class="yb-giftcards__label">{{ t.giftcard_delivery_date }}</label>
                    <input type="date" id="yb-gc-delivery-date" class="yb-giftcards__input">
                  </div>
                </div>
                {# Right: Payment #}
                <div class="yb-giftcards__checkout-right">
                  <h3 class="yb-giftcards__payment-title">{{ t.checkout_payment_title }}</h3>
                  <div id="yb-gc-stored-card" class="yb-checkout-stored-card" hidden>
                      <label class="yb-checkout-stored-card__option yb-checkout-stored-card__option--active" id="yb-gc-use-stored">
                        <input type="radio" name="yb-gc-payment-method" value="stored" checked>
                        <span class="yb-checkout-stored-card__label">{{ t.checkout_use_stored }}</span>
                        <span class="yb-checkout-stored-card__detail" id="yb-gc-stored-label"></span>
                      </label>
                      <label class="yb-checkout-stored-card__option" id="yb-gc-use-new">
                        <input type="radio" name="yb-gc-payment-method" value="new">
                        <span class="yb-checkout-stored-card__label">{{ t.checkout_use_new }}</span>
                      </label>
                  </div>
                  <div id="yb-gc-card-fields">
                    <div class="yb-giftcards__field">
                      <label class="yb-giftcards__label">{{ t.checkout_card_name }}</label>
                      <input type="text" id="yb-gc-cardholder" class="yb-giftcards__input" autocomplete="cc-name">
                    </div>
                    <div class="yb-giftcards__field">
                      <label class="yb-giftcards__label">{{ t.checkout_card_number }}</label>
                      <input type="text" id="yb-gc-cardnumber" class="yb-giftcards__input" inputmode="numeric" autocomplete="cc-number" maxlength="19">
                    </div>
                    <div class="yb-giftcards__field-row">
                      <div class="yb-giftcards__field">
                        <label class="yb-giftcards__label">{{ t.checkout_card_expiry }}</label>
                        <input type="text" id="yb-gc-expiry" class="yb-giftcards__input" placeholder="MM/YY" inputmode="numeric" autocomplete="cc-exp" maxlength="5">
                      </div>
                      <div class="yb-giftcards__field">
                        <label class="yb-giftcards__label">{{ t.checkout_card_cvv }}</label>
                        <input type="text" id="yb-gc-cvv" class="yb-giftcards__input" inputmode="numeric" autocomplete="cc-csc" maxlength="4">
                      </div>
                    </div>
                    <label class="yb-giftcards__save-card">
                      <input type="checkbox" id="yb-gc-save-card">
                      <span>{{ t.checkout_save_card }}</span>
                    </label>
                  </div>
                  <div class="yb-auth-error" id="yb-gc-error" hidden></div>
                  <button type="button" class="yb-btn yb-btn--primary yb-giftcards__buy-btn" id="yb-gc-buy-btn">{{ t.giftcard_buy_btn }}</button>
                  <button type="button" class="yb-btn yb-btn--outline yb-giftcards__cancel-btn" id="yb-gc-cancel-btn">{{ t.giftcard_cancel_btn }}</button>
                </div>
              </div>
            </div>
            {# Success state #}
            <div id="yb-giftcard-success" class="yb-giftcards__success" hidden>
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              <h3>{{ t.giftcard_success_title }}</h3>
              <p>{{ t.giftcard_success_text }}</p>
              <button type="button" class="yb-btn yb-btn--outline" id="yb-gc-success-close">{{ t.giftcard_success_close }}</button>
            </div>
          </div>
          </div>
        </div>

        {# ═══════ CRM Panels (marketing/admin) — switch t to course-admin translations ═══════ #}
        {% set t_profile = t %}
        {% set t = i18n["course-admin"][lang or "da"] %}

        {# ═══════ TAB: CRM Leads ═══════ #}
        <div class="yb-profile__tab-panel" data-yb-panel="crm-leads" data-yb-role="marketing,admin" style="display:none">
          <div class="yb-profile__content-area yb-profile__crm-panel">
            {% include "partials/admin-leads-panel.njk" %}
          </div>
        </div>

        {# ═══════ TAB: CRM Applications ═══════ #}
        <div class="yb-profile__tab-panel" data-yb-panel="crm-applications" data-yb-role="marketing,admin" style="display:none">
          <div class="yb-profile__content-area yb-profile__crm-panel">
            {% include "partials/admin-applications-panel.njk" %}
          </div>
        </div>

        {# ═══════ TAB: CRM Appointments ═══════ #}
        <div class="yb-profile__tab-panel" data-yb-panel="crm-appointments" data-yb-role="marketing,admin" style="display:none">
          <div class="yb-profile__content-area yb-profile__crm-panel">
            {% include "partials/admin-appointments-panel.njk" %}
          </div>
        </div>

        {# Restore profile translations #}
        {% set t = t_profile %}

      </div><!-- end .yb-profile__wrap -->
    </div><!-- end #yb-profile-user -->
  </div>

  {# Bulk Status Picker Modal (for CRM panels) #}
  <div id="yb-bulk-status-modal" class="yb-lead__modal" hidden>
    <div class="yb-lead__modal-overlay" data-close-bulk-status></div>
    <div class="yb-bulk-status__box">
      <div class="yb-bulk-status__header">
        <h3 id="yb-bulk-status-title">{{ t.tab_crm_leads }}</h3>
        <button type="button" class="yb-admin__icon-btn" data-close-bulk-status>&times;</button>
      </div>
      <p class="yb-bulk-status__subtitle" id="yb-bulk-status-subtitle"></p>
      <div class="yb-bulk-status__grid" id="yb-bulk-status-grid"></div>
    </div>
  </div>
</section>

<script src="/js/profile.js"></script>
