    {# Recordings section — shown to users with recordings permission #}
    <div data-yb-requires="recordings" style="display:none">
      <style>
        .yb-rec {
          max-width: 960px;
          margin: 0 auto;
          padding: 2.5rem 1.5rem 3rem;
        }
        .yb-rec__header {
          display: flex;
          align-items: center;
          justify-content: space-between;
          margin-bottom: 1.75rem;
          flex-wrap: wrap;
          gap: 1rem;
        }
        .yb-rec__title {
          font-size: 1.2rem;
          color: #FFFCF9;
          margin: 0;
          display: flex;
          align-items: center;
          gap: 0.5rem;
        }
        .yb-rec__count {
          font-size: 0.75rem;
          color: #6F6A66;
        }
        .yb-rec__toolbar {
          display: none;
          gap: 0.6rem;
          flex-wrap: wrap;
          align-items: center;
          margin-bottom: 1.5rem;
        }
        .yb-rec__search-wrap {
          position: relative;
          flex: 1;
          min-width: 200px;
        }
        .yb-rec__search-icon {
          position: absolute;
          left: 12px;
          top: 50%;
          transform: translateY(-50%);
          pointer-events: none;
          opacity: 0.5;
        }
        .yb-rec__input {
          width: 100%;
          padding: 0.55rem 0.75rem 0.55rem 2.2rem;
          background: rgba(255,255,255,0.05);
          border: 1px solid rgba(255,255,255,0.1);
          border-radius: 8px;
          color: #FFFCF9;
          font-size: 0.82rem;
          outline: none;
          font-family: inherit;
          transition: border-color 0.2s ease, box-shadow 0.2s ease;
        }
        .yb-rec__input:focus {
          border-color: #f75c03;
          box-shadow: 0 0 0 3px rgba(247,92,3,0.1);
        }
        .yb-rec__select {
          padding: 0.55rem 0.75rem;
          background: rgba(255,255,255,0.05);
          border: 1px solid rgba(255,255,255,0.1);
          border-radius: 8px;
          color: #FFFCF9;
          font-size: 0.82rem;
          outline: none;
          font-family: inherit;
          cursor: pointer;
          transition: border-color 0.2s ease;
        }
        .yb-rec__select:focus {
          border-color: #f75c03;
        }
        .yb-rec__grid {
          display: grid;
          grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
          gap: 1.25rem;
        }
        @media (max-width: 640px) {
          .yb-rec__grid {
            grid-template-columns: 1fr;
          }
          .yb-rec__toolbar {
            gap: 0.5rem;
          }
          .yb-rec__search-wrap {
            min-width: 100%;
          }
        }
      </style>
      <div class="yb-rec">
        <div class="yb-rec__header">
          <h2 class="yb-rec__title">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#FFFCF9" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="opacity:0.5"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
            <span data-yj-da>Optagelser</span><span data-yj-en>Recordings</span>
          </h2>
          <span id="yb-ma-rec-count" class="yb-rec__count"></span>
        </div>

        <div id="yb-ma-recordings-toolbar" class="yb-rec__toolbar">
          <div class="yb-rec__search-wrap">
            <svg class="yb-rec__search-icon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#FFFCF9" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="yb-ma-rec-search" class="yb-rec__input" placeholder="">
          </div>
          <select id="yb-ma-rec-instructor" class="yb-rec__select">
            <option value="">—</option>
          </select>
          <select id="yb-ma-rec-sort" class="yb-rec__select">
            <option value="newest">—</option>
            <option value="oldest">—</option>
          </select>
        </div>

        <div id="yb-ma-recordings-list" class="yb-rec__grid"></div>
        <p id="yb-ma-recordings-empty" style="color:#6F6A66;text-align:center;padding:2rem 0" hidden>
          <span data-yj-da>Ingen optagelser tilgængelige endnu.</span><span data-yj-en>No recordings available yet.</span>
        </p>
      </div>
    </div>
    {# No access message — shown to users without permission #}
    <div id="yb-ma-live-noaccess" style="display:none">
      <section style="padding:6rem 0;background:#0F0F0F;text-align:center;min-height:60vh;display:flex;align-items:center">
        <div class="container" style="max-width:600px">
          <div style="margin-bottom:2rem">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          </div>
          <h2 style="font-size:clamp(1.5rem,3.5vw,2.25rem);margin:0 0 1rem;color:#FFFCF9">{{ i18n.member[lang or "da"].live_noaccess_title }}</h2>
          <p style="color:#6F6A66;font-size:1rem;line-height:1.7;margin:0">{{ i18n.member[lang or "da"].live_noaccess_text }}</p>
        </div>
      </section>
    </div>
  </div>
  {% set t = i18n.member[lang or "da"] %}

  {# ── TAB: Events (placeholder) ── #}
  <div class="yb-ma-tp" id="yb-ma-tp-events" data-yb-ma-panel="events" hidden>
    <section style="padding:6rem 0;background:var(--yb-warm-white, #FFFCF9);text-align:center;min-height:60vh;display:flex;align-items:center">
      <div class="container" style="max-width:600px">
        <div style="margin-bottom:2rem">
          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/></svg>
        </div>
        <p class="yb-ma-eyebrow yb-ma-eyebrow--line">{{ t.events_placeholder_eyebrow }}</p>
        <h2 class="section-title" style="margin:0.5rem 0 1rem">{{ t.events_placeholder_title }}</h2>
        <p style="color:var(--yb-muted, #6F6A66);font-size:1rem;line-height:1.7;margin:0">{{ t.events_placeholder_text }}</p>
      </div>
    </section>
  </div>

  {# ── TAB: Training Materials (role-gated) ── #}
  <div class="yb-ma-tp" id="yb-ma-tp-materials" data-yb-ma-panel="materials" hidden data-yb-role="trainee,teacher,admin" style="display:none">
    <script>
      window._ybMemberMaterialsT = {
        materials_cat_manual: {{ t.materials_cat_manual | dump | safe }},
        materials_cat_workbook: {{ t.materials_cat_workbook | dump | safe }},
        materials_cat_reference: {{ t.materials_cat_reference | dump | safe }},
        materials_cat_schedule: {{ t.materials_cat_schedule | dump | safe }},
        materials_open: {{ t.materials_open | dump | safe }},
        materials_download: {{ t.materials_download | dump | safe }}
      };
    </script>
    <section style="padding:3rem 0 4rem;background:var(--yb-warm-white, #FFFCF9);min-height:50vh">
      <div class="container" style="max-width:800px">
        <div style="margin-bottom:2rem">
          <h2 class="section-title" style="margin:0 0 0.5rem">{{ t.materials_title }}</h2>
          <p style="color:var(--yb-muted, #6F6A66);margin:0">{{ t.materials_subtitle }}</p>
        </div>
        <div id="yb-mat-loading" style="text-align:center;padding:3rem 0">
          <div class="yb-mb-spinner" style="margin:0 auto 1rem"></div>
          <span style="color:#6F6A66">{{ t.materials_loading }}</span>
        </div>
        <div id="yb-mat-list"></div>
        <div id="yb-mat-empty" hidden style="text-align:center;padding:4rem 0">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          <h3 style="margin:1rem 0 0.5rem;color:#0F0F0F">{{ t.materials_empty_title }}</h3>
          <p style="color:#6F6A66;margin:0">{{ t.materials_empty_text }}</p>
        </div>
      </div>
    </section>
  </div>

  {# ── TAB: Profile (iframe — bare embed page, no site chrome) ── #}
  <div class="yb-ma-tp" id="yb-ma-tp-profile" data-yb-ma-panel="profile" hidden>
    <iframe class="yb-ma-iframe" data-src="{{ lp }}/embed/profile/#profile" title="{{ t.hub_profile_title }}"></iframe>
  </div>

  {# ── TAB: Leads (iframe — marketing & admin only) ── #}
  <div class="yb-ma-tp" id="yb-ma-tp-leads" data-yb-ma-panel="leads" hidden data-yb-role="marketing,admin" style="display:none">
    <iframe class="yb-ma-iframe" data-src="{{ lp }}/embed/leads/" title="{{ t.tab_leads }}"></iframe>
  </div>

</div>

{# ── Styles ── #}
<style>
  /* ── Guest page styles ── */
  .yb-ma-eyebrow {
    display: inline-flex;
    align-items: center;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--yb-brand, #f75c03);
    margin-bottom: 0.5rem;
  }
  .yb-ma-eyebrow--line::before {
    content: "";
    width: 30px;
    height: 1px;
    background: currentColor;
    margin-right: 10px;
  }

  .yb-ma-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 600px) {
    .yb-ma-grid { grid-template-columns: 1fr; }
  }

  .yb-ma-card {
    background: var(--yb-warm-white, #FFFCF9);
    border: 1px solid var(--yb-border, #E8E4E0);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    transition: all 0.3s ease;
  }
  .yb-ma-card--lift:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.12);
  }
  .yb-ma-card--dark {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.08);
  }
  .yb-ma-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--yb-light-bg, #F5F3F0);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .yb-ma-card__icon--dark {
    background: rgba(247,92,3,0.1);
  }
  .yb-ma-card__title {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.375rem;
    color: #0F0F0F;
  }
  .yb-ma-card__desc {
    font-size: 0.875rem;
    color: var(--yb-muted, #6F6A66);
    margin: 0;
    line-height: 1.55;
  }

  .yb-ma-checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .yb-ma-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    font-size: 1rem;
    line-height: 1.5;
  }
  .yb-ma-checklist svg { flex-shrink: 0; margin-top: 2px; }

  /* ══════════════════════════════════════
     LOGGED-IN HUB STYLES
     ══════════════════════════════════════ */

  /* ── Header bar ── */
  .yb-ma-header {
    background: #0F0F0F;
    padding: 2.5rem 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }
  .yb-ma-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .yb-ma-header__title {
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--yb-brand, #f75c03);
    margin: 0 0 0.25rem;
    font-weight: 400;
  }
  .yb-ma-header__sub {
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 700;
    color: #FFFCF9;
    margin: 0;
  }
  .yb-ma-header__profile-link {
    text-decoration: none;
  }
  .yb-ma-header__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--yb-brand, #f75c03);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    transition: box-shadow 0.2s ease;
  }
  .yb-ma-header__profile-link:hover .yb-ma-header__avatar {
    box-shadow: 0 0 0 3px rgba(247,92,3,0.3);
  }

  /* ── Hub section ── */
  .yb-ma-hub {
    background: var(--yb-light-bg, #F5F3F0);
    padding: 3rem 0 4rem;
    min-height: 60vh;
  }

  /* ── Hub grid: 4-col base, primaries span 2 ── */
  .yb-ma-hub__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }
  @media (max-width: 960px) {
    .yb-ma-hub__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 520px) {
    .yb-ma-hub__grid { grid-template-columns: 1fr; }
    .yb-ma-hub__card--primary { grid-column: span 1; }
  }

  /* ── Hub card ── */
  .yb-ma-hub__card {
    display: flex;
    flex-direction: column;
    background: var(--yb-warm-white, #FFFCF9);
    border: 1px solid var(--yb-border, #E8E4E0);
    border-radius: 12px;
    padding: 1.5rem;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }
  a.yb-ma-hub__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,0.08);
    border-color: var(--yb-brand, #f75c03);
  }

  /* Primary card: spans 2 columns, taller */
  .yb-ma-hub__card--primary {
    grid-column: span 2;
    padding: 2rem;
  }

  /* Dark variant for Live card */
  .yb-ma-hub__card--dark {
    background: #0F0F0F;
    border-color: rgba(255,255,255,0.08);
    color: #FFFCF9;
  }
  a.yb-ma-hub__card--dark:hover {
    border-color: var(--yb-brand, #f75c03);
    box-shadow: 0 12px 32px rgba(0,0,0,0.3);
  }

  /* Coming-soon card */
  .yb-ma-hub__card--soon {
    opacity: 0.55;
    cursor: default;
  }

  /* Card inner elements */
  .yb-ma-hub__card-top {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .yb-ma-hub__badge {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    border-radius: 100px;
    background: rgba(247,92,3,0.1);
    color: var(--yb-brand, #f75c03);
  }
  .yb-ma-hub__badge--dark {
    background: rgba(247,92,3,0.2);
    color: #ff9966;
  }
  .yb-ma-hub__badge--muted {
    background: var(--yb-light-bg, #F5F3F0);
    color: var(--yb-muted, #6F6A66);
  }
  .yb-ma-hub__card--dark .yb-ma-hub__badge--muted {
    background: rgba(255,255,255,0.08);
    color: rgba(255,255,255,0.5);
  }
  .yb-ma-hub__soon-tag {
    font-size: 0.6rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--yb-muted, #6F6A66);
  }

  .yb-ma-hub__card-icon {
    color: var(--yb-brand, #f75c03);
    margin-bottom: 1rem;
  }
  .yb-ma-hub__card--primary .yb-ma-hub__card-icon {
    margin-bottom: 1.25rem;
  }

  .yb-ma-hub__card-title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
  }
  .yb-ma-hub__card--primary .yb-ma-hub__card-title {
    font-size: 1.35rem;
  }

  .yb-ma-hub__card-desc {
    font-size: 0.85rem;
    color: var(--yb-muted, #6F6A66);
    margin: 0;
    line-height: 1.5;
    flex-grow: 1;
  }

  .yb-ma-hub__card-arrow {
    display: inline-block;
    margin-top: 1rem;
    font-size: 1.2rem;
    color: var(--yb-brand, #f75c03);
    transition: transform 0.2s ease;
  }
  a.yb-ma-hub__card:hover .yb-ma-hub__card-arrow {
    transform: translateX(4px);
  }

  /* Role badge — shown in welcome header */
  .yb-ma-role-badge {
    margin-top: 1.25rem;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }
  .yb-ma-role-badge__pill {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.35rem 1rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    border: 1.5px solid;
  }
  .yb-ma-role-badge__detail {
    font-size: 0.8rem;
    color: #6F6A66;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ══════════════════════════════════════
     TAB NAVIGATION BAR
     ══════════════════════════════════════ */
  .yb-ma-tabs {
    background: #0F0F0F;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .yb-ma-tabs__scroll {
    display: flex;
    gap: 0.375rem;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 0.625rem 0;
  }
  .yb-ma-tabs__scroll::-webkit-scrollbar { display: none; }

  .yb-ma-tabs__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.85rem;
    font-family: inherit;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: rgba(255,255,255,0.5);
    background: transparent;
    border: 1px solid transparent;
    border-radius: 100px;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }
  .yb-ma-tabs__btn:hover {
    color: rgba(255,255,255,0.85);
    background: rgba(255,255,255,0.06);
  }
  .yb-ma-tabs__btn.is-active {
    color: #fff;
    background: var(--yb-brand, #f75c03);
    border-color: var(--yb-brand, #f75c03);
  }
  .yb-ma-tabs__btn svg {
    flex-shrink: 0;
    opacity: 0.7;
  }
  .yb-ma-tabs__btn.is-active svg {
    opacity: 1;
  }

  /* ══════════════════════════════════════
     TAB PANELS
     ══════════════════════════════════════ */
  .yb-ma-tp[hidden] { display: none; }

  /* Iframe panels */
  .yb-ma-iframe {
    width: 100%;
    min-height: 80vh;
    border: none;
    display: block;
    background: var(--yb-warm-white, #FFFCF9);
  }

  /* Embedded content panels — hide heroes and CTAs */
  .yb-ma-tp__body > .yb-hero,
  .yb-ma-tp__body > .cta-section { display: none !important; }

  /* ── Philosophy quote ── */
  .yb-ma-quote {
    border: none;
    margin: 0;
    padding: 2rem;
    background: rgba(255,255,255,0.04);
    border-left: 3px solid var(--yb-brand, #f75c03);
    border-radius: 0 12px 12px 0;
    text-align: left;
  }
  .yb-ma-quote__text {
    font-size: 1.15rem;
    font-style: italic;
    color: #FFFCF9;
    margin: 0 0 0.5rem;
    line-height: 1.6;
  }
  .yb-ma-quote__source {
    font-size: 0.8rem;
    color: var(--yb-brand, #f75c03);
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  /* ── Link-style cards ── */
  .yb-ma-card--link {
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  /* ── 3-column grid variant ── */
  .yb-ma-grid--3 {
    grid-template-columns: repeat(3, 1fr);
  }
  @media (max-width: 768px) {
    .yb-ma-grid--3 { grid-template-columns: 1fr; }
  }

  /* ══════════════════════════════════════
     MY COURSES — CARD LIST
     ══════════════════════════════════════ */
  .yb-ma-course-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    background: var(--yb-warm-white, #FFFCF9);
    border: 1px solid var(--yb-border, #E8E4E0);
    border-radius: 12px;
    padding: 1.25rem 1.5rem;
    margin-bottom: 1rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
  }
  .yb-ma-course-card:hover {
    border-color: var(--yb-brand, #f75c03);
    box-shadow: 0 4px 16px rgba(0,0,0,0.06);
  }
  .yb-ma-course-card__icon {
    font-size: 2rem;
    flex-shrink: 0;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--yb-light-bg, #F5F3F0);
    border-radius: 12px;
  }
  .yb-ma-course-card__info {
    flex: 1;
    min-width: 0;
  }
  .yb-ma-course-card__title {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.25rem;
    color: #0F0F0F;
  }
  .yb-ma-course-card__desc {
    font-size: 0.85rem;
    color: var(--yb-muted, #6F6A66);
    margin: 0 0 0.375rem;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .yb-ma-course-card__meta {
    font-size: 0.75rem;
    color: var(--yb-muted, #6F6A66);
  }
  .yb-ma-course-card__btn {
    flex-shrink: 0;
    white-space: nowrap;
  }
  @media (max-width: 600px) {
    .yb-ma-course-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.75rem;
    }
    .yb-ma-course-card__btn {
      align-self: stretch;
      text-align: center;
    }
  }

  /* ── Live tab embedded — override min-height for member area ── */
  .yb-ma-tp .yb-live {
    min-height: auto;
  }

  /* ══════════════════════════════════════
     TRAINING MATERIALS — CARD LIST
     ══════════════════════════════════════ */
  .yb-mat__group {
    margin-bottom: 2rem;
  }
  .yb-mat__group-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--yb-brand, #f75c03);
    margin: 0 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--yb-border, #E8E4E0);
  }
  .yb-mat__cards {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
  }
  .yb-mat__card {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: var(--yb-warm-white, #FFFCF9);
    border: 1px solid var(--yb-border, #E8E4E0);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
