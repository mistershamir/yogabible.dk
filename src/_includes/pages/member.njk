<script>
  // Show live no-access message for users without live-streaming permission
  document.addEventListener('yb:user-loaded', function(e) {
    var perms = (e.detail && e.detail.permissions) || [];
    var noAccess = document.getElementById('yb-ma-live-noaccess');
    if (noAccess && perms.indexOf('live-streaming') === -1) {
      noAccess.style.display = '';
    }
  });
</script>
