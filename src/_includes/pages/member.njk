{% set t = i18n.member[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

{# ══════════════════════════════════════════════════════════════
   GUEST STATE — not logged in
   ══════════════════════════════════════════════════════════════ #}
<div id="yb-member-guest">

  {# ── Hero: Dark Cinematic (Hero E pattern from /samples) ── #}
  <section class="yb-hero">
    <div class="yb-hero__glow"></div>
    <div class="yb-hero__content">
      <p class="yb-hero__tagline">{{ t.hero_eyebrow }}</p>
      <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
      <p class="yb-hero__subtitle" style="max-width:640px;margin-left:auto;margin-right:auto">{{ t.hero_subtitle }}</p>
      <div class="yb-hero__line"></div>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:1.5rem">
        <button class="yb-btn yb-btn--primary" type="button" data-yb-auth-open="register">{{ t.hero_cta_register }}</button>
        <button class="yb-btn yb-btn--outline-light" type="button" data-yb-auth-open="login">{{ t.hero_cta_login }}</button>
      </div>
    </div>
    <div class="yb-hero__scroll">
      <span>Scroll</span>
      <div class="yb-hero__scroll-line"></div>
    </div>
  </section>

  {# ── Intro ── #}
  <section style="padding:5rem 0;background:var(--yb-warm-white, #FFFCF9)">
    <div class="container" style="max-width:760px;text-align:center">
      <h2 class="section-title">{{ t.intro_title }}</h2>
      <p style="color:var(--yb-muted, #6F6A66);font-size:1.05rem;line-height:1.7;margin:1rem 0 0">{{ t.intro_text }}</p>
    </div>
  </section>

  {# ── Free for Everyone: 2x2 card grid ── #}
  <section style="padding:5rem 0;background:var(--yb-light-bg, #F5F3F0)">
    <div class="container" style="max-width:960px">
      <div style="text-align:center;margin-bottom:3rem">
        <p class="yb-ma-eyebrow yb-ma-eyebrow--line">{{ t.free_eyebrow }}</p>
        <h2 class="section-title">{{ t.free_title }}</h2>
        <p style="color:var(--yb-muted, #6F6A66);max-width:560px;margin:0.5rem auto 0">{{ t.free_subtitle }}</p>
      </div>
      <div class="yb-ma-grid">
        <div class="yb-ma-card yb-ma-card--lift">
          <div class="yb-ma-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
          <h3 class="yb-ma-card__title">{{ t.free_1_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.free_1_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--lift">
          <div class="yb-ma-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="yb-ma-card__title">{{ t.free_2_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.free_2_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--lift">
          <div class="yb-ma-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="yb-ma-card__title">{{ t.free_3_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.free_3_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--lift">
          <div class="yb-ma-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="yb-ma-card__title">{{ t.free_4_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.free_4_desc }}</p>
        </div>
      </div>
    </div>
  </section>

  {# ── Students: Dark section ── #}
  <section style="padding:5rem 0;background:#0F0F0F;color:#FFFCF9">
    <div class="container" style="max-width:960px">
      <div style="text-align:center;margin-bottom:3rem">
        <p class="yb-ma-eyebrow yb-ma-eyebrow--line">{{ t.student_eyebrow }}</p>
        <h2 style="font-size:clamp(1.5rem,3.5vw,2.25rem);margin:0.5rem 0 0;color:#FFFCF9">{{ t.student_title }}</h2>
        <p style="color:#6F6A66;max-width:580px;margin:0.75rem auto 0">{{ t.student_subtitle }}</p>
      </div>
      <div class="yb-ma-grid">
        <div class="yb-ma-card yb-ma-card--dark">
          <div class="yb-ma-card__icon yb-ma-card__icon--dark">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 class="yb-ma-card__title" style="color:#FFFCF9">{{ t.student_1_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.student_1_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--dark">
          <div class="yb-ma-card__icon yb-ma-card__icon--dark">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          </div>
          <h3 class="yb-ma-card__title" style="color:#FFFCF9">{{ t.student_2_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.student_2_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--dark">
          <div class="yb-ma-card__icon yb-ma-card__icon--dark">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h3 class="yb-ma-card__title" style="color:#FFFCF9">{{ t.student_3_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.student_3_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--dark">
          <div class="yb-ma-card__icon yb-ma-card__icon--dark">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <h3 class="yb-ma-card__title" style="color:#FFFCF9">{{ t.student_4_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.student_4_desc }}</p>
        </div>
      </div>
    </div>
  </section>

  {# ── Studios & Businesses ── #}
  <section style="padding:5rem 0;background:var(--yb-warm-white, #FFFCF9)">
    <div class="container" style="max-width:760px">
      <div style="text-align:center;margin-bottom:2.5rem">
        <p class="yb-ma-eyebrow yb-ma-eyebrow--line">{{ t.studio_eyebrow }}</p>
        <h2 class="section-title">{{ t.studio_title }}</h2>
        <p style="color:var(--yb-muted, #6F6A66);max-width:580px;margin:0.5rem auto 0">{{ t.studio_subtitle }}</p>
      </div>
      <ul class="yb-ma-checklist">
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.studio_1 }}</span>
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.studio_2 }}</span>
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.studio_3 }}</span>
        </li>
      </ul>
    </div>
  </section>

  {# ── Bottom CTA ── #}
  <section style="background:#0F0F0F;color:#FFFCF9;padding:4.5rem 0;text-align:center">
    <div class="container" style="max-width:600px">
      <h2 style="font-size:clamp(1.5rem,3vw,2rem);margin:0 0 0.75rem;color:#FFFCF9">{{ t.cta_title }}</h2>
      <p style="color:#6F6A66;margin:0 0 2rem">{{ t.cta_text }}</p>
      <button class="yb-btn yb-btn--primary" type="button" data-yb-auth-open="register">{{ t.cta_register }}</button>
      <p style="color:#6F6A66;margin-top:1.25rem">{{ t.cta_login_note }} <a href="#" data-yb-auth-open="login" style="color:var(--yb-brand, #f75c03)">{{ t.cta_login }}</a></p>
    </div>
  </section>

</div>

{# ══════════════════════════════════════════════════════════════
   USER STATE — logged in, tabbed interface
   ══════════════════════════════════════════════════════════════ #}
<div id="yb-member-user" style="display:none">

  {# ── Header bar ── #}
  <section class="yb-ma-header">
    <div class="container">
      <div class="yb-ma-header__inner">
        <div>
          <h1 class="yb-ma-header__title">{{ t.user_title }}</h1>
          <p class="yb-ma-header__sub">{{ t.user_greeting }}, <span id="yb-member-name" style="color:var(--yb-brand, #f75c03)"></span></p>
          <div id="yb-member-role-badge" class="yb-ma-role-badge" style="display:none"></div>
        </div>
        <span class="yb-ma-header__avatar" id="yb-member-avatar">YB</span>
      </div>
    </div>
  </section>

  {# ── Tab navigation bar ── #}
  <nav class="yb-ma-tabs" id="yb-ma-tabs">
    <div class="container">
      <div class="yb-ma-tabs__scroll">
        {# 1. Dashboard #}
        <button class="yb-ma-tabs__btn is-active" type="button" data-yb-ma-tab="hub">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
          {{ t.tab_hub }}
        </button>
        {# 2. Courses #}
        <button class="yb-ma-tabs__btn" type="button" data-yb-ma-tab="courses">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          {{ t.tab_courses }}
        </button>
        {# 3. Schedule (daily use — moved up) #}
        <button class="yb-ma-tabs__btn" type="button" data-yb-ma-tab="schedule">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          {{ t.tab_schedule }}
        </button>
        {# 4. Live & Recordings #}
        <button class="yb-ma-tabs__btn" type="button" data-yb-ma-tab="live">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          {{ t.tab_live }}
        </button>
        {# 5. Glossary #}
        <button class="yb-ma-tabs__btn" type="button" data-yb-ma-tab="glossary">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          {{ t.tab_glossary }}
        </button>
        {# 6. Journal #}
        <button class="yb-ma-tabs__btn" type="button" data-yb-ma-tab="journal">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          {{ t.tab_journal }}
        </button>
        {# 7. Events (placeholder — pushed down) #}
        <button class="yb-ma-tabs__btn" type="button" data-yb-ma-tab="events">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/></svg>
          {{ t.tab_events }}
        </button>
        {# Materials — trainee, teacher & admin only #}
        <button class="yb-ma-tabs__btn" type="button" data-yb-ma-tab="materials" data-yb-role="trainee,teacher,admin" style="display:none">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          {{ t.tab_materials }}
        </button>
        {# 8. Profile #}
        <button class="yb-ma-tabs__btn" type="button" data-yb-ma-tab="profile">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          {{ t.tab_profile }}
        </button>
        {# Leads — marketing & admin only #}
        <button class="yb-ma-tabs__btn" type="button" data-yb-ma-tab="leads" data-yb-role="marketing,admin" style="display:none">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          {{ t.tab_leads }}
        </button>
      </div>
    </div>
  </nav>

  {# ══════════════════════════════════════════════════════════════
     TAB PANELS
     ══════════════════════════════════════════════════════════════ #}

  {# ── TAB: Dashboard (default) ── #}
  <div class="yb-ma-tp" id="yb-ma-tp-hub" data-yb-ma-panel="hub">
    <script>
      window._ybDashT = {
        morning: {{ t.dash_morning | dump | safe }},
        afternoon: {{ t.dash_afternoon | dump | safe }},
        evening: {{ t.dash_evening | dump | safe }},
        continue_label: {{ t.dash_continue | dump | safe }},
        start_label: {{ t.dash_start | dump | safe }},
        modules: {{ t.dash_modules | dump | safe }},
        chapters_read: {{ t.dash_chapters_read | dump | safe }},
        course_card_title: {{ t.dash_course_card_title | dump | safe }},
        no_courses_title: {{ t.dash_no_courses_title | dump | safe }},
        no_courses_desc: {{ t.dash_no_courses_desc | dump | safe }}
      };
    </script>

    <section class="yb-dash">
      <div class="container" style="max-width:960px">

        {# ── Greeting ── #}
        <h2 class="yb-dash__greeting" id="yb-dash-greeting"></h2>

        {# ── Action cards ── #}
        <div class="yb-dash__actions">

          {# Continue course — populated by JS #}
          <div class="yb-dash__action yb-dash__action--course" id="yb-dash-course" style="display:none">
            <div class="yb-dash__action-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <div class="yb-dash__action-body" id="yb-dash-course-body"></div>
          </div>

          {# Book a class #}
          <a href="#schedule" class="yb-dash__action" data-yb-ma-tab="schedule">
            <div class="yb-dash__action-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            </div>
            <div class="yb-dash__action-body">
              <h3 class="yb-dash__action-title">{{ t.dash_book_title }}</h3>
              <p class="yb-dash__action-desc">{{ t.dash_book_desc }} &rarr;</p>
            </div>
          </a>

          {# Live & Recordings #}
          <a href="#live" class="yb-dash__action" data-yb-ma-tab="live">
            <div class="yb-dash__action-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
            </div>
            <div class="yb-dash__action-body">
              <h3 class="yb-dash__action-title">{{ t.hub_live_title }}</h3>
              <p class="yb-dash__action-desc">{{ t.tab_live }} &rarr;</p>
            </div>
          </a>
        </div>

        {# ── Quick access grid ── #}
        <h3 class="yb-dash__section-title">{{ t.dash_quick_access }}</h3>
        <div class="yb-dash__grid">

          <a href="#courses" class="yb-dash__link" data-yb-ma-tab="courses">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            <span>{{ t.hub_courses_title }}</span>
          </a>

          <a href="#live" class="yb-dash__link" data-yb-ma-tab="live">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
            <span>{{ t.hub_live_title }}</span>
          </a>

          <a href="#schedule" class="yb-dash__link" data-yb-ma-tab="schedule">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>{{ t.hub_schedule_title }}</span>
          </a>

