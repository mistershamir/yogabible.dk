{% set t = i18n.member[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

{# ── Guest state (not logged in) ── #}
<div id="yb-member-guest">

  <section class="yb-hero">
    <div class="yb-hero__glow"></div>
    <div class="yb-hero__content">
      <p class="yb-hero__tagline">{{ t.hero_eyebrow }}</p>
      <h1 class="yb-hero__title">{{ t.guest_title }}</h1>
      <p class="yb-hero__subtitle">{{ t.guest_text }}</p>
      <div class="yb-hero__line"></div>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:1.5rem">
        <button class="yb-btn yb-btn--primary" type="button" data-yb-auth-open="login">{{ t.guest_login_btn }}</button>
        <button class="yb-btn yb-btn--outline-light" type="button" data-yb-auth-open="register">{{ t.guest_register_btn }}</button>
      </div>
    </div>
    <div class="yb-hero__scroll">
      <span>Scroll</span>
      <div class="yb-hero__scroll-line"></div>
    </div>
  </section>

  <section style="padding:5rem 0;background:#FFFCF9">
    <div class="container" style="max-width:800px">
      <h2 class="section-title" style="text-align:center">{{ t.guest_benefit_heading }}</h2>
      <ul style="list-style:none;padding:0;margin:2.5rem 0 0;display:grid;gap:1.25rem">
        <li style="display:flex;align-items:flex-start;gap:0.875rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.guest_benefit_1 }}</span>
        </li>
        <li style="display:flex;align-items:flex-start;gap:0.875rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.guest_benefit_2 }}</span>
        </li>
        <li style="display:flex;align-items:flex-start;gap:0.875rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.guest_benefit_3 }}</span>
        </li>
        <li style="display:flex;align-items:flex-start;gap:0.875rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.guest_benefit_4 }}</span>
        </li>
        <li style="display:flex;align-items:flex-start;gap:0.875rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.guest_benefit_5 }}</span>
        </li>
        <li style="display:flex;align-items:flex-start;gap:0.875rem">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink:0;margin-top:2px"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.guest_benefit_6 }}</span>
        </li>
      </ul>
      <div style="text-align:center;margin-top:3rem">
        <p style="color:#6F6A66;margin-bottom:0.75rem">{{ t.guest_register_note }}</p>
        <button class="yb-btn yb-btn--primary" type="button" data-yb-auth-open="register">{{ t.guest_register_btn }}</button>
        <p style="color:#6F6A66;margin-top:1.5rem">{{ t.guest_login_note }} <a href="#" data-yb-auth-open="login" style="color:#f75c03">{{ t.guest_login_btn }}</a></p>
      </div>
    </div>
  </section>

</div>

{# ── Member state (logged in) ── #}
<div id="yb-member-user" style="display:none">

  {# Welcome header #}
  <section style="background:#0F0F0F;color:#FFFCF9;padding:4rem 0 3rem;text-align:center">
    <div class="container">
      <span style="display:inline-block;font-size:0.75rem;letter-spacing:0.15em;text-transform:uppercase;color:#f75c03;margin-bottom:0.75rem">{{ t.hero_eyebrow }}</span>
      <h1 style="font-size:clamp(2rem,5vw,3.5rem);margin:0 0 0.5rem">{{ t.hero_title }}, <span id="yb-member-name" style="color:#f75c03"></span></h1>
      <p style="color:#6F6A66;font-size:1.1rem;margin:0">{{ t.hero_subtitle }}</p>
    </div>
  </section>

  {# Quick access grid #}
  <section style="padding:5rem 0;background:#F5F3F0">
    <div class="container">
      <div style="text-align:center;margin-bottom:3rem">
        <span style="display:inline-block;font-size:0.75rem;letter-spacing:0.15em;text-transform:uppercase;color:#f75c03;margin-bottom:0.5rem">{{ t.section_quick_title }}</span>
        <p style="color:#6F6A66;margin:0">{{ t.section_quick_subtitle }}</p>
      </div>

      <div class="yb-member-grid">
        {# Card: Profile #}
        <a href="{{ lp }}/profile" class="yb-member-card">
          <div class="yb-member-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <h3 class="yb-member-card__title">{{ t.card_profile_title }}</h3>
          <p class="yb-member-card__desc">{{ t.card_profile_desc }}</p>
        </a>

        {# Card: Schedule #}
        <a href="{{ lp }}/profile#schedule" class="yb-member-card" id="yb-member-card-schedule">
          <div class="yb-member-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="yb-member-card__title">{{ t.card_schedule_title }}</h3>
          <p class="yb-member-card__desc">{{ t.card_schedule_desc }}</p>
        </a>

        {# Card: Store #}
        <a href="{{ lp }}/profile#store" class="yb-member-card" id="yb-member-card-store">
          <div class="yb-member-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
          </div>
          <h3 class="yb-member-card__title">{{ t.card_store_title }}</h3>
          <p class="yb-member-card__desc">{{ t.card_store_desc }}</p>
        </a>

        {# Card: Courses #}
        <a href="{{ lp }}/profile#courses" class="yb-member-card" id="yb-member-card-courses">
          <div class="yb-member-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="yb-member-card__title">{{ t.card_courses_title }}</h3>
          <p class="yb-member-card__desc">{{ t.card_courses_desc }}</p>
        </a>

        {# Card: Visits #}
        <a href="{{ lp }}/profile#visits" class="yb-member-card" id="yb-member-card-visits">
          <div class="yb-member-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <h3 class="yb-member-card__title">{{ t.card_visits_title }}</h3>
          <p class="yb-member-card__desc">{{ t.card_visits_desc }}</p>
        </a>

        {# Card: Journal #}
        <a href="{{ lp }}/yoga-journal" class="yb-member-card">
          <div class="yb-member-card__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </div>
          <h3 class="yb-member-card__title">{{ t.card_journal_title }}</h3>
          <p class="yb-member-card__desc">{{ t.card_journal_desc }}</p>
        </a>
      </div>
    </div>
  </section>

  {# Member perks #}
  <section style="padding:5rem 0;background:#FFFCF9">
    <div class="container" style="max-width:960px">
      <div style="text-align:center;margin-bottom:3rem">
        <h2 class="section-title">{{ t.section_perks_title }}</h2>
        <p style="color:#6F6A66;max-width:600px;margin:0.5rem auto 0">{{ t.section_perks_subtitle }}</p>
      </div>

      <div class="yb-member-perks">
        <div class="yb-member-perk">
          <div class="yb-member-perk__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="yb-member-perk__title">{{ t.perk_1_title }}</h3>
          <p class="yb-member-perk__desc">{{ t.perk_1_desc }}</p>
        </div>
        <div class="yb-member-perk">
          <div class="yb-member-perk__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          </div>
          <h3 class="yb-member-perk__title">{{ t.perk_2_title }}</h3>
          <p class="yb-member-perk__desc">{{ t.perk_2_desc }}</p>
        </div>
        <div class="yb-member-perk">
          <div class="yb-member-perk__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="yb-member-perk__title">{{ t.perk_3_title }}</h3>
          <p class="yb-member-perk__desc">{{ t.perk_3_desc }}</p>
        </div>
        <div class="yb-member-perk">
          <div class="yb-member-perk__icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#f75c03" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          </div>
          <h3 class="yb-member-perk__title">{{ t.perk_4_title }}</h3>
          <p class="yb-member-perk__desc">{{ t.perk_4_desc }}</p>
        </div>
      </div>
    </div>
  </section>

  {# Bottom CTA #}
  <section style="background:#0F0F0F;color:#FFFCF9;padding:4rem 0;text-align:center">
    <div class="container" style="max-width:600px">
      <h2 style="font-size:clamp(1.5rem,3vw,2rem);margin:0 0 0.75rem">{{ t.section_cta_title }}</h2>
      <p style="color:#6F6A66;margin:0 0 2rem">{{ t.section_cta_text }}</p>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap">
        <a href="{{ lp }}/profile#schedule" class="yb-btn yb-btn--primary" id="yb-member-cta-schedule">{{ t.section_cta_btn }}</a>
        <a href="{{ lp }}/profile#store" class="yb-btn yb-btn--outline-light" id="yb-member-cta-store">{{ t.section_cta_btn2 }}</a>
      </div>
    </div>
  </section>

</div>

<style>
  .yb-member-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 768px) {
    .yb-member-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .yb-member-grid { grid-template-columns: 1fr; }
  }
  .yb-member-card {
    display: block;
    background: #FFFCF9;
    border: 1px solid #E8E4E0;
    border-radius: 12px;
    padding: 2rem 1.5rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .yb-member-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }
  .yb-member-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: #F5F3F0;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    color: #f75c03;
  }
  .yb-member-card__title {
    font-size: 1.1rem;
    font-weight: 700;
    margin: 0 0 0.375rem;
    color: #0F0F0F;
  }
  .yb-member-card__desc {
    font-size: 0.875rem;
    color: #6F6A66;
    margin: 0;
    line-height: 1.5;
  }

  .yb-member-perks {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  @media (max-width: 600px) {
    .yb-member-perks { grid-template-columns: 1fr; }
  }
  .yb-member-perk {
    padding: 1.5rem;
    border-radius: 12px;
    border: 1px solid #E8E4E0;
    background: #F5F3F0;
  }
  .yb-member-perk__icon {
    margin-bottom: 0.75rem;
  }
  .yb-member-perk__title {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 0.375rem;
    color: #0F0F0F;
  }
  .yb-member-perk__desc {
    font-size: 0.875rem;
    color: #6F6A66;
    margin: 0;
    line-height: 1.5;
  }
</style>

<script>
(function() {
  'use strict';
  var guest = document.getElementById('yb-member-guest');
  var user = document.getElementById('yb-member-user');
  var nameEl = document.getElementById('yb-member-name');
  if (!guest || !user) return;

  firebase.auth().onAuthStateChanged(function(u) {
    if (u) {
      guest.style.display = 'none';
      user.style.display = '';
      if (nameEl) nameEl.textContent = (u.displayName || u.email.split('@')[0]).split(' ')[0];
    } else {
      guest.style.display = '';
      user.style.display = 'none';
    }
  });
})();
</script>
