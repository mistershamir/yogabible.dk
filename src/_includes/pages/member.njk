{% set t = i18n.member[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

{# ══════════════════════════════════════════════════════════════
   GUEST STATE — not logged in
   ══════════════════════════════════════════════════════════════ #}
<div id="yb-member-guest">

  {# ── Hero: Dark Cinematic (Hero E pattern from /samples) ── #}
  <section class="yb-hero">
    <div class="yb-hero__glow"></div>
    <div class="yb-hero__content">
      <p class="yb-hero__tagline">{{ t.hero_eyebrow }}</p>
      <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
      <p class="yb-hero__subtitle" style="max-width:640px;margin-left:auto;margin-right:auto">{{ t.hero_subtitle }}</p>
      <div class="yb-hero__line"></div>
      <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;margin-top:1.5rem">
        <button class="yb-btn yb-btn--primary" type="button" data-yb-auth-open="register">{{ t.hero_cta_register }}</button>
        <button class="yb-btn yb-btn--outline-light" type="button" data-yb-auth-open="login">{{ t.hero_cta_login }}</button>
      </div>
    </div>
    <div class="yb-hero__scroll">
      <span>Scroll</span>
      <div class="yb-hero__scroll-line"></div>
    </div>
  </section>

  {# ── Intro ── #}
  <section style="padding:5rem 0;background:var(--yb-warm-white, #FFFCF9)">
    <div class="container" style="max-width:760px;text-align:center">
      <h2 class="section-title">{{ t.intro_title }}</h2>
      <p style="color:var(--yb-muted, #6F6A66);font-size:1.05rem;line-height:1.7;margin:1rem 0 0">{{ t.intro_text }}</p>
    </div>
  </section>

  {# ── Free for Everyone: 2x2 card grid ── #}
  <section style="padding:5rem 0;background:var(--yb-light-bg, #F5F3F0)">
    <div class="container" style="max-width:960px">
      <div style="text-align:center;margin-bottom:3rem">
        <p class="yb-ma-eyebrow yb-ma-eyebrow--line">{{ t.free_eyebrow }}</p>
        <h2 class="section-title">{{ t.free_title }}</h2>
        <p style="color:var(--yb-muted, #6F6A66);max-width:560px;margin:0.5rem auto 0">{{ t.free_subtitle }}</p>
      </div>
      <div class="yb-ma-grid">
        <div class="yb-ma-card yb-ma-card--lift">
          <div class="yb-ma-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
          <h3 class="yb-ma-card__title">{{ t.free_1_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.free_1_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--lift">
          <div class="yb-ma-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h3 class="yb-ma-card__title">{{ t.free_2_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.free_2_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--lift">
          <div class="yb-ma-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="yb-ma-card__title">{{ t.free_3_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.free_3_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--lift">
          <div class="yb-ma-card__icon">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="yb-ma-card__title">{{ t.free_4_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.free_4_desc }}</p>
        </div>
      </div>
    </div>
  </section>

  {# ── Students: Dark section ── #}
  <section style="padding:5rem 0;background:#0F0F0F;color:#FFFCF9">
    <div class="container" style="max-width:960px">
      <div style="text-align:center;margin-bottom:3rem">
        <p class="yb-ma-eyebrow yb-ma-eyebrow--line">{{ t.student_eyebrow }}</p>
        <h2 style="font-size:clamp(1.5rem,3.5vw,2.25rem);margin:0.5rem 0 0;color:#FFFCF9">{{ t.student_title }}</h2>
        <p style="color:#6F6A66;max-width:580px;margin:0.75rem auto 0">{{ t.student_subtitle }}</p>
      </div>
      <div class="yb-ma-grid">
        <div class="yb-ma-card yb-ma-card--dark">
          <div class="yb-ma-card__icon yb-ma-card__icon--dark">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 class="yb-ma-card__title" style="color:#FFFCF9">{{ t.student_1_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.student_1_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--dark">
          <div class="yb-ma-card__icon yb-ma-card__icon--dark">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          </div>
          <h3 class="yb-ma-card__title" style="color:#FFFCF9">{{ t.student_2_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.student_2_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--dark">
          <div class="yb-ma-card__icon yb-ma-card__icon--dark">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          </div>
          <h3 class="yb-ma-card__title" style="color:#FFFCF9">{{ t.student_3_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.student_3_desc }}</p>
        </div>
        <div class="yb-ma-card yb-ma-card--dark">
          <div class="yb-ma-card__icon yb-ma-card__icon--dark">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
          </div>
          <h3 class="yb-ma-card__title" style="color:#FFFCF9">{{ t.student_4_title }}</h3>
          <p class="yb-ma-card__desc">{{ t.student_4_desc }}</p>
        </div>
      </div>
    </div>
  </section>

  {# ── Studios & Businesses ── #}
  <section style="padding:5rem 0;background:var(--yb-warm-white, #FFFCF9)">
    <div class="container" style="max-width:760px">
      <div style="text-align:center;margin-bottom:2.5rem">
        <p class="yb-ma-eyebrow yb-ma-eyebrow--line">{{ t.studio_eyebrow }}</p>
        <h2 class="section-title">{{ t.studio_title }}</h2>
        <p style="color:var(--yb-muted, #6F6A66);max-width:580px;margin:0.5rem auto 0">{{ t.studio_subtitle }}</p>
      </div>
      <ul class="yb-ma-checklist">
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.studio_1 }}</span>
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.studio_2 }}</span>
        </li>
        <li>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand, #f75c03)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t.studio_3 }}</span>
        </li>
      </ul>
    </div>
  </section>

  {# ── Bottom CTA ── #}
  <section style="background:#0F0F0F;color:#FFFCF9;padding:4.5rem 0;text-align:center">
    <div class="container" style="max-width:600px">
      <h2 style="font-size:clamp(1.5rem,3vw,2rem);margin:0 0 0.75rem;color:#FFFCF9">{{ t.cta_title }}</h2>
      <p style="color:#6F6A66;margin:0 0 2rem">{{ t.cta_text }}</p>
      <button class="yb-btn yb-btn--primary" type="button" data-yb-auth-open="register">{{ t.cta_register }}</button>
      <p style="color:#6F6A66;margin-top:1.25rem">{{ t.cta_login_note }} <a href="#" data-yb-auth-open="login" style="color:var(--yb-brand, #f75c03)">{{ t.cta_login }}</a></p>
    </div>
  </section>

</div>

{# ══════════════════════════════════════════════════════════════
   USER STATE — logged in hub
   ══════════════════════════════════════════════════════════════ #}
<div id="yb-member-user" style="display:none">

  {# ── Header bar ── #}
  <section class="yb-ma-header">
    <div class="container">
      <div class="yb-ma-header__inner">
        <div>
          <h1 class="yb-ma-header__title">{{ t.user_title }}</h1>
          <p class="yb-ma-header__sub">{{ t.user_greeting }}, <span id="yb-member-name" style="color:var(--yb-brand, #f75c03)"></span></p>
        </div>
        <a href="{{ lp }}/profile" class="yb-ma-header__profile-link">
          <span class="yb-ma-header__avatar" id="yb-member-avatar">YB</span>
        </a>
      </div>
    </div>
  </section>

  {# ── Hub grid ── #}
  <section class="yb-ma-hub">
    <div class="container">
      <div class="yb-ma-hub__grid">

        {# ── PRIMARY: My Courses (large card, spans 2 cols) ── #}
        <a href="{{ lp }}/profile#courses" class="yb-ma-hub__card yb-ma-hub__card--primary">
          <div class="yb-ma-hub__card-top">
            <span class="yb-ma-hub__badge">{{ t.hub_courses_badge }}</span>
          </div>
          <div class="yb-ma-hub__card-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          </div>
          <h2 class="yb-ma-hub__card-title">{{ t.hub_courses_title }}</h2>
          <p class="yb-ma-hub__card-desc">{{ t.hub_courses_desc }}</p>
          <span class="yb-ma-hub__card-arrow">&rarr;</span>
        </a>

        {# ── PRIMARY: Live & Recordings (large card, spans 2 cols) ── #}
        <a href="{{ lp }}/member#live" class="yb-ma-hub__card yb-ma-hub__card--primary yb-ma-hub__card--dark">
          <div class="yb-ma-hub__card-top">
            <span class="yb-ma-hub__badge yb-ma-hub__badge--dark">{{ t.hub_live_badge }}</span>
          </div>
          <div class="yb-ma-hub__card-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
          </div>
          <h2 class="yb-ma-hub__card-title">{{ t.hub_live_title }}</h2>
          <p class="yb-ma-hub__card-desc">{{ t.hub_live_desc }}</p>
          <span class="yb-ma-hub__card-arrow">&rarr;</span>
        </a>

        {# ── SECONDARY: Class Schedule ── #}
        <a href="{{ lp }}/profile#schedule" class="yb-ma-hub__card">
          <div class="yb-ma-hub__card-top">
            <span class="yb-ma-hub__badge">{{ t.hub_schedule_badge }}</span>
          </div>
          <div class="yb-ma-hub__card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
          </div>
          <h3 class="yb-ma-hub__card-title">{{ t.hub_schedule_title }}</h3>
          <p class="yb-ma-hub__card-desc">{{ t.hub_schedule_desc }}</p>
          <span class="yb-ma-hub__card-arrow">&rarr;</span>
        </a>

        {# ── SECONDARY: Yoga Glossary ── #}
        <a href="{{ lp }}/yoga-glossary" class="yb-ma-hub__card">
          <div class="yb-ma-hub__card-top">
            <span class="yb-ma-hub__badge">{{ t.hub_glossary_badge }}</span>
          </div>
          <div class="yb-ma-hub__card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/><line x1="8" y1="7" x2="16" y2="7"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
          </div>
          <h3 class="yb-ma-hub__card-title">{{ t.hub_glossary_title }}</h3>
          <p class="yb-ma-hub__card-desc">{{ t.hub_glossary_desc }}</p>
          <span class="yb-ma-hub__card-arrow">&rarr;</span>
        </a>

        {# ── SECONDARY: Yoga Journal ── #}
        <a href="{{ lp }}/yoga-journal" class="yb-ma-hub__card">
          <div class="yb-ma-hub__card-top">
            <span class="yb-ma-hub__badge">{{ t.hub_journal_badge }}</span>
          </div>
          <div class="yb-ma-hub__card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          </div>
          <h3 class="yb-ma-hub__card-title">{{ t.hub_journal_title }}</h3>
          <p class="yb-ma-hub__card-desc">{{ t.hub_journal_desc }}</p>
          <span class="yb-ma-hub__card-arrow">&rarr;</span>
        </a>

        {# ── SECONDARY: Events ── #}
        <div class="yb-ma-hub__card yb-ma-hub__card--soon">
          <div class="yb-ma-hub__card-top">
            <span class="yb-ma-hub__badge yb-ma-hub__badge--muted">{{ t.hub_events_badge }}</span>
            <span class="yb-ma-hub__soon-tag">{{ t.hub_coming_soon }}</span>
          </div>
          <div class="yb-ma-hub__card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><path d="M8 14h.01"/><path d="M12 14h.01"/><path d="M16 14h.01"/></svg>
          </div>
          <h3 class="yb-ma-hub__card-title">{{ t.hub_events_title }}</h3>
          <p class="yb-ma-hub__card-desc">{{ t.hub_events_desc }}</p>
        </div>

        {# ── SECONDARY: Forum ── #}
        <div class="yb-ma-hub__card yb-ma-hub__card--soon">
          <div class="yb-ma-hub__card-top">
            <span class="yb-ma-hub__badge yb-ma-hub__badge--muted">{{ t.hub_forum_badge }}</span>
            <span class="yb-ma-hub__soon-tag">{{ t.hub_coming_soon }}</span>
          </div>
          <div class="yb-ma-hub__card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 class="yb-ma-hub__card-title">{{ t.hub_forum_title }}</h3>
          <p class="yb-ma-hub__card-desc">{{ t.hub_forum_desc }}</p>
        </div>

        {# ── SECONDARY: My Profile ── #}
        <a href="{{ lp }}/profile" class="yb-ma-hub__card">
          <div class="yb-ma-hub__card-top">
            <span class="yb-ma-hub__badge yb-ma-hub__badge--muted">{{ t.hub_profile_badge }}</span>
          </div>
          <div class="yb-ma-hub__card-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <h3 class="yb-ma-hub__card-title">{{ t.hub_profile_title }}</h3>
          <p class="yb-ma-hub__card-desc">{{ t.hub_profile_desc }}</p>
          <span class="yb-ma-hub__card-arrow">&rarr;</span>
        </a>

      </div>
    </div>
  </section>

</div>

{# ── Styles ── #}
<style>
  /* ── Guest page styles ── */
  .yb-ma-eyebrow {
    display: inline-flex;
    align-items: center;
    font-size: 0.65rem;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--yb-brand, #f75c03);
    margin-bottom: 0.5rem;
  }
  .yb-ma-eyebrow--line::before {
    content: "";
    width: 30px;
    height: 1px;
    background: currentColor;
    margin-right: 10px;
  }

  .yb-ma-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  @media (max-width: 600px) {
    .yb-ma-grid { grid-template-columns: 1fr; }
  }

  .yb-ma-card {
    background: var(--yb-warm-white, #FFFCF9);
    border: 1px solid var(--yb-border, #E8E4E0);
    border-radius: 12px;
    padding: 2rem 1.5rem;
    transition: all 0.3s ease;
  }
  .yb-ma-card--lift:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 50px rgba(0,0,0,0.12);
  }
  .yb-ma-card--dark {
    background: rgba(255,255,255,0.04);
    border-color: rgba(255,255,255,0.08);
  }
  .yb-ma-card__icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background: var(--yb-light-bg, #F5F3F0);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
  }
  .yb-ma-card__icon--dark {
    background: rgba(247,92,3,0.1);
  }
  .yb-ma-card__title {
    font-size: 1.05rem;
    font-weight: 700;
    margin: 0 0 0.375rem;
    color: #0F0F0F;
  }
  .yb-ma-card__desc {
    font-size: 0.875rem;
    color: var(--yb-muted, #6F6A66);
    margin: 0;
    line-height: 1.55;
  }

  .yb-ma-checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.25rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }
  .yb-ma-checklist li {
    display: flex;
    align-items: flex-start;
    gap: 0.875rem;
    font-size: 1rem;
    line-height: 1.5;
  }
