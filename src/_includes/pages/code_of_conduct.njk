          <summary class="yb-coc-acc__sum">{{ t.s5_summary }}</summary>
          <div class="yb-coc-acc__body">
            <p>{{ t.s5_intro }}</p>
            <h3>{{ t.s5_academic_heading }}</h3>
            <ul class="yb-coc-list">
              <li>{{ t.s5_plagiarism | safe }}</li>
              <li>{{ t.s5_sharing | safe }}</li>
              <li>{{ t.s5_recording | safe }}</li>
              <li>{{ t.s5_respect | safe }}</li>
            </ul>
