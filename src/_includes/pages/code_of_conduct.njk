            <p>{{ t.s5_boundaries_text }}</p>
          </div>
        </details>

        {# --- Section 6: Online conduct --- #}
        <details class="yb-coc-acc" id="c6">
          <summary class="yb-coc-acc__sum">{{ t.s6_summary }}</summary>
          <div class="yb-coc-acc__body">
            <p>{{ t.s6_intro }}</p>
            <ul class="yb-coc-list">
              <li>{{ t.s6_harassment | safe }}</li>
              <li>{{ t.s6_doxxing | safe }}</li>
              <li>{{ t.s6_unauthorized | safe }}</li>
              <li>{{ t.s6_brand | safe }}</li>
