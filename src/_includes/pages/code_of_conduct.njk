            <ul class="yb-coc-list">
              <li>{{ t.s2_sexual }}</li>
              <li>{{ t.s2_threats }}</li>
              <li>{{ t.s2_discrimination }}</li>
              <li>{{ t.s2_pressure }}</li>
              <li>{{ t.s2_unsafe }}</li>
            </ul>
            <div class="yb-coc-callout">{{ t.s2_callout | safe }}</div>
          </div>
        </details>

        {# --- Section 3: Safety in practice --- #}
        <details class="yb-coc-acc" id="c3">
          <summary class="yb-coc-acc__sum">{{ t.s3_summary }}</summary>
          <div class="yb-coc-acc__body">
            <p>{{ t.s3_intro }}</p>

            <h3>{{ t.s3_participants_heading }}</h3>
            <ul class="yb-coc-list">
              <li>{{ t.s3_listen | safe }}</li>
              <li>{{ t.s3_inform | safe }}</li>
              <li>{{ t.s3_sober | safe }}</li>
              <li>{{ t.s3_quiet | safe }}</li>
            </ul>

            <h3>{{ t.s3_adjustments_heading }}</h3>
            <p>{{ t.s3_adjustments_intro | safe }}</p>
            <ul class="yb-coc-list">
              <li>{{ t.s3_adjust_no | safe }}</li>
              <li>{{ t.s3_adjust_respect | safe }}</li>
              <li>{{ t.s3_adjust_communicate | safe }}</li>
            </ul>
            <div class="yb-coc-callout">{{ t.s3_adjust_callout | safe }}</div>

            <h3>{{ t.s3_minors_heading }}</h3>
            <p>{{ t.s3_minors_intro | safe }}</p>
            <ul class="yb-coc-list">
              <li>{{ t.s3_minors_consent | safe }}</li>
              <li>{{ t.s3_minors_present | safe }}</li>
              <li>{{ t.s3_minors_responsible | safe }}</li>
