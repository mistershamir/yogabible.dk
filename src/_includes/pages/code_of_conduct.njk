<style>
  /* =========================================================
     Code of Conduct v2 — scoped styles
     ========================================================= */
  #yb-coc {
    --coc-accent: #f75c03;
    --coc-bg: #FCFBF9;
    --coc-card: #ffffff;
    --coc-border: #EBE7E3;
    --coc-text: #1A1A1A;
    --coc-muted: #6B6B6B;
    font-family: 'Abacaxi', "Helvetica Neue", Helvetica, Arial, system-ui, -apple-system, sans-serif;
    color: var(--coc-text);
    background: var(--coc-bg);
    padding: 72px 20px;
  }
  #yb-coc, #yb-coc * { box-sizing: border-box; }
  #yb-coc .yb-coc__inner { max-width: 1120px; margin: 0 auto; }

  /* Header */
  #yb-coc .yb-coc__eyebrow {
    letter-spacing: .12em; text-transform: uppercase; font-size: 12px;
    color: var(--coc-muted); margin: 0 0 10px;
  }
  #yb-coc .yb-coc__title {
    margin: 0 0 10px; font-size: 44px; line-height: 1.08; letter-spacing: -.02em;
  }
  #yb-coc .yb-coc__lead {
    margin: 0 0 16px; font-size: 16px; line-height: 1.65; color: #2a2a2a; max-width: 78ch;
  }

  /* Meta rows */
  #yb-coc .yb-coc__meta {
    display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
    color: var(--coc-muted); font-size: 13px; margin: 0 0 10px;
  }
  #yb-coc .yb-coc__metaSep { opacity: .65; }
  #yb-coc .yb-coc__meta a {
    color: var(--coc-accent);
    text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px;
  }

  /* Notice */
  #yb-coc .yb-coc__notice {
    background: #fff; border: 1px solid var(--coc-border);
    border-radius: 16px; padding: 14px 16px; line-height: 1.55; margin: 10px 0 18px;
  }

  /* TOC chips */
  #yb-coc .yb-coc__toc { display: flex; flex-wrap: wrap; gap: 10px; margin: 14px 0 0; }
  #yb-coc .yb-chip {
    display: inline-flex; align-items: center;
    border: 1px solid var(--coc-border); background: #fff;
    border-radius: 999px; padding: 10px 12px; font-size: 13px;
    color: var(--coc-text); text-decoration: none;
    transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
  }
  #yb-coc .yb-chip:hover {
    border-color: rgba(247, 92, 3, .45);
    box-shadow: 0 18px 60px rgba(0, 0, 0, .10);
    transform: translateY(-1px);
  }

  /* Grid layout */
  #yb-coc .yb-coc__grid { display: grid; gap: 18px; margin-top: 26px; }
  @media (min-width: 980px) {
    #yb-coc .yb-coc__grid { grid-template-columns: 360px minmax(0, 1fr); align-items: start; }
    #yb-coc .yb-coc__side { position: sticky; top: 20px; }
  }

  /* Cards */
  #yb-coc .yb-coc-card {
    background: var(--coc-card); border: 1px solid var(--coc-border);
    border-radius: 20px; padding: 18px;
    box-shadow: 0 18px 60px rgba(0, 0, 0, .10);
  }
  #yb-coc .yb-coc-card__title { margin: 0 0 10px; font-size: 16px; letter-spacing: -.01em; }
  #yb-coc .yb-coc-card__subtitle {
    margin: 0 0 8px; font-size: 13px; color: var(--coc-muted);
    text-transform: uppercase; letter-spacing: .10em;
  }

  /* Utility */
  #yb-coc .yb-coc-divider { height: 1px; background: var(--coc-border); margin: 14px 0; }
  #yb-coc .yb-coc-list { margin: 0; padding-left: 18px; color: #2a2a2a; line-height: 1.7; font-size: 14px; }
  #yb-coc .yb-coc-muted { color: var(--coc-muted); line-height: 1.6; font-size: 14px; margin: 0; }

  /* Accordions */
  #yb-coc .yb-coc-acc {
    border: 1px solid var(--coc-border); border-radius: 20px; background: #fff;
    margin: 0 0 12px; overflow: hidden; scroll-margin-top: 18px;
  }
  #yb-coc .yb-coc-acc__sum {
    list-style: none; cursor: pointer; padding: 16px; font-weight: 700;
    letter-spacing: -.01em; display: flex; align-items: center;
    justify-content: space-between; gap: 12px; outline: none;
  }
  #yb-coc details > summary::-webkit-details-marker { display: none; }
  #yb-coc .yb-coc-acc__sum::after {
    content: "\25BE"; color: var(--coc-muted); font-weight: 600;
    transition: transform .15s ease;
  }
  #yb-coc details[open] .yb-coc-acc__sum::after { transform: rotate(180deg); }
  #yb-coc .yb-coc-acc__sum:focus-visible {
    box-shadow: 0 0 0 3px rgba(247, 92, 3, .22); border-radius: 14px; margin: 6px;
  }
  #yb-coc .yb-coc-acc__body {
    padding: 0 16px 16px; line-height: 1.7; font-size: 14px; color: #2a2a2a;
  }
  #yb-coc .yb-coc-acc__body a {
    color: var(--coc-accent); text-decoration: underline;
    text-decoration-thickness: 1px; text-underline-offset: 3px;
  }
  #yb-coc .yb-coc-acc__body h3 { margin: 14px 0 8px; font-size: 14px; letter-spacing: -.01em; }

  /* Callout */
  #yb-coc .yb-coc-callout {
    border: 1px solid rgba(247, 92, 3, .28); background: rgba(247, 92, 3, .06);
    border-radius: 16px; padding: 12px; margin: 12px 0;
  }

  /* Bottom card + actions */
  #yb-coc .yb-coc__bottomCard { margin-top: 10px; }
  #yb-coc .yb-coc-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }

  /* Buttons (scoped) */
  #yb-coc .yb-coc-btn {
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 999px; padding: 10px 14px; font-size: 13px;
    text-decoration: none; border: 1px solid var(--coc-border);
    transition: transform .15s ease, box-shadow .15s ease, filter .15s ease, background .15s ease, color .15s ease;
    white-space: nowrap;
  }
  #yb-coc .yb-coc-btn--primary {
    background: var(--coc-accent); border-color: var(--coc-accent);
    color: #fff; box-shadow: 0 18px 60px rgba(0, 0, 0, .12);
  }
  #yb-coc .yb-coc-btn--primary:hover { filter: brightness(.98); transform: translateY(-1px); }
  #yb-coc .yb-coc-btn--ghost {
    background: #fff; color: var(--coc-accent); border-color: rgba(247, 92, 3, .45);
  }
  #yb-coc .yb-coc-btn--ghost:hover { background: rgba(247, 92, 3, .06); transform: translateY(-1px); }

  @media (max-width: 520px) {
    #yb-coc .yb-coc__title { font-size: 34px; }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('yb-coc');
    if (!root) return;

    var details = root.querySelectorAll('details.yb-coc-acc');
    details.forEach(function (d) {
      d.addEventListener('toggle', function () {
        if (!d.open) return;
        details.forEach(function (other) { if (other !== d) other.open = false; });
      });
    });

    function openFromHash() {
      var id = (window.location.hash || '').replace('#', '');
      if (!id) return;
      var target = root.querySelector('#' + CSS.escape(id));
      if (target && target.tagName.toLowerCase() === 'details') {
        target.open = true;
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
    window.addEventListener('hashchange', openFromHash);
    setTimeout(openFromHash, 40);
  })();
</script>
