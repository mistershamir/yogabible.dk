{% set t = i18n.code_of_conduct[lang or "da"] %}

<!-- Hero — yb-hero unified design with yogic trust bar -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a class="yb-btn yb-btn--primary yb-btn--large" href="#yb-coc">{{ t.hero_cta_read }}</a>
      <a class="yb-btn yb-btn--outline-light yb-btn--large" href="mailto:info@yogabible.dk?subject=Code%20of%20Conduct%20%E2%80%94%20henvendelse">{{ t.hero_cta_contact }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust_ahimsa }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust_satya }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust_saucha }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

<!-- Code of Conduct — Full v2 content -->
<section id="yb-coc" class="yb-coc" aria-label="Code of Conduct">
  <div class="yb-coc__inner">

    <header class="yb-coc__head">
      <p class="yb-coc__eyebrow">{{ t.eyebrow }}</p>
      <h2 class="yb-coc__title">{{ t.section_title }}</h2>
      <p class="yb-coc__lead">{{ t.lead }}</p>

      <div class="yb-coc__meta">
        <span class="yb-coc__metaItem"><strong>{{ t.meta_entity_label }}</strong> {{ t.meta_entity }}</span>
        <span class="yb-coc__metaSep" aria-hidden="true">&bull;</span>
        <span class="yb-coc__metaItem"><strong>{{ t.meta_cvr_label }}</strong> {{ t.meta_cvr }}</span>
        <span class="yb-coc__metaSep" aria-hidden="true">&bull;</span>
        <span class="yb-coc__metaItem"><strong>{{ t.meta_vat_label }}</strong> {{ t.meta_vat }}</span>
      </div>

      <div class="yb-coc__meta">
        <span class="yb-coc__metaItem"><strong>{{ t.meta_address_label }}</strong> {{ t.meta_address }}</span>
        <span class="yb-coc__metaSep" aria-hidden="true">&bull;</span>
        <span class="yb-coc__metaItem"><strong>{{ t.meta_contact_label }}</strong> <a href="mailto:info@yogabible.dk">info@yogabible.dk</a> &bull; <a href="tel:+4553881209">+45 53 88 12 09</a></span>
      </div>

      <div class="yb-coc__meta">
        <span class="yb-coc__metaItem"><strong>{{ t.meta_applies_label }}</strong> {{ t.meta_applies }}</span>
      </div>

      <div class="yb-coc__meta">
        <span class="yb-coc__metaItem"><strong>{{ t.meta_updated_label }}</strong> <time datetime="{{ t.meta_updated_datetime }}">{{ t.meta_updated_date }}</time></span>
      </div>

      <div class="yb-coc__notice" role="note">
        {{ t.notice | safe }}
      </div>

      <nav class="yb-coc__toc" aria-label="Table of contents">
        <a class="yb-chip" href="#c1">{{ t.toc_1 }}</a>
        <a class="yb-chip" href="#c2">{{ t.toc_2 }}</a>
        <a class="yb-chip" href="#c3">{{ t.toc_3 }}</a>
        <a class="yb-chip" href="#c4">{{ t.toc_4 }}</a>
        <a class="yb-chip" href="#c5">{{ t.toc_5 }}</a>
        <a class="yb-chip" href="#c6">{{ t.toc_6 }}</a>
        <a class="yb-chip" href="#c7">{{ t.toc_7 }}</a>
        <a class="yb-chip" href="#c8">{{ t.toc_8 }}</a>
        <a class="yb-chip" href="#c9">{{ t.toc_9 }}</a>
        <a class="yb-chip" href="#c10">{{ t.toc_10 }}</a>
      </nav>
    </header>

    <div class="yb-coc__grid">

      <!-- Sticky sidebar -->
      <aside class="yb-coc__side" aria-label="Overview">
        <div class="yb-coc-card">
          <h2 class="yb-coc-card__title">{{ t.sidebar_title }}</h2>
          <ul class="yb-coc-list">
            <li>{{ t.sidebar_ahimsa | safe }}</li>
            <li>{{ t.sidebar_satya | safe }}</li>
            <li>{{ t.sidebar_saucha | safe }}</li>
            <li>{{ t.sidebar_professionalism | safe }}</li>
            <li>{{ t.sidebar_privacy | safe }}</li>
          </ul>

          <div class="yb-coc-divider" role="separator" aria-hidden="true"></div>

          <h3 class="yb-coc-card__subtitle">{{ t.sidebar_concern_title }}</h3>
          <p class="yb-coc-muted">{{ t.sidebar_concern_text }}</p>

          <div class="yb-coc-actions">
            <a class="yb-coc-btn yb-coc-btn--primary" href="mailto:info@yogabible.dk?subject=Code%20of%20Conduct%20%E2%80%94%20henvendelse">{{ t.sidebar_cta_contact }}</a>
            <a class="yb-coc-btn yb-coc-btn--ghost" href="#c9">{{ t.sidebar_cta_report }}</a>
          </div>

          <div class="yb-coc-callout" style="margin-top:12px;">
            {{ t.sidebar_emergency | safe }}
          </div>
        </div>
      </aside>

      <!-- Main accordion content -->
      <div class="yb-coc__main" role="main" aria-label="Code of Conduct content">

        {# --- Section 1: Principles --- #}
        <details class="yb-coc-acc" id="c1">
          <summary class="yb-coc-acc__sum">{{ t.s1_summary }}</summary>
          <div class="yb-coc-acc__body">
            <p>{{ t.s1_intro }}</p>
            <ul class="yb-coc-list">
              <li>{{ t.s1_respect | safe }}</li>
              <li>{{ t.s1_safety | safe }}</li>
              <li>{{ t.s1_integrity | safe }}</li>
              <li>{{ t.s1_responsibility | safe }}</li>
              <li>{{ t.s1_privacy | safe }}</li>
            </ul>
          </div>
        </details>

        {# --- Section 2: Respect & safety --- #}
        <details class="yb-coc-acc" id="c2">
          <summary class="yb-coc-acc__sum">{{ t.s2_summary }}</summary>
