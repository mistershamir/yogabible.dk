        {# --- Section 8: Collaboration --- #}
        <details class="yb-coc-acc" id="c8">
          <summary class="yb-coc-acc__sum">{{ t.s8_summary }}</summary>
          <div class="yb-coc-acc__body">
            <p>{{ t.s8_intro }}</p>
            <h3>{{ t.s8_confidentiality_heading }}</h3>
            <ul class="yb-coc-list">
              <li>{{ t.s8_confidentiality_1 }}</li>
              <li>{{ t.s8_confidentiality_2 }}</li>
