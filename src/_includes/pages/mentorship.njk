        <div class="yb-mentor2__how">
          <h3 class="yb-mentor2__boxTitle">Sådan arbejder vi</h3>
          <ol class="yb-mentor2__steps">
            <li><span class="yb-mentor2__stepNum">1</span><div class="yb-mentor2__stepBody"><p class="yb-mentor2__stepTitle">Afklaring</p><p class="yb-mentor2__stepText">Mål, styrker, udfordringer og din undervisningsstil.</p></div></li>
            <li><span class="yb-mentor2__stepNum">2</span><div class="yb-mentor2__stepBody"><p class="yb-mentor2__stepTitle">Konkrete værktøjer</p><p class="yb-mentor2__stepText">Struktur, cues, stemme, sekvensering og klasseledelse.</p></div></li>
            <li><span class="yb-mentor2__stepNum">3</span><div class="yb-mentor2__stepBody"><p class="yb-mentor2__stepTitle">Feedback &amp; implementering</p><p class="yb-mentor2__stepText">Observation eller video — med en enkel plan til din næste klasse.</p></div></li>
          </ol>
        </div>
      </div>

      <!-- RIGHT COLUMN -->
