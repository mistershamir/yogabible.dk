  #ybintake-modal .yb-modal-intake__field input, #ybintake-modal .yb-modal-intake__field select { height:48px !important; }
  #ybintake-modal .yb-modal-intake__field textarea { resize:vertical; min-height:92px; }
  #ybintake-modal .yb-modal-intake__field input:focus, #ybintake-modal .yb-modal-intake__field select:focus, #ybintake-modal .yb-modal-intake__field textarea:focus { border-color:var(--yb-primary) !important; box-shadow:0 0 0 3px rgba(247,92,3,0.15) !important; }
  #ybintake-modal input:-webkit-autofill, #ybintake-modal input:-webkit-autofill:hover, #ybintake-modal input:-webkit-autofill:focus, #ybintake-modal select:-webkit-autofill, #ybintake-modal textarea:-webkit-autofill { -webkit-box-shadow:0 0 0 1000px #fff inset !important; box-shadow:0 0 0 1000px #fff inset !important; -webkit-text-fill-color:var(--yb-ink) !important; border:1px solid var(--yb-border) !important; transition:background-color 9999s ease-in-out 0s; }
  #ybintake-modal .yb-modal-intake__hint { display:block; margin-top:0.5rem; color:var(--yb-muted) !important; font-size:0.8rem !important; line-height:1.4 !important; }
  #ybintake-modal .yb-modal-intake__subs { border:1px solid var(--yb-border) !important; border-radius:12px; background:var(--yb-surface) !important; padding:1rem; }
  #ybintake-modal .yb-modal-intake__subs[hidden] { display:none !important; }
