  #ybintake-modal .yb-modal-intake__subs-grid { display:grid; grid-template-columns:1fr 1fr; gap:0.75rem 1rem; margin-bottom:0.75rem; }
  #ybintake-modal .yb-modal-intake__subs-grid label { display:flex; gap:0.6rem; align-items:flex-start; font-size:0.9rem !important; line-height:1.5 !important; color:#333 !important; cursor:pointer; }
  #ybintake-modal .yb-modal-intake__subs-grid input { margin-top:3px; width:18px !important; height:18px !important; accent-color:var(--yb-primary) !important; flex:0 0 auto; }
  #ybintake-modal .yb-modal-intake__notsure { display:flex; gap:0.6rem; align-items:flex-start; padding-top:0.75rem; border-top:1px solid var(--yb-border) !important; font-size:0.9rem !important; line-height:1.5 !important; color:#333 !important; cursor:pointer; }
  #ybintake-modal .yb-modal-intake__notsure input { margin-top:3px; width:18px !important; height:18px !important; accent-color:var(--yb-primary) !important; }
  #ybintake-modal .yb-btn { display:inline-flex; align-items:center; justify-content:center; padding:0.85rem 1.6rem; border-radius:999px; font-weight:700; font-size:0.95rem; font-family:inherit; text-decoration:none; border:2px solid transparent; cursor:pointer; transition:all 0.15s ease; }
  #ybintake-modal .yb-btn:focus-visible { outline:3px solid var(--yb-primary); outline-offset:2px; }
  #ybintake-modal .yb-btn:active { transform:scale(0.98); }
  #ybintake-modal .yb-btn--cta { background:var(--yb-primary) !important; color:#fff !important; border-color:var(--yb-primary) !important; box-shadow:0 4px 14px rgba(247,92,3,0.25); width:fit-content; }
  #ybintake-modal .yb-btn--cta:hover { background:var(--yb-primary-dark) !important; border-color:var(--yb-primary-dark) !important; box-shadow:0 6px 20px rgba(247,92,3,0.3); transform:translateY(-1px); }
  #ybintake-modal .yb-btn--cta[disabled] { opacity:0.6 !important; cursor:not-allowed !important; box-shadow:none !important; transform:none !important; }
  #ybintake-modal .yb-btn--outline { background:#fff !important; color:var(--yb-primary) !important; border-color:var(--yb-primary) !important; }
  #ybintake-modal .yb-btn--outline:hover { background:var(--yb-primary) !important; color:#fff !important; }
  #ybintake-modal .yb-modal-intake__fine { margin:0 !important; color:var(--yb-muted) !important; font-size:0.8rem !important; line-height:1.5 !important; }
  #ybintake-modal .yb-modal-intake__error { margin:0 0 1rem !important; padding:0.75rem 1rem; background:#FEF2F2; border:1px solid #FECACA; border-radius:12px; font-size:0.9rem !important; color:#991B1B !important; line-height:1.5 !important; }
  #ybintake-modal .yb-modal-intake__error a { color:var(--yb-primary) !important; text-decoration:underline !important; }
  #ybintake-modal .yb-modal-intake__success { text-align:center; padding:1rem 0; }
  #ybintake-modal .yb-modal-intake__success-icon { width:56px; height:56px; border-radius:999px; background:var(--yb-primary); color:#fff; font-size:1.5rem; font-weight:700; display:flex; align-items:center; justify-content:center; margin:0 auto 1rem; }
  #ybintake-modal .yb-modal-intake__success h3 { margin:0 0 0.5rem !important; font-size:1.25rem !important; }
  #ybintake-modal .yb-modal-intake__success p { margin:0 0 0.75rem !important; color:#444 !important; line-height:1.6 !important; }
  #ybintake-modal .yb-modal-intake__success-contact { margin:0 0 1.25rem !important; font-size:0.9rem !important; }
  #ybintake-modal .yb-modal-intake__success-contact a { color:var(--yb-primary) !important; text-decoration:none !important; border-bottom:1px solid rgba(247,92,3,0.35) !important; }
  #ybintake-modal .yb-modal-intake__success-contact a:hover { border-bottom-color:var(--yb-primary) !important; }
  @media (max-width:599px) { #ybintake-modal .yb-modal-intake__grid { grid-template-columns:1fr; } #ybintake-modal .yb-modal-intake__subs-grid { grid-template-columns:1fr; } #ybintake-modal .yb-btn--cta { width:100%; } }
</style>
<script>
(function(){
  var YBINTAKE_WEBAPP_URL="/.netlify/functions/lead";
  var modal=document.getElementById("ybintake-modal");
  var form=document.getElementById("ybintake-form");
  var frame=document.getElementsByName("ybintakeFrame")[0];
  var viewForm=document.getElementById("ybintake-view-form");
  var viewSuccess=document.getElementById("ybintake-view-success");
  var errorBox=document.getElementById("ybintake-error");
  var submitBtn=document.getElementById("ybintake-submit");
  var service=document.getElementById("ybintake-service");
  var subsWrap=document.getElementById("ybintake-subs");
  var subsGrid=document.getElementById("ybintake-subsGrid");
  var notSure=document.getElementById("ybintake-notSure");
  var metaUrl=document.getElementById("ybintake-sourceUrl");
  var metaTitle=document.getElementById("ybintake-pageTitle");
  var metaUA=document.getElementById("ybintake-userAgent");
  var metaAt=document.getElementById("ybintake-submittedAt");
  try{if(modal.parentElement!==document.body)document.body.appendChild(modal);}catch(e){}
  var pendingSubmit=false;
  var SUBS={
    "Personlig praksis":["Basis & alignment","Dybere stillinger (inversions / backbends / splits)","Mobilitet (skuldre / hofter / ryg)","Hands-on justeringer (valgfrit)","\u00C5ndedr\u00E6t & fokus","Andet"],
    "Undervisning":["Cueing & sprog (tydelighed / timing)","Stemme & presence (ro / autoritet)","Selvtillid & l\u00E6reridentitet","Sekvensering & klasseflow","Hands-on (etik & sikkerhed)","Klassepsykologi & energi","At blive mere efterspurgt","Andet"],
    "Yoga Business":["Find job (CV / auditions / studio match)","Start studio / forretning","Lokation & lejekontrakt (sparring)","Pris & pakker (pricing)","Staff & drift","Booking-systemer","Marketing & strategi","SoMe / reels / produktion","YouTube / online kurser","Merch / brand","Tech / workflow (v\u00E6rkt\u00F8jer)","Andet"],
    "Ikke sikker endnu":[]
  };
  function closeModal(){modal.setAttribute('aria-hidden','true');document.documentElement.style.overflow='';document.body.style.overflow='';}
  function openModal(){modal.setAttribute('aria-hidden','false');document.documentElement.style.overflow='hidden';document.body.style.overflow='hidden';}
  function clearSubs(){if(subsGrid)subsGrid.innerHTML="";if(notSure)notSure.checked=false;}
  function hideSubs(){clearSubs();if(subsWrap)subsWrap.hidden=true;}
  function renderSubs(serviceValue){
    hideSubs();var s=(serviceValue||"").trim();if(!s)return;
    if(s==="Ikke sikker endnu"){subsWrap.hidden=false;notSure.checked=true;return;}
    var list=SUBS[s]||[];if(!list.length)return;subsWrap.hidden=false;
    list.forEach(function(label,idx){var id="ybintake-sub-"+s.replace(/\W+/g,"-").toLowerCase()+"-"+idx;var row=document.createElement("label");row.setAttribute("for",id);var cb=document.createElement("input");cb.type="checkbox";cb.name="subcategories";cb.value=label;cb.id=id;row.appendChild(cb);row.appendChild(document.createTextNode(" "+label));subsGrid.appendChild(row);});
  }
  function resetModal(){
    pendingSubmit=false;if(errorBox)errorBox.hidden=true;if(viewSuccess)viewSuccess.hidden=true;if(viewForm)viewForm.hidden=false;
    try{form.reset();}catch(e){}if(service)service.selectedIndex=0;hideSubs();
    if(submitBtn){submitBtn.disabled=false;submitBtn.textContent="Send";}
  }
  function showSuccess(){if(viewForm)viewForm.hidden=true;if(viewSuccess)viewSuccess.hidden=false;}
  function doOpenModal(){
    form.setAttribute("action",YBINTAKE_WEBAPP_URL);
    if(metaUrl)metaUrl.value=window.location.href;if(metaTitle)metaTitle.value=document.title||"";if(metaUA)metaUA.value=navigator.userAgent||"";
    resetModal();openModal();
    if(window.location.hash==="#yb-intake"){history.replaceState(null,document.title,window.location.pathname+window.location.search);}
    var first=form.querySelector('input[name="firstName"]');if(first)setTimeout(function(){first.focus();},30);
  }
  document.addEventListener('click',function(e){
    var opener=e.target.closest('a[href="#yb-intake"]');if(opener){e.preventDefault();doOpenModal();return;}
    var closer=e.target.closest("[data-ybintake-close]");if(closer&&modal.getAttribute('aria-hidden')==='false'){e.preventDefault();closeModal();resetModal();return;}
  });
  document.addEventListener("keydown",function(e){if(e.key==="Escape"&&modal.getAttribute('aria-hidden')==='false'){closeModal();resetModal();}});
  if(window.location.hash==="#yb-intake"){doOpenModal();}
  if(service){service.addEventListener("change",function(){renderSubs(service.value);});}
  if(form){
    form.addEventListener("submit",function(ev){
      ev.preventDefault();
      if(errorBox)errorBox.hidden=true;var required=form.querySelectorAll("[required]");
      for(var i=0;i<required.length;i++){if(!required[i].value){required[i].focus();return;}}
      if(metaAt)metaAt.value=new Date().toISOString();
      if(submitBtn){submitBtn.disabled=true;submitBtn.textContent="Sender\u2026";}
      var fd=new FormData(form);
      var subs=[];fd.getAll("subcategories").forEach(function(v){subs.push(v);});
      var payload={
        action:"lead_mentorship",
        firstName:fd.get("firstName")||"",
        lastName:fd.get("lastName")||"",
        email:fd.get("email")||"",
        phone:fd.get("phone")||"",
        service:fd.get("service")||"",
        subcategories:subs,
        message:fd.get("message")||"",
        sourceUrl:window.location.href
      };
      fetch(YBINTAKE_WEBAPP_URL,{method:"POST",headers:{"Content-Type":"application/json"},body:JSON.stringify(payload)})
        .then(function(r){return r.json();})
        .then(function(data){
          if(submitBtn){submitBtn.disabled=false;submitBtn.textContent="Send";}
          if(data&&data.ok){showSuccess();}else{if(errorBox)errorBox.hidden=false;}
        })
        .catch(function(){
          if(submitBtn){submitBtn.disabled=false;submitBtn.textContent="Send";}
          if(errorBox)errorBox.hidden=false;
        });
    });
  }
  closeModal();
})();
</script>
