        title.textContent=d.title; note.textContent=d.note;
        setColTitle(listA,d.aTitle); setColTitle(listB,d.bTitle);
        listA.innerHTML=d.a.map(function(x){return"<li>"+x+"</li>";}).join("");
        listB.innerHTML=d.b.map(function(x){return"<li>"+x+"</li>";}).join("");
        setActive(key);
        requestAnimationFrame(function(){[title,note,listA,listB].forEach(function(el){el.classList.add("is-in");}); setTimeout(function(){[title,note,listA,listB].forEach(function(el){el.classList.remove("yb-bizFade","is-in");});},220);});
      });
    }
    tabs.forEach(function(btn){btn.addEventListener("click",function(){render(btn.getAttribute("data-b"));});});

    // Accordion
    var accRoot=document.querySelector(".yb-biz [data-biz-accordion]");
    if(accRoot){var btns=Array.prototype.slice.call(accRoot.querySelectorAll(".yb-bizBtn"));btns.forEach(function(btn){btn.addEventListener("click",function(){var isOpen=btn.getAttribute("aria-expanded")==="true";btns.forEach(function(b){var id=b.getAttribute("aria-controls");var p=id?document.getElementById(id):null;b.setAttribute("aria-expanded","false");if(p)p.hidden=true;});if(!isOpen){var id2=btn.getAttribute("aria-controls");var p2=id2?document.getElementById(id2):null;btn.setAttribute("aria-expanded","true");if(p2)p2.hidden=false;}});});}
    render("launch");
  })();
  </script>
</section>

<!-- ═══════════════════════════════════════════════════════════════
     GLOBAL INTAKE MODAL (ybintake) — Book en samtale
