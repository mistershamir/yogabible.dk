{% set t = i18n.mentorship[lang or "da"] %}


<!-- FAQPage Schema (AEO — featured snippets for AI search) -->
<script type="application/ld+json">
{%- set _faqs = [
      [t.faq1_q, t.faq1_a],
      [t.faq2_q, t.faq2_a],
      [t.faq3_q, t.faq3_a],
      [t.faq4_q, t.faq4_a],
      [t.faq5_q, t.faq5_a]
    ] -%}
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in _faqs %}
    {
      "@type": "Question",
      "name": {{ faq[0] | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq[1] | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

<!-- ═══════════════════════════════════════════════════════════════
     HERO — Dark Cinematic with Breathing Glow
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="#yb-intake" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════════
     SECTION 2 — FOR DIN PRAKSIS
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-practice" aria-labelledby="yb-practice-title">
  <div class="yb-practice__wrap">
    <div class="yb-practice__grid">
      <!-- LEFT: Media -->
      <div class="yb-practice__mediaCol" aria-label="Billede eller video">
        <div class="yb-practice__media" id="ybPracticeMedia">
          <video class="yb-practice__video" id="ybPracticeVideo" playsinline muted loop preload="metadata">
            <source id="ybPracticeVideoSource" src="" type="video/mp4" />
          </video>
          <img class="yb-practice__img" id="ybPracticeImage" alt="Privatundervisning" loading="lazy" decoding="async"
               src="https://www.yogabible.dk/s/mentor_03_private_class_inversions_course.jpg" />
          <button class="yb-practice__play" id="ybPracticePlay" type="button" aria-label="Afspil video">
            <span class="yb-practice__playIcon" aria-hidden="true"></span>
          </button>
          <div class="yb-practice__badge" aria-hidden="true">
            <span class="yb-practice__badgeKicker">1:1</span>
            <span class="yb-practice__badgeTitle">Praksis</span>
          </div>
        </div>
        <div class="yb-practice__mini">
          <div class="yb-practice__miniItem">
            <p class="yb-practice__miniTitle">Fokus</p>
            <p class="yb-practice__miniText">Basis · Alignment · Dybere stillinger</p>
          </div>
          <div class="yb-practice__miniItem">
            <p class="yb-practice__miniTitle">Format</p>
            <p class="yb-practice__miniText">Studio eller online</p>
          </div>
          <div class="yb-practice__miniItem">
            <p class="yb-practice__miniTitle">Tempo</p>
            <p class="yb-practice__miniText">Trygt, tydeligt, trin-for-trin</p>
          </div>
        </div>
      </div>

      <!-- RIGHT: Content + FAQ -->
      <div class="yb-practice__content">
        <div class="yb-practice__head">
          <p class="yb-practice__eyebrow">Yoga Bible · Privatundervisning</p>
          <h2 id="yb-practice-title" class="yb-practice__title">For din praksis</h2>
          <p class="yb-practice__sub">Byg en stærk base, få bedre alignment og gå dybere i de stillinger, du drømmer om — på en sikker og effektiv måde.</p>
        </div>

        <div class="yb-practice__selector" role="tablist" aria-label="Vælg fokus">
          <button class="yb-practiceChip is-active" type="button" role="tab" aria-selected="true" data-p="foundation">Basis &amp; alignment</button>
          <button class="yb-practiceChip" type="button" role="tab" aria-selected="false" data-p="deep">Dybere stillinger</button>
          <button class="yb-practiceChip" type="button" role="tab" aria-selected="false" data-p="mobility">Mobilitet &amp; styrke</button>
          <button class="yb-practiceChip" type="button" role="tab" aria-selected="false" data-p="recovery">Skader &amp; tilbagevenden</button>
        </div>

        <div class="yb-practice__panel" aria-live="polite">
          <div class="yb-practice__panelTop">
            <h3 class="yb-practice__panelTitle" id="ybPracticePanelTitle">Hvad vi arbejder med · Basis &amp; alignment</h3>
            <p class="yb-practice__panelNote" id="ybPracticePanelNote">Perfekt til dig, der vil blive stærk i det grundlæggende og få en praksis, der føles stabil og fri.</p>
          </div>
          <ul class="yb-practice__list" id="ybPracticeList">
            <li><strong>Alignment-check</strong> — fødder, knæ, hofter, skuldre og nakke</li>
            <li><strong>Teknik i klassikere</strong> — fremoverbøjninger, twists, balance og core</li>
            <li><strong>Åndedræt &amp; tempo</strong> — ro, kontrol og bedre fokus</li>
            <li><strong>Personlige cues</strong> — præcise rettelser du kan huske og bruge selv</li>
          </ul>
          <div class="yb-practice__ctaRow">
            <a class="yb-btn yb-btn--primary" href="#yb-intake">Book en samtale</a>
          </div>
        </div>

        <div class="yb-practice__faq">
          <h3 class="yb-practice__faqTitle">FAQ</h3>
          <div class="yb-pracAcc" data-prac-accordion>
            <div class="yb-pracItem">
              <button class="yb-pracBtn" type="button" aria-expanded="false" aria-controls="ybPrF1" id="ybPrFB1">Hvem passer privatundervisning til?<span class="yb-pracIcon" aria-hidden="true"></span></button>
              <div class="yb-pracPanel" id="ybPrF1" role="region" aria-labelledby="ybPrFB1" hidden><p>Til både begyndere og øvede. For begyndere skaber vi en solid base. For øvede går vi målrettet efter dine mål — fx dybere stillinger, bedre kontrol eller mere frihed i kroppen.</p></div>
            </div>
            <div class="yb-pracItem">
              <button class="yb-pracBtn" type="button" aria-expanded="false" aria-controls="ybPrF2" id="ybPrFB2">Kan vi arbejde med inversions, backbends eller splits?<span class="yb-pracIcon" aria-hidden="true"></span></button>
              <div class="yb-pracPanel" id="ybPrF2" role="region" aria-labelledby="ybPrFB2" hidden><p>Ja — vi bygger det op sikkert og systematisk med teknik, mobilitet og styrke, så du får progression uden at presse kroppen.</p></div>
            </div>
            <div class="yb-pracItem">
              <button class="yb-pracBtn" type="button" aria-expanded="false" aria-controls="ybPrF3" id="ybPrFB3">Er hands-on justeringer en del af det?<span class="yb-pracIcon" aria-hidden="true"></span></button>
              <div class="yb-pracPanel" id="ybPrF3" role="region" aria-labelledby="ybPrFB3" hidden><p>Kun hvis du ønsker det. Alternativt bruger vi verbale cues, spejl, video og simple "self-adjustments". Tryghed og tydelige grænser først.</p></div>
            </div>
            <div class="yb-pracItem">
              <button class="yb-pracBtn" type="button" aria-expanded="false" aria-controls="ybPrF4" id="ybPrFB4">Hvor mange sessioner giver bedst effekt?<span class="yb-pracIcon" aria-hidden="true"></span></button>
              <div class="yb-pracPanel" id="ybPrF4" role="region" aria-labelledby="ybPrFB4" hidden><p>De fleste får stor værdi af <strong>3–5 sessioner</strong>. Det giver tid til at lære, integrere og mærke reelle ændringer.</p></div>
            </div>
            <div class="yb-pracItem">
              <button class="yb-pracBtn" type="button" aria-expanded="false" aria-controls="ybPrF5" id="ybPrFB5">Kan det være online?<span class="yb-pracIcon" aria-hidden="true"></span></button>
              <div class="yb-pracPanel" id="ybPrF5" role="region" aria-labelledby="ybPrFB5" hidden><p>Ja. Online fungerer godt til teknik, alignment, styrke/mobilitet-plan og tydelige cues. Hvis du vil have hands-on, anbefaler vi studio.</p></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <style>
    .yb-practice, .yb-practice * { box-sizing: border-box; }
    .yb-practice {
      font-family: 'Abacaxi', "Helvetica Neue", Helvetica, Arial, system-ui, sans-serif;
      background: #FCFBF9; padding: clamp(28px, 5vw, 76px) 0;
      overflow-x: clip; position: relative;
      --ybAccent: #f75c03; --ybAccentRgb: 247, 92, 3;
    }
    .yb-practice::before { content:""; position:absolute; left:-220px; top:40px; width:520px; height:520px; border-radius:999px; background:rgba(var(--ybAccentRgb),0.14); filter:blur(36px); pointer-events:none; }
    .yb-practice::after { content:""; position:absolute; right:-260px; bottom:40px; width:520px; height:520px; border-radius:999px; background:rgba(26,26,26,0.08); filter:blur(40px); pointer-events:none; }
    .yb-practice__wrap { max-width:1120px; margin:0 auto; padding:0 16px; }
    @media (min-width:1024px) { .yb-practice__wrap { padding:0 24px; } }
    .yb-practice__grid { display:grid; grid-template-columns:0.95fr 1.05fr; gap:clamp(16px,3vw,32px); align-items:start; }
    .yb-practice__mediaCol { min-width:0; display:grid; gap:14px; }
    .yb-practice__media { position:relative; border-radius:20px; border:1px solid #EBE7E3; overflow:hidden; background:#FFFFFF; box-shadow:0 18px 60px rgba(0,0,0,0.10); aspect-ratio:4/5; min-height:420px; }
    .yb-practice__video, .yb-practice__img { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block; }
    .yb-practice__video { display:none; }
    .yb-practice__badge { position:absolute; left:14px; bottom:14px; display:grid; gap:2px; padding:10px 12px; border-radius:16px; border:1px solid #EBE7E3; background:rgba(255,255,255,0.82); backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px); box-shadow:0 18px 60px rgba(0,0,0,0.10); }
    .yb-practice__badgeKicker { font-size:12px; letter-spacing:0.12em; text-transform:uppercase; color:#6B6B6B; line-height:1; }
    .yb-practice__badgeTitle { font-size:16px; font-weight:750; color:#1A1A1A; line-height:1.1; letter-spacing:-0.01em; }
    .yb-practice__play { position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); width:64px; height:64px; border-radius:999px; border:1px solid #EBE7E3; background:rgba(255,255,255,0.82); box-shadow:0 18px 60px rgba(0,0,0,0.10); backdrop-filter:blur(10px); -webkit-backdrop-filter:blur(10px); display:grid; place-items:center; cursor:pointer; opacity:0; pointer-events:none; transition:opacity 180ms ease, transform 180ms ease; }
    .yb-practice__playIcon { width:0; height:0; border-left:14px solid var(--ybAccent); border-top:10px solid transparent; border-bottom:10px solid transparent; margin-left:3px; }
    .yb-practice__media.has-video .yb-practice__play { opacity:1; pointer-events:auto; }
    .yb-practice__media.is-playing .yb-practice__play { opacity:0; pointer-events:none; transform:translate(-50%,-50%) scale(0.98); }
    .yb-practice__media.has-video:hover .yb-practice__play { transform:translate(-50%,-50%) scale(1.02); }
    .yb-practice__play:focus-visible { outline:none; box-shadow:0 0 0 4px rgba(var(--ybAccentRgb),0.22), 0 18px 60px rgba(0,0,0,0.10); }
    .yb-practice__mini { display:grid; grid-template-columns:1fr; gap:10px; }
    .yb-practice__miniItem { border:1px solid #EBE7E3; border-radius:16px; background:rgba(255,255,255,0.72); box-shadow:0 18px 60px rgba(0,0,0,0.06); padding:12px 14px; }
    .yb-practice__miniTitle { margin:0 0 4px 0; color:#6B6B6B; font-size:12px; letter-spacing:0.12em; text-transform:uppercase; }
    .yb-practice__miniText { margin:0; color:#1A1A1A; font-size:14px; line-height:1.5; font-weight:650; letter-spacing:-0.01em; }
    .yb-practice__content { min-width:0; display:grid; gap:14px; }
    .yb-practice__head { border:1px solid #EBE7E3; border-radius:20px; background:rgba(255,255,255,0.72); box-shadow:0 18px 60px rgba(0,0,0,0.06); padding:clamp(16px,2.4vw,22px); }
    .yb-practice__eyebrow { margin:0 0 10px 0; color:#6B6B6B; font-size:13px; letter-spacing:0.12em; text-transform:uppercase; }
    .yb-practice__title { margin:0 0 10px 0; color:#1A1A1A; font-size:clamp(28px,3.2vw,40px); line-height:1.12; font-weight:780; letter-spacing:-0.02em; overflow-wrap:anywhere; hyphens:auto; }
    .yb-practice__sub { margin:0; color:#333; font-size:15px; line-height:1.65; }
    .yb-practice__selector { display:flex; flex-wrap:wrap; gap:10px; }
    .yb-practiceChip { appearance:none; border:1px solid var(--ybAccent); color:var(--ybAccent); background:#fff; border-radius:999px; padding:9px 14px; font-size:13px; font-family:inherit; line-height:1; cursor:pointer; transition:transform 160ms ease, background 160ms ease, color 160ms ease, box-shadow 160ms ease; max-width:100%; }
    .yb-practiceChip:hover { transform:translateY(-1px); box-shadow:0 10px 24px rgba(0,0,0,0.08); }
    .yb-practiceChip:focus-visible { outline:none; box-shadow:0 0 0 4px rgba(var(--ybAccentRgb),0.22); }
    .yb-practiceChip.is-active { background:var(--ybAccent); color:#fff; border-color:var(--ybAccent); box-shadow:0 12px 30px rgba(0,0,0,0.12); }
    .yb-practice__panel { border:1px solid #EBE7E3; border-radius:20px; background:#FFFFFF; box-shadow:0 18px 60px rgba(0,0,0,0.08); padding:clamp(16px,2.4vw,22px); }
    .yb-practice__panelTop { margin-bottom:10px; }
    .yb-practice__panelTitle { margin:0 0 6px 0; color:#1A1A1A; font-size:16px; font-weight:750; letter-spacing:-0.01em; }
    .yb-practice__panelNote { margin:0; color:#6B6B6B; font-size:14px; line-height:1.55; }
    .yb-practice__list { margin:12px 0 0 0; padding:0; list-style:none; display:grid; gap:10px; color:#333; font-size:14px; line-height:1.6; }
    .yb-practice__list li { position:relative; padding-left:14px; }
    .yb-practice__list li::before { content:""; position:absolute; left:0; top:0.65em; width:6px; height:6px; border-radius:50%; background:var(--ybAccent); transform:translateY(-50%); opacity:.9; }
    .yb-practice__list strong { color:#1A1A1A; }
    .yb-practice__ctaRow { margin-top:14px; display:flex; justify-content:flex-start; }
    .yb-practice__faq { border:1px solid #EBE7E3; border-radius:20px; background:rgba(255,255,255,0.72); box-shadow:0 18px 60px rgba(0,0,0,0.06); padding:clamp(16px,2.4vw,22px); }
    .yb-practice__faqTitle { margin:0 0 10px 0; color:#1A1A1A; font-size:16px; font-weight:750; letter-spacing:-0.01em; }
    .yb-pracAcc { border-top:1px solid #EBE7E3; }
    .yb-pracItem { border-bottom:1px solid #EBE7E3; }
    .yb-pracBtn { width:100%; text-align:left; appearance:none; background:transparent; border:0; padding:14px 0; display:flex; align-items:center; justify-content:space-between; gap:14px; cursor:pointer; color:#1A1A1A; font-weight:650; font-size:14px; font-family:inherit; line-height:1.35; }
    .yb-pracBtn:hover { color:#111; }
    .yb-pracBtn:focus-visible { outline:none; box-shadow:0 0 0 4px rgba(var(--ybAccentRgb),0.18); border-radius:12px; padding-left:10px; padding-right:10px; margin-left:-10px; margin-right:-10px; }
    .yb-pracIcon { width:18px; height:18px; flex:0 0 auto; position:relative; opacity:.8; }
    .yb-pracIcon::before, .yb-pracIcon::after { content:""; position:absolute; left:50%; top:50%; width:14px; height:2px; background:#1A1A1A; transform:translate(-50%,-50%); border-radius:2px; }
    .yb-pracIcon::after { transform:translate(-50%,-50%) rotate(90deg); transition:transform 180ms ease; }
    .yb-pracBtn[aria-expanded="true"] .yb-pracIcon::after { transform:translate(-50%,-50%) rotate(0deg); }
    .yb-pracPanel { padding:0 0 14px 0; color:#333; font-size:14px; line-height:1.65; }
    .yb-pracPanel p { margin:0; }
    .yb-prFade { opacity:0; transform:translateY(2px); transition:opacity 180ms ease, transform 180ms ease; }
    .yb-prFade.is-in { opacity:1; transform:translateY(0); }
    @media (max-width:980px) { .yb-practice__grid { grid-template-columns:1fr; } .yb-practice__media { min-height:0; max-height:440px; } .yb-practice__mini { grid-template-columns:1fr; } }
    @media (max-width:640px) { .yb-practice .yb-btn--primary { width:100%; } }
  </style>
  <script>
  (function(){
    var media = document.getElementById("ybPracticeMedia");
    var video = document.getElementById("ybPracticeVideo");
    var srcEl = document.getElementById("ybPracticeVideoSource");
    var img = document.getElementById("ybPracticeImage");
    var play = document.getElementById("ybPracticePlay");
    function getSrc(){ var s=srcEl&&srcEl.getAttribute("src")?srcEl.getAttribute("src").trim():""; var d=video?(video.getAttribute("src")||"").trim():""; return s||d; }
    function showVideo(){ if(!media||!video||!img)return; media.classList.add("has-video"); img.style.display="none"; video.style.display="block"; var p=video.play(); if(p&&typeof p.then==="function"){p.then(function(){media.classList.add("is-playing");}).catch(function(){media.classList.remove("is-playing");});} }
    function showImage(){ if(!media||!video||!img)return; media.classList.remove("has-video"); media.classList.remove("is-playing"); try{video.pause();}catch(e){} video.style.display="none"; img.style.display="block"; }
    function refresh(){ if(getSrc()) showVideo(); else showImage(); }
    if(play&&video){ play.addEventListener("click",function(){ if(!getSrc())return; var p=video.play(); if(p&&typeof p.then==="function"){p.then(function(){media.classList.add("is-playing");}).catch(function(){media.classList.remove("is-playing");});} }); video.addEventListener("pause",function(){media.classList.remove("is-playing");}); video.addEventListener("play",function(){media.classList.add("is-playing");}); video.addEventListener("error",showImage); video.addEventListener("stalled",showImage); }
    if(srcEl&&window.MutationObserver){ var obs=new MutationObserver(refresh); obs.observe(srcEl,{attributes:true,attributeFilter:["src"]}); }
    refresh();

    // Selector chips
    var chips=Array.prototype.slice.call(document.querySelectorAll(".yb-practiceChip[data-p]"));
    var title=document.getElementById("ybPracticePanelTitle");
    var note=document.getElementById("ybPracticePanelNote");
    var list=document.getElementById("ybPracticeList");
    var presets={
      foundation:{title:"Hvad vi arbejder med \u00B7 Basis & alignment",note:"Perfekt til dig, der vil blive st\u00E6rk i det grundl\u00E6ggende og f\u00E5 en praksis, der f\u00F8les stabil og fri.",items:["<strong>Alignment-check</strong> \u2014 f\u00F8dder, kn\u00E6, hofter, skuldre og nakke","<strong>Teknik i klassikere</strong> \u2014 fremoverbøjninger, twists, balance og core","<strong>\u00C5ndedræt &amp; tempo</strong> \u2014 ro, kontrol og bedre fokus","<strong>Personlige cues</strong> \u2014 pr\u00E6cise rettelser du kan huske og bruge selv"]},
      deep:{title:"Hvad vi arbejder med \u00B7 Dybere stillinger",note:"M\u00E5lrettet progression i fx inversions, backbends eller splits \u2014 med en sikker opbygning.",items:["<strong>Forberedende \u00F8velser</strong> \u2014 mobilitet + styrke for din krop","<strong>Teknik &amp; linjer</strong> \u2014 hvor du skaber stabilitet og l\u00E6ngde","<strong>Progression</strong> \u2014 trin-for-trin og realistiske delm\u00E5l","<strong>Smartere tr\u00E6ning</strong> \u2014 mindre pres, bedre resultat"]},
      mobility:{title:"Hvad vi arbejder med \u00B7 Mobilitet & styrke",note:"For dig der vil \u00E5bne kroppen, f\u00F8le dig st\u00E6rkere og f\u00E5 mere kontrol i praksis.",items:["<strong>Hofter &amp; bagk\u00E6de</strong> \u2014 fleksibilitet uden at \u201Ch\u00E6nde\u201D","<strong>Skuldre &amp; bryst</strong> \u2014 bedre range + stabilitet","<strong>Core &amp; balance</strong> \u2014 kontrol, holdning, flow","<strong>Mini-program</strong> \u2014 en enkel plan du kan gentage hjemme"]},
      recovery:{title:"Hvad vi arbejder med \u00B7 Skader & tilbagevenden",note:"Vi tilpasser, bygger op og skaber tryghed, s\u00E5 du kan komme tilbage med struktur og ro.",items:["<strong>Tilpasninger</strong> \u2014 hvad du kan g\u00F8re, og hvad du b\u00F8r undg\u00E5","<strong>Gradvis opbygning</strong> \u2014 belastning, pauser, progression","<strong>Teknisk oprydning</strong> \u2014 f\u00E6rre kompensationer, mere stabilitet","<strong>Plan for praksis</strong> \u2014 s\u00E5 du ved pr\u00E6cis hvad n\u00E6ste skridt er"]}
    };
    function setActive(key){ chips.forEach(function(b){ var on=b.getAttribute("data-p")===key; b.classList.toggle("is-active",on); b.setAttribute("aria-selected",on?"true":"false"); }); }
    function render(key){ var d=presets[key]; if(!d||!title||!note||!list)return; title.classList.add("yb-prFade"); note.classList.add("yb-prFade"); list.classList.add("yb-prFade"); requestAnimationFrame(function(){ title.textContent=d.title; note.textContent=d.note; list.innerHTML=d.items.map(function(html){return"<li>"+html+"</li>";}).join(""); setActive(key); requestAnimationFrame(function(){ title.classList.add("is-in"); note.classList.add("is-in"); list.classList.add("is-in"); setTimeout(function(){ title.classList.remove("yb-prFade","is-in"); note.classList.remove("yb-prFade","is-in"); list.classList.remove("yb-prFade","is-in"); },220); }); }); }
    chips.forEach(function(btn){ btn.addEventListener("click",function(){ render(btn.getAttribute("data-p")); }); });

    // Accordion
    var accRoot=document.querySelector(".yb-practice [data-prac-accordion]");
    if(accRoot){ var btns=Array.prototype.slice.call(accRoot.querySelectorAll(".yb-pracBtn")); btns.forEach(function(btn){ btn.addEventListener("click",function(){ var isOpen=btn.getAttribute("aria-expanded")==="true"; btns.forEach(function(b){ var id=b.getAttribute("aria-controls"); var p=id?document.getElementById(id):null; b.setAttribute("aria-expanded","false"); if(p)p.hidden=true; }); if(!isOpen){ var id2=btn.getAttribute("aria-controls"); var p2=id2?document.getElementById(id2):null; btn.setAttribute("aria-expanded","true"); if(p2)p2.hidden=false; } }); }); }
  })();
