<script>
(function(){
  var root=document.getElementById('yb-splits-4weeks');
  if(!root) return;
  var grid=root.querySelector('.yb-splits4__grid');
  var left=document.getElementById('yb-splits-left');
  var right=document.getElementById('yb-splits-right');
  var faq=document.getElementById('yb-splits-faq');
  var rightWrap=right?right.querySelector('.yb-splits4__video-wrap'):null;

  /* FAQ accordion */
  var faqItems=root.querySelectorAll('.yb-faq__item');
  function recalcHeight(){if(window.matchMedia('(min-width:880px)').matches) matchHeights();}
  faqItems.forEach(function(item){
    var btn=item.querySelector('.yb-faq__toggle');
    var panel=item.querySelector('.yb-faq__panel');
    if(!btn||!panel) return;
    btn.addEventListener('click',function(){
      var open=item.classList.contains('is-open');
      if(open){
        item.classList.remove('is-open');
        panel.style.maxHeight='0px';
      } else {
        faqItems.forEach(function(o){
          if(o!==item){o.classList.remove('is-open');var op=o.querySelector('.yb-faq__panel');if(op) op.style.maxHeight='0px';}
        });
        item.classList.add('is-open');
        panel.style.maxHeight=panel.scrollHeight+'px';
      }
      setTimeout(recalcHeight,180);
    });
  });

  /* Video play/pause + poster */
  var video=document.getElementById('yb-splits-video');
  var toggle=root.querySelector('.yb-video-toggle');
  var posterBtn=document.getElementById('yb-splits-video-poster');

  function setUI(playing){
    if(toggle){toggle.classList.toggle('is-playing',playing);toggle.setAttribute('aria-pressed',playing?'true':'false');}
    if(posterBtn){posterBtn.classList.toggle('is-hidden',playing);}
  }
  function tryPlay(resetToStart){
    if(!video) return;
    if(resetToStart){try{video.currentTime=0;}catch(e){}}
    video.loop=true;
    var p=video.play();
    if(p&&p.catch){p.catch(function(){});}
  }
  if(posterBtn){posterBtn.addEventListener('click',function(){tryPlay();});}
  if(toggle){
    toggle.addEventListener('click',function(){if(!video) return;if(video.paused){tryPlay();}else{video.pause();}});
    toggle.addEventListener('keydown',function(e){if(e.key===' '||e.key==='Enter'){e.preventDefault();toggle.click();}});
  }
  /* Progress bar */
  var progressWrap=document.getElementById('yb-splits-progress');
  var progressBar=document.getElementById('yb-splits-progress-bar');
  function updateProgress(){
    if(!video||!progressBar||!video.duration) return;
    progressBar.style.width=(video.currentTime/video.duration*100)+'%';
  }
  if(progressWrap&&video){
    progressWrap.addEventListener('click',function(e){
      var rect=progressWrap.getBoundingClientRect();
      var pct=(e.clientX-rect.left)/rect.width;
      video.currentTime=pct*video.duration;
    });
  }

  if(video){
    video.addEventListener('click',function(){if(video.paused){tryPlay();}else{video.pause();}});
    video.addEventListener('play',function(){setUI(true);});
    video.addEventListener('pause',function(){setUI(false);});
    video.addEventListener('ended',function(){setUI(false);tryPlay(true);});
    video.addEventListener('timeupdate',updateProgress);
  }

  function matchHeights(){
    if(!left||!rightWrap) return;
    if(!window.matchMedia('(min-width:880px)').matches){rightWrap.style.height='auto';return;}
    var h=left.offsetHeight;
    rightWrap.style.height=Math.max(200,h-1)+'px';
  }
  function placeFAQ(){
    if(!faq||!left||!right||!grid) return;
    if(window.matchMedia('(max-width:879px)').matches){
      if(faq.parentElement!==grid){grid.appendChild(faq);}
    } else {
      if(faq.parentElement!==left){left.appendChild(faq);}
    }
    matchHeights();
  }
  window.addEventListener('load',function(){placeFAQ();matchHeights();setUI(false);});
  window.addEventListener('resize',function(){placeFAQ();});
  setTimeout(function(){placeFAQ();},300);
})();
</script>


