{% set t = i18n.splits[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}


<!-- FAQPage Schema (AEO — featured snippets for AI search) -->
<script type="application/ld+json">
{%- set _faqs = [
      [t.s2_faq1_q, t.s2_faq1_a],
      [t.s2_faq2_q, t.s2_faq2_a],
      [t.s2_faq3_q, t.s2_faq3_a],
      [t.s2_faq4_q, t.s2_faq4_a],
      [t.s2_faq5_q, t.s2_faq5_a]
    ] -%}
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in _faqs %}
    {
      "@type": "Question",
      "name": {{ faq[0] | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq[1] | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

<!-- ═══════════════════════════════════════════════════════════════
     PRIMARY HERO — Dark Cinematic with Breathing Glow
     ═══════════════════════════════════════════════════════════════ -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title | safe }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_lead }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="#course-months" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta_prefix }} ›</a>
      <button type="button" data-ybc-open="brochure" data-ybc-course="Splits" data-ybc-source="Splits – hero" class="yb-btn yb-btn--outline-white yb-btn--large">{{ t.hero_btn_schedule }}</button>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════════════
     SECTION 1 — COURSE DETAILS HERO
     ═══════════════════════════════════════════════════════════════ -->
<section id="ybS-hero" class="ybS-hero" aria-label="{{ t.hero_aria_label }}">
  <div class="ybS-hero__inner">

    <!-- LEFT: Text -->
    <div class="ybS-hero__content">
      <p class="ybS-eyebrow">{{ t.hero_eyebrow }}</p>

      <h2 class="ybS-title">
        {{ t.hero_title | safe }}
      </h2>

      <p class="ybS-sub">{{ t.hero_sub }}</p>
      <p class="ybS-kicker">{{ t.hero_kicker }}</p>

      <p class="ybS-lead">
        {{ t.hero_lead }}
      </p>

      <p class="ybS-meta">
        {{ t.hero_meta | safe }}
      </p>

      <!-- Pricing pill -->
      <div class="ybS-price">
        <div class="ybS-price__row">
          <span class="ybS-price__label">{{ t.hero_price_label }}</span>
          <span class="ybS-price__value">{{ t.hero_price_value }}</span>
          <span class="ybS-price__hint">{{ t.hero_price_hint }}</span>
        </div>
        <div class="ybS-price__row">
          <span class="ybS-price__label">{{ t.hero_dropin_label }}</span>
          <span class="ybS-price__value">{{ t.hero_dropin_value }}</span>
        </div>
      </div>

      <!-- Month chip (April 2026 only) -->
      <div class="ybS-months" id="course-months" role="tablist" aria-label="{{ t.hero_months_aria }}">
        <button class="ybS-chip is-active" data-month="April 2026"
                data-href="https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=41&sTG=43&prodId=100150">April 2026</button>
      </div>

      <!-- CTAs -->
      <div class="ybS-ctas">
        <button
          id="ybS-openModal"
          class="ybS-btn ybS-btn--outline"
          type="button"
          data-ybc-open="brochure"
          data-ybc-course="Splits"
          data-ybc-source="Splits – landing page"
        >{{ t.hero_btn_schedule }}</button>
        <a id="ybS-ctaMain" class="ybS-btn"
           href="https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=41&sTG=43&prodId=100150"
           target="_blank" rel="noopener noreferrer nofollow">
          {{ t.hero_cta_prefix }} april 2026{{ t.hero_cta_suffix }}
        </a>
      </div>
    </div>

    <!-- RIGHT: Media -->
    <figure class="ybS-hero__media" aria-hidden="true">
      <img
        src="https://www.yogabible.dk/s/Splits_Course_Kursus_Kbenhavn_Copenhagen_Yoga_Bible.jpg"
        alt="{{ t.hero_img_alt }}"
        loading="eager" decoding="async">
      <span class="ybS-frame"></span>
    </figure>
  </div>
</section>

<style>
  #ybS-hero{
    --ybS-accent:#f75c03;
    --ybS-accent-dark:#d64d00;
    --ybS-ink:#0f0f0f;
    --ybS-muted:#5b5f67;
    --ybS-bg:#fff;
    --ybS-ring:rgba(247,92,3,.30);
    --ybS-radius:20px;
    --ybS-gutter:clamp(18px,4vw,28px);
  }
  #ybS-hero.ybS-hero{
    font-family:"Helvetica Neue",Helvetica,Arial,system-ui,-apple-system,sans-serif;
    background:
      radial-gradient(80% 60% at 20% 10%,rgba(247,92,3,.06),transparent 60%),
      linear-gradient(#fff,#fff);
    color:var(--ybS-ink);
    padding-block:clamp(48px,6vw,96px);
  }
  #ybS-hero .ybS-hero__inner{
    width:min(1120px,100%);
    margin:0 auto;
    padding-inline:var(--ybS-gutter);
    display:grid;
    grid-template-columns:1fr;
    gap:clamp(22px,4vw,48px);
    align-items:center;
    box-sizing:border-box;
  }
  #ybS-hero .ybS-hero__content{max-width:640px;margin-inline:auto;}
  @media(min-width:920px){
    #ybS-hero .ybS-hero__inner{grid-template-columns:1.1fr 0.9fr;gap:clamp(32px,5vw,72px);}
    #ybS-hero .ybS-hero__content{max-width:none;margin-inline:0;}
  }
  #ybS-hero .ybS-eyebrow{
    margin:0 0 .35rem;text-transform:uppercase;letter-spacing:.12em;
    font-size:.82rem;color:var(--ybS-accent);font-weight:800;
  }
  #ybS-hero .ybS-title{
    margin:0;font-weight:900;letter-spacing:-.01em;line-height:1.02;
    font-size:clamp(2.2rem,6.5vw,4.2rem);
  }
  #ybS-hero .hide-sm{display:none;}
  @media(min-width:560px){ #ybS-hero .hide-sm{display:inline;} }
  #ybS-hero .ybS-sub{
    margin:.15rem 0 0;font-weight:800;letter-spacing:.08em;
    font-size:clamp(.9rem,1.7vw,1rem);text-transform:uppercase;color:#1f242b;opacity:.95;
  }
  #ybS-hero .ybS-kicker{
    margin:.25rem 0 .85rem;text-transform:uppercase;letter-spacing:.14em;
    font-weight:750;font-size:.82rem;color:var(--ybS-muted);
  }
  #ybS-hero .ybS-lead{
    margin:.2rem 0 .6rem;max-width:60ch;font-size:clamp(1rem,2.1vw,1.125rem);color:#222;
  }
  #ybS-hero .ybS-meta{margin:0 0 1rem;color:#333;opacity:.95;}
  #ybS-hero .ybS-price{
    display:inline-flex;flex-direction:column;gap:.25rem;
    width:fit-content;background:#fff;border:1px solid #eff2f5;
    border-radius:12px;box-shadow:0 6px 16px rgba(0,0,0,.05);
    padding:.5rem .7rem;margin:.3rem 0 .9rem;
    font-size:.94rem;line-height:1.35;
  }
  #ybS-hero .ybS-price__row{display:flex;flex-wrap:wrap;align-items:baseline;gap:.45rem .6rem;}
  #ybS-hero .ybS-price__label{font-weight:700;color:#1f232a;}
  #ybS-hero .ybS-price__value{font-weight:800;}
  #ybS-hero .ybS-price__hint{
    font-weight:700;color:#3a4250;background:#f6f7f9;border:1px solid #e9ecf0;
    border-radius:999px;padding:.14rem .46rem;font-size:.8rem;white-space:nowrap;
  }
  #ybS-hero .ybS-months{display:flex;flex-wrap:wrap;gap:.5rem;margin:.1rem 0 1.1rem;}
  #ybS-hero .ybS-chip{
    appearance:none;border:1px solid rgba(247,92,3,.35);background:#fff;color:#111;
    padding:.48rem .78rem;border-radius:999px;font-weight:800;font-size:.95rem;
    cursor:pointer;
    transition:background .18s ease,color .18s ease,border-color .18s ease,transform .06s ease,box-shadow .18s ease;
  }
  #ybS-hero .ybS-chip:hover{
    background:#fff5ef;border-color:rgba(247,92,3,.6);
    transform:translateY(-1px);box-shadow:0 10px 22px rgba(247,92,3,.10);
  }
  #ybS-hero .ybS-chip.is-active{
    background:var(--ybS-accent);color:#fff;border-color:transparent;
    box-shadow:0 10px 24px rgba(247,92,3,.18);
  }
  #ybS-hero .ybS-chip:focus-visible{outline:0;box-shadow:0 0 0 6px var(--ybS-ring);}
  #ybS-hero .ybS-ctas{display:flex;flex-wrap:wrap;gap:.7rem;align-items:center;}
  #ybS-hero .ybS-btn{
    display:inline-block;white-space:nowrap;padding:.8rem 1.15rem;border-radius:14px;border:0;
    text-decoration:none;font-weight:900;letter-spacing:.01em;font-size:.95rem;
    background:var(--ybS-accent);color:#fff;box-shadow:0 12px 28px rgba(247,92,3,.22);
    transition:transform .06s ease,box-shadow .2s ease,background .15s ease,border-color .2s ease,color .2s ease;
    cursor:pointer;
  }
  #ybS-hero .ybS-btn:hover{
    background:var(--ybS-accent-dark);transform:translateY(-1px);box-shadow:0 16px 36px rgba(247,92,3,.26);
  }
  #ybS-hero .ybS-btn:focus-visible{outline:0;box-shadow:0 0 0 6px var(--ybS-ring);}
  #ybS-hero .ybS-btn--outline{
    background:#fff;color:var(--ybS-accent);border:1px solid rgba(247,92,3,.6);box-shadow:none;
  }
  #ybS-hero .ybS-btn--outline:hover{
    background:#fff5ef;border-color:var(--ybS-accent);color:var(--ybS-accent-dark);
    transform:translateY(-1px);box-shadow:0 10px 26px rgba(247,92,3,.14);
  }
  #ybS-hero .ybS-hero__media{
    position:relative;margin:0 auto;width:100%;
    max-width:clamp(320px,36vw,560px);justify-self:center;
    border-radius:var(--ybS-radius);overflow:hidden;
    box-shadow:0 14px 50px rgba(0,0,0,.12);
  }
  #ybS-hero .ybS-hero__media img{width:100%;height:auto;display:block;object-fit:cover;background:#000;}
  #ybS-hero .ybS-frame{
    position:absolute;inset:0;border-radius:var(--ybS-radius);pointer-events:none;
    box-shadow:inset 0 0 0 1px rgba(0,0,0,.06),inset 0 0 0 2px rgba(247,92,3,.10);
  }
  @media(max-width:919px){
    #ybS-hero .ybS-hero__content{text-align:center;}
    #ybS-hero .ybS-lead,
    #ybS-hero .ybS-meta,
    #ybS-hero .ybS-price{margin-left:auto;margin-right:auto;text-align:left;}
    #ybS-hero .ybS-months{justify-content:center;}
    #ybS-hero .ybS-ctas{justify-content:center;}
  }
</style>

<script>
(function(){
  var root=document.getElementById('ybS-hero');
  if(!root) return;
  var chips=root.querySelectorAll('.ybS-chip');
  var cta=root.querySelector('#ybS-ctaMain');
  function setMonth(btn){
    chips.forEach(function(b){b.classList.toggle('is-active',b===btn);});
    var label=(btn.dataset.month||btn.textContent||'').trim();
    var link=btn.dataset.href||'#';
    if(cta){
      cta.textContent={{ t.hero_cta_prefix | dump | safe }}+' '+label.toLowerCase()+{{ t.hero_cta_suffix | dump | safe }};
      cta.setAttribute('href',link);
      cta.setAttribute('target','_blank');
      cta.setAttribute('rel','noopener noreferrer nofollow');
    }
  }
  chips.forEach(function(btn){btn.addEventListener('click',function(){setMonth(btn);});});
  var active=root.querySelector('.ybS-chip.is-active')||chips[0];
  if(active) setMonth(active);
})();
</script>


<!-- ═══════════════════════════════════════════════════════════════
     SECTION 2 — 4-WEEK STRUCTURE + VIDEO + FAQ
