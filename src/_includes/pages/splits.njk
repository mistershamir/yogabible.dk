  #hvad-er-splits .yb-tile:hover img{transform:scale(1.03);}
  @media(min-width:960px){
    #hvad-er-splits.yb-splits-what{grid-template-columns:minmax(0,0.9fr) minmax(0,1.1fr);column-gap:clamp(20px,4vw,48px);row-gap:1.2rem;}
    #hvad-er-splits .yb-splits-what__grid{grid-template-columns:repeat(3,minmax(0,1fr));gap:.9rem;margin-top:0;}
  }
  @media(max-width:719px){ #hvad-er-splits .yb-splits-what__grid{margin-top:.5rem;} }
</style>


<!-- ═══════════════════════════════════════════════════════════════
     SECTION 5 — EXPLORE MORE (Courses + Teacher Training)
     ═══════════════════════════════════════════════════════════════ -->
<section id="yb-splits-more" class="yb-more" aria-labelledby="yb-splits-more-title">
  <style>
    #yb-splits-more{
      background:#FFFCF9;
      padding:80px 20px;
      font-family:"Helvetica Neue",Helvetica,Arial,system-ui,-apple-system,sans-serif;
    }
    #yb-splits-more .yb-more__inner{max-width:1140px;margin:0 auto;padding:0;}
    #yb-splits-more .yb-more__header{max-width:720px;margin-bottom:2rem;}
    #yb-splits-more .yb-more__grid{display:grid;grid-template-columns:1fr;gap:1.5rem;}
    @media(min-width:900px){ #yb-splits-more .yb-more__grid{grid-template-columns:1fr 1fr;gap:2rem;} }
    #yb-splits-more .yb-more-card{
      background:#fff;border:1px solid #E8E4E0;border-radius:16px;overflow:hidden;
      display:flex;flex-direction:column;box-shadow:0 8px 24px rgba(0,0,0,.06);
      transition:box-shadow .2s ease;
    }
    #yb-splits-more .yb-more-card:hover{box-shadow:0 12px 32px rgba(0,0,0,.1);}
    #yb-splits-more .yb-more-card__image{
      position:relative;margin:0;aspect-ratio:4/3;overflow:hidden;background:#f5f4f2;
      flex-shrink:0;width:100%;display:block;
    }
    #yb-splits-more .yb-more-card__image img{display:block;width:100%;height:100%;object-fit:cover;object-position:center;}
    #yb-splits-more .yb-more-card__body{padding:1.5rem;display:flex;flex-direction:column;flex-grow:1;}
    #yb-splits-more .yb-more-card__blurb{margin:0 0 1.25rem;font-size:.9rem;color:#6F6A66;line-height:1.6;flex-grow:1;}
    #yb-splits-more .yb-more-card__list{list-style:none;margin:0 0 1.25rem;padding:0;flex-grow:1;}
    #yb-splits-more .yb-more-card__list li{position:relative;padding-left:1.5rem;margin:.5rem 0;font-size:.95rem;color:#1C1C1C;line-height:1.5;}
    #yb-splits-more .yb-more-card__list li::before{content:"\2192";position:absolute;left:0;color:#F65D04;font-weight:700;}
    @media(max-width:599px){
      #yb-splits-more{padding:56px 20px;}
      #yb-splits-more .yb-more-card__body{padding:1.25rem;}
      #yb-splits-more .yb-btn{width:100%;text-align:center;}
    }
  </style>
  <div class="yb-more__inner">

    <header class="yb-more__header">
      <p class="yb-more__kicker">{{ t.s5_kicker }}</p>
      <h2 id="yb-splits-more-title" class="yb-more__title">{{ t.s5_title }}</h2>
      <p class="yb-more__lead">{{ t.s5_lead }}</p>
    </header>

    <div class="yb-more__grid">

      <!-- Card 1: Other Courses (Inversions / Backbends) -->
      <article class="yb-more-card">
        <figure class="yb-more-card__image">
          <img id="ybSplitsCourseImg"
               src="https://www.yogabible.dk/s/Inversions_Course_Copenhagen.jpg?format=1500w"
               alt="Inversions {% if lang == 'en' %}course{% else %}kursus{% endif %}"
               loading="lazy">
          <span class="yb-more-card__badge yb-more-card__badge--soft">{{ t.s5_courses_badge }}</span>
        </figure>

        <div class="yb-more-card__body">
          <h3 class="yb-more-card__title">{{ t.s5_courses_title }}</h3>
          <p class="yb-more-card__text">{{ t.s5_courses_desc }}</p>

          <div class="yb-more-card__pills" role="tablist" aria-label="{% if lang == 'en' %}Select course{% else %}Vælg kursus{% endif %}">
            <button class="yb-pill is-active" role="tab" aria-selected="true" data-splcourse="inv">Inversions</button>
            <button class="yb-pill" role="tab" aria-selected="false" data-splcourse="bb">Backbends</button>
          </div>

          <p id="ybSplitsCourseBlurb" class="yb-more-card__blurb"></p>

          <a id="ybSplitsCourseCta" class="yb-btn yb-btn--outline" href="{{ lp }}/inversions"></a>
        </div>
      </article>

      <!-- Card 2: Teacher Training (18w / 4w) -->
      <article class="yb-more-card">
        <figure class="yb-more-card__image">
          <img id="ybSplitsProgramImg"
               src="https://www.yogabible.dk/s/200timer-Yoga-Education-Kbenhavn.png?format=1500w"
               alt=""
               loading="lazy">
          <span id="ybSplitsProgramBadge" class="yb-more-card__badge yb-more-card__badge--primary">{{ t.s5_programs_badge_flex }}</span>
        </figure>

        <div class="yb-more-card__body">
          <h3 id="ybSplitsProgramTitle" class="yb-more-card__title"></h3>

          <div class="yb-more-card__pills" role="tablist" aria-label="{% if lang == 'en' %}Select program{% else %}Vælg program{% endif %}">
            <button class="yb-pill is-active" role="tab" aria-selected="true" data-splprogram="18w">18 Weeks Flexible</button>
            <button class="yb-pill" role="tab" aria-selected="false" data-splprogram="4w">4 Weeks Intensive</button>
          </div>

          <p id="ybSplitsProgramBlurb" class="yb-more-card__blurb"></p>
          <ul id="ybSplitsProgramList" class="yb-more-card__list"></ul>
          <a id="ybSplitsProgramCta" class="yb-btn yb-btn--cta" href=""></a>
        </div>
      </article>

    </div>
  </div>
</section>

<script>
(function(){
  var isEN=(document.documentElement.lang==='en')||(window.location.pathname.indexOf('/en/')===0);
  var lp=isEN?'/en':'';

  /* ── Course pills (Inversions / Backbends) ── */
  var COURSE_DATA={
    inv:{
      image:'https://www.yogabible.dk/s/Inversions_Course_Copenhagen.jpg?format=1500w',
      blurb:isEN?'Learn to work safely with handstands, forearm balances, and headstands – technique, strength, and courage.':'Lær at arbejde sikkert med håndstande, underarmsbalancer og hovedstande – teknik, styrke og mod.',
      href:lp+'/inversions',
      label:isEN?'Learn more about Inversions':'Læs mere om Inversions',
      alt:isEN?'Inversions course':'Inversions kursus'
    },
    bb:{
      image:'https://www.yogabible.dk/s/professional-backbend-yoga-training-copenhagen.jpg?format=1500w',
      blurb:isEN?'Healthy backbends with focus on breath, stability, and gradual mobility in the thoracic spine and hips.':'Sunde bagoverbøjninger med fokus på åndedræt, stabilitet og gradvis mobilitet i brystryg og hofter.',
      href:lp+'/backbends',
      label:isEN?'Learn more about Backbends':'Læs mere om Backbends',
      alt:isEN?'Backbends course':'Backbends kursus'
    }
  };

  var courseImg=document.getElementById('ybSplitsCourseImg');
  var courseBlurb=document.getElementById('ybSplitsCourseBlurb');
  var courseCta=document.getElementById('ybSplitsCourseCta');
  var coursePills=document.querySelectorAll('#yb-splits-more [data-splcourse]');

  if(courseImg&&courseBlurb&&courseCta&&coursePills.length){
    var setCourse=function(key){
      var data=COURSE_DATA[key];
      if(!data) return;
      coursePills.forEach(function(p){
        var isActive=p.dataset.splcourse===key;
        p.classList.toggle('is-active',isActive);
        p.setAttribute('aria-selected',isActive);
      });
      courseImg.src=data.image;
      courseImg.alt=data.alt;
      courseBlurb.textContent=data.blurb;
      courseCta.href=data.href;
      courseCta.textContent=data.label+' \u2192';
    };
    coursePills.forEach(function(p){p.addEventListener('click',function(){setCourse(p.dataset.splcourse);});});
    setCourse('inv');
  }

  /* ── Program pills (18w / 4w) ── */
  var PROGRAM_DATA={
    '18w':{
      title:isEN?'200 hours – 18-week flexible program':'200 timer – 18 ugers fleksibelt program',
      badge:isEN?'Flexible':'Fleksibelt',
      blurb:isEN?'The same <strong>Yoga Alliance-certified</strong> training – spread over <strong>18 weeks</strong> with maximum flexibility. Perfect alongside a job, studies, or family life.':'Samme <strong>Yoga Alliance\u2013certificerede</strong> uddannelse – fordelt over <strong>18 uger</strong> med maksimal fleksibilitet. Perfekt ved siden af job, studie eller familieliv.',
      list:isEN?[
        'Weekday or weekend track \u2014 switch freely',
        'Approx. 12 hours per week incl. homework',
        'Can be combined with full-time work'
      ]:[
        'Hverdags- eller weekendforl\u00f8b \u2014 skift frit',
        'Ca. 12 timer om ugen inkl. hjemmeopgaver',
        'Kan kombineres med fuldtidsarbejde'
      ],
      href:lp+'/200-hours-18-weeks-flexible-programs',
      ctaLabel:isEN?'Go to 18-week flexible training \u2192':'G\u00e5 til 18-ugers fleksibel uddannelse \u2192',
      alt:isEN?'200-hour \u2013 18-week flexible program':'200-timers \u2013 18 ugers fleksibelt program'
    },
    '4w':{
      title:isEN?'200 hours – 4-week intensive program':'200 timer – 4 ugers intensivt program',
      badge:isEN?'Intensive':'Intensivt',
      blurb:isEN?'The same <strong>Yoga Alliance-certified</strong> training – concentrated in <strong>4 weeks</strong> of full immersion. Ideal if you want to dive deep without interruption.':'Samme <strong>Yoga Alliance\u2013certificerede</strong> uddannelse – koncentreret i <strong>4 ugers</strong> fuld fordybelse. Ideelt hvis du vil dykke dybt uden afbrydelser.',
      list:isEN?[
        'Full-time for 4 weeks (Mon\u2013Sat)',
        'Complete immersion in theory and practice',
        '<strong>Accommodation option</strong> during the program'
      ]:[
        'Fuldtid i 4 uger (man\u2013l\u00f8r)',
        'Total fordybelse i teori og praksis',
        '<strong>Mulighed for indkvartering</strong> under forl\u00f8bet'
      ],
      href:lp+'/200-hours-4-weeks-intensive-programs',
      ctaLabel:isEN?'Go to 4-week intensive training \u2192':'G\u00e5 til 4-ugers intensiv uddannelse \u2192',
      alt:isEN?'200-hour \u2013 4-week intensive program':'200-timers \u2013 4 ugers intensivt program'
    }
  };

  var programTitle=document.getElementById('ybSplitsProgramTitle');
  var programBadge=document.getElementById('ybSplitsProgramBadge');
  var programBlurb=document.getElementById('ybSplitsProgramBlurb');
  var programList=document.getElementById('ybSplitsProgramList');
  var programCta=document.getElementById('ybSplitsProgramCta');
  var programImg=document.getElementById('ybSplitsProgramImg');
  var programPills=document.querySelectorAll('#yb-splits-more [data-splprogram]');

  if(programTitle&&programBlurb&&programCta&&programPills.length){
    var setProgram=function(key){
      var data=PROGRAM_DATA[key];
      if(!data) return;
      programPills.forEach(function(p){
        var isActive=p.dataset.splprogram===key;
        p.classList.toggle('is-active',isActive);
        p.setAttribute('aria-selected',isActive);
      });
      programTitle.textContent=data.title;
      if(programBadge) programBadge.textContent=data.badge;
      programBlurb.innerHTML=data.blurb;
      if(programImg) programImg.alt=data.alt;
      if(programList){
        programList.innerHTML='';
        data.list.forEach(function(item){
          var li=document.createElement('li');
          li.innerHTML=item;
          programList.appendChild(li);
        });
      }
      programCta.href=data.href;
      programCta.textContent=data.ctaLabel;
    };
    programPills.forEach(function(p){p.addEventListener('click',function(){setProgram(p.dataset.splprogram);});});
    setProgram('18w');
  }
})();
</script>
