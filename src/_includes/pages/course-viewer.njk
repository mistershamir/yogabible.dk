{% set t = i18n["course-viewer"][lang or "da"] %}
{% set tc = i18n.common[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

<!-- Pass translations to JS -->
<script>
  window._ybCVLang = '{{ lang or "da" }}';
  window._ybCVTranslations = {{ i18n["course-viewer"][lang or "da"] | dump | safe }};
</script>

<section class="yb-cv" id="yb-cv-wrapper">

  <!-- ═══════════════════════════════════════
       GATE WALL (not logged in / not enrolled)
       ═══════════════════════════════════════ -->
  <div class="yb-cv-gate" id="yb-cv-gate" hidden>
    <div class="yb-cv-gate__inner">
      <div class="yb-cv-gate__card">
        <!-- Login gate -->
        <div id="yb-cv-gate-login" hidden>
          <svg class="yb-cv-gate__icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <h2 class="yb-cv-gate__title">{{ t.gate_login_title }}</h2>
          <p class="yb-cv-gate__text">{{ t.gate_login_text }}</p>
          <button class="yb-btn yb-btn--primary" type="button" data-yb-auth-open="login">{{ t.gate_login_btn }}</button>
        </div>
        <!-- Enrollment gate -->
        <div id="yb-cv-gate-enroll" hidden>
          <svg class="yb-cv-gate__icon" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
          <h2 class="yb-cv-gate__title">{{ t.gate_enroll_title }}</h2>
          <p class="yb-cv-gate__text">{{ t.gate_enroll_text }}</p>
          <a href="{{ lp }}/kontakt" class="yb-btn yb-btn--primary">{{ t.gate_enroll_btn }}</a>
        </div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════
       LOADING STATE
       ═══════════════════════════════════════ -->
  <div class="yb-cv-loading" id="yb-cv-loading" hidden>
    <div class="yb-cv-loading__spinner"></div>
    <p class="yb-cv-loading__text">{{ t.loading }}</p>
  </div>

  <!-- ═══════════════════════════════════════
       ERROR STATE
       ═══════════════════════════════════════ -->
  <div class="yb-cv-error-page" id="yb-cv-error-page" hidden>
    <div class="yb-cv-error-page__inner">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <p class="yb-cv-error-page__msg" id="yb-cv-error-msg">{{ t.error_load_failed }}</p>
      <a href="{{ lp }}/profil" class="yb-btn yb-btn--outline">{{ t.back_to_courses }}</a>
    </div>
  </div>

  <!-- ═══════════════════════════════════════
       COURSE VIEWER
       ═══════════════════════════════════════ -->
  <div class="yb-cv-viewer" id="yb-cv-viewer" hidden>

    <!-- Top Bar -->
    <div class="yb-cv-topbar">
      <a href="{{ lp }}/profil#mine-kurser" class="yb-cv-topbar__back" id="yb-cv-back-link">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        {{ t.back_to_courses }}
      </a>
      <h1 class="yb-cv-topbar__title" id="yb-cv-course-title"></h1>
      <div class="yb-cv-topbar__actions">
        <button class="yb-cv-topbar__btn" type="button" id="yb-cv-search-toggle" aria-label="{{ t.search_btn }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        </button>
        <button class="yb-cv-topbar__btn yb-cv-topbar__btn--sidebar" type="button" id="yb-cv-sidebar-toggle" aria-label="{{ t.sidebar_toggle }}">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
    </div>

    <!-- Search Panel -->
    <div class="yb-cv-search" id="yb-cv-search" hidden>
      <div class="yb-cv-search__inner">
        <div class="yb-cv-search__field">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="search" id="yb-cv-search-input" class="yb-cv-search__input" placeholder="{{ t.search_placeholder }}" autocomplete="off">
          <button type="button" class="yb-cv-search__close" id="yb-cv-search-close" aria-label="{{ t.close_btn }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </button>
        </div>
        <div class="yb-cv-search__results" id="yb-cv-search-results"></div>
      </div>
    </div>

    <!-- Main Layout -->
    <div class="yb-cv-layout">

      <!-- Sidebar Overlay (mobile) -->
      <div class="yb-cv-sidebar-overlay" id="yb-cv-sidebar-overlay"></div>

      <!-- Sidebar -->
      <aside class="yb-cv-sidebar" id="yb-cv-sidebar">
        <div class="yb-cv-sidebar__header">
          <div class="yb-cv-sidebar__progress">
            <div class="yb-cv-sidebar__progress-track">
              <div class="yb-cv-sidebar__progress-bar" id="yb-cv-progress-bar" style="width:0%"></div>
            </div>
            <span class="yb-cv-sidebar__progress-text" id="yb-cv-progress-text">0%</span>
          </div>
        </div>
        <nav class="yb-cv-sidebar__nav" id="yb-cv-sidebar-modules">
          <!-- Rendered by JS -->
        </nav>
        <div class="yb-cv-sidebar__footer">
          <button class="yb-cv-sidebar__notes-btn" type="button" id="yb-cv-my-comments-btn">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
            {{ t.my_comments_btn }}
          </button>
        </div>
      </aside>

      <!-- Content Area -->
      <main class="yb-cv-content" id="yb-cv-content">

        <!-- Chapter View -->
        <article class="yb-cv-chapter" id="yb-cv-chapter" hidden>
          <div class="yb-cv-chapter__header">
            <span class="yb-cv-chapter__eyebrow" id="yb-cv-chapter-eyebrow"></span>
            <h1 class="yb-cv-chapter__title" id="yb-cv-chapter-title"></h1>
          </div>
          <div class="yb-cv-chapter__body" id="yb-cv-chapter-content">
            <!-- Chapter HTML content loaded by JS -->
          </div>

          <!-- Chapter Navigation -->
          <div class="yb-cv-chapter-nav" id="yb-cv-chapter-nav">
            <button class="yb-cv-chapter-nav__btn yb-cv-chapter-nav__btn--prev" id="yb-cv-nav-prev" type="button" hidden>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
              <span id="yb-cv-nav-prev-label">{{ t.nav_previous }}</span>
            </button>
            <button class="yb-cv-chapter-nav__btn yb-cv-chapter-nav__btn--next" id="yb-cv-nav-next" type="button" hidden>
              <span id="yb-cv-nav-next-label">{{ t.nav_next }}</span>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 6 15 12 9 18"/></svg>
            </button>
          </div>

          <!-- Comments Section -->
          <div class="yb-cv-comments" id="yb-cv-comments">
            <h3 class="yb-cv-comments__title">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
              {{ t.comments_title }}
            </h3>
            <form class="yb-cv-comments__form" id="yb-cv-comment-form">
              <textarea id="yb-cv-comment-input" class="yb-cv-comments__input" placeholder="{{ t.comments_placeholder }}" rows="3"></textarea>
              <button type="submit" class="yb-btn yb-btn--primary yb-btn--sm">{{ t.comments_post }}</button>
            </form>
            <div class="yb-cv-comments__list" id="yb-cv-comments-list"></div>
          </div>
        </article>

        <!-- My Comments View -->
        <div class="yb-cv-my-comments" id="yb-cv-my-comments" hidden>
          <div class="yb-cv-my-comments__header">
            <h2 class="yb-cv-my-comments__title">{{ t.my_comments_title }}</h2>
            <button class="yb-btn yb-btn--outline yb-btn--sm" type="button" id="yb-cv-my-comments-close">{{ t.close_btn }}</button>
          </div>
          <div class="yb-cv-my-comments__list" id="yb-cv-my-comments-list"></div>
        </div>

      </main>
    </div>
  </div>
</section>

<script src="/js/course-viewer.js"></script>
