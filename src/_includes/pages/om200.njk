</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 6: DETAILED HOUR BREAKDOWN
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-breakdown" id="om2-breakdown" aria-labelledby="om2-breakdown-title">
  <div class="om2-breakdown__inner">
    <div class="om2-breakdown__grid">

      {# LEFT: Title + intro #}
      <div class="om2-breakdown__left">
        <header>
          <p class="om2-breakdown__eyebrow">{{ t.breakdown_eyebrow }}</p>
          <h2 id="om2-breakdown-title" class="om2-breakdown__title">{{ t.breakdown_title }}</h2>
          <p class="om2-breakdown__lead">{{ t.breakdown_lead1 | safe }}</p>
          <p class="om2-breakdown__lead">{{ t.breakdown_lead2 | safe }}</p>

          <div class="om2-breakdown__chips" role="list">
            {% for i in range(1, 5) %}
            <span role="listitem" class="om2-breakdown__chip">
              {% if i == 1 %}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              {% elif i == 2 %}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
              {% elif i == 3 %}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
              {% elif i == 4 %}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
              {% endif %}
              {{ t["breakdown_chip" + (i | string)] }}
            </span>
            {% endfor %}
          </div>

          <div class="om2-breakdown__note">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            <p>{{ t.breakdown_note | safe }}</p>
          </div>

          {# Curriculum animation — replaces video placeholder #}
          {% include "components/curriculum-animation.njk" %}
        </header>
      </div>

      {# RIGHT: Total + accordion #}
      <div class="om2-breakdown__right">
        <div class="om2-breakdown__total">
          <span class="om2-breakdown__total-num">{{ t.breakdown_total }}</span>
          <span class="om2-breakdown__total-text">{{ t.breakdown_total_label }}</span>
        </div>

        <div class="om2-breakdown__accordion" role="list" aria-label="{{ t.breakdown_acc_label }}" data-om2-single-accordion>
          {% for i in range(1, 10) %}
          <details class="om2-breakdown__item" role="listitem"{% if i == 1 %} open{% endif %}>
            <summary class="om2-breakdown__summary">
              <span class="om2-breakdown__hours-pill">{{ t["breakdown_a" + (i | string) + "_hours"] }}</span>
              <span class="om2-breakdown__label">{{ t["breakdown_a" + (i | string) + "_label"] }}</span>
              <span class="om2-breakdown__chev" aria-hidden="true"></span>
            </summary>
            <div class="om2-breakdown__body">
              {{ t["breakdown_a" + (i | string) + "_body"] | safe }}
            </div>
          </details>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 7: ONLINE PARTICIPATION
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-online" id="om2-online" aria-labelledby="om2-online-title">
