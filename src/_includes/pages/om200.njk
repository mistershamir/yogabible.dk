      {% for f in range(1, 4) %}
      <article class="om2-formats__card">
        <div class="om2-formats__card-head">
          <span class="om2-formats__badge">{{ t["format" + (f | string) + "_badge"] }}</span>
          <h3 class="om2-formats__card-name">{{ t["format" + (f | string) + "_name"] }}</h3>
          <span class="om2-formats__card-price">{{ t["format" + (f | string) + "_price"] }}</span>
          <p class="om2-formats__card-desc">{{ t["format" + (f | string) + "_desc"] }}</p>
        </div>
        <div class="om2-formats__card-details">
          {% for d in range(1, 6) %}
          <div class="om2-formats__detail-row">
            <span class="om2-formats__detail-label">{{ t["format" + (f | string) + "_detail" + (d | string) + "_label"] }}</span>
            <span class="om2-formats__detail-value">{{ t["format" + (f | string) + "_detail" + (d | string) + "_value"] }}</span>
          </div>
          {% endfor %}
        </div>
        <p class="om2-formats__suitable">{{ t["format" + (f | string) + "_suitable"] }}</p>
        <div class="om2-formats__card-foot">
          {% if f == 1 %}
          <a class="yb-btn yb-btn--primary" href="{{ lp }}/200-hours-18-weeks-flexible-programs" target="_blank" rel="noopener">
          {% elif f == 2 %}
          <a class="yb-btn yb-btn--outline-brand" href="{{ lp }}/200-hours-8-weeks-semi-intensive-programs" target="_blank" rel="noopener">
          {% else %}
          <a class="yb-btn yb-btn--outline-brand" href="{{ lp }}/200-hours-4-weeks-intensive-programs" target="_blank" rel="noopener">
          {% endif %}
            <span>{{ t["format" + (f | string) + "_cta"] }}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 10b: PRICING BREAKDOWN
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-pricing" id="om2-pricing" aria-labelledby="om2-pricing-title">
  <div class="om2-pricing__inner">
    <div class="om2-pricing__header">
      <p class="om2-pricing__eyebrow">{{ t.pricing_eyebrow }}</p>
      <h2 id="om2-pricing-title" class="om2-pricing__title">{{ t.pricing_title }}</h2>
      <p class="om2-pricing__lead">{{ t.pricing_lead }}</p>
    </div>
    <div class="om2-pricing__grid">

      {# LEFT: Breakdown #}
      <div class="om2-pricing__breakdown">
        <div class="om2-pricing__rows">
          {% for r in range(1, 5) %}
          <div class="om2-pricing__row">
            <div class="om2-pricing__row-main">
              <span class="om2-pricing__row-label">{{ t["pricing_row" + (r | string) + "_label"] }}</span>
              <span class="om2-pricing__row-value">{{ t["pricing_row" + (r | string) + "_value"] }}</span>
            </div>
            <p class="om2-pricing__row-desc">{{ t["pricing_row" + (r | string) + "_desc"] }}</p>
          </div>
          {% endfor %}

          <div class="om2-pricing__total-row">
            <span class="om2-pricing__total-label">{{ t.pricing_total_label }}</span>
            <span class="om2-pricing__total-value">{{ t.pricing_total }}</span>
          </div>
        </div>
      </div>

      {# RIGHT: Includes + CTA #}
      <div class="om2-pricing__sidebar">
        <div class="om2-pricing__includes">
          <h3 class="om2-pricing__includes-title">{{ t.pricing_includes_title }}</h3>
          <ul class="om2-pricing__includes-list">
            {% for i in range(1, 7) %}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              <span>{{ t["pricing_inc" + (i | string)] }}</span>
            </li>
            {% endfor %}
          </ul>
        </div>

        <div class="om2-pricing__notes">
          <p class="om2-pricing__deposit">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
            {{ t.pricing_deposit }}
          </p>
          <p class="om2-pricing__installment">{{ t.pricing_installment }}</p>
        </div>

        <div style="display:flex;flex-direction:column;gap:.75rem">
          <button onclick="openYBScheduleModal('all')" class="yb-btn yb-btn--primary yb-btn--large om2-pricing__cta">
            <span>{{ t.pricing_cta }}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 11: YOGA ALLIANCE CERTIFICATION
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-ya" id="om2-ya" aria-labelledby="om2-ya-title">
  <div class="om2-ya__inner">
    {# TOP ROW: Intro + Badges side by side #}
    <div class="om2-ya__top">
      <div class="om2-ya__intro">
        <p class="om2-ya__eyebrow">{{ t.ya_eyebrow }}</p>
        <h2 id="om2-ya-title" class="om2-ya__title">{{ t.ya_title }}</h2>
        <div class="om2-ya__meta">
          <span class="om2-ya__chip">{{ t.ya_chip_rys }}</span>
          <span class="om2-ya__chip">{{ t.ya_chip_eryt }}</span>
          <span class="om2-ya__chip">{{ t.ya_chip_yacep }}</span>
          <span class="om2-ya__chip om2-ya__chip--highlight">{{ t.ya_chip_intl }}</span>
        </div>
        <p class="om2-ya__lead">{{ t.ya_lead }}</p>

        <div class="om2-ya__path" aria-label="{{ t.ya_path_label }}">
          <span class="om2-ya__step">{{ t.ya_path_step1 }}</span>
          <span class="om2-ya__arrow-icon">→</span>
          <span class="om2-ya__step">{{ t.ya_path_step2 }}</span>
          <span class="om2-ya__arrow-icon">→</span>
          <span class="om2-ya__step">{{ t.ya_path_step3 }}</span>
        </div>
      </div>

      <aside class="om2-ya__badges" aria-label="{{ t.ya_badges_label }}">
        <figure class="om2-ya__badge-card">
          <div class="om2-ya__hero-badge">
            <div class="om2-ya__tile om2-ya__tile--dark om2-ya__tile--hero" data-label="Yoga Alliance">
              <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/brand/ya-logo-white.webp"
                   alt="Yoga Alliance logo" loading="lazy" decoding="async"
                   onerror="this.style.display='none';this.closest('.om2-ya__tile').classList.add('om2-ya__tile--fallback');">
            </div>
          </div>
          <div class="om2-ya__badge-grid" role="list">
            <div class="om2-ya__tile" role="listitem" data-label="E-RYT 500">
              <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/brand/eryt500.png" alt="E-RYT 500 badge" loading="lazy" decoding="async"
                   onerror="this.style.display='none';this.closest('.om2-ya__tile').classList.add('om2-ya__tile--fallback');">
            </div>
            <div class="om2-ya__tile" role="listitem" data-label="RYS 200">
              <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/brand/rys200.png" alt="RYS 200 badge" loading="lazy" decoding="async"
                   onerror="this.style.display='none';this.closest('.om2-ya__tile').classList.add('om2-ya__tile--fallback');">
            </div>
            <div class="om2-ya__tile" role="listitem" data-label="YACEP">
              <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/brand/yacep.png" alt="YACEP badge" loading="lazy" decoding="async"
                   onerror="this.style.display='none';this.closest('.om2-ya__tile').classList.add('om2-ya__tile--fallback');">
            </div>
          </div>
        </figure>
      </aside>
    </div>

    {# STYLES + DOORS: Two columns #}
    <div class="om2-ya__content-row">
      <div class="om2-ya__styles">
        <h3 class="om2-ya__sub-title">{{ t.ya_styles_title }}</h3>
        <div class="om2-ya__style-cards">
          {% set style_emojis = ["🧘", "🌊", "🌙", "🔥", "🧠"] %}
          {% for i in range(1, 6) %}
          <div class="om2-ya__style-card">
            <span class="om2-ya__style-icon">{{ style_emojis[i - 1] }}</span>
            <div>
              <h4 class="om2-ya__style-name">{{ t["ya_style" + (i | string) + "_title"] }}</h4>
              <p class="om2-ya__style-desc">{{ t["ya_style" + (i | string) + "_desc"] }}</p>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>

      <div class="om2-ya__doors">
        <h3 class="om2-ya__sub-title">{{ t.ya_doors_title }}</h3>
        <ul class="om2-ya__doors-list">
          {% for i in range(1, 6) %}
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{{ t["ya_door" + (i | string)] | safe }}</span>
          </li>
          {% endfor %}
        </ul>

        <div class="om2-ya__accordion" data-om2-ya-accordion>
          {% for i in range(1, 5) %}
          <div class="om2-ya__acc-item">
            <button type="button" class="om2-ya__acc-btn" aria-expanded="false" aria-controls="om2-ya-p{{ i }}">
              <span>{{ t["ya_faq" + (i | string) + "_q"] }}</span>
              <span class="om2-ya__chev" aria-hidden="true"></span>
            </button>
            <div id="om2-ya-p{{ i }}" class="om2-ya__acc-panel" hidden>
              <p>{{ t["ya_faq" + (i | string) + "_a"] | safe }}</p>
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </div>

    {# CLOSING + CTA #}
    <div class="om2-ya__footer">
      <p class="om2-ya__closing">{{ t.ya_closing }}</p>
      <a class="yb-btn yb-btn--primary" href="https://www.yogaalliance.org/" target="_blank" rel="noopener">
        <span>{{ t.ya_cta_external }}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
      </a>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 11: FAQ — General Questions
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-faq" id="om2-faq" aria-labelledby="om2-faq-title">
  <div class="om2-faq__inner">
    <header class="om2-faq__head">
      <p class="om2-faq__eyebrow">{{ t.faq_eyebrow }}</p>
      <h2 class="om2-faq__title" id="om2-faq-title">{{ t.faq_title }}</h2>
      <p class="om2-faq__lead">{{ t.faq_lead }}</p>
    </header>

    <div class="om2-faq__grid" data-om2-faq-accordion>
      {% for i in range(1, 11) %}
      <div class="om2-faq__item">
        <button type="button" class="om2-faq__btn" aria-expanded="false" aria-controls="om2-faq-p{{ i }}">
          <span>{{ t["faq" + (i | string) + "_q"] }}</span>
          <span class="om2-faq__chev" aria-hidden="true"></span>
        </button>
        <div id="om2-faq-p{{ i }}" class="om2-faq__panel" hidden>
          <p>{{ t["faq" + (i | string) + "_a"] | safe }}</p>
        </div>
      </div>
      {% endfor %}
    </div>

    <div class="om2-faq__contact">
      <a href="{{ lp }}{{ t.faq_contact_link }}" class="yb-btn yb-btn--outline-brand" target="_blank" rel="noopener">
        <span>{{ t.faq_contact }}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   CTA SECTION
   ═══════════════════════════════════════════════════════════ #}
<section class="cta-section">
  <div class="container">
    <h2 class="cta-section__title">{{ t.cta_title }}</h2>
    <p class="cta-section__text">{{ t.cta_text }}</p>
    <div style="display:flex;flex-wrap:wrap;gap:1rem;justify-content:center">
      <button onclick="openYBScheduleModal('all')" class="yb-btn yb-btn--primary yb-btn--large">{{ t.cta_button }}</button>
    </div>
  </div>
</section>
