            {{ t.online_chip1 }}
          </li>
          <li class="om2-online__chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
            {{ t.online_chip2 }}
          </li>
          <li class="om2-online__chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            {{ t.online_chip3 }}
          </li>
          <li class="om2-online__chip">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
            {{ t.online_chip4 }}
          </li>
        </ul>

        <div class="om2-online__content">
          <p>{{ t.online_detail1 | safe }}</p>
          <p>{{ t.online_detail2 | safe }}</p>
          <p>{{ t.online_detail3 | safe }}</p>
          <p>{{ t.online_detail4 | safe }}</p>
          <p class="om2-online__result">{{ t.online_result | safe }}</p>
        </div>

        <div class="om2-online__how">
          <h3 class="om2-online__how-title">{{ t.online_how_title }}</h3>
          <ul class="om2-online__checklist">
            {% for i in range(1, 5) %}
            <li>
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
              {{ t["online_check" + (i | string)] | safe }}
