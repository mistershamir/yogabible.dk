        <p class="om2-prep__lead">{{ t.prep_lead | safe }}</p>
        <p class="om2-prep__text">{{ t.prep_text1 | safe }}</p>
        <p class="om2-prep__text">{{ t.prep_text2 | safe }}</p>

        <div class="om2-prep__refund">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>{{ t.prep_refund }}</span>
        </div>
      </div>

      {# RIGHT: Price badge + checklist + CTA #}
