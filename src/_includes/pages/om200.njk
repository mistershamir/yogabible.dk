    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 5b: PREPARATION PHASE — Info + Benefits
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-prep" id="om2-prep" aria-labelledby="om2-prep-title">
