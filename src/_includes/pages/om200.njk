{% set t = i18n.om200[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}


<!-- FAQPage Schema (AEO — featured snippets for AI search) -->
<script type="application/ld+json">
{%- set _faqs = [
      [t.faq1_q, t.faq1_a],
      [t.faq2_q, t.faq2_a],
      [t.faq3_q, t.faq3_a],
      [t.faq4_q, t.faq4_a],
      [t.faq5_q, t.faq5_a],
      [t.faq6_q, t.faq6_a],
      [t.faq7_q, t.faq7_a],
      [t.faq8_q, t.faq8_a],
      [t.faq9_q, t.faq9_a],
      [t.faq10_q, t.faq10_a],
      [t.ya_faq1_q, t.ya_faq1_a],
      [t.ya_faq2_q, t.ya_faq2_a],
      [t.ya_faq3_q, t.ya_faq3_a],
      [t.ya_faq4_q, t.ya_faq4_a]
    ] -%}
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in _faqs %}
    {
      "@type": "Question",
      "name": {{ faq[0] | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq[1] | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

{# ═══════════════════════════════════════════════════════════
   PRIMARY HERO — Dark Cinematic (full-width)
   ═══════════════════════════════════════════════════════════ #}
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title | safe }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <button type="button" class="yb-btn yb-btn--primary yb-btn--large" onclick="openYBScheduleModal('all')">{{ t.hero_cta_schedule }}</button>
      <a href="#om2-formats" class="yb-btn yb-btn--outline-white yb-btn--large">{{ t.hero_cta_formats }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 1: HERO — Split layout (content + image carousel)
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-hero" id="om2-hero">
  <div class="om2-hero__inner">

    {# CONTENT (Left on desktop, second on mobile) #}
    <div class="om2-hero__content">
      <p class="om2-hero__eyebrow">{{ t.hero_tagline }}</p>
      <h1 class="om2-hero__title">{{ t.hero_title }}</h1>
      <p class="om2-hero__lead">{{ t.hero_subtitle }}</p>
      <p class="om2-hero__subtext">{{ t.hero_subtext }}</p>
      <div class="om2-hero__divider"></div>

      <p class="om2-hero__acc-label">{{ t.hero_acc_label }}</p>
      <div class="om2-hero__accordions" aria-label="{{ t.hero_acc_label }}">
        {% for i in range(1, 7) %}
        <details class="om2-hero__acc">
          <summary class="om2-hero__acc-sum">
            <span class="om2-hero__acc-icon">◇</span>
            <span class="om2-hero__acc-title">{{ t["hero_acc" + (i | string) + "_title"] }}</span>
            <span class="om2-hero__acc-chevron"></span>
          </summary>
          <div class="om2-hero__acc-body">{{ t["hero_acc" + (i | string) + "_body"] }}</div>
        </details>
        {% endfor %}
        {# Special: Business of Yoga with badge #}
        <details class="om2-hero__acc">
          <summary class="om2-hero__acc-sum">
            <span class="om2-hero__acc-icon">★</span>
            <span class="om2-hero__acc-title">{{ t.hero_acc7_title }}</span>
            <span class="om2-hero__acc-badge">{{ t.hero_acc7_badge }}</span>
            <span class="om2-hero__acc-chevron"></span>
          </summary>
          <div class="om2-hero__acc-body">{{ t.hero_acc7_body }}</div>
        </details>
      </div>

      {# MOBILE CTAs #}
      <div class="om2-hero__ctas om2-hero__ctas--mobile">
        <a class="yb-btn yb-btn--primary" href="{{ lp }}/200-hours-18-weeks-flexible-programs" target="_blank" rel="noopener">
          <span>{{ t.hero_cta_18w }}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a class="yb-btn yb-btn--outline-brand" href="{{ lp }}/200-hours-8-weeks-semi-intensive-programs" target="_blank" rel="noopener">
          <span>{{ t.hero_cta_8w }}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a class="yb-btn yb-btn--outline-brand" href="{{ lp }}/200-hours-4-weeks-intensive-programs" target="_blank" rel="noopener">
          <span>{{ t.hero_cta_4w }}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>

    {# MEDIA (Right on desktop, first on mobile) — Vertical review video #}
    <div class="om2-hero__media-wrap">
      <div class="om2-hero__video-wrap" data-review-video>
        <video muted playsinline preload="metadata"
          poster="{{ "yoga-bible-DK/programs/om200/yogalaereruddannelse-200-timer-elev-anmeldelse.jpg" | cloudvid("w_608,c_fill,so_1,q_60") }}">
          <source src="{{ "yoga-bible-DK/programs/om200/yogalaereruddannelse-200-timer-elev-anmeldelse" | cloudvid("w_608,q_auto") }}" type="video/mp4">
        </video>
        <button type="button" data-mute-toggle class="om2-hero__mute-btn" aria-label="Toggle sound">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/>
            <line class="yb-mute-x1" x1="23" y1="9" x2="17" y2="15"/>
            <line class="yb-mute-x2" x1="17" y1="9" x2="23" y2="15"/>
          </svg>
        </button>
      </div>

      {# DESKTOP CTAs #}
      <div class="om2-hero__ctas om2-hero__ctas--desktop">
        <a class="yb-btn yb-btn--primary" href="{{ lp }}/200-hours-18-weeks-flexible-programs" target="_blank" rel="noopener">
          <span>{{ t.hero_cta_18w }}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a class="yb-btn yb-btn--outline-brand" href="{{ lp }}/200-hours-8-weeks-semi-intensive-programs" target="_blank" rel="noopener">
          <span>{{ t.hero_cta_8w }}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
        <a class="yb-btn yb-btn--outline-brand" href="{{ lp }}/200-hours-4-weeks-intensive-programs" target="_blank" rel="noopener">
          <span>{{ t.hero_cta_4w }}</span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 2: 200 HOURS — Donut Chart + Module Cards
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-hours" id="om2-hours" aria-labelledby="om2-hours-title">
  <div class="om2-hours__inner">
    <header class="om2-hours__head">
      <p class="om2-hours__eyebrow">{{ t.hours_eyebrow }}</p>
      <h2 class="om2-hours__title" id="om2-hours-title">{{ t.hours_title }}</h2>
      <p class="om2-hours__lead">{{ t.hours_lead | safe }}</p>
    </header>

    <div class="om2-hours__grid">
      {# LEFT: Donut + legend #}
      <aside class="om2-hours__viz" aria-label="{{ t.hours_legend_label }}">
        <div class="om2-hours__donut" role="img" aria-label="{{ t.hours_chart_label }}">
          <div class="om2-hours__donut-core">
            <span class="om2-hours__total" data-om2-total>200</span>
            <span class="om2-hours__total-sub">{{ t.hours_total_label }}</span>
          </div>
        </div>
        <ul class="om2-hours__legend" data-om2-legend aria-label="{{ t.hours_legend_label }}"></ul>
      </aside>

      {# RIGHT: Module cards #}
      <div class="om2-hours__rightcol">
        <div class="om2-hours__modules">
          {% set icons = ["🧘", "🌊", "🌙", "🦴", "📿", "📚"] %}
          {% for i in range(1, 7) %}
          <article class="om2-hours__card">
            <div class="om2-hours__card-icon">{{ icons[i - 1] }}</div>
            <div class="om2-hours__card-content">
              <h3 class="om2-hours__card-title">{{ t["hours_mod" + (i | string) + "_title"] | safe }}</h3>
              <p class="om2-hours__card-text">{{ t["hours_mod" + (i | string) + "_desc"] | safe }}</p>
            </div>
          </article>
          {% endfor %}
        </div>
        <footer class="om2-hours__foot">
          <a class="yb-btn yb-btn--primary" href="#om2-breakdown" aria-label="{{ t.hours_cta }}">
            <span>{{ t.hours_cta }}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <p class="om2-hours__note">{{ t.hours_note }}</p>
        </footer>
      </div>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 2b: EDUCATION METHODS — Triangle Method + Vinyasa Plus
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-methods" id="om2-methods" aria-labelledby="om2-methods-title">
  <div class="om2-methods__inner">
    <header class="om2-methods__head">
      <p class="om2-methods__eyebrow">{{ t.methods_eyebrow }}</p>
      <h2 class="om2-methods__title" id="om2-methods-title">{{ t.methods_title }}</h2>
      <p class="om2-methods__lead">{{ t.methods_lead | safe }}</p>
    </header>

    <div class="om2-methods__cards">

      {# ── THE TRIANGLE METHOD ── #}
      <article class="om2-methods__card om2-methods__card--triangle">
        <div class="om2-methods__card-badge">{{ t.tri_badge }}</div>
        <h3 class="om2-methods__card-title">{{ t.tri_title }}</h3>
        <p class="om2-methods__card-subtitle">{{ t.tri_subtitle }}</p>
        <p class="om2-methods__card-lead">{{ t.tri_lead }}</p>

        {# Animated Triangle Visual #}
        {% include "components/triangle-method-animation.njk" %}

        <div class="om2-methods__styles">
          <div class="om2-methods__style">
            <span class="om2-methods__style-icon">🧘</span>
            <div>
              <h4 class="om2-methods__style-name">{{ t.tri_hatha_title }}</h4>
              <p class="om2-methods__style-desc">{{ t.tri_hatha_desc }}</p>
            </div>
          </div>
          <div class="om2-methods__style">
            <span class="om2-methods__style-icon">🌊</span>
            <div>
              <h4 class="om2-methods__style-name">{{ t.tri_vinyasa_title }}</h4>
              <p class="om2-methods__style-desc">{{ t.tri_vinyasa_desc }}</p>
            </div>
          </div>
          <div class="om2-methods__style">
            <span class="om2-methods__style-icon">🌙</span>
            <div>
              <h4 class="om2-methods__style-name">{{ t.tri_yin_title }}</h4>
              <p class="om2-methods__style-desc">{{ t.tri_yin_desc }}</p>
            </div>
          </div>
        </div>

        <div class="om2-methods__why">
          <h4 class="om2-methods__why-title">{{ t.tri_why_title }}</h4>
          <p class="om2-methods__why-text">{{ t.tri_why_text | safe }}</p>
        </div>

        <ul class="om2-methods__benefits">
          {% for i in range(1, 4) %}
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{{ t["tri_benefit" + (i | string)] | safe }}</span>
          </li>
          {% endfor %}
        </ul>
      </article>

      {# ── VINYASA PLUS ── #}
      <article class="om2-methods__card om2-methods__card--vinyasa-plus">
        <div class="om2-methods__card-badge om2-methods__card-badge--alt">{{ t.vp_badge }}</div>
        <h3 class="om2-methods__card-title">{{ t.vp_title }}</h3>
        <p class="om2-methods__card-subtitle">{{ t.vp_subtitle }}</p>
        <p class="om2-methods__card-lead">{{ t.vp_lead }}</p>

        {# Animated Vinyasa Plus Visual #}
        {% include "components/vinyasa-plus-animation.njk" %}

        <div class="om2-methods__split">
          <h4 class="om2-methods__split-title">{{ t.vp_split_title }}</h4>
          <div class="om2-methods__split-bars">
            <div class="om2-methods__split-bar om2-methods__split-bar--vinyasa">
              <span class="om2-methods__split-label">{{ t.vp_split_vinyasa }}</span>
              <p class="om2-methods__split-desc">{{ t.vp_split_vinyasa_desc }}</p>
            </div>
            <div class="om2-methods__split-bar om2-methods__split-bar--yin">
              <span class="om2-methods__split-label">{{ t.vp_split_yin }}</span>
              <p class="om2-methods__split-desc">{{ t.vp_split_yin_desc }}</p>
            </div>
          </div>
        </div>

        <div class="om2-methods__why">
          <h4 class="om2-methods__why-title">{{ t.vp_why_title }}</h4>
          <p class="om2-methods__why-text">{{ t.vp_why_text | safe }}</p>
        </div>

        <ul class="om2-methods__benefits">
          {% for i in range(1, 4) %}
          <li>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{{ t["vp_benefit" + (i | string)] | safe }}</span>
          </li>
          {% endfor %}
        </ul>
      </article>
    </div>

    {# SHARED: Both methods include #}
    <div class="om2-methods__shared">
      <h3 class="om2-methods__shared-title">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        {{ t.methods_shared_title }}
      </h3>
      <ul class="om2-methods__shared-list">
        {% for i in range(1, 4) %}
        <li>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          <span>{{ t["methods_shared" + (i | string)] | safe }}</span>
        </li>
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 3: MEET THE TEACHERS
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-teachers" id="om2-teachers" aria-labelledby="om2-teachers-title">
  <div class="om2-teachers__inner">
    <header class="om2-teachers__head">
      <p class="om2-teachers__eyebrow">{{ t.teachers_eyebrow }}</p>
      <h2 class="om2-teachers__title" id="om2-teachers-title">{{ t.teachers_title }}</h2>
      <p class="om2-teachers__lead">{{ t.teachers_lead | safe }}</p>
    </header>

    <div class="om2-teachers__grid">
      {% for i in range(1, 5) %}
      <article class="om2-teachers__card{% if i == 1 %} om2-teachers__card--lead{% endif %}">
        <div class="om2-teachers__portrait">
          {# PLACEHOLDER — Replace with actual image: 400×500px portrait #}
          <div class="om2-teachers__placeholder" aria-label="{{ t.teachers_img_placeholder }}">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" opacity="0.4">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
            <span class="om2-teachers__placeholder-dim">{{ t.teachers_img_dimensions }}</span>
          </div>
        </div>
        <div class="om2-teachers__info">
          <h3 class="om2-teachers__name">{{ t["teachers" + (i | string) + "_name"] }}</h3>
          <p class="om2-teachers__role">{{ t["teachers" + (i | string) + "_role"] }}</p>
          <p class="om2-teachers__bio">{{ t["teachers" + (i | string) + "_bio"] }}</p>
          <div class="om2-teachers__specs">
            {% for s in range(1, 4) %}
            <span class="om2-teachers__spec">{{ t["teachers" + (i | string) + "_spec" + (s | string)] }}</span>
            {% endfor %}
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

    <div class="om2-teachers__cta-wrap">
      <a class="yb-btn yb-btn--outline-brand" href="{{ lp }}{{ t.teachers_cta_link }}" target="_blank" rel="noopener">
        <span>{{ t.teachers_cta }}</span>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 4: CREDENTIALS — Experience, Quality, Certification
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-cred" id="om2-cred" aria-labelledby="om2-cred-title">
  <div class="om2-cred__inner">
    {# MEDIA (certificate image) #}
    <div class="om2-cred__media">
      <div class="om2-cred__image">
        <img
          src="https://res.cloudinary.com/ddcynsa30/image/upload/v1771966816/Sample_Certificate_jzjtfx.png"
          alt="Yoga Alliance RYS 200 Certificate Sample"
          loading="lazy"
          decoding="async"
        >
      </div>
    </div>

    {# CONTENT #}
    <div class="om2-cred__content">
      <p class="om2-cred__eyebrow">{{ t.cred_eyebrow }}</p>
      <h2 id="om2-cred-title" class="om2-cred__title">{{ t.cred_title }}</h2>
      <p class="om2-cred__lead">{{ t.cred_lead }}</p>

      <div class="om2-cred__stats">
        <div class="om2-cred__stat">
          <span class="om2-cred__stat-num">{{ t.cred_stat1_num }}</span>
          <span class="om2-cred__stat-label">{{ t.cred_stat1_label }}</span>
        </div>
        <div class="om2-cred__stat">
          <span class="om2-cred__stat-num">{{ t.cred_stat2_num }}</span>
          <span class="om2-cred__stat-label">{{ t.cred_stat2_label }}</span>
        </div>
        <div class="om2-cred__stat">
          <span class="om2-cred__stat-num">{{ t.cred_stat3_num }}</span>
          <span class="om2-cred__stat-label">{{ t.cred_stat3_label }}</span>
        </div>
      </div>

      <p class="om2-cred__body">{{ t.cred_body | safe }}</p>

      <blockquote class="om2-cred__quote">{{ t.cred_quote }}</blockquote>

      <div class="om2-cred__badges">
        <div class="om2-cred__badge">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>{{ t.cred_badge1 }}</span>
        </div>
        <div class="om2-cred__badge">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          <span>{{ t.cred_badge2 }}</span>
        </div>
      </div>
    </div>
  </div>
</section>

{# ═══════════════════════════════════════════════════════════
   SECTION 5: 60 HOURS PRACTICE
   ═══════════════════════════════════════════════════════════ #}
<section class="om2-practice" id="om2-practice" aria-labelledby="om2-practice-title">
  <div class="om2-practice__inner">
    <div class="om2-practice__grid">

      {# LEFT: Content #}
      <div class="om2-practice__content">
        <p class="om2-practice__eyebrow">{{ t.practice_eyebrow }}</p>
        <h2 id="om2-practice-title" class="om2-practice__title">{{ t.practice_title }}</h2>
        <p class="om2-practice__lead">{{ t.practice_lead | safe }}</p>
        <p class="om2-practice__text">{{ t.practice_text1 | safe }}</p>
        <p class="om2-practice__text">{{ t.practice_text2 | safe }}</p>

        <div class="om2-practice__highlight">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>{{ t.practice_highlight }}</span>
        </div>
      </div>

      {# RIGHT: Checklist + CTA #}
      <div class="om2-practice__details">
        <div class="om2-practice__big-number">
