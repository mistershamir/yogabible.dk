{# =========================================================
   SECTION 9: FAQ
========================================================= #}
<section class="cb-faq" aria-labelledby="cb-faq-title">
  <div class="cb-inner">
    <div class="cb-faq__head">
      <p class="cb-eyebrow">{{ t.faq_eyebrow }}</p>
      <h2 id="cb-faq-title" class="cb-section-title">{{ t.faq_title }}</h2>
      <p class="cb-section-lead" style="margin-inline:auto">{{ t.faq_lead }}</p>
    </div>

    <div class="cb-faq__list" data-cb-accordion>
      {% for i in [1, 2, 3, 4, 5, 6] %}
      <article class="cb-faq__item">
        <h3 class="cb-faq__q">
          <button class="cb-faq__btn" type="button" aria-expanded="false">
            {{ t["faq_q" + i] }}
            <span class="cb-faq__icon" aria-hidden="true"></span>
          </button>
        </h3>
        <div class="cb-faq__a" hidden>
          <div class="cb-faq__a-inner">
            <p>{{ t["faq_a" + i] | safe }}</p>
          </div>
        </div>
      </article>
      {% endfor %}
    </div>

    <div class="cb-faq__contact">
      <p>{{ t.faq_contact_text }} <a class="cb-faq__link" href="mailto:{{ t.faq_contact_email }}">{{ t.faq_contact_email }}</a></p>
    </div>
  </div>
</section>

