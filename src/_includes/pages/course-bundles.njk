        <header class="cb-accom-card__head">
          <h3 class="cb-accom-card__title">{{ t.accom_double_title }}</h3>
          <p class="cb-accom-card__tag">{{ t.accom_double_tag }}</p>
        </header>
        <div class="cb-accom-card__price">
          <div class="cb-accom-card__price-main">
            <span class="cb-accom-card__amount">{{ t.accom_double_price }}</span>
            <span class="cb-accom-card__note">{{ t.accom_double_note }}</span>
          </div>
          <p class="cb-accom-card__fine">{{ t.accom_double_fine }}</p>
