{% set t = i18n["course-bundles"][lang or "da"] %}

<!-- Hero -->
<section class="program-hero">
  <div class="container">
    <div class="program-hero__badge">{{ t.hero_badge }}</div>
    <h1 class="program-hero__title">{{ t.hero_title }}</h1>
    <p class="program-hero__subtitle">{{ t.hero_subtitle }}</p>

    <div class="program-hero__meta">
      <div class="program-hero__meta-item">
        <strong>{{ t.hero_meta_format_label }}</strong> {{ t.hero_meta_format }}
      </div>
      <div class="program-hero__meta-item">
        <strong>{{ t.hero_meta_location_label }}</strong> {{ t.hero_meta_location }}
      </div>
    </div>

    <div class="program-hero__cta">
      <a href="#bundle-builder" class="btn btn--large btn--primary">{{ t.hero_cta }}</a>
    </div>
  </div>
</section>

<!-- Pricing Overview -->
<section class="program-overview">
  <div class="container">
    <h2 class="section-title">{{ t.pricing_title }}</h2>
    <p class="section-subtitle">{{ t.pricing_subtitle }}</p>

    <div class="program-grid">
      <div class="program-feature">
        <div class="program-feature__icon">1</div>
        <h3>{{ t.price1_label }}</h3>
        <p>{{ t.price1_detail | safe }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">2</div>
        <h3>{{ t.price2_label }}</h3>
        <p>{{ t.price2_detail | safe }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">3</div>
        <h3>{{ t.price3_label }}</h3>
        <p>{{ t.price3_detail | safe }}</p>
      </div>
    </div>
  </div>
</section>

<!-- Bundle Builder -->
<section class="program-schedule" id="bundle-builder">
  <div class="container">
    <h2 class="section-title">{{ t.builder_title }}</h2>

    <div class="yb-bundle-builder">
      <!-- Month Selection -->
      <div class="yb-apply-section">
        <h3 class="yb-apply-section__title">{{ t.builder_month_title }}</h3>
        <div class="yb-month-chips" id="ybBundleMonths">
          <label class="yb-month-chip"><input type="radio" name="bundleMonth" value="Februar 2026"><span>Februar 2026</span></label>
          <label class="yb-month-chip"><input type="radio" name="bundleMonth" value="Marts 2026"><span>Marts 2026</span></label>
          <label class="yb-month-chip"><input type="radio" name="bundleMonth" value="April 2026"><span>April 2026</span></label>
          <label class="yb-month-chip"><input type="radio" name="bundleMonth" value="Maj 2026"><span>Maj 2026</span></label>
        </div>
      </div>

      <!-- Course Selection -->
      <div class="yb-apply-section" style="margin-top:24px">
        <h3 class="yb-apply-section__title">{{ t.builder_courses_title }}</h3>
        <div class="yb-apply-radio-group">
          <label class="yb-apply-checkbox">
            <input type="checkbox" name="bundleCourse" value="Inversions" id="ybBundleInv">
            <span>{{ t.builder_inv_label | safe }}</span>
          </label>
          <label class="yb-apply-checkbox">
            <input type="checkbox" name="bundleCourse" value="Splits" id="ybBundleSplits">
            <span>{{ t.builder_splits_label | safe }}</span>
          </label>
          <label class="yb-apply-checkbox">
            <input type="checkbox" name="bundleCourse" value="Backbends" id="ybBundleBack">
            <span>{{ t.builder_back_label | safe }}</span>
          </label>
        </div>
      </div>

      <!-- Summary -->
      <div class="yb-apply-card" id="ybBundleSummary" style="margin-top:24px">
        <h3>{{ t.builder_summary_title }}</h3>
        <p id="ybBundleInfo">{{ t.builder_summary_default }}</p>
        <p id="ybBundlePrice" style="font-size:1.5rem; font-weight:700; color:var(--yb-brand); display:none;"></p>
        <p id="ybBundleDiscount" style="color:var(--yb-brand); display:none;"></p>
        <a id="ybBundleCta" class="btn btn--large btn--primary" href="#" target="_blank" rel="noopener" style="display:none; margin-top:16px;">{{ t.builder_cta }}</a>
      </div>
    </div>
  </div>
</section>

<!-- Course Details -->
<section class="program-overview">
  <div class="container">
    <h2 class="section-title">{{ t.courses_title }}</h2>

    <div class="program-grid">
      <div class="program-feature">
        <div class="program-feature__icon">&#129336;</div>
        <h3>{{ t.course_inv_title }}</h3>
        <p>{{ t.course_inv_desc }}</p>
        <a href="{% if lang == 'en' %}/en/inversions{% else %}/inversions{% endif %}" style="color:var(--yb-brand)">{{ t.course_inv_link }} &rarr;</a>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">&#129496;</div>
        <h3>{{ t.course_splits_title }}</h3>
        <p>{{ t.course_splits_desc }}</p>
        <a href="{% if lang == 'en' %}/en/splits{% else %}/splits{% endif %}" style="color:var(--yb-brand)">{{ t.course_splits_link }} &rarr;</a>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">&#127769;</div>
        <h3>{{ t.course_back_title }}</h3>
        <p>{{ t.course_back_desc }}</p>
        <a href="{% if lang == 'en' %}/en/backbends{% else %}/backbends{% endif %}" style="color:var(--yb-brand)">{{ t.course_back_link }} &rarr;</a>
      </div>
    </div>
  </div>
</section>

<!-- Accommodation -->
<section class="program-schedule">
  <div class="container">
    <h2 class="section-title">{{ t.accom_title }}</h2>
    <p class="section-subtitle">{{ t.accom_subtitle }}</p>

    <div class="schedule-options">
      <div class="schedule-card">
        <h3>{{ t.accom_card_title }}</h3>
        <ul>
          <li>{{ t.accom_item1 }}</li>
          <li>{{ t.accom_item2 }}</li>
          <li>{{ t.accom_item3 }}</li>
          <li>{{ t.accom_item4 }}</li>
          <li>{{ t.accom_item5 }}</li>
        </ul>
        <a href="{% if lang == 'en' %}/en/kontakt{% else %}/kontakt{% endif %}" class="btn btn--primary" style="margin-top:16px">{{ t.accom_cta }}</a>
      </div>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <h2 class="cta-section__title">{{ t.cta_title }}</h2>
    <p class="cta-section__text">{{ t.cta_text }}</p>
    <a href="#bundle-builder" class="btn btn--large btn--primary">{{ t.cta_button }}</a>
  </div>
</section>

<script>
(function() {
  'use strict';
  var PRICE = 2300;
  var PASS_VALUE = 1399;
  var BASE = 'https://clients.mindbodyonline.com/app/business/classic/ws?studio=HotYogaCopenhagenHQ&stype=40&prodid=';

  var BUNDLE_URLS = {
    'Februar 2026': { 'Backbends|Inversions': 113, 'Inversions|Splits': 114, 'Backbends|Splits': 115, 'ALL': 125 },
    'Marts 2026':   { 'Backbends|Inversions': 116, 'Inversions|Splits': 117, 'Backbends|Splits': 118, 'ALL': 126 },
    'April 2026':   { 'Backbends|Inversions': 119, 'Inversions|Splits': 120, 'Backbends|Splits': 121, 'ALL': 127 },
    'Maj 2026':     { 'Backbends|Inversions': 122, 'Inversions|Splits': 123, 'Backbends|Splits': 124, 'ALL': 128 }
  };

  var langPrefix = {{ ("'" + (lang or "da") + "'") | safe }};
  var SINGLE_PAGES = {
    'Inversions': (langPrefix === 'en' ? '/en/inversions' : '/inversions'),
    'Splits': (langPrefix === 'en' ? '/en/splits' : '/splits'),
    'Backbends': (langPrefix === 'en' ? '/en/backbends' : '/backbends')
  };

  var i18n = {
    defaultInfo: {{ t.builder_summary_default | dump | safe }},
    ctaBundle: {{ t.builder_cta | dump | safe }},
    ctaAllin: {{ t.builder_cta_allin | dump | safe }},
    ctaGoto: {{ t.builder_cta_goto | dump | safe }},
    ctaCourseSuffix: {{ t.builder_cta_course_suffix | dump | safe }},
    discount2: {{ t.builder_discount_2 | dump | safe }},
    discount3: {{ t.builder_discount_3 | dump | safe }},
    discountPass: {{ t.builder_discount_pass | dump | safe }},
    kr: {{ t.builder_kr | dump | safe }}
  };

  var monthRadios = document.querySelectorAll('#ybBundleMonths input');
  var courseChecks = document.querySelectorAll('input[name="bundleCourse"]');
  var info = document.getElementById('ybBundleInfo');
  var priceEl = document.getElementById('ybBundlePrice');
  var discountEl = document.getElementById('ybBundleDiscount');
  var cta = document.getElementById('ybBundleCta');

  function comboKey(a, b) { return [a, b].sort().join('|'); }

  function update() {
    var month = '';
    monthRadios.forEach(function(r) { if (r.checked) month = r.value; });
    var selected = [];
    courseChecks.forEach(function(c) { if (c.checked) selected.push(c.value); });

    if (!month || selected.length === 0) {
      info.textContent = i18n.defaultInfo;
      priceEl.style.display = 'none';
      discountEl.style.display = 'none';
      cta.style.display = 'none';
      return;
    }

    var count = selected.length;
    var total, discount, passBonus = false;

    if (count === 1) {
      total = PRICE;
      discount = '';
    } else if (count === 2) {
      total = Math.round(PRICE * 2 * 0.90);
      discount = i18n.discount2 + ' ' + (PRICE * 2 - total) + ' ' + i18n.kr;
    } else {
      total = Math.round(PRICE * 3 * 0.85);
      discount = i18n.discount3 + ' ' + (PRICE * 3 - total) + ' ' + i18n.kr + ' ' + i18n.discountPass + ' ' + PASS_VALUE + ' ' + i18n.kr + ')';
      passBonus = true;
    }

    info.textContent = selected.join(' + ') + ' \u2014 ' + month;
    priceEl.textContent = total.toLocaleString('da-DK') + ' ' + i18n.kr;
    priceEl.style.display = 'block';
    discountEl.textContent = discount;
    discountEl.style.display = discount ? 'block' : 'none';

    // Set CTA link
    var monthData = BUNDLE_URLS[month];
    if (count === 1) {
      cta.href = SINGLE_PAGES[selected[0]] + '#course-months';
      cta.textContent = i18n.ctaGoto + ' ' + selected[0] + i18n.ctaCourseSuffix;
      cta.removeAttribute('target');
    } else if (count === 2 && monthData) {
      var key = comboKey(selected[0], selected[1]);
      var prodId = monthData[key];
      cta.href = prodId ? BASE + prodId : '#';
      cta.textContent = i18n.ctaBundle;
      cta.setAttribute('target', '_blank');
    } else if (count === 3 && monthData) {
      cta.href = monthData['ALL'] ? BASE + monthData['ALL'] : '#';
      cta.textContent = i18n.ctaAllin;
      cta.setAttribute('target', '_blank');
    }
    cta.style.display = 'inline-block';
  }

  monthRadios.forEach(function(r) { r.addEventListener('change', update); });
  courseChecks.forEach(function(c) { c.addEventListener('change', update); });
})();
</script>
