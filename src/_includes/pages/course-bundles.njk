    <div class="cb-accom__grid">
      {# Single Studio #}
      <article class="cb-accom-card" data-accom="single">
        <div class="cb-gallery" aria-label="{{ t.accom_single_title }}">
          <div class="cb-gallery__track">
            <img src="/s/Yoga-Teacher-Training-Copenhagen-Accommodation-Single-Studio-Apartment.jpg" alt="{{ t.accom_single_title }} – 1" loading="lazy" decoding="async">
