        </div>
        <ul class="cb-accom-card__list">
          {% for i in [1, 2, 3, 4, 5, 6] %}<li>{{ t["accom_item" + i] | safe }}</li>{% endfor %}
        </ul>
        <div class="cb-accom-card__ctas">
          <a class="cb-btn cb-btn--primary" href="{{ lp }}/accommodation">{{ t.accom_cta_see }}</a>
          <a class="cb-accom-card__mini-link" href="#coursebuilder">{{ t.accom_cta_builder }}</a>
        </div>
