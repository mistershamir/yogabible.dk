{% set t = i18n.privacy_policy[lang or "da"] %}

<!-- Hero — yb-hero unified design with trust bar -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a class="yb-btn yb-btn--primary yb-btn--large" href="#yb-privacy">{{ t.hero_cta_read }}</a>
      <a class="yb-btn yb-btn--outline-light yb-btn--large" href="mailto:info@yogabible.dk?subject=GDPR%20anmodning%20%E2%80%94%20Yoga%20Bible">{{ t.hero_cta_contact }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust_1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust_2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust_3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

<!-- Privacy Policy — Full v2 content -->
<section id="yb-privacy" class="yb-privacy" lang="{{ lang or 'da' }}" aria-label="{{ t.hero_title }}">
  <div class="yb-privacy__inner">

    <header class="yb-privacy__head">
      <p class="yb-privacy__lead">{{ t.lead }}</p>

      <div class="yb-privacy__meta">
        <span class="yb-privacy__metaItem"><strong>{{ t.meta_entity_label }}</strong> {{ t.meta_entity }}</span>
        <span class="yb-privacy__metaSep" aria-hidden="true">&bull;</span>
        <span class="yb-privacy__metaItem"><strong>{{ t.meta_cvr_label }}</strong> {{ t.meta_cvr }}</span>
        <span class="yb-privacy__metaSep" aria-hidden="true">&bull;</span>
        <span class="yb-privacy__metaItem"><strong>{{ t.meta_vat_label }}</strong> {{ t.meta_vat }}</span>
      </div>

      <div class="yb-privacy__meta">
        <span class="yb-privacy__metaItem"><strong>{{ t.meta_address_label }}</strong> {{ t.meta_address }}</span>
        <span class="yb-privacy__metaSep" aria-hidden="true">&bull;</span>
        <span class="yb-privacy__metaItem"><strong>{{ t.meta_phone_label }}</strong> <a href="tel:+4553881209">{{ t.meta_phone }}</a></span>
        <span class="yb-privacy__metaSep" aria-hidden="true">&bull;</span>
        <span class="yb-privacy__metaItem"><strong>{{ t.meta_email_label }}</strong> <a href="mailto:{{ t.meta_email }}">{{ t.meta_email }}</a></span>
      </div>

      <div class="yb-privacy__meta">
        <span class="yb-privacy__metaItem"><strong>{{ t.meta_scope_label }}</strong> {{ t.meta_scope }}</span>
      </div>

      <div class="yb-privacy__meta">
        <span class="yb-privacy__metaItem"><strong>{{ t.meta_updated_label }}</strong> <time datetime="{{ t.meta_updated_datetime }}">{{ t.meta_updated }}</time></span>
      </div>

      <div class="yb-privacy__notice" role="note">
        {{ t.notice | safe }}
      </div>

      <nav class="yb-privacy__toc" aria-label="TOC">
        <a class="yb-privacy-chip" href="#p1">{{ t.toc_1 }}</a>
        <a class="yb-privacy-chip" href="#p2">{{ t.toc_2 }}</a>
        <a class="yb-privacy-chip" href="#p3">{{ t.toc_3 }}</a>
        <a class="yb-privacy-chip" href="#p4">{{ t.toc_4 }}</a>
        <a class="yb-privacy-chip" href="#p5">{{ t.toc_5 }}</a>
        <a class="yb-privacy-chip" href="#p6">{{ t.toc_6 }}</a>
        <a class="yb-privacy-chip" href="#p7">{{ t.toc_7 }}</a>
        <a class="yb-privacy-chip" href="#p8">{{ t.toc_8 }}</a>
        <a class="yb-privacy-chip" href="#p9">{{ t.toc_9 }}</a>
        <a class="yb-privacy-chip" href="#p10">{{ t.toc_10 }}</a>
        <a class="yb-privacy-chip" href="#p11">{{ t.toc_11 }}</a>
        <a class="yb-privacy-chip" href="#p12">{{ t.toc_12 }}</a>
