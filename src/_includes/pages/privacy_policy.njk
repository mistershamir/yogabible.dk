<style>
  /* =========================================================
     Privacy Policy v2 — scoped styles
     ========================================================= */
  #yb-privacy {
    --pp-accent: #f75c03;
    --pp-bg: #FCFBF9;
    --pp-card: #ffffff;
    --pp-border: #EBE7E3;
    --pp-text: #1A1A1A;
    --pp-muted: #6B6B6B;
    font-family: 'Abacaxi', "Helvetica Neue", Helvetica, Arial, system-ui, -apple-system, sans-serif;
    color: var(--pp-text);
    background: var(--pp-bg);
    padding: 72px 20px;
  }
  #yb-privacy, #yb-privacy * { box-sizing: border-box; }
  #yb-privacy .yb-privacy__inner { max-width: 1120px; margin: 0 auto; }

  /* Header */
  #yb-privacy .yb-privacy__lead {
    margin: 0 0 16px; font-size: 16px; line-height: 1.65; color: #2a2a2a; max-width: 78ch;
  }

  /* Meta rows */
  #yb-privacy .yb-privacy__meta {
    display: flex; flex-wrap: wrap; gap: 10px; align-items: center;
    color: var(--pp-muted); font-size: 13px; margin: 0 0 10px;
  }
  #yb-privacy .yb-privacy__metaSep { opacity: .65; }
  #yb-privacy .yb-privacy__meta a {
    color: var(--pp-accent);
    text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 3px;
  }

  /* Notice */
  #yb-privacy .yb-privacy__notice {
    background: #fff; border: 1px solid var(--pp-border);
    border-radius: 16px; padding: 14px 16px; line-height: 1.55; margin: 10px 0 18px;
  }

  /* TOC chips */
  #yb-privacy .yb-privacy__toc { display: flex; flex-wrap: wrap; gap: 10px; margin: 14px 0 0; }
  #yb-privacy .yb-privacy-chip {
    display: inline-flex; align-items: center;
    border: 1px solid var(--pp-border); background: #fff;
    border-radius: 999px; padding: 10px 12px; font-size: 13px;
    color: var(--pp-text); text-decoration: none;
    transition: transform .15s ease, box-shadow .15s ease, border-color .15s ease;
  }
  #yb-privacy .yb-privacy-chip:hover {
    border-color: rgba(247, 92, 3, .45);
    box-shadow: 0 18px 60px rgba(0, 0, 0, .10);
    transform: translateY(-1px);
  }

  /* Grid layout */
  #yb-privacy .yb-privacy__grid { display: grid; gap: 18px; margin-top: 26px; }
  @media (min-width: 980px) {
    #yb-privacy .yb-privacy__grid { grid-template-columns: 360px minmax(0, 1fr); align-items: start; }
    #yb-privacy .yb-privacy__side { position: sticky; top: 20px; }
  }

  /* Cards */
  #yb-privacy .yb-privacy-card {
    background: var(--pp-card); border: 1px solid var(--pp-border);
    border-radius: 20px; padding: 18px;
    box-shadow: 0 18px 60px rgba(0, 0, 0, .10);
  }
  #yb-privacy .yb-privacy-card__title { margin: 0 0 10px; font-size: 16px; letter-spacing: -.01em; }
  #yb-privacy .yb-privacy-card__subtitle {
    margin: 0 0 8px; font-size: 13px; color: var(--pp-muted);
    text-transform: uppercase; letter-spacing: .10em;
  }

  /* Utility */
  #yb-privacy .yb-privacy-divider { height: 1px; background: var(--pp-border); margin: 14px 0; }
  #yb-privacy .yb-privacy-list { margin: 0; padding-left: 18px; color: #2a2a2a; line-height: 1.7; font-size: 14px; }
  #yb-privacy .yb-privacy-list--compact { font-size: 13px; color: var(--pp-muted); }
  #yb-privacy .yb-privacy-muted { color: var(--pp-muted); line-height: 1.6; font-size: 14px; margin: 0; }

  /* Accordions */
  #yb-privacy .yb-privacy-acc {
    border: 1px solid var(--pp-border); border-radius: 20px; background: #fff;
    margin: 0 0 12px; overflow: hidden; scroll-margin-top: 18px;
  }
  #yb-privacy .yb-privacy-acc__sum {
    list-style: none; cursor: pointer; padding: 16px; font-weight: 700;
    letter-spacing: -.01em; display: flex; align-items: center;
    justify-content: space-between; gap: 12px; outline: none;
  }
  #yb-privacy details > summary::-webkit-details-marker { display: none; }
  #yb-privacy .yb-privacy-acc__sum::after {
    content: "\25BE"; color: var(--pp-muted); font-weight: 600;
    transition: transform .15s ease;
  }
  #yb-privacy details[open] .yb-privacy-acc__sum::after { transform: rotate(180deg); }
  #yb-privacy .yb-privacy-acc__sum:focus-visible {
    box-shadow: 0 0 0 3px rgba(247, 92, 3, .22); border-radius: 14px; margin: 6px;
  }
  #yb-privacy .yb-privacy-acc__body {
    padding: 0 16px 16px; line-height: 1.7; font-size: 14px; color: #2a2a2a;
  }
  #yb-privacy .yb-privacy-acc__body a {
    color: var(--pp-accent); text-decoration: underline;
    text-decoration-thickness: 1px; text-underline-offset: 3px;
  }
  #yb-privacy .yb-privacy-acc__body h3 { margin: 14px 0 8px; font-size: 14px; letter-spacing: -.01em; }

  /* Callout */
  #yb-privacy .yb-privacy-callout {
    border: 1px solid rgba(247, 92, 3, .28); background: rgba(247, 92, 3, .06);
    border-radius: 16px; padding: 12px; margin: 12px 0;
  }

  /* Bottom card + actions */
  #yb-privacy .yb-privacy__bottomCard { margin-top: 10px; }
  #yb-privacy .yb-privacy-actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 14px; }

  /* Buttons (scoped) */
  #yb-privacy .yb-privacy-btn {
    display: inline-flex; align-items: center; justify-content: center;
    border-radius: 999px; padding: 10px 14px; font-size: 13px;
    text-decoration: none; border: 1px solid var(--pp-border);
    transition: transform .15s ease, box-shadow .15s ease, filter .15s ease, background .15s ease, color .15s ease;
    white-space: nowrap;
  }
  #yb-privacy .yb-privacy-btn--primary {
    background: var(--pp-accent); border-color: var(--pp-accent);
    color: #fff; box-shadow: 0 18px 60px rgba(0, 0, 0, .12);
  }
  #yb-privacy .yb-privacy-btn--primary:hover { filter: brightness(.98); transform: translateY(-1px); }
  #yb-privacy .yb-privacy-btn--ghost {
    background: #fff; color: var(--pp-accent); border-color: rgba(247, 92, 3, .45);
  }
  #yb-privacy .yb-privacy-btn--ghost:hover { background: rgba(247, 92, 3, .06); transform: translateY(-1px); }

  @media (max-width: 520px) {
    #yb-privacy { padding: 48px 16px; }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('yb-privacy');
    if (!root) return;

    var details = root.querySelectorAll('details.yb-privacy-acc');
    details.forEach(function (d) {
      d.addEventListener('toggle', function () {
        if (!d.open) return;
        details.forEach(function (other) { if (other !== d) other.open = false; });
      });
    });

    function openFromHash() {
      var id = (window.location.hash || '').replace('#', '');
      if (!id) return;
      var target = root.querySelector('#' + CSS.escape(id));
      if (target && target.tagName.toLowerCase() === 'details') {
        target.open = true;
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }
    window.addEventListener('hashchange', openFromHash);
    setTimeout(openFromHash, 40);
  })();
</script>
