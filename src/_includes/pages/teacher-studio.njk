{% set t = i18n["teacher-studio"][lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

<link rel="stylesheet" href="/css/teacher-studio.css">

<div class="yts" id="yts-root"
  data-lang="{{ lang or 'da' }}"
  data-t-today="{{ t.session_today }}"
  data-t-tomorrow="{{ t.session_tomorrow }}"
  data-t-live-now="{{ t.session_picker_live }}"
  data-t-empty="{{ t.session_picker_empty }}"
  data-t-connecting="{{ t.status_connecting }}"
  data-t-live="{{ t.status_live }}"
  data-t-ended="{{ t.status_ended }}"
  data-t-error="{{ t.status_error }}"
  data-t-idle="{{ t.status_idle }}"
  data-t-confirm-end="{{ t.confirm_end }}"
  data-t-permission-denied="{{ t.permission_denied }}"
  data-t-no-session="{{ t.no_session_selected }}"
  data-t-whip-not-supported="{{ t.whip_not_supported }}">

  {# ── Auth gate: only visible to teacher/admin ── #}
  <div class="yts-gate" id="yts-gate">
    <div class="yts-gate__card">
      <div class="yts-gate__icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
      </div>
      <h2 class="yts-gate__title">{{ t.teacher_only_notice }}</h2>
    </div>
  </div>

  {# ── Main studio UI (hidden until auth confirmed) ── #}
  <div class="yts-studio" id="yts-studio" style="display:none;">

    {# Hero #}
    <div class="yts-hero">
      <p class="yts-hero__tagline">{{ t.hero_tagline }}</p>
      <h1 class="yts-hero__title">{{ t.hero_title }}</h1>
      <p class="yts-hero__subtitle">{{ t.hero_subtitle }}</p>
    </div>

    {# Two-column layout: preview + controls #}
    <div class="yts-main">
      <div class="yts-main__grid">

        {# ── Left: Camera Preview ── #}
        <div class="yts-preview">
          <div class="yts-preview__header">
            <h2 class="yts-preview__title">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="m22 8-6 4 6 4V8Z"/>
                <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
              </svg>
              {{ t.preview_title }}
            </h2>
          </div>

          <div class="yts-preview__viewport" id="yts-viewport">
            <video id="yts-preview-video" autoplay muted playsinline></video>
            <div class="yts-preview__placeholder" id="yts-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <path d="m22 8-6 4 6 4V8Z"/>
                <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
              </svg>
              <button class="yts-btn yts-btn--outline" id="yts-start-camera">{{ t.preview_start_camera }}</button>
            </div>

            {# Live badge overlay on preview #}
            <div class="yts-preview__live-badge" id="yts-live-badge" style="display:none;">
              <span class="yts-preview__live-dot"></span>
              LIVE
            </div>

            {# Elapsed timer overlay #}
            <div class="yts-preview__elapsed" id="yts-elapsed" style="display:none;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
              <span>{{ t.elapsed_label }}</span>
              <span id="yts-elapsed-time">00:00</span>
            </div>
          </div>

          {# Device selectors #}
          <div class="yts-devices" id="yts-devices" style="display:none;">
            <div class="yts-devices__row">
              <label class="yts-devices__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="m22 8-6 4 6 4V8Z"/>
                  <rect x="1" y="5" width="15" height="14" rx="2" ry="2"/>
                </svg>
                {{ t.preview_select_camera }}
              </label>
              <select id="yts-camera-select" class="yts-devices__select"></select>
            </div>
            <div class="yts-devices__row">
              <label class="yts-devices__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/>
                  <path d="M19 10v2a7 7 0 0 1-14 0v-2"/>
                  <line x1="12" y1="19" x2="12" y2="23"/>
                  <line x1="8" y1="23" x2="16" y2="23"/>
                </svg>
                {{ t.preview_select_mic }}
              </label>
              <select id="yts-mic-select" class="yts-devices__select"></select>
            </div>
            <div class="yts-devices__row">
              <label class="yts-devices__label">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                </svg>
                {{ t.stream_quality_label }}
              </label>
              <select id="yts-quality-select" class="yts-devices__select">
                <option value="480">{{ t.stream_quality_480 }}</option>
                <option value="720" selected>{{ t.stream_quality_720 }}</option>
                <option value="1080">{{ t.stream_quality_1080 }}</option>
              </select>
            </div>
          </div>
        </div>

        {# ── Right: Session Picker + Controls ── #}
        <div class="yts-controls">

          {# Session picker #}
          <div class="yts-sessions">
            <h2 class="yts-sessions__title">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              {{ t.session_picker_title }}
            </h2>
            <div class="yts-sessions__list" id="yts-session-list">
              <div class="yts-sessions__loading">
                <div class="yts-spinner"></div>
              </div>
            </div>
          </div>

          {# Status indicator #}
          <div class="yts-status" id="yts-status">
            <div class="yts-status__indicator" id="yts-status-dot"></div>
            <span id="yts-status-text">{{ t.status_idle }}</span>
          </div>

          {# Go live / End stream buttons #}
          <div class="yts-actions">
            <button class="yts-btn yts-btn--live" id="yts-go-live" disabled>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
              {{ t.go_live_btn }}
            </button>
            <button class="yts-btn yts-btn--end" id="yts-end-stream" style="display:none;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="6" y="6" width="12" height="12" rx="2"/>
              </svg>
              {{ t.end_stream_btn }}
            </button>
          </div>

        </div>
      </div>
    </div>

    {# Footer #}
    <div class="yts-footer">
      <div class="yts-footer__line"></div>
      <p class="yts-footer__text">
        {{ t.footer_note }} <a href="{{ lp }}/live">{{ t.footer_link_text }}</a>.
      </p>
    </div>

  </div>
</div>

<script src="/js/teacher-studio.js" defer></script>
