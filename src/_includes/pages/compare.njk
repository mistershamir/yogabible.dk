      <div class="schedule-card">
        <h3>{{ t.hundred_bridge_title }}</h3>
        <ul>
          <li>{{ t.hundred_bridge1 | safe }}</li>
          <li>{{ t.hundred_bridge2 | safe }}</li>
          <li>{{ t.hundred_bridge3 | safe }}</li>
          <li>{{ t.hundred_bridge4 | safe }}</li>
          <li>{{ t.hundred_bridge5 | safe }}</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 5: COURSES vs. TEACHER TRAININGS -->
<section class="program-overview" id="courses-vs-trainings">
  <div class="container">
    <span class="ds-eyebrow ds-eyebrow--brand">{{ t.cvt_eyebrow }}</span>
    <h2 class="section-title">{{ t.cvt_title }}</h2>
    <p class="section-subtitle">{{ t.cvt_subtitle }}</p>

    <div class="ds-split ds-split--dark-light" style="max-width:1000px; margin:40px auto 0;">
      <div class="ds-split__side">
        <span class="ds-eyebrow ds-eyebrow--white">{{ t.cvt_course_eyebrow }}</span>
        <h3 style="font-size:1.4rem; margin:12px 0 20px;">{{ t.cvt_course_title }}</h3>
        <ul style="list-style:none; padding:0; margin:0;">
          <li style="padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.1); font-size:0.9rem;">{{ t.cvt_course1 | safe }}</li>
          <li style="padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.1); font-size:0.9rem;">{{ t.cvt_course2 | safe }}</li>
          <li style="padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.1); font-size:0.9rem;">{{ t.cvt_course3 | safe }}</li>
          <li style="padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.1); font-size:0.9rem;">{{ t.cvt_course4 | safe }}</li>
          <li style="padding:8px 0; border-bottom:1px solid rgba(255,255,255,0.1); font-size:0.9rem;">{{ t.cvt_course5 | safe }}</li>
          <li style="padding:8px 0; font-size:0.9rem;">{{ t.cvt_course6 | safe }}</li>
        </ul>
      </div>
      <div class="ds-split__side">
        <span class="ds-eyebrow ds-eyebrow--brand">{{ t.cvt_training_eyebrow }}</span>
        <h3 style="font-size:1.4rem; margin:12px 0 20px; color:#0F0F0F;">{{ t.cvt_training_title }}</h3>
        <ul style="list-style:none; padding:0; margin:0;">
          <li style="padding:8px 0; border-bottom:1px solid var(--ds-border); font-size:0.9rem;">{{ t.cvt_training1 | safe }}</li>
          <li style="padding:8px 0; border-bottom:1px solid var(--ds-border); font-size:0.9rem;">{{ t.cvt_training2 | safe }}</li>
          <li style="padding:8px 0; border-bottom:1px solid var(--ds-border); font-size:0.9rem;">{{ t.cvt_training3 | safe }}</li>
          <li style="padding:8px 0; border-bottom:1px solid var(--ds-border); font-size:0.9rem;">{{ t.cvt_training4 | safe }}</li>
          <li style="padding:8px 0; border-bottom:1px solid var(--ds-border); font-size:0.9rem;">{{ t.cvt_training5 | safe }}</li>
          <li style="padding:8px 0; font-size:0.9rem;">{{ t.cvt_training6 | safe }}</li>
        </ul>
      </div>
    </div>

    <!-- Journal CTA: Courses vs Trainings -->
    <div style="max-width:1000px; margin:32px auto 0; background:var(--ds-bg-light); border-radius:12px; padding:24px 32px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px;">
      <div>
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--yb-brand); font-weight:700; margin-bottom:4px;">{{ t.journal_cta_label }}</p>
        <p style="font-weight:700; font-size:1rem; margin:0;">{{ t.journal_cvt_title }}</p>
      </div>
      <a href="{% if lang == 'en' %}/en/yoga-journal{% else %}/yoga-journal{% endif %}" style="color:var(--yb-brand); font-weight:700; font-size:0.9rem; white-space:nowrap;">{{ t.journal_read_more }} →</a>
    </div>

    <!-- Concrete examples -->
    <div style="max-width:1000px; margin:40px auto 0;">
      <div class="schedule-card" style="padding:32px;">
        <h3 style="text-align:center; margin-bottom:24px;">{{ t.cvt_examples_title }}</h3>
        <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(280px, 1fr)); gap:32px;">
          <div>
            <h4 style="font-size:0.85rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--ds-text-muted); margin-bottom:12px;">{{ t.cvt_example_courses_label }}</h4>
            <ul style="padding-left:20px; font-size:0.9rem; line-height:1.8;">
              <li>{{ t.cvt_ex_course1 }}</li>
              <li>{{ t.cvt_ex_course2 }}</li>
              <li>{{ t.cvt_ex_course3 }}</li>
              <li>{{ t.cvt_ex_course4 }}</li>
            </ul>
          </div>
          <div>
            <h4 style="font-size:0.85rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--ds-text-muted); margin-bottom:12px;">{{ t.cvt_example_trainings_label }}</h4>
            <ul style="padding-left:20px; font-size:0.9rem; line-height:1.8;">
              <li>{{ t.cvt_ex_training1 }}</li>
              <li>{{ t.cvt_ex_training2 }}</li>
              <li>{{ t.cvt_ex_training3 }}</li>
              <li>{{ t.cvt_ex_training4 }}</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 6: 200 HOURS — THE GOLD STANDARD -->
<section class="program-schedule" id="200h-gold-standard">
  <div class="container">
    <span class="ds-eyebrow ds-eyebrow--brand">{{ t.gold_eyebrow }}</span>
    <h2 class="section-title">{{ t.gold_title }}</h2>
    <p class="section-subtitle">{{ t.gold_subtitle }}</p>

    <img src="/assets/images/compare/200-timers-yogalareruddannelse-certificering.jpg" alt="{{ t.img_200h_alt }}" style="width:100%; max-width:800px; border-radius:8px; aspect-ratio:16/9; object-fit:cover; background:#f5f3f0; margin:0 auto 32px; display:block;" loading="lazy">

    <!-- Curriculum Bar Chart -->
    <div style="max-width:700px; margin:40px auto;">
      <h3 style="text-align:center; margin-bottom:24px; font-size:1.1rem;">{{ t.ya_chart_title }}</h3>

      <!-- Techniques & Training -->
      <div style="margin-bottom:16px;">
        <div style="display:flex; justify-content:space-between; margin-bottom:4px;">
          <span style="font-weight:700; font-size:0.9rem;">{{ t.ya_techniques }}</span>
          <span style="font-weight:700; color:var(--yb-brand);">100+ {{ t.ya_hours_label }}</span>
        </div>
        <div style="background:var(--ds-bg-light); border-radius:8px; height:28px; overflow:hidden;">
          <div style="background:var(--yb-brand); height:100%; width:50%; border-radius:8px; transition:width 1s;"></div>
        </div>
      </div>

      <!-- Teaching Methodology -->
      <div style="margin-bottom:16px;">
        <div style="display:flex; justify-content:space-between; margin-bottom:4px;">
          <span style="font-weight:700; font-size:0.9rem;">{{ t.ya_methodology }}</span>
          <span style="font-weight:700; color:var(--yb-brand);">25+ {{ t.ya_hours_label }}</span>
        </div>
        <div style="background:var(--ds-bg-light); border-radius:8px; height:28px; overflow:hidden;">
          <div style="background:var(--yb-brand); height:100%; width:12.5%; border-radius:8px; transition:width 1s;"></div>
        </div>
      </div>

      <!-- Anatomy & Physiology -->
      <div style="margin-bottom:16px;">
        <div style="display:flex; justify-content:space-between; margin-bottom:4px;">
          <span style="font-weight:700; font-size:0.9rem;">{{ t.ya_anatomy }}</span>
          <span style="font-weight:700; color:var(--yb-brand);">20+ {{ t.ya_hours_label }}</span>
        </div>
        <div style="background:var(--ds-bg-light); border-radius:8px; height:28px; overflow:hidden;">
          <div style="background:var(--yb-brand); height:100%; width:10%; border-radius:8px; transition:width 1s;"></div>
        </div>
      </div>

      <!-- Yoga Philosophy -->
      <div style="margin-bottom:16px;">
        <div style="display:flex; justify-content:space-between; margin-bottom:4px;">
          <span style="font-weight:700; font-size:0.9rem;">{{ t.ya_philosophy }}</span>
          <span style="font-weight:700; color:var(--yb-brand);">30+ {{ t.ya_hours_label }}</span>
        </div>
        <div style="background:var(--ds-bg-light); border-radius:8px; height:28px; overflow:hidden;">
          <div style="background:var(--yb-brand); height:100%; width:15%; border-radius:8px; transition:width 1s;"></div>
        </div>
      </div>

      <!-- Practicum -->
      <div style="margin-bottom:16px;">
        <div style="display:flex; justify-content:space-between; margin-bottom:4px;">
          <span style="font-weight:700; font-size:0.9rem;">{{ t.ya_practicum }}</span>
          <span style="font-weight:700; color:var(--yb-brand);">10+ {{ t.ya_hours_label }}</span>
        </div>
        <div style="background:var(--ds-bg-light); border-radius:8px; height:28px; overflow:hidden;">
          <div style="background:var(--yb-brand); height:100%; width:5%; border-radius:8px; transition:width 1s;"></div>
        </div>
      </div>

      <p style="text-align:center; color:var(--ds-text-muted); font-size:0.8rem; margin-top:16px;">{{ t.ya_chart_note }}</p>
    </div>

    <!-- Three info cards -->
    <div class="schedule-options" style="margin-top:48px;">
      <div class="schedule-card">
        <h3>{{ t.gold_learn_title }}</h3>
        <ul>
          <li>{{ t.gold_learn1 | safe }}</li>
          <li>{{ t.gold_learn2 | safe }}</li>
          <li>{{ t.gold_learn3 | safe }}</li>
          <li>{{ t.gold_learn4 | safe }}</li>
          <li>{{ t.gold_learn5 | safe }}</li>
          <li>{{ t.gold_learn6 | safe }}</li>
          <li>{{ t.gold_learn7 | safe }}</li>
        </ul>
      </div>

      <div class="schedule-card">
