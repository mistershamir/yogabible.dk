{% set t = i18n.compare[lang or "da"] %}

<!-- Hero -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title | safe }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="#format-comparison" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta_format }}</a>
      <a href="#destinations" class="yb-btn yb-btn--outline-white yb-btn--large">{{ t.hero_cta_dest }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

<!-- Table of Contents -->
<section class="program-overview">
  <div class="container">
    <h2 class="section-title">{{ t.toc_title }}</h2>
    <p class="section-subtitle">{{ t.toc_subtitle }}</p>

    <div class="program-grid" style="max-width: 800px; margin: 0 auto;">
      <div class="program-feature">
        <div class="program-feature__icon">1</div>
        <h3><a href="#format-comparison" style="color:inherit; text-decoration:none;">{{ t.toc1_title }}</a></h3>
        <p>{{ t.toc1_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">2</div>
        <h3><a href="#seasons" style="color:inherit; text-decoration:none;">{{ t.toc2_title }}</a></h3>
        <p>{{ t.toc2_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">3</div>
        <h3><a href="#destinations" style="color:inherit; text-decoration:none;">{{ t.toc3_title }}</a></h3>
        <p>{{ t.toc3_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">4</div>
        <h3><a href="#choosing" style="color:inherit; text-decoration:none;">{{ t.toc4_title }}</a></h3>
        <p>{{ t.toc4_desc }}</p>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 1: FORMAT COMPARISON -->
<section class="program-schedule" id="format-comparison">
