    <h2 class="section-title">{{ t.fifty_title }}</h2>
    <p class="section-subtitle">{{ t.fifty_subtitle }}</p>

    <img src="/assets/images/compare/50-timers-yoga-specialisering.jpg" alt="{{ t.img_50h_alt }}" style="width:100%; max-width:800px; border-radius:8px; aspect-ratio:16/9; object-fit:cover; background:#f5f3f0; margin:0 auto 32px; display:block;" loading="lazy">

    <div class="schedule-options">
      <div class="schedule-card">
        <h3>{{ t.fifty_programs_title }}</h3>
        <ul>
          <li>{{ t.fifty_programs1 | safe }}</li>
          <li>{{ t.fifty_programs2 | safe }}</li>
          <li>{{ t.fifty_programs3 | safe }}</li>
          <li>{{ t.fifty_programs4 | safe }}</li>
          <li>{{ t.fifty_programs5 | safe }}</li>
        </ul>
      </div>

      <div class="schedule-card">
        <h3>{{ t.fifty_know_title }}</h3>
        <ul>
          <li>{{ t.fifty_know1 | safe }}</li>
          <li>{{ t.fifty_know2 | safe }}</li>
          <li>{{ t.fifty_know3 | safe }}</li>
          <li>{{ t.fifty_know4 | safe }}</li>
          <li>{{ t.fifty_know5 | safe }}</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- 4d: 100-HOUR TRAININGS -->
<section class="program-schedule" id="100h-trainings">
  <div class="container">
    <div style="display:flex; align-items:center; gap:12px; justify-content:center; margin-bottom:16px;">
      <span class="ds-eyebrow ds-eyebrow--brand">{{ t.hundred_eyebrow }}</span>
      <span class="ds-badge ds-badge--secondary">{{ t.hundred_badge }}</span>
    </div>
    <h2 class="section-title">{{ t.hundred_title }}</h2>
    <p class="section-subtitle">{{ t.hundred_subtitle }}</p>

    <img src="/assets/images/compare/100-timers-yoga-uddannelse.jpg" alt="{{ t.img_100h_alt }}" style="width:100%; max-width:800px; border-radius:8px; aspect-ratio:16/9; object-fit:cover; background:#f5f3f0; margin:0 auto 32px; display:block;" loading="lazy">

    <div class="schedule-options">
      <div class="schedule-card">
        <h3>{{ t.hundred_covers_title }}</h3>
        <ul>
          <li>{{ t.hundred_covers1 | safe }}</li>
          <li>{{ t.hundred_covers2 | safe }}</li>
          <li>{{ t.hundred_covers3 | safe }}</li>
          <li>{{ t.hundred_covers4 | safe }}</li>
          <li>{{ t.hundred_covers5 | safe }}</li>
