{% set t = i18n.compare[lang or "da"] %}

<!-- Hero -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title | safe }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="#knowledge-pillars" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta_explore }}</a>
      <a href="#hour-spectrum" class="yb-btn yb-btn--outline-white yb-btn--large">{{ t.hero_cta_hours }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

<!-- Table of Contents -->
<section class="program-overview">
  <div class="container">
    <h2 class="section-title">{{ t.toc_title }}</h2>
    <p class="section-subtitle">{{ t.toc_subtitle }}</p>

    <div class="program-grid" style="max-width:1000px; margin:0 auto;">
      <div class="program-feature">
        <div class="program-feature__icon">1</div>
        <h3><a href="#knowledge-pillars" style="color:inherit; text-decoration:none;">{{ t.toc1_title }}</a></h3>
        <p>{{ t.toc1_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">2</div>
        <h3><a href="#hour-spectrum" style="color:inherit; text-decoration:none;">{{ t.toc2_title }}</a></h3>
        <p>{{ t.toc2_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">3</div>
        <h3><a href="#courses-vs-trainings" style="color:inherit; text-decoration:none;">{{ t.toc3_title }}</a></h3>
        <p>{{ t.toc3_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">4</div>
        <h3><a href="#200h-gold-standard" style="color:inherit; text-decoration:none;">{{ t.toc4_title }}</a></h3>
        <p>{{ t.toc4_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">5</div>
        <h3><a href="#300h-advanced" style="color:inherit; text-decoration:none;">{{ t.toc5_title }}</a></h3>
        <p>{{ t.toc5_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon">6</div>
        <h3><a href="#decision-framework" style="color:inherit; text-decoration:none;">{{ t.toc6_title }}</a></h3>
        <p>{{ t.toc6_desc }}</p>
      </div>
    </div>
  </div>
</section>

<!-- SECTION 3: Knowledge Pillars — What It Takes to Teach Yoga -->
<section class="program-schedule" id="knowledge-pillars">
  <div class="container">
    <span class="ds-eyebrow ds-eyebrow--brand">{{ t.pillars_eyebrow }}</span>
    <h2 class="section-title">{{ t.pillars_title }}</h2>
    <p class="section-subtitle">{{ t.pillars_subtitle }}</p>

    <div class="program-grid" style="max-width:1100px; margin:40px auto 0;">
      <div class="program-feature">
        <div class="program-feature__icon" style="font-size:1.6rem;">📜</div>
        <h3>{{ t.pillar1_title }}</h3>
        <p>{{ t.pillar1_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon" style="font-size:1.6rem;">🧘</div>
        <h3>{{ t.pillar2_title }}</h3>
        <p>{{ t.pillar2_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon" style="font-size:1.6rem;">🦴</div>
        <h3>{{ t.pillar3_title }}</h3>
        <p>{{ t.pillar3_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon" style="font-size:1.6rem;">🌱</div>
        <h3>{{ t.pillar4_title }}</h3>
        <p>{{ t.pillar4_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon" style="font-size:1.6rem;">🎯</div>
        <h3>{{ t.pillar5_title }}</h3>
        <p>{{ t.pillar5_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon" style="font-size:1.6rem;">🗣️</div>
        <h3>{{ t.pillar6_title }}</h3>
        <p>{{ t.pillar6_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon" style="font-size:1.6rem;">🧠</div>
        <h3>{{ t.pillar7_title }}</h3>
        <p>{{ t.pillar7_desc }}</p>
      </div>
      <div class="program-feature">
        <div class="program-feature__icon" style="font-size:1.6rem;">💼</div>
        <h3>{{ t.pillar8_title }}</h3>
        <p>{{ t.pillar8_desc }}</p>
      </div>
    </div>

    <!-- Blockquote about why hours matter -->
    <div style="max-width:800px; margin:48px auto 0;">
      <div class="ds-quote-brand">
        <p class="quote-text">{{ t.pillars_quote }}</p>
        <p class="quote-author">{{ t.pillars_quote_author }}</p>
      </div>
    </div>

    <!-- Journal CTA: Yoga Philosophy Deep Dive -->
    <div style="max-width:800px; margin:32px auto 0; background:white; border-radius:12px; padding:24px 32px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:16px; box-shadow:0 2px 12px rgba(0,0,0,0.06);">
      <div>
        <p style="font-size:0.75rem; text-transform:uppercase; letter-spacing:0.1em; color:var(--yb-brand); font-weight:700; margin-bottom:4px;">{{ t.journal_cta_label }}</p>
        <p style="font-weight:700; font-size:1rem; margin:0;">{{ t.journal_philosophy_title }}</p>
      </div>
      <a href="{% if lang == 'en' %}/en/yoga-journal{% else %}/yoga-journal{% endif %}" style="color:var(--yb-brand); font-weight:700; font-size:0.9rem; white-space:nowrap;">{{ t.journal_read_more }} →</a>
    </div>
  </div>
</section>

<!-- SECTION 4: THE HOUR SPECTRUM -->

<!-- 4a: Spectrum Intro -->
<section class="program-overview" id="hour-spectrum">
  <div class="container">
    <span class="ds-eyebrow ds-eyebrow--brand">{{ t.spectrum_eyebrow }}</span>
    <h2 class="section-title">{{ t.spectrum_title }}</h2>
    <p class="section-subtitle">{{ t.spectrum_subtitle }}</p>

    <!-- Visual Spectrum Bar -->
    <div style="display:flex; max-width:800px; margin:40px auto; border-radius:12px; overflow:hidden; font-size:0.8rem; font-weight:700; text-align:center; color:white;">
      <div style="flex:1; background:var(--ds-text-muted); padding:16px 8px;">{{ t.spectrum_30h }}</div>
      <div style="flex:1.5; background:#8a7968; padding:16px 8px;">{{ t.spectrum_50h }}</div>
      <div style="flex:2; background:#6a5a4a; padding:16px 8px;">{{ t.spectrum_100h }}</div>
      <div style="flex:4; background:var(--yb-brand); padding:16px 8px;">{{ t.spectrum_200h }}</div>
      <div style="flex:3; background:var(--yb-brand-dark); padding:16px 8px;">{{ t.spectrum_300h }}</div>
    </div>
    <p style="text-align:center; color:var(--ds-text-muted); font-size:0.85rem; max-width:600px; margin:0 auto;">{{ t.spectrum_caption }}</p>
  </div>
</section>

<!-- 4b: 30-HOUR TRAININGS -->
<section class="program-schedule" id="30h-trainings">
  <div class="container">
    <div style="display:flex; align-items:center; gap:12px; justify-content:center; margin-bottom:16px;">
      <span class="ds-eyebrow ds-eyebrow--brand">{{ t.thirty_eyebrow }}</span>
      <span class="ds-badge ds-badge--muted">{{ t.thirty_badge }}</span>
    </div>
    <h2 class="section-title">{{ t.thirty_title }}</h2>
    <p class="section-subtitle">{{ t.thirty_subtitle }}</p>

    <img src="/assets/images/compare/30-timers-yoga-workshop.jpg" alt="{{ t.img_30h_alt }}" style="width:100%; max-width:800px; border-radius:8px; aspect-ratio:16/9; object-fit:cover; background:#f5f3f0; margin:0 auto 32px; display:block;" loading="lazy">

    <div class="schedule-options">
      <div class="schedule-card">
        <h3>{{ t.thirty_covers_title }}</h3>
        <ul>
          <li>{{ t.thirty_covers1 | safe }}</li>
          <li>{{ t.thirty_covers2 | safe }}</li>
          <li>{{ t.thirty_covers3 | safe }}</li>
          <li>{{ t.thirty_covers4 | safe }}</li>
          <li>{{ t.thirty_covers5 | safe }}</li>
          <li>{{ t.thirty_covers6 | safe }}</li>
        </ul>
      </div>

      <div class="schedule-card">
        <h3>{{ t.thirty_understand_title }}</h3>
        <ul>
          <li>{{ t.thirty_understand1 | safe }}</li>
          <li>{{ t.thirty_understand2 | safe }}</li>
          <li>{{ t.thirty_understand3 | safe }}</li>
          <li>{{ t.thirty_understand4 | safe }}</li>
          <li>{{ t.thirty_understand5 | safe }}</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- 4c: 50-HOUR TRAININGS -->
<section class="program-overview" id="50h-trainings">
  <div class="container">
    <div style="display:flex; align-items:center; gap:12px; justify-content:center; margin-bottom:16px;">
      <span class="ds-eyebrow ds-eyebrow--brand">{{ t.fifty_eyebrow }}</span>
      <span class="ds-badge ds-badge--outline">{{ t.fifty_badge }}</span>
