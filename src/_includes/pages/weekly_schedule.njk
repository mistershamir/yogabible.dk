<!-- EXPLORE MORE -->
<section id="yb-explore" class="ybEX" aria-labelledby="yb-explore-title">
  <div class="ybEX__inner">
    <header class="ybEX__header">
      <p class="ybEX__kicker">{{ t.explore_kicker }}</p>
      <h2 id="yb-explore-title" class="ybEX__title">{{ t.explore_title | safe }}</h2>
      <p class="ybEX__lead">{{ t.explore_lead | safe }}</p>
    </header>
    <div class="ybEX__grid">
      <article class="ybEX-card">
        <figure class="ybEX-card__image">
          <img id="ybCourseImg" src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/courses/inversions-course.jpg" alt="Inversions" loading="lazy">
          <span class="ybEX-card__badge ybEX-card__badge--soft">{{ t.explore_courses_badge }}</span>
        </figure>
        <div class="ybEX-card__body">
          <h3 class="ybEX-card__title">{{ t.explore_courses_title }}</h3>
          <p class="ybEX-card__text">{{ t.explore_courses_text | safe }}</p>
          <div class="ybEX-card__pills" role="tablist" aria-label="Courses">
            <button class="ybEX-pill is-active" role="tab" aria-selected="true" data-course="inv">Inversions</button>
            <button class="ybEX-pill" role="tab" aria-selected="false" data-course="spl">Splits</button>
            <button class="ybEX-pill" role="tab" aria-selected="false" data-course="bb">Backbends</button>
          </div>
          <p id="ybCourseBlurb" class="ybEX-card__blurb">{{ t.explore_inv_blurb }}</p>
          <a id="ybCourseCta" class="ybEX-btn ybEX-btn--outline" href="https://www.yogabible.dk/inversions">{{ t.explore_inv_cta }} &rarr;</a>
        </div>
      </article>
      <article class="ybEX-card">
        <figure class="ybEX-card__image">
          <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/programs/ytt-200h-education.png" alt="{{ t.explore_4w_title }}" loading="lazy">
          <span class="ybEX-card__badge ybEX-card__badge--primary">{{ t.explore_4w_badge_primary }}</span>
          <span class="ybEX-card__badge ybEX-card__badge--soft ybEX-card__badge--right">{{ t.explore_4w_badge_soft }}</span>
        </figure>
        <div class="ybEX-card__body">
          <h3 class="ybEX-card__title">{{ t.explore_4w_title }}</h3>
          <p class="ybEX-card__text">{{ t.explore_4w_text | safe }}</p>
          <ul class="ybEX-card__list">
            <li>{{ t.explore_4w_li1 }}</li>
            <li>{{ t.explore_4w_li2 | safe }}</li>
            <li>{{ t.explore_4w_li3 | safe }}</li>
          </ul>
          <a class="ybEX-btn ybEX-btn--cta" href="{% if lang == 'en' %}/en/200-hours-4-weeks-intensive-programs{% else %}/200-hours-4-weeks-intensive-programs{% endif %}">{{ t.explore_4w_cta }} &rarr;</a>
        </div>
      </article>
      <article class="ybEX-card">
        <figure class="ybEX-card__image">
          <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/programs/ytt-200h-education.png" alt="{{ t.explore_18w_title }}" loading="lazy">
          <span class="ybEX-card__badge ybEX-card__badge--primary">{{ t.explore_18w_badge }}</span>
        </figure>
        <div class="ybEX-card__body">
          <h3 class="ybEX-card__title">{{ t.explore_18w_title }}</h3>
          <p class="ybEX-card__text">{{ t.explore_18w_text | safe }}</p>
          <ul class="ybEX-card__list">
            <li>{{ t.explore_18w_li1 }}</li>
            <li>{{ t.explore_18w_li2 | safe }}</li>
            <li>{{ t.explore_18w_li3 }}</li>
          </ul>
          <a class="ybEX-btn ybEX-btn--cta" href="{% if lang == 'en' %}/en/200-hours-18-weeks-flexible-programs{% else %}/200-hours-18-weeks-flexible-programs{% endif %}">{{ t.explore_18w_cta }} &rarr;</a>
        </div>
      </article>
    </div>
  </div>

  <style>
    #yb-explore{ --ybEX-primary: var(--yb-brand); --ybEX-primary-dark:#e05402; --ybEX-ink:#161616; --ybEX-muted:#6F6A66; --ybEX-border:#e5e0db; --ybEX-surface:#FFFCF9; color:var(--ybEX-ink); background:var(--ybEX-surface); padding: clamp(48px, 6vw, 96px) clamp(18px, 4vw, 28px); }
    #yb-explore .ybEX__inner{ max-width:1120px; margin:0 auto; }
    #yb-explore .ybEX__header{ max-width:720px; margin-bottom:clamp(28px,4vw,40px); }
    #yb-explore .ybEX__kicker{ display:inline-block; margin:0 0 .5rem; font-weight:700; text-transform:uppercase; letter-spacing:.12em; font-size:.82rem; color:var(--ybEX-primary); }
    #yb-explore .ybEX__title{ margin:0 0 .75rem; font-size:clamp(1.75rem,3.6vw,2.25rem); color:var(--ybEX-ink); line-height:1.15; letter-spacing:-.01em; }
    #yb-explore .ybEX__lead{ margin:0; color:#6F6A66; line-height:1.65; font-size:clamp(1rem,1.6vw,1.06rem); }
    #yb-explore .ybEX__grid{ display:grid; grid-template-columns:1fr; gap:1.5rem; }
    @media (min-width:720px){ #yb-explore .ybEX__grid{ grid-template-columns:1fr 1fr; gap:1.5rem; } }
    @media (min-width:1000px){ #yb-explore .ybEX__grid{ grid-template-columns:1fr 1fr 1fr; gap:1.75rem; } }
    #yb-explore .ybEX-card{ background:#fff; border:1px solid var(--ybEX-border); border-radius:18px; overflow:hidden; display:flex; flex-direction:column; box-shadow:0 12px 34px rgba(0,0,0,.05); transition:box-shadow .2s ease, transform .2s ease; }
    #yb-explore .ybEX-card:hover{ box-shadow:0 16px 44px rgba(0,0,0,.1); transform:translateY(-2px); }
    #yb-explore .ybEX-card__image{ position:relative; margin:0; aspect-ratio:4/3; overflow:hidden; background:#f5f4f2; }
    #yb-explore .ybEX-card__image img{ width:100%; height:100%; object-fit:cover; object-position:center; }
    #yb-explore .ybEX-card__badge{ position:absolute; top:.75rem; left:.75rem; padding:.4rem .75rem; border-radius:999px; font-weight:700; font-size:.72rem; letter-spacing:.02em; text-transform:uppercase; }
    #yb-explore .ybEX-card__badge--primary{ background:var(--ybEX-primary); color:#fff; box-shadow:0 4px 12px rgba(247,92,3,.3); }
    #yb-explore .ybEX-card__badge--soft{ background:rgba(255,255,255,.95); color:var(--ybEX-ink); border:1px solid rgba(0,0,0,.08); backdrop-filter:blur(4px); }
    #yb-explore .ybEX-card__badge--right{ left:auto; right:.75rem; }
    #yb-explore .ybEX-card__body{ padding:1.25rem; display:flex; flex-direction:column; flex-grow:1; }
    #yb-explore .ybEX-card__title{ margin:0 0 .6rem; font-size:1.08rem; color:var(--ybEX-ink); line-height:1.3; }
    #yb-explore .ybEX-card__text{ margin:0 0 .85rem; font-size:.92rem; color:#6F6A66; line-height:1.6; }
    #yb-explore .ybEX-card__pills{ display:flex; flex-wrap:wrap; gap:.4rem; margin-bottom:.85rem; }
    #yb-explore .ybEX-pill{ appearance:none; background:#fff; color:var(--ybEX-ink); border:1px solid var(--ybEX-border); padding:.4rem .85rem; border-radius:999px; font-weight:700; font-size:.85rem; cursor:pointer; transition:all .15s ease; font-family:inherit; }
    #yb-explore .ybEX-pill:hover{ border-color:var(--ybEX-primary); color:var(--ybEX-primary); }
    #yb-explore .ybEX-pill.is-active{ background:rgba(247,92,3,.08); border-color:var(--ybEX-primary); color:var(--ybEX-primary); }
    #yb-explore .ybEX-card__blurb{ margin:0 0 1rem; font-size:.88rem; color:var(--ybEX-muted); line-height:1.6; flex-grow:1; }
    #yb-explore .ybEX-card__list{ list-style:none; margin:0 0 1rem; padding:0; flex-grow:1; }
    #yb-explore .ybEX-card__list li{ position:relative; padding-left:1.4rem; margin:.4rem 0; font-size:.9rem; color:var(--ybEX-ink); line-height:1.5; }
    #yb-explore .ybEX-card__list li::before{ content:"\2192"; position:absolute; left:0; color:var(--ybEX-primary); font-weight:700; }
    #yb-explore .ybEX-btn{ display:inline-flex; align-items:center; justify-content:center; padding:.75rem 1.25rem; border-radius:999px; font-weight:700; font-size:.9rem; text-decoration:none; border:2px solid transparent; cursor:pointer; transition:all .15s ease; margin-top:auto; }
    #yb-explore .ybEX-btn:focus-visible{ outline:3px solid var(--ybEX-primary); outline-offset:2px; }
    #yb-explore .ybEX-btn:active{ transform:scale(.98); }
    #yb-explore .ybEX-btn--cta{ background:var(--ybEX-primary); color:#fff; border-color:var(--ybEX-primary); box-shadow:0 4px 14px rgba(247,92,3,.25); }
    #yb-explore .ybEX-btn--cta:hover{ background:var(--ybEX-primary-dark); border-color:var(--ybEX-primary-dark); box-shadow:0 6px 20px rgba(247,92,3,.3); transform:translateY(-1px); }
    #yb-explore .ybEX-btn--outline{ background:transparent; color:var(--ybEX-primary); border-color:var(--ybEX-primary); }
    #yb-explore .ybEX-btn--outline:hover{ background:var(--ybEX-primary); color:#fff; }
    @media (max-width:599px){ #yb-explore .ybEX-card__body{ padding:1.1rem; } #yb-explore .ybEX-btn{ width:100%; text-align:center; } }
    @media (prefers-reduced-motion: reduce){ #yb-explore, #yb-explore *{ transition:none !important; } }
  </style>

  <script>
    (function(){
      const root = document.getElementById('yb-explore');
      if(!root) return;
      const COURSE_DATA = {
        inv: { image: 'https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/courses/inversions-course.jpg', blurb: '{{ t.explore_inv_blurb }}', href: 'https://www.yogabible.dk/inversions', label: '{{ t.explore_inv_cta }}', alt: 'Inversions' },
        spl: { image: 'https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/courses/splits-course.jpg', blurb: '{{ t.explore_spl_blurb }}', href: 'https://www.yogabible.dk/splits', label: '{{ t.explore_spl_cta }}', alt: 'Splits' },
        bb: { image: 'https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/courses/backbend-training-pro.jpg', blurb: '{{ t.explore_bb_blurb }}', href: 'https://www.yogabible.dk/backbends', label: '{{ t.explore_bb_cta }}', alt: 'Backbends' }
      };
      const img = document.getElementById('ybCourseImg');
      const blurb = document.getElementById('ybCourseBlurb');
      const cta = document.getElementById('ybCourseCta');
      const pills = root.querySelectorAll('.ybEX-pill');
      if (!img || !blurb || !cta || !pills.length) return;
      const setCourse = (key) => { const data = COURSE_DATA[key]; if (!data) return; pills.forEach(p => { const isActive = p.dataset.course === key; p.classList.toggle('is-active', isActive); p.setAttribute('aria-selected', isActive); }); img.src = data.image; img.alt = data.alt; blurb.textContent = data.blurb; cta.href = data.href; cta.textContent = data.label + ' \u2192'; };
      pills.forEach(p => { p.addEventListener('click', () => setCourse(p.dataset.course)); });
      setCourse('inv');
    })();
  </script>
</section>
