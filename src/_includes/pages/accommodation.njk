{% set t = i18n.accommodation[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

<!-- JSON-LD: Accommodation Structured Data (AEO) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "LodgingBusiness",
  "name": "{{ t.jsonld_name }}",
  "description": "{{ t.jsonld_desc }}",
  "url": "{{ site.url }}{{ lp }}/accommodation/",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "København K",
    "postalCode": "1400",
    "addressCountry": "DK"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 55.6722,
    "longitude": 12.5930
  },
  "priceRange": "6500-9500 DKK",
  "amenityFeature": [
    { "@type": "LocationFeatureSpecification", "name": "Kitchen", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "WiFi", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Fitness Center", "value": true },
    { "@type": "LocationFeatureSpecification", "name": "Laundry", "value": true }
  ],
  "parentOrganization": {
    "@type": "EducationalOrganization",
    "name": "Yoga Bible",
    "url": "{{ site.url }}"
  }
}
</script>

<!-- FAQPage Schema (AEO — helps with featured snippets) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "{{ t.jsonld_faq1_q }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ t.jsonld_faq1_a }}"
      }
    },
    {
      "@type": "Question",
      "name": "{{ t.jsonld_faq2_q }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ t.jsonld_faq2_a }}"
      }
    },
    {
      "@type": "Question",
      "name": "{{ t.jsonld_faq3_q }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ t.jsonld_faq3_a }}"
      }
    },
    {
      "@type": "Question",
      "name": "{{ t.jsonld_faq4_q }}",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "{{ t.jsonld_faq4_a }}"
      }
    }
  ]
}
</script>


<!-- ═══════════════════════════════════════════════════════════
     HERO — Dark Cinematic with Breathing Glow
     ═══════════════════════════════════════════════════════════ -->
<section class="yb-hero">
  <div class="yb-hero__bg">
    <video autoplay muted loop playsinline preload="auto" aria-hidden="true"
      poster="{{ "yoga-bible-DK/accommodation/accommodation-hero-loop.jpg" | cloudvid("w_1920,c_fill,so_0,q_60") }}">
      <source src="{{ "yoga-bible-DK/accommodation/accommodation-hero-loop" | cloudvid("w_1280,q_auto") }}" type="video/mp4">
    </video>
  </div>
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="#roomoptions" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta_rooms }}</a>
      <a href="mailto:info@yogabible.dk?subject=Accommodation%20inquiry" class="yb-btn yb-btn--outline-white yb-btn--large">{{ t.hero_cta_contact }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>



<!-- ═══════════════════════════════════════════════════════════
     SECTION 2 — WHY WE OFFER ACCOMMODATION
     ═══════════════════════════════════════════════════════════ -->
<section class="yba-section yba-section--light" id="why-accommodation">
  <div class="yba-container">
    <div class="yba-split">
      <div class="yba-split__content">
        <p class="yba-eyebrow">{{ t.why_eyebrow }}</p>
        <h2 class="yba-h2">{{ t.why_title }}</h2>
        <p class="yba-lead">{{ t.why_lead }}</p>
        <ul class="yba-checklist">
          {% for item in t.why_checks.split("|") %}
          <li>{{ item | safe }}</li>
          {% endfor %}
        </ul>
        <a href="#roomoptions" class="btn btn--primary">{{ t.why_cta }}</a>
      </div>
      <div class="yba-split__media">
        <video autoplay muted loop playsinline preload="metadata" style="width:100%; border-radius:12px; aspect-ratio:9/16; object-fit:cover;"
          poster="{{ "yoga-bible-DK/accommodation/student-apartment-living-copenhagen.jpg" | cloudvid("w_600,c_fill,so_0,q_60") }}">
          <source src="{{ "yoga-bible-DK/accommodation/student-apartment-living-copenhagen" | cloudvid("w_600,q_auto") }}" type="video/mp4">
        </video>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     SECTION 3 — ROOM OPTIONS
     ═══════════════════════════════════════════════════════════ -->
<section id="roomoptions" class="yba-rooms" aria-label="{{ t.rooms_title }}">
  <div class="yba-rooms__inner">

    <header class="yba-rooms__header">
      <p class="yba-eyebrow" style="text-align:center;">{{ t.rooms_eyebrow }}</p>
      <h2 class="yba-h2" style="text-align:center;">{{ t.rooms_title }}</h2>
      <p class="yba-rooms__lead">{{ t.rooms_lead }}</p>
    </header>

    <div class="yba-rooms__grid" aria-label="{{ t.rooms_aria }}">

      <!-- ── Single Studio Apartment ── -->
      <article class="yba-room-card" data-type="single">
        <div class="yba-gallery" aria-label="{{ t.single_gallery_aria }}">
          <button class="yba-gallery__prev" type="button" aria-label="{{ t.single_prev_aria }}">‹</button>
          <div class="yba-gallery__track">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/accommodation/single-apartment-hero.jpg" alt="Single studio apartment for yoga students Copenhagen — interior view 1" loading="lazy" decoding="async">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/accommodation/single-apartment-01.jpg" alt="Single studio apartment Copenhagen — bedroom" loading="lazy" decoding="async">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/accommodation/single-apartment-03.jpg" alt="Studio apartment kitchen yoga student accommodation" loading="lazy" decoding="async">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/accommodation/single-apartment-02.jpg" alt="Single studio apartment — bathroom" loading="lazy" decoding="async">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/accommodation/single-apartment-04.jpg" alt="Single studio apartment workspace and living area" loading="lazy" decoding="async">
          </div>
          <button class="yba-gallery__next" type="button" aria-label="{{ t.single_next_aria }}">›</button>
          <div class="yba-gallery__dots"></div>
          <span class="yba-gallery__frame" aria-hidden="true"></span>
        </div>

        <header class="yba-room-card__head">
          <h3>{{ t.single_title }}</h3>
          <p class="yba-room-card__tag">{{ t.single_tag }}</p>
        </header>

        <div class="yba-room-card__price">
          <div class="yba-price__main">
            <span class="yba-price__amount">{{ t.single_price }}</span>
            <span class="yba-price__note">{{ t.single_price_note }}</span>
          </div>
          <p class="yba-price__fine">{{ t.single_price_fine }}</p>
        </div>

        <ul class="yba-room-card__list">
          {% for item in t.single_features.split("|") %}
          <li>{{ item | safe }}</li>
          {% endfor %}
        </ul>

        <div class="yba-room-card__cta">
          <a href="mailto:info@yogabible.dk?subject=Accommodation%20inquiry%20—%20Single%20Studio" class="yba-btn yba-btn--cta">{{ t.hero_cta_contact }}</a>
        </div>
      </article>

      <!-- ── Double Studio Apartment ── -->
      <article class="yba-room-card" data-type="double">
        <div class="yba-gallery" aria-label="{{ t.double_gallery_aria }}">
          <button class="yba-gallery__prev" type="button" aria-label="{{ t.double_prev_aria }}">‹</button>
          <div class="yba-gallery__track">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/accommodation/double-bedroom-03.jpg" alt="Double studio apartment yoga student Copenhagen — bedroom" loading="lazy" decoding="async">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/accommodation/double-bedroom-01.jpg" alt="Shared apartment private bedroom" loading="lazy" decoding="async">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/accommodation/double-bedroom-07.jpg" alt="Shared apartment common area yoga accommodation" loading="lazy" decoding="async">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/accommodation/double-bedroom-02.jpg" alt="Double studio bathroom and kitchen" loading="lazy" decoding="async">
            <img src="https://res.cloudinary.com/ddcynsa30/image/upload/f_auto,q_auto/yoga-bible-DK/accommodation/double-bedroom-04.jpg" alt="Shared yoga student accommodation Copenhagen living space" loading="lazy" decoding="async">
          </div>
          <button class="yba-gallery__next" type="button" aria-label="{{ t.double_next_aria }}">›</button>
          <div class="yba-gallery__dots"></div>
          <span class="yba-gallery__frame" aria-hidden="true"></span>
        </div>

        <header class="yba-room-card__head">
          <h3>{{ t.double_title }}</h3>
          <p class="yba-room-card__tag">{{ t.double_tag }}</p>
        </header>

        <div class="yba-room-card__price">
          <div class="yba-price__main">
            <span class="yba-price__amount">{{ t.double_price }}</span>
            <span class="yba-price__note">{{ t.double_price_note }}</span>
          </div>
          <p class="yba-price__fine">{{ t.double_price_fine }}</p>
        </div>

        <ul class="yba-room-card__list">
          {% for item in t.double_features.split("|") %}
          <li>{{ item | safe }}</li>
          {% endfor %}
        </ul>

        <div class="yba-room-card__cta">
          <a href="mailto:info@yogabible.dk?subject=Accommodation%20inquiry%20—%20Double%20Studio" class="yba-btn yba-btn--cta">{{ t.hero_cta_contact }}</a>
        </div>
      </article>

    </div>

    <footer class="yba-rooms__footer">
      <div class="yba-rooms__refund">
        <p>{{ t.rooms_refund | safe }}</p>
      </div>
      <p class="yba-rooms__tip">{{ t.rooms_tip | safe }}</p>
    </footer>

  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     SECTION 4 — THE RESIDENCE — WHAT'S INCLUDED
     ═══════════════════════════════════════════════════════════ -->
<section class="yba-section yba-section--warm" id="amenities">
  <div class="yba-container">
    <p class="yba-eyebrow" style="text-align:center;">{{ t.amenity_eyebrow }}</p>
    <h2 class="yba-h2" style="text-align:center;">{{ t.amenity_title }}</h2>
