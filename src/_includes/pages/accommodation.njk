        <div class="yba-amenity-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
        </div>
        <h3>{{ t.amenity3_title }}</h3>
        <p>{{ t.amenity3_desc }}</p>
      </div>

      <div class="yba-amenity-card">
        <div class="yba-amenity-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 3l-4 4-4-4"/><circle cx="12" cy="14" r="3"/></svg>
        </div>
        <h3>{{ t.amenity4_title }}</h3>
        <p>{{ t.amenity4_desc }}</p>
      </div>

      <div class="yba-amenity-card">
        <div class="yba-amenity-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/><path d="M2 8a10 10 0 0 1 20 0"/></svg>
        </div>
        <h3>{{ t.amenity5_title }}</h3>
        <p>{{ t.amenity5_desc }}</p>
      </div>

      <div class="yba-amenity-card">
        <div class="yba-amenity-card__icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <h3>{{ t.amenity6_title }}</h3>
        <p>{{ t.amenity6_desc }}</p>
      </div>

    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     SECTION 5 — COOK YOUR OWN FOOD
     ═══════════════════════════════════════════════════════════ -->
<section class="yba-section" id="cooking">
  <div class="yba-container">
    <div class="yba-split yba-split--reverse">
      <div class="yba-split__content">
        <p class="yba-eyebrow">{{ t.cook_eyebrow }}</p>
        <h2 class="yba-h2">{{ t.cook_title }}</h2>
        <p class="yba-lead">{{ t.cook_lead }}</p>
        <p>{{ t.cook_desc | safe }}</p>

        <div class="yba-quote-side">
          <div class="yba-quote-bar"></div>
          <div>
            <p class="yba-quote-text">{{ t.cook_tip | safe }}</p>
          </div>
        </div>

        <div class="yba-food-stats">
          <div class="yba-food-stat">
            <span class="yba-food-stat__number">{{ t.cook_stat1_num }}</span>
            <span class="yba-food-stat__label">{{ t.cook_stat1_label | safe }}</span>
          </div>
          <div class="yba-food-stat">
            <span class="yba-food-stat__number">{{ t.cook_stat2_num }}</span>
            <span class="yba-food-stat__label">{{ t.cook_stat2_label | safe }}</span>
          </div>
          <div class="yba-food-stat">
            <span class="yba-food-stat__number">{{ t.cook_stat3_num }}</span>
            <span class="yba-food-stat__label">{{ t.cook_stat3_label | safe }}</span>
          </div>
        </div>
      </div>
      <div class="yba-split__media">
        <video autoplay muted loop playsinline preload="metadata" style="width:100%; border-radius:12px; aspect-ratio:9/16; object-fit:cover;"
          poster="{{ "yoga-bible-DK/accommodation/yoga-student-cooking-copenhagen-kitchen.jpg" | cloudvid("w_600,c_fill,so_0,q_60") }}">
          <source src="{{ "yoga-bible-DK/accommodation/yoga-student-cooking-copenhagen-kitchen" | cloudvid("w_600,q_auto") }}" type="video/mp4">
        </video>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     SECTION 6 — LOCATION & MAP
     ═══════════════════════════════════════════════════════════ -->
<section class="yba-section yba-section--dark" id="location">
  <div class="yba-container">
    <p class="yba-eyebrow yba-eyebrow--white" style="text-align:center;">{{ t.loc_eyebrow }}</p>
    <h2 class="yba-h2" style="text-align:center; color:#fff;">{{ t.loc_title }}</h2>
    <p class="yba-lead" style="text-align:center; max-width:60ch; margin:0 auto 2.5rem; color:rgba(255,255,255,.75);">{{ t.loc_lead }}</p>

    <div style="margin-bottom:2.5rem; border-radius:12px; overflow:hidden;">
      <video autoplay muted loop playsinline preload="metadata" style="width:100%; aspect-ratio:16/9; object-fit:cover; display:block;"
        poster="{{ "yoga-bible-DK/accommodation/christianshavn-copenhagen-neighbourhood.jpg" | cloudvid("w_1280,c_fill,so_0,q_60") }}">
        <source src="{{ "yoga-bible-DK/accommodation/christianshavn-copenhagen-neighbourhood" | cloudvid("w_1280,q_auto") }}" type="video/mp4">
      </video>
    </div>

    <div class="yba-map-wrapper">
      <div class="yba-map-container">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2250.089!2d12.5905!3d55.6722!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x4652530fa0a14c27%3A0x3d4b6e5c8a2e0a0a!2sTorvegade%2066%2C%201400%20K%C3%B8benhavn!5e0!3m2!1s{% if lang == 'en' %}en{% else %}da{% endif %}!2sdk!4v1700000000000!5m2!1s{% if lang == 'en' %}en{% else %}da{% endif %}!2sdk"
          width="100%"
          height="100%"
          style="border:0;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="{{ t.loc_map_title }}">
        </iframe>
      </div>

      <div class="yba-map-info">
        <h3>{{ t.loc_info_title }}</h3>
        <p class="yba-map-address">{{ t.loc_info_address }}</p>

        <div class="yba-map-distances">
          <div class="yba-map-distance">
            <span class="yba-map-distance__icon">🚶</span>
            <div>
              <strong>{{ t.loc_dist1_title }}</strong>
              <p>{{ t.loc_dist1_desc }}</p>
            </div>
          </div>
          <div class="yba-map-distance">
            <span class="yba-map-distance__icon">🚇</span>
            <div>
              <strong>{{ t.loc_dist2_title }}</strong>
              <p>{{ t.loc_dist2_desc }}</p>
            </div>
          </div>
          <div class="yba-map-distance">
            <span class="yba-map-distance__icon">🛒</span>
            <div>
              <strong>{{ t.loc_dist3_title }}</strong>
              <p>{{ t.loc_dist3_desc }}</p>
            </div>
          </div>
          <div class="yba-map-distance">
            <span class="yba-map-distance__icon">🏊</span>
            <div>
              <strong>{{ t.loc_dist4_title }}</strong>
              <p>{{ t.loc_dist4_desc }}</p>
            </div>
          </div>
        </div>

        <a href="https://maps.google.com/?q=Torvegade+66,+1400+København+K,+Denmark" target="_blank" rel="noopener" class="btn btn--primary" style="margin-top:1.25rem;">{{ t.loc_cta }}</a>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════════
     SECTION 7 — BUDGET ESTIMATION
     ═══════════════════════════════════════════════════════════ -->
<section class="yba-section" id="budget">
  <div class="yba-container">
    <p class="yba-eyebrow" style="text-align:center;">{{ t.budget_eyebrow }}</p>
    <h2 class="yba-h2" style="text-align:center;">{{ t.budget_title }}</h2>
    <p class="yba-lead" style="text-align:center; max-width:65ch; margin:0 auto 2.5rem;">{{ t.budget_lead }}</p>

    <div class="yba-budget-table-wrap">
      <table class="yba-budget-table">
        <thead>
          <tr>
            <th>{{ t.budget_th_category }}</th>
            <th>{{ t.budget_th_budget }}</th>
            <th>{{ t.budget_th_comfort }}</th>
            <th>{{ t.budget_th_note }}</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td data-label="{{ t.budget_th_category }}">
              <span class="yba-budget-icon">🍳</span>
              <strong>{{ t.budget_row1_cat }}</strong>
            </td>
            <td data-label="{{ t.budget_th_budget }}">{{ t.budget_row1_budget }}</td>
            <td data-label="{{ t.budget_th_comfort }}">{{ t.budget_row1_comfort }}</td>
            <td data-label="{{ t.budget_th_note }}">{{ t.budget_row1_note }}</td>
          </tr>
