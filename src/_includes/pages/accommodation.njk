<!-- ═══════════════════════════════════════════════════════════
     STYLES — Scoped to .yba-* (Yoga Bible Accommodation)
     ═══════════════════════════════════════════════════════════ -->
<style>
/* ── Variables ── */
:root {
  --yba-brand: #f75c03;
  --yba-brand-dark: #e05402;
  --yba-brand-light: #ff9966;
  --yba-ink: #0F0F0F;
  --yba-muted: #6F6A66;
  --yba-border: #E8E4E0;
  --yba-bg-light: #F5F3F0;
  --yba-bg-warm: #FFFCF9;
  --yba-ring: rgba(247,92,3,.30);
}

/* ── Sections ── */
.yba-section {
  padding: clamp(48px,7vw,96px) clamp(18px,4vw,28px);
}
.yba-section--light { background: var(--yba-bg-light); }
.yba-section--warm { background: var(--yba-bg-warm); }
.yba-section--dark { background: var(--yba-ink); color: #fff; }
.yba-section--brand {
  background: linear-gradient(135deg, #f75c03, #d94f02 60%, #c44600);
  color: #fff;
}

.yba-container {
  max-width: 1140px;
  margin: 0 auto;
}


/* ══════════════════════════════════
   TYPOGRAPHY
   ══════════════════════════════════ */
.yba-eyebrow {
  display: block;
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--yba-brand);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin: 0 0 0.5rem;
}

.yba-eyebrow--white { color: rgba(255,255,255,.7); }

.yba-h2 {
  font-size: clamp(1.8rem, 3.5vw, 2.5rem);
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: -0.01em;
  margin: 0 0 0.75rem;
  color: var(--yba-ink);
}

.yba-section--dark .yba-h2 { color: #fff; }
.yba-section--brand .yba-h2 { color: #fff; }

.yba-h3 {
  font-size: clamp(1.2rem, 2vw, 1.5rem);
  font-weight: 700;
  color: var(--yba-ink);
  margin: 0 0 0.5rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.yba-h3__icon { font-size: 1.3em; }

.yba-lead {
  font-size: clamp(0.95rem, 1.5vw, 1.08rem);
  color: var(--yba-muted);
  line-height: 1.65;
  margin: 0 0 1.5rem;
}


/* ══════════════════════════════════
   SPLIT LAYOUT
   ══════════════════════════════════ */
.yba-split {
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
  align-items: center;
}

@media (min-width: 800px) {
  .yba-split { grid-template-columns: 1fr 1fr; gap: 3.5rem; }
  .yba-split--reverse .yba-split__media { order: -1; }
}

.yba-split__media {
  border-radius: 16px;
  overflow: hidden;
}

.yba-img-placeholder {
  background: var(--yba-bg-light);
  border: 2px dashed var(--yba-border);
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: var(--yba-muted);
  font-size: 0.85rem;
  line-height: 1.5;
  padding: 1rem;
}


/* ══════════════════════════════════
   CHECKLIST
   ══════════════════════════════════ */
.yba-checklist {
  list-style: none;
  padding: 0;
  margin: 0 0 1.5rem;
  display: grid;
  gap: 0.65rem;
}

.yba-checklist li {
  padding-left: 1.75rem;
  position: relative;
  font-size: 0.95rem;
  font-weight: 550;
  color: var(--yba-ink);
  line-height: 1.5;
}

.yba-checklist li::before {
  content: "\2713";
  position: absolute;
  left: 0;
  color: var(--yba-brand);
  font-weight: 700;
  font-size: 1rem;
}


/* ══════════════════════════════════
   ROOM OPTIONS
   ══════════════════════════════════ */
.yba-rooms, .yba-rooms * { box-sizing: border-box; }

.yba-rooms {
  color: var(--yba-ink);
  background:
    radial-gradient(80% 60% at 20% 5%, rgba(247,92,3,.06), transparent 60%),
    linear-gradient(#fff,#fff);
  padding: clamp(48px,6vw,92px) clamp(18px,4vw,28px);
}

.yba-rooms__inner {
  max-width: 1140px;
  margin: 0 auto;
}

.yba-rooms__header {
  max-width: 900px;
  margin: 0 auto clamp(24px,3vw,36px);
}

.yba-rooms__lead {
  text-align: center;
  margin: 0.6rem auto 0;
  max-width: 70ch;
  color: #333;
  line-height: 1.65;
  font-size: clamp(0.95rem,1.5vw,1.05rem);
}

/* Grid */
.yba-rooms__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  align-items: stretch;
}
@media (min-width: 960px) {
  .yba-rooms__grid { grid-template-columns: 1fr 1fr; gap: 1.75rem; }
}

/* Card */
.yba-room-card {
  border: 1px solid var(--yba-border);
  border-radius: 20px;
  background: #fff;
  box-shadow: 0 18px 60px rgba(0,0,0,.10);
  overflow: hidden;
  display: grid;
  grid-template-rows: auto auto auto 1fr auto auto;
  min-height: 100%;
}

/* Gallery */
.yba-gallery {
  position: relative;
  width: 100%;
  aspect-ratio: 16/11;
  background: #f6f3f0;
  overflow: hidden;
}

.yba-gallery__track {
  height: 100%;
  display: flex;
  transform: translateX(0);
  transition: transform 0.35s ease;
}

.yba-gallery__track img {
  flex: 0 0 100%;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.yba-gallery__frame {
  position: absolute;
  inset: 0;
  pointer-events: none;
  box-shadow: inset 0 0 0 1px rgba(0,0,0,.06), inset 0 0 0 2px rgba(247,92,3,.10);
}

.yba-gallery__prev,
.yba-gallery__next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 42px;
  height: 42px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.55);
  background: rgba(15,15,15,.35);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  cursor: pointer;
  z-index: 2;
  transition: background 0.18s, transform 0.1s, box-shadow 0.18s;
  box-shadow: 0 10px 22px rgba(0,0,0,.18);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.yba-gallery__prev { left: 12px; }
.yba-gallery__next { right: 12px; }

.yba-gallery__prev:hover,
.yba-gallery__next:hover {
  background: rgba(247,92,3,.92);
  border-color: rgba(247,92,3,.4);
  transform: translateY(-50%) translateY(-1px);
  box-shadow: 0 16px 34px rgba(247,92,3,.25);
}

.yba-gallery__prev:focus-visible,
.yba-gallery__next:focus-visible {
  outline: 0;
  box-shadow: 0 0 0 6px var(--yba-ring);
}

/* Dots */
.yba-gallery__dots {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 12px;
  display: flex;
  justify-content: center;
  gap: 6px;
  z-index: 2;
}

.yba-gallery__dot {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: rgba(255,255,255,.6);
  border: 1px solid rgba(0,0,0,.10);
  box-shadow: 0 6px 14px rgba(0,0,0,.12);
  cursor: pointer;
  padding: 0;
  transition: all 0.15s;
}

.yba-gallery__dot.is-active {
  background: rgba(247,92,3,.95);
  border-color: rgba(247,92,3,.25);
  box-shadow: 0 10px 22px rgba(247,92,3,.20);
  transform: scale(1.15);
}

/* Card Head */
.yba-room-card__head { padding: 1rem 1.25rem 0; }

.yba-room-card__head h3 {
  margin: 0;
  font-weight: 900;
  letter-spacing: -0.01em;
  font-size: 1.15rem;
  line-height: 1.25;
  text-transform: uppercase;
}

.yba-room-card__tag {
  margin: 0.35rem 0 0;
  color: var(--yba-muted);
  font-weight: 600;
  font-size: 0.95rem;
  line-height: 1.45;
}

/* Price */
.yba-room-card__price { padding: 0.85rem 1.25rem 0; }

.yba-price__main {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 0.75rem;
  align-items: baseline;
}

.yba-price__amount {
  font-weight: 900;
  font-size: 1.6rem;
  letter-spacing: -0.01em;
  color: var(--yba-ink);
}

.yba-price__note {
  color: var(--yba-muted);
  font-weight: 650;
  font-size: 0.95rem;
}

.yba-price__fine {
  margin: 0.5rem 0 0;
  color: #2a2f3a;
  line-height: 1.55;
  font-weight: 550;
  font-size: 0.9rem;
}

/* Room List */
.yba-room-card__list {
  margin: 1rem 0 0;
  padding: 0 1.25rem;
  list-style: none;
  display: grid;
  gap: 0.6rem;
}

.yba-room-card__list li {
  position: relative;
  padding-left: 1.25rem;
  color: var(--yba-ink);
  line-height: 1.5;
  font-size: 0.95rem;
  font-weight: 550;
}

.yba-room-card__list li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.55em;
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: var(--yba-brand);
  box-shadow: 0 6px 14px rgba(247,92,3,.16);
  transform: translateY(-50%);
}

.yba-room-card__list strong { font-weight: 800; }

/* Month Chips */
.yba-room-card__months {
  padding: 1rem 1.25rem 0;
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}

.yba-chip {
  appearance: none;
  border: 1px solid var(--yba-border);
  background: #fff;
  color: var(--yba-ink);
  padding: 0.5rem 1rem;
  border-radius: 999px;
  font-weight: 700;
  font-size: 0.9rem;
  cursor: pointer;
  transition: background 0.16s, color 0.16s, border-color 0.16s, transform 0.1s, box-shadow 0.16s;
  font-family: inherit;
}

.yba-chip:hover {
  background: #fff5ef;
  border-color: var(--yba-brand);
  transform: translateY(-1px);
  box-shadow: 0 8px 20px rgba(247,92,3,.10);
}

.yba-chip.is-active {
  background: var(--yba-brand);
  color: #fff;
  border-color: var(--yba-brand);
  box-shadow: 0 10px 24px rgba(247,92,3,.18);
}

/* CTA Button */
.yba-room-card__cta {
  padding: 1.25rem;
  margin-top: auto;
}

.yba-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  padding: 0.85rem 1.5rem;
  border-radius: 999px;
  border: 2px solid transparent;
  text-decoration: none;
  font-weight: 700;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all 0.15s;
  font-family: inherit;
}

.yba-btn:focus-visible {
  outline: 0;
  box-shadow: 0 0 0 5px var(--yba-ring);
}

.yba-btn--cta {
  background: var(--yba-brand);
  color: #fff;
  border-color: var(--yba-brand);
  box-shadow: 0 8px 24px rgba(247,92,3,.22);
}

.yba-btn--cta:hover {
  background: var(--yba-brand-dark);
  border-color: var(--yba-brand-dark);
  transform: translateY(-1px);
  box-shadow: 0 12px 32px rgba(247,92,3,.28);
}

/* Footer */
.yba-rooms__footer {
  margin-top: 2rem;
  text-align: center;
}

.yba-rooms__refund {
  display: inline-block;
  background: #fff;
  border: 2px solid var(--yba-brand);
  border-radius: 12px;
  padding: 0.85rem 1.5rem;
  margin-bottom: 1rem;
}

.yba-rooms__refund p {
  margin: 0;
  font-size: 0.95rem;
  color: var(--yba-ink);
  line-height: 1.5;
}

.yba-rooms__refund strong { color: var(--yba-brand); }

.yba-rooms__tip {
  margin: 0;
  color: var(--yba-muted);
  font-size: 0.88rem;
  line-height: 1.55;
  font-weight: 550;
}

.yba-rooms__tip a {
  color: var(--yba-brand);
  text-decoration: none;
  font-weight: 700;
}

.yba-rooms__tip a:hover { text-decoration: underline; }


/* ══════════════════════════════════
   AMENITIES GRID
   ══════════════════════════════════ */
.yba-amenities-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.25rem;
}

.yba-amenity-card {
  background: #fff;
  border: 1px solid var(--yba-border);
  border-radius: 16px;
  padding: 1.5rem;
  transition: transform 0.2s, box-shadow 0.2s;
}

.yba-amenity-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(0,0,0,.08);
}

.yba-amenity-card__icon {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: rgba(247,92,3,.08);
  color: var(--yba-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1rem;
}

.yba-amenity-card h3 {
  font-size: 1.05rem;
  font-weight: 700;
  margin: 0 0 0.5rem;
}

.yba-amenity-card p {
  margin: 0;
  font-size: 0.9rem;
  color: var(--yba-muted);
  line-height: 1.55;
}


/* ══════════════════════════════════
   QUOTE SIDE
   ══════════════════════════════════ */
.yba-quote-side {
  display: flex;
  gap: 1rem;
  padding: 1rem 0;
  margin: 1rem 0 1.5rem;
}

.yba-quote-bar {
  width: 3px;
  background: var(--yba-brand);
  border-radius: 2px;
  flex-shrink: 0;
}

.yba-quote-text {
  margin: 0;
  font-size: 0.92rem;
  color: var(--yba-muted);
  line-height: 1.6;
  font-style: italic;
}


/* ══════════════════════════════════
   FOOD STATS
   ══════════════════════════════════ */
.yba-food-stats {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1rem;
  margin-top: 1.5rem;
}

.yba-food-stat {
  text-align: center;
  background: var(--yba-bg-light);
  border-radius: 12px;
  padding: 1rem 0.5rem;
}

.yba-food-stat__number {
  display: block;
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--yba-brand);
  margin-bottom: 0.25rem;
}

.yba-food-stat__label {
  font-size: 0.78rem;
  color: var(--yba-muted);
  line-height: 1.35;
  font-weight: 600;
}


/* ══════════════════════════════════
   MAP
   ══════════════════════════════════ */
.yba-map-wrapper {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0;
  border-radius: 20px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,.1);
  box-shadow: 0 24px 60px rgba(0,0,0,.3);
}

@media (min-width: 800px) {
  .yba-map-wrapper { grid-template-columns: 1.3fr 1fr; }
}

.yba-map-container {
  min-height: 350px;
  background: #2a2a2a;
}

.yba-map-container iframe {
  width: 100%;
  height: 100%;
  min-height: 350px;
  display: block;
}

.yba-map-info {
  padding: 2rem;
  background: rgba(255,255,255,.06);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.yba-map-info h3 {
  font-size: 1.25rem;
  font-weight: 700;
  color: #fff;
  margin: 0 0 0.25rem;
}

.yba-map-address {
  color: var(--yba-brand-light);
  font-size: 0.9rem;
  font-weight: 600;
  margin: 0 0 1.5rem;
}

.yba-map-distances {
  display: grid;
  gap: 1rem;
}

.yba-map-distance {
  display: flex;
  gap: 0.75rem;
  align-items: flex-start;
}

.yba-map-distance__icon {
  font-size: 1.3rem;
  flex-shrink: 0;
  margin-top: 2px;
}

.yba-map-distance strong {
  display: block;
  color: #fff;
  font-size: 0.9rem;
  font-weight: 700;
}

.yba-map-distance p {
  margin: 0.15rem 0 0;
  color: rgba(255,255,255,.6);
  font-size: 0.82rem;
}


/* ══════════════════════════════════
   BUDGET TABLE
   ══════════════════════════════════ */
.yba-budget-table-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  border-radius: 16px;
  border: 1px solid var(--yba-border);
  background: #fff;
  box-shadow: 0 8px 32px rgba(0,0,0,.06);
}

.yba-budget-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 0.92rem;
}

.yba-budget-table thead {
  background: var(--yba-brand);
  color: #fff;
}

.yba-budget-table th {
  padding: 0.85rem 1.25rem;
  text-align: left;
  font-weight: 700;
  font-size: 0.85rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.yba-budget-table td {
  padding: 0.85rem 1.25rem;
  border-bottom: 1px solid var(--yba-bg-light);
  vertical-align: middle;
}

.yba-budget-table tbody tr:hover {
  background: rgba(247,92,3,.03);
}

.yba-budget-table__total {
  background: var(--yba-bg-light) !important;
}

.yba-budget-table__total td {
  border-bottom: none;
  font-size: 1rem;
}

.yba-budget-icon {
  margin-right: 0.5rem;
  font-size: 1.1rem;
}

/* Budget table mobile */
@media (max-width: 640px) {
  .yba-budget-table thead { display: none; }
  .yba-budget-table tr {
    display: block;
    padding: 1rem;
    border-bottom: 1px solid var(--yba-bg-light);
  }
  .yba-budget-table td {
    display: flex;
    justify-content: space-between;
    padding: 0.35rem 0;
    border-bottom: none;
  }
  .yba-budget-table td::before {
    content: attr(data-label);
    font-weight: 700;
    color: var(--yba-muted);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
}


/* ══════════════════════════════════
   BUDGET TIPS
   ══════════════════════════════════ */
.yba-budget-tips {
  margin-top: 2.5rem;
}

.yba-budget-tips h3 {
  text-align: center;
  font-size: 1.15rem;
  font-weight: 700;
  margin: 0 0 1.25rem;
}

.yba-budget-tips__grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1rem;
}

.yba-tip-card {
  background: var(--yba-bg-light);
  border-radius: 12px;
  padding: 1.25rem;
  display: flex;
  gap: 0.75rem;
  align-items: flex-start;
  transition: transform 0.15s;
}

.yba-tip-card:hover { transform: translateY(-2px); }

.yba-tip-card__icon {
  font-size: 1.5rem;
  flex-shrink: 0;
}

.yba-tip-card p {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.55;
  color: var(--yba-ink);
}

.yba-tip-card strong {
  display: block;
  margin-bottom: 0.2rem;
}


/* ══════════════════════════════════
   ALTERNATIVE ACCOMMODATION
   ══════════════════════════════════ */
.yba-alt-section {
  margin-bottom: 3rem;
}

.yba-alt-section:last-child { margin-bottom: 0; }

.yba-alt-section__desc {
  color: var(--yba-muted);
  font-size: 0.92rem;
  line-height: 1.6;
  margin: 0 0 1.25rem;
  max-width: 60ch;
}

/* Hotel Cards */
.yba-hotel-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.25rem;
}

.yba-hotel-card {
  background: #fff;
  border: 1px solid var(--yba-border);
  border-radius: 16px;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
}

.yba-hotel-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(0,0,0,.08);
}

.yba-hotel-card__img {
  aspect-ratio: 3/2;
  background: var(--yba-bg-light);
  overflow: hidden;
}

.yba-hotel-card__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.yba-hotel-card__body {
  padding: 1.25rem;
}

.yba-hotel-card__body h4 {
  font-size: 1.05rem;
  font-weight: 700;
  margin: 0.5rem 0;
}

.yba-hotel-card__body p {
  font-size: 0.88rem;
  color: var(--yba-muted);
  line-height: 1.55;
  margin: 0 0 0.75rem;
}

.yba-hotel-card__meta {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 0.75rem;
}

.yba-hotel-card__meta span {
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--yba-ink);
  background: var(--yba-bg-light);
  padding: 0.3rem 0.6rem;
  border-radius: 6px;
}

/* Badge */
.yba-badge {
  display: inline-block;
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 0.3rem 0.65rem;
  border-radius: 999px;
}

.yba-badge--primary {
  background: var(--yba-brand);
  color: #fff;
}

.yba-badge--outline {
  background: transparent;
  border: 1px solid var(--yba-border);
  color: var(--yba-muted);
}

/* Link Arrow */
.yba-link {
  color: var(--yba-brand);
  font-weight: 700;
  font-size: 0.88rem;
  text-decoration: none;
  transition: color 0.15s;
}

.yba-link:hover { color: var(--yba-brand-dark); text-decoration: underline; }


/* Platform Cards */
.yba-platform-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 0.75rem;
}

.yba-platform-card {
  display: block;
  background: #fff;
  border: 1px solid var(--yba-border);
  border-radius: 12px;
  padding: 1.25rem;
  text-decoration: none;
  transition: border-color 0.15s, transform 0.15s, box-shadow 0.15s;
}

.yba-platform-card:hover {
  border-color: var(--yba-brand);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(247,92,3,.08);
}

.yba-platform-card strong {
  display: block;
  color: var(--yba-ink);
  font-size: 1rem;
  margin-bottom: 0.2rem;
}

.yba-platform-card p {
  margin: 0;
  color: var(--yba-muted);
  font-size: 0.82rem;
}


/* Coliving Cards */
.yba-coliving-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  gap: 1rem;
}

.yba-coliving-card {
  background: #fff;
  border: 1px solid var(--yba-border);
  border-radius: 16px;
  padding: 1.5rem;
  transition: transform 0.15s, box-shadow 0.15s;
}

.yba-coliving-card:hover {
  transform: translateY(-3px);
  box-shadow: 0 12px 36px rgba(0,0,0,.06);
}

.yba-coliving-card h4 {
  font-size: 1.05rem;
  font-weight: 700;
  margin: 0 0 0.5rem;
}

.yba-coliving-card p {
  font-size: 0.88rem;
  color: var(--yba-muted);
  line-height: 1.55;
  margin: 0 0 0.75rem;
}

.yba-coliving-card__price {
  font-size: 1rem;
  font-weight: 700;
  color: var(--yba-brand);
  margin-bottom: 0.5rem;
}


/* Facebook Groups */
.yba-fb-groups {
  display: grid;
  gap: 0.5rem;
  margin-bottom: 1rem;
}

.yba-fb-group {
  background: #fff;
  border: 1px solid var(--yba-border);
  border-radius: 12px;
  padding: 1rem 1.25rem;
  display: flex;
  flex-wrap: wrap;
  gap: 0.25rem 1rem;
  align-items: baseline;
}

.yba-fb-group strong {
  font-size: 0.95rem;
  color: var(--yba-ink);
}

.yba-fb-group p {
  margin: 0;
  font-size: 0.82rem;
  color: var(--yba-muted);
}

.yba-scam-warning {
  background: #fff5ef;
  border: 1px solid rgba(247,92,3,.25);
  border-radius: 12px;
  padding: 1rem 1.25rem;
  font-size: 0.88rem;
  color: var(--yba-ink);
  line-height: 1.55;
}

.yba-scam-warning strong {
  color: var(--yba-brand);
}


/* ══════════════════════════════════
   COURSE CARDS
   ══════════════════════════════════ */
.yba-course-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 1.25rem;
}

.yba-course-card {
  background: #fff;
  border: 1px solid var(--yba-border);
  border-radius: 16px;
  overflow: hidden;
  text-decoration: none;
  color: var(--yba-ink);
  transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  display: block;
}

.yba-course-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 20px 48px rgba(0,0,0,.10);
  border-color: var(--yba-brand);
}

.yba-course-card__img {
  aspect-ratio: 3/2;
  background: var(--yba-bg-light);
  overflow: hidden;
}

.yba-course-card__img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.yba-course-card__body {
  padding: 1.25rem;
}

.yba-course-card__body h3 {
  font-size: 1.15rem;
  font-weight: 700;
  margin: 0.5rem 0 0.5rem;
}

.yba-course-card__body p {
  font-size: 0.88rem;
  color: var(--yba-muted);
  line-height: 1.55;
  margin: 0 0 0.75rem;
}

.yba-course-card__link {
  color: var(--yba-brand);
  font-weight: 700;
  font-size: 0.9rem;
}


/* ══════════════════════════════════
   FAQ ACCORDION
   ══════════════════════════════════ */
.yba-faq-list {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.yba-faq-item {
  background: var(--yba-bg-light);
  border-radius: 12px;
  overflow: hidden;
  transition: box-shadow 0.2s;
}

.yba-faq-item:hover {
  box-shadow: 0 4px 16px rgba(0,0,0,.04);
}

.yba-faq-trigger {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 1.1rem 1.25rem;
  border: none;
  background: transparent;
  cursor: pointer;
  text-align: left;
  gap: 1rem;
  font-family: inherit;
}

.yba-faq-trigger span:first-child {
  font-weight: 700;
  font-size: 0.95rem;
  color: var(--yba-ink);
  line-height: 1.4;
}

.yba-faq-icon {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  border: 1.5px solid var(--yba-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  color: var(--yba-brand);
  flex-shrink: 0;
  transition: all 0.2s;
}

.yba-faq-item.is-open .yba-faq-icon {
  background: var(--yba-brand);
  color: #fff;
}

.yba-faq-body {
  padding: 0 1.25rem 1.1rem;
}

.yba-faq-body p {
  margin: 0;
  font-size: 0.9rem;
  color: var(--yba-muted);
  line-height: 1.65;
}

.yba-faq-body a {
  color: var(--yba-brand);
  font-weight: 600;
}


/* ══════════════════════════════════
   MOBILE TWEAKS
   ══════════════════════════════════ */
@media (max-width: 599px) {
  .yba-gallery__prev,
  .yba-gallery__next {
    width: 36px;
    height: 36px;
    font-size: 18px;
  }
  .yba-gallery__prev { left: 8px; }
  .yba-gallery__next { right: 8px; }

  .yba-food-stats {
    grid-template-columns: 1fr;
  }
}
</style>


<!-- ═══════════════════════════════════════════════════════════
     JAVASCRIPT — Galleries, Chips, FAQ Accordion
     ═══════════════════════════════════════════════════════════ -->
<script>
(function(){
  var galleryAriaPrefix = '{{ t.js_gallery_aria }}';

  /* ── Room Cards: Gallery ── */
  document.querySelectorAll('.yba-room-card').forEach(function(card) {
    /* Gallery */
    var gallery = card.querySelector('.yba-gallery');
    if (!gallery) return;

    var track = gallery.querySelector('.yba-gallery__track');
    var imgs = track ? Array.from(track.querySelectorAll('img')) : [];
    var prevBtn = gallery.querySelector('.yba-gallery__prev');
    var nextBtn = gallery.querySelector('.yba-gallery__next');
    var dotsWrap = gallery.querySelector('.yba-gallery__dots');

    if (imgs.length <= 1) return;

    var index = 0;

    var dots = imgs.map(function(_, i) {
      var d = document.createElement('button');
      d.type = 'button';
      d.className = 'yba-gallery__dot' + (i === 0 ? ' is-active' : '');
      d.setAttribute('aria-label', galleryAriaPrefix + ' ' + (i + 1));
      d.addEventListener('click', function() { goTo(i); });
      dotsWrap.appendChild(d);
      return d;
    });

    function goTo(n) {
      index = (n + imgs.length) % imgs.length;
      track.style.transform = 'translateX(-' + (index * 100) + '%)';
      dots.forEach(function(d, i) { d.classList.toggle('is-active', i === index); });
    }

    prevBtn.addEventListener('click', function(e) { e.preventDefault(); goTo(index - 1); });
    nextBtn.addEventListener('click', function(e) { e.preventDefault(); goTo(index + 1); });

    /* Touch/Swipe */
    var startX = 0, diffX = 0, dragging = false;
    gallery.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; diffX = 0; dragging = true; }, { passive: true });
    gallery.addEventListener('touchmove', function(e) { if (!dragging) return; diffX = e.touches[0].clientX - startX; }, { passive: true });
    gallery.addEventListener('touchend', function() { dragging = false; if (diffX < -40) goTo(index + 1); if (diffX > 40) goTo(index - 1); startX = diffX = 0; });

    /* Auto-advance */
    var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReduced) {
      var timer = setInterval(function() { goTo(index + 1); }, 5000);
      card.addEventListener('mouseenter', function() { clearInterval(timer); });
      card.addEventListener('mouseleave', function() { timer = setInterval(function() { goTo(index + 1); }, 5000); });
    }
  });


  /* ── FAQ Accordion ── */
  document.querySelectorAll('.yba-faq-trigger').forEach(function(trigger) {
    trigger.addEventListener('click', function() {
      var item = trigger.closest('.yba-faq-item');
      var body = item.querySelector('.yba-faq-body');
      var icon = trigger.querySelector('.yba-faq-icon');
      var isOpen = item.classList.contains('is-open');

      if (isOpen) {
        item.classList.remove('is-open');
        body.hidden = true;
        icon.textContent = '+';
        trigger.setAttribute('aria-expanded', 'false');
      } else {
        item.classList.add('is-open');
        body.hidden = false;
        icon.textContent = '\u00d7';
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });


  /* ── Smooth scroll for anchor links ── */
  document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.querySelector(a.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

})();
</script>
