{% set t = i18n.yogaphotography[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}
{% set mailto_book = "mailto:info@yogabible.dk?subject=Booking%20af%20yoga%20fotosession&body=Hej%20Yoga%20Bible%0A%0AJeg%20vil%20gerne%20booke%20en%20yoga%20fotosession.%0A%0ANavn:%0ATelefon:%0A%0A%C3%98nsket%20dato:%0ALokation:%0AKort%20beskrivelse:%0A%0AVenlig%20hilsen%0A" %}
{% set mailto_ask = "mailto:info@yogabible.dk?subject=Sp%C3%B8rgsm%C3%A5l%20til%20yoga%20fotosession&body=Hej%20Yoga%20Bible%0A%0AJeg%20har%20et%20sp%C3%B8rgsm%C3%A5l%20om%20yoga%20fotosession:%0A%0A" %}

{# ── Models data array for loop ── #}
{% set models = [
  { key: "anna",      variation: "a" },
  { key: "sita",      variation: "b" },
  { key: "kerti",     variation: "c" },
  { key: "eva",       variation: "c" },
  { key: "nanna",     variation: "a" },
  { key: "vanja",     variation: "b" },
  { key: "christina", variation: "b" },
  { key: "jana",      variation: "c" },
  { key: "ida",       variation: "a" },
  { key: "sophie",    variation: "a" },
  { key: "frederik",  variation: "b" }
] %}

<!-- FAQPage Schema (AEO — featured snippets for AI search) -->
<script type="application/ld+json">
{%- set _faqs = [
      [t.faq1_q, t.faq1_a],
      [t.faq2_q, t.faq2_a],
      [t.faq3_q, t.faq3_a],
      [t.faq4_q, t.faq4_a],
      [t.faq5_q, t.faq5_a],
      [t.faq6_q, t.faq6_a]
    ] -%}
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in _faqs %}
    {
      "@type": "Question",
      "name": {{ faq[0] | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq[1] | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

<!-- ═══════════════════════════════════════════════════════
     Hero
     ═══════════════════════════════════════════════════════ -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="{{ mailto_book }}" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════
     Purpose Statement (pitch text from old hero)
     ═══════════════════════════════════════════════════════ -->
<section class="yphoto-purpose">
  <div class="yphoto-purpose__inner yphoto-reveal">
    <p class="yphoto-purpose__text">{{ t.intro_pitch | safe }}</p>
    <div class="yphoto-purpose__meta">
      <span>{{ t.intro_meta1 }}</span>
      <span class="yphoto-purpose__dot" aria-hidden="true">&bull;</span>
      <span>{{ t.intro_meta2 }}</span>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════
     Session Details (light split)
     ═══════════════════════════════════════════════════════ -->
<section class="yphoto-session" aria-label="{{ t.session_kicker }}">
  <div class="yphoto-session__inner">
    <div class="yphoto-session__grid">
      {# IMAGE #}
      <figure class="yphoto-session__figure yphoto-reveal">
        <div class="yphoto-session__imgWrap">
          <img
            class="yphoto-session__img"
            src="{{ 'yoga-bible-DK/yogaphotography/session-hero' | cloudimg('w_1200,c_fill,g_auto') }}"
            alt="{{ t.session_img_alt }}"
            loading="lazy"
            decoding="async"
          />
          <figcaption class="yphoto-session__cap">
            <span class="yphoto-session__cap-pill">{{ t.session_img_pill }}</span>
            <span class="yphoto-session__cap-text">{{ t.session_img_loc }}</span>
          </figcaption>
        </div>
      </figure>
      {# COPY #}
      <div class="yphoto-session__copy yphoto-reveal">
        <div class="yphoto-session__top">
          <div class="yphoto-session__kicker">
            <span class="yphoto-session__kicker-dot" aria-hidden="true"></span>
            <span class="yphoto-session__kicker-text">{{ t.session_kicker }}</span>
          </div>
          <h2 class="yphoto-session__title">{{ t.session_title }}</h2>
          <p class="yphoto-session__lead">{{ t.session_lead }}</p>
          {# Highlights #}
          <div class="yphoto-session__highlights">
            <div class="yphoto-hl">
              <div class="yphoto-hl__top">
                <span class="yphoto-hl__tag">{{ t.session_hl1_tag }}</span>
                <span class="yphoto-hl__value">{{ t.session_hl1_val }}</span>
              </div>
              <p class="yphoto-hl__desc">{{ t.session_hl1_desc }}</p>
            </div>
            <div class="yphoto-hl">
              <div class="yphoto-hl__top">
                <span class="yphoto-hl__tag">{{ t.session_hl2_tag }}</span>
                <span class="yphoto-hl__value">{{ t.session_hl2_val }}</span>
              </div>
              <p class="yphoto-hl__desc">{{ t.session_hl2_desc }}</p>
            </div>
            <div class="yphoto-hl">
              <div class="yphoto-hl__top">
                <span class="yphoto-hl__tag">{{ t.session_hl3_tag }}</span>
                <span class="yphoto-hl__value">{{ t.session_hl3_val }}</span>
              </div>
              <p class="yphoto-hl__desc">{{ t.session_hl3_desc }}</p>
            </div>
          </div>
          {# List #}
          <div class="yphoto-session__list">
            <h3 class="yphoto-session__list-title">{{ t.session_list_title }}</h3>
            <ul class="yphoto-session__ul">
              <li>{{ t.session_list1 }}</li>
              <li>{{ t.session_list2 }}</li>
              <li>{{ t.session_list3 }}</li>
            </ul>
          </div>
        </div>
        <div class="yphoto-session__bottom">
          <div class="yphoto-session__ctaRow">
            <a class="yphoto-btn yphoto-btn--primary" href="{{ mailto_book }}">
              <span>{{ t.session_cta_book }}</span>
              <span class="yphoto-arrow" aria-hidden="true">&rarr;</span>
            </a>
            <a class="yphoto-btn yphoto-btn--secondary" href="{{ mailto_ask }}">{{ t.session_cta_ask }}</a>
          </div>
          <p class="yphoto-session__note">{{ t.session_note }}</p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════
     Prep Guide + FAQ (2 cards)
     ═══════════════════════════════════════════════════════ -->
<section class="yphoto-prepfaq" aria-label="{{ t.prep_title }}">
  <div class="yphoto-prepfaq__inner">
    <div class="yphoto-prepfaq__grid">

      {# CARD 1: PREP #}
      <article class="yphoto-card">
        <header class="yphoto-card__head">
          <div class="yphoto-kicker">
            <span class="yphoto-kicker__dot" aria-hidden="true"></span>
            <span class="yphoto-kicker__text">{{ t.prep_kicker }}</span>
          </div>
          <h2 class="yphoto-card__title">{{ t.prep_title }}</h2>
          <p class="yphoto-card__lede">{{ t.prep_lede }}</p>
        </header>
        <ul class="yphoto-prepList">
          {% for i in range(1, 7) %}
          <li class="yphoto-prepItem">
            <span class="yphoto-prepIcon" aria-hidden="true">{{ t["prep" + i + "_icon"] }}</span>
            <div class="yphoto-prepText">
              <strong>{{ t["prep" + i + "_title"] }}</strong>
              <span>{{ t["prep" + i + "_desc"] }}</span>
            </div>
          </li>
          {% endfor %}
        </ul>
        <div class="yphoto-card__foot">
          <a class="yphoto-btn yphoto-btn--primary" href="{{ mailto_book }}">
            {{ t.prep_cta }}
            <span class="yphoto-arrow" aria-hidden="true">&rarr;</span>
          </a>
          <p class="yphoto-note">{{ t.prep_note }}</p>
        </div>
      </article>

      {# CARD 2: FAQ #}
      <article class="yphoto-card">
        <header class="yphoto-card__head">
          <div class="yphoto-kicker">
            <span class="yphoto-kicker__dot" aria-hidden="true"></span>
            <span class="yphoto-kicker__text">{{ t.faq_kicker }}</span>
          </div>
          <h2 class="yphoto-card__title">{{ t.faq_title }}</h2>
          <p class="yphoto-card__lede">{{ t.faq_lede }}</p>
        </header>
        <div class="yphoto-faq" role="list">
          {% for i in range(1, 7) %}
          <details class="yphoto-faqItem" role="listitem">
            <summary class="yphoto-faqQ">{{ t["faq" + i + "_q"] }}</summary>
            <div class="yphoto-faqA">{{ t["faq" + i + "_a"] | safe }}</div>
          </details>
          {% endfor %}
        </div>
        <div class="yphoto-card__foot yphoto-card__foot--split">
          <a class="yphoto-btn yphoto-btn--ghost" href="{{ mailto_ask }}">{{ t.faq_cta_ask }}</a>
          <a class="yphoto-btn yphoto-btn--primary" href="{{ mailto_book }}">
            {{ t.faq_cta_book }}
            <span class="yphoto-arrow" aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </article>

    </div>
  </div>
</section>


