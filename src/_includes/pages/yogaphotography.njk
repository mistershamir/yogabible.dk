{# ── Model Card ── #}
{% set mk = m.key %}
{% set mname = t["model_" + mk + "_name"] %}
{% set mbio = t["model_" + mk + "_bio"] %}
{% set mig = t["model_" + mk + "_ig"] %}

<section class="yphoto-model yphoto-model--{{ m.variation }}" aria-label="{{ mname }}">
  <div class="yphoto-model__inner yphoto-reveal">
    <div class="yphoto-model__intro">
      <div class="yphoto-model__portrait">
        {# CLOUDINARY: yoga-bible-DK/yogaphotography/models/{{mk}}-portrait.jpg — 520x680 portrait #}
        <img
          src="{{ ('yoga-bible-DK/yogaphotography/models/' + mk + '-portrait') | cloudimg('w_520,h_680,c_fill') }}"
          alt="{{ mname }}"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="yphoto-model__info">
        <p class="yphoto-model__eyebrow">Yoga Bible Model</p>
        <h3 class="yphoto-model__name">{{ mname }}</h3>
        <p class="yphoto-model__bio">{{ mbio }}</p>
        {% if mig %}
        <div class="yphoto-model__links">
          <a href="https://instagram.com/{{ mig | replace('@', '') }}" target="_blank" rel="noopener">{{ mig }}</a>
        </div>
        {% endif %}
      </div>
    </div>
    <div class="yphoto-model__gallery">
      <div class="yphoto-model__photo yphoto-model__photo--1">
        <img src="{{ ('yoga-bible-DK/yogaphotography/models/' + mk + '-1') | cloudimg('w_800,h_600,c_fill') }}" alt="{{ mname }} — Yoga Photography" loading="lazy" decoding="async" />
      </div>
      <div class="yphoto-model__photo yphoto-model__photo--2">
        <img src="{{ ('yoga-bible-DK/yogaphotography/models/' + mk + '-2') | cloudimg('w_600,h_800,c_fill') }}" alt="{{ mname }} — Yoga Photography" loading="lazy" decoding="async" />
      </div>
      <div class="yphoto-model__photo yphoto-model__photo--3">
        <img src="{{ ('yoga-bible-DK/yogaphotography/models/' + mk + '-3') | cloudimg('w_700,h_500,c_fill') }}" alt="{{ mname }} — Yoga Photography" loading="lazy" decoding="async" />
      </div>
    </div>
  </div>
</section>

{% endfor %}


<!-- ═══════════════════════════════════════════════════════
