          <span class="yphoto-kicker__text">{{ t.quote1_kicker }}</span>
        </div>
        <h2 class="yphoto-quote__headline">{{ t.quote1_text }}</h2>
        <a class="yphoto-btn yphoto-btn--primary" href="{{ mailto_book }}">
          <span>{{ t.quote1_cta }}</span>
          <span class="yphoto-arrow" aria-hidden="true">&rarr;</span>
        </a>
        <div class="yphoto-quote__micro">{{ t.quote1_micro }}</div>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════
