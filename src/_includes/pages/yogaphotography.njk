{# ── Model Card ── #}
{% set mk = m.key %}
{% set mname = t["model_" + mk + "_name"] %}
{% set mbio = t["model_" + mk + "_bio"] %}
{% set mig = t["model_" + mk + "_ig"] %}

<section class="yphoto-model yphoto-model--{{ m.variation }}" aria-label="{{ mname }}">
  <div class="yphoto-model__inner yphoto-reveal">
    <div class="yphoto-model__intro">
      {# Portrait — use override or default path, no forced crop #}
      {% set portrait_src = m.img_p if m.img_p else ('yoga-bible-DK/yogaphotography/models/' + m.folder + '/' + mk + '-portrait') %}
      <div class="yphoto-model__portrait">
        <img
          src="{{ portrait_src | cloudimg('w_520,c_scale') }}"
          alt="{{ mname }}"
          loading="lazy"
          decoding="async"
        />
      </div>
      <div class="yphoto-model__info">
        <p class="yphoto-model__eyebrow">Yoga Bible Model</p>
        <h3 class="yphoto-model__name">{{ mname }}</h3>
        <p class="yphoto-model__bio">{{ mbio }}</p>
        {% if mig %}
        <div class="yphoto-model__links">
          <a href="https://instagram.com/{{ mig | replace('@', '') }}" target="_blank" rel="noopener">{{ mig }}</a>
        </div>
        {% endif %}
      </div>
    </div>
    {# Gallery — use overrides or default paths, no forced crop #}
    {% set g1 = m.img_1 if m.img_1 else ('yoga-bible-DK/yogaphotography/models/' + m.folder + '/' + mk + '-1') %}
    {% set g2 = m.img_2 if m.img_2 else ('yoga-bible-DK/yogaphotography/models/' + m.folder + '/' + mk + '-2') %}
    {% set g3 = m.img_3 if m.img_3 else ('yoga-bible-DK/yogaphotography/models/' + m.folder + '/' + mk + '-3') %}
    <div class="yphoto-model__gallery">
      <div class="yphoto-model__photo yphoto-model__photo--1">
        <img src="{{ g1 | cloudimg('w_800,c_scale') }}" alt="{{ mname }} — Yoga Photography" loading="lazy" decoding="async" />
      </div>
      <div class="yphoto-model__photo yphoto-model__photo--2">
        <img src="{{ g2 | cloudimg('w_600,c_scale') }}" alt="{{ mname }} — Yoga Photography" loading="lazy" decoding="async" />
      </div>
      <div class="yphoto-model__photo yphoto-model__photo--3">
        <img src="{{ g3 | cloudimg('w_700,c_scale') }}" alt="{{ mname }} — Yoga Photography" loading="lazy" decoding="async" />
      </div>
    </div>
  </div>
</section>

{% endfor %}


<!-- ═══════════════════════════════════════════════════════
     Final CTA
     ═══════════════════════════════════════════════════════ -->
<section class="cta-section">
  <div class="container">
    <h2 class="cta-section__title">{{ t.cta_title }}</h2>
    <p class="cta-section__text">{{ t.cta_text }}</p>
    <button class="btn btn--large btn--primary" data-open-photo-booking>{{ t.cta_btn }}</button>
  </div>
</section>


<!-- Scroll Reveal Observer -->
<script>
(function(){
  var els = document.querySelectorAll('.yphoto-reveal');
  if (!els.length) return;
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(e){
      if (e.isIntersecting) {
        e.target.classList.add('is-visible');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.15 });
  els.forEach(function(el){ io.observe(el); });
})();
</script>
