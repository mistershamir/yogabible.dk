{% set t = i18n.yogaphotography[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}
{# Photo booking now uses the request modal instead of mailto #}
{% set mailto_ask = "mailto:info@yogabible.dk?subject=Sp%C3%B8rgsm%C3%A5l%20til%20yoga%20fotosession&body=Hej%20Yoga%20Bible%0A%0AJeg%20har%20et%20sp%C3%B8rgsm%C3%A5l%20om%20yoga%20fotosession:%0A%0A" %}

{# ── Models data array for loop ── #}
{# imgBase = Bunny CDN folder for each model. Images: {key}-portrait, {key}-1, {key}-2, {key}-3
   OR override with img_p / img_1 / img_2 / img_3 for custom Bunny paths #}
{% set models = [
  { key: "anna",      folder: "Anna",      variation: "a",
    img_p: "DSC_6049_qx8dow",
    img_1: "DSC_6430_mwuxlj",
    img_2: "Inversion_Course_Kursus_K%C3%B8benhavn_l%C3%A6re_fi9ik3",
    img_3: "DSC_6263_u780xe" },
  { key: "sita",      folder: "Sita",      variation: "b" },
  { key: "kerti",     folder: "Kerti",     variation: "c" },
  { key: "eva",       folder: "Eva",       variation: "c" },
  { key: "nanna",     folder: "Nanna",     variation: "a" },
  { key: "vanja",     folder: "Vanja",     variation: "b" },
  { key: "christina", folder: "Christina", variation: "b" },
  { key: "jana",      folder: "Jana",      variation: "c" },
  { key: "ida",       folder: "Ida",       variation: "a" },
  { key: "sophie",    folder: "Sophie",    variation: "a" },
  { key: "frederik",  folder: "Frederik",  variation: "b" }
] %}

<!-- FAQPage Schema (AEO — featured snippets for AI search) -->
<script type="application/ld+json">
{%- set _faqs = [
      [t.faq1_q, t.faq1_a],
      [t.faq2_q, t.faq2_a],
      [t.faq3_q, t.faq3_a],
      [t.faq4_q, t.faq4_a],
      [t.faq5_q, t.faq5_a],
      [t.faq6_q, t.faq6_a]
    ] -%}
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in _faqs %}
    {
      "@type": "Question",
      "name": {{ faq[0] | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq[1] | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>

<!-- ═══════════════════════════════════════════════════════
     Hero
     ═══════════════════════════════════════════════════════ -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <button class="yb-btn yb-btn--primary yb-btn--large" data-open-photo-booking>{{ t.hero_cta }}</button>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════
     Purpose Statement
     ═══════════════════════════════════════════════════════ -->
<section class="yphoto-purpose">
  <div class="yphoto-purpose__inner yphoto-reveal">
    <p class="yphoto-purpose__text">{{ t.intro_pitch | safe }}</p>
    <div class="yphoto-purpose__meta">
      <span>{{ t.intro_meta1 }}</span>
      <span class="yphoto-purpose__dot" aria-hidden="true">&bull;</span>
      <span>{{ t.intro_meta2 }}</span>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════
     Session Details — design system split layout
     ═══════════════════════════════════════════════════════ -->
<section class="yphoto-session" aria-label="{{ t.session_kicker }}">
  <div class="yphoto-session__wrap">
    <div class="yphoto-session__grid">

      {# IMAGE SIDE #}
      <div class="yphoto-session__media yphoto-reveal">
        {# CLOUDINARY: yoga-bible-DK/yogaphotography/session-hero.jpg — portrait, studio yoga #}
        <img
          class="yphoto-session__img"
          src="{{ 'yoga-bible-DK/yogaphotography/session-hero' | cloudimg('w_1200,c_fill,g_auto') }}"
          alt="{{ t.session_img_alt }}"
          loading="lazy"
          decoding="async"
        />
        <div class="yphoto-session__badge">
          <span class="yphoto-session__badge-pill">{{ t.session_img_pill }}</span>
          <span class="yphoto-session__badge-loc">{{ t.session_img_loc }}</span>
        </div>
      </div>

      {# CONTENT SIDE #}
      <div class="yphoto-session__content yphoto-reveal">
        <div class="yphoto-session__eyebrow">
          <span class="yphoto-session__eyebrow-dot" aria-hidden="true"></span>
          <span>{{ t.session_kicker }}</span>
        </div>
        <h2 class="yphoto-session__title">{{ t.session_title }}</h2>
        <p class="yphoto-session__lead">{{ t.session_lead }}</p>

        {# Highlight cards — Duration / Delivery / Price #}
        <div class="yphoto-session__highlights">
          {% for i in range(1, 4) %}
          <div class="yphoto-session__hl">
            <div class="yphoto-session__hl-row">
              <span class="yphoto-session__hl-tag">{{ t["session_hl" + i + "_tag"] }}</span>
              <span class="yphoto-session__hl-val">{{ t["session_hl" + i + "_val"] }}</span>
            </div>
            <p class="yphoto-session__hl-desc">{{ t["session_hl" + i + "_desc"] }}</p>
          </div>
          {% endfor %}
        </div>

        {# Feature list — design system checkmark list #}
        <div class="yphoto-session__features">
          <h3 class="yphoto-session__features-title">{{ t.session_list_title }}</h3>
          <ul class="yphoto-session__list">
            <li>{{ t.session_list1 }}</li>
            <li>{{ t.session_list2 }}</li>
            <li>{{ t.session_list3 }}</li>
          </ul>
        </div>

        {# CTA row #}
        <div class="yphoto-session__ctas">
          <button class="yb-btn yb-btn--primary" data-open-photo-booking>{{ t.session_cta_book }}</button>
          <a class="yb-btn yb-btn--outline" href="{{ mailto_ask }}">{{ t.session_cta_ask }}</a>
        </div>
        <p class="yphoto-session__note">{{ t.session_note }}</p>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════
     Prep Guide + FAQ — two side-by-side cards
     ═══════════════════════════════════════════════════════ -->
<section class="yphoto-prepfaq" aria-label="{{ t.prep_title }}">
  <div class="yphoto-prepfaq__wrap">
    <div class="yphoto-prepfaq__grid">

      {# CARD 1: PREP GUIDE #}
      <div class="yphoto-prepfaq__card yphoto-reveal">
        <div class="yphoto-prepfaq__card-head">
          <div class="yphoto-prepfaq__eyebrow">
            <span class="yphoto-prepfaq__eyebrow-dot" aria-hidden="true"></span>
            <span>{{ t.prep_kicker }}</span>
          </div>
          <h2 class="yphoto-prepfaq__card-title">{{ t.prep_title }}</h2>
          <p class="yphoto-prepfaq__card-desc">{{ t.prep_lede }}</p>
        </div>

        <ul class="yphoto-prep__list">
          {% for i in range(1, 7) %}
          <li class="yphoto-prep__item">
            <span class="yphoto-prep__icon" aria-hidden="true">{{ t["prep" + i + "_icon"] }}</span>
            <div class="yphoto-prep__text">
              <strong class="yphoto-prep__label">{{ t["prep" + i + "_title"] }}</strong>
              <p class="yphoto-prep__desc">{{ t["prep" + i + "_desc"] }}</p>
            </div>
          </li>
          {% endfor %}
        </ul>

        <div class="yphoto-prepfaq__card-foot">
          <button class="yb-btn yb-btn--primary" data-open-photo-booking>{{ t.prep_cta }}</button>
          <p class="yphoto-prepfaq__note">{{ t.prep_note }}</p>
        </div>
      </div>

      {# CARD 2: FAQ — design system accordion pattern #}
      <div class="yphoto-prepfaq__card yphoto-reveal">
        <div class="yphoto-prepfaq__card-head">
          <div class="yphoto-prepfaq__eyebrow">
            <span class="yphoto-prepfaq__eyebrow-dot" aria-hidden="true"></span>
            <span>{{ t.faq_kicker }}</span>
          </div>
          <h2 class="yphoto-prepfaq__card-title">{{ t.faq_title }}</h2>
          <p class="yphoto-prepfaq__card-desc">{{ t.faq_lede }}</p>
        </div>

        <div class="yphoto-faq__list" role="list">
          {% for i in range(1, 7) %}
          <div class="yphoto-faq__item" role="listitem">
            <button class="yphoto-faq__toggle" aria-expanded="false" onclick="this.setAttribute('aria-expanded', this.getAttribute('aria-expanded') === 'true' ? 'false' : 'true'); this.closest('.yphoto-faq__item').classList.toggle('is-open');">
              <span>{{ t["faq" + i + "_q"] }}</span>
              <span class="yphoto-faq__icon" aria-hidden="true"></span>
            </button>
            <div class="yphoto-faq__panel">
              <p>{{ t["faq" + i + "_a"] | safe }}</p>
            </div>
          </div>
          {% endfor %}
        </div>

        <div class="yphoto-prepfaq__card-foot yphoto-prepfaq__card-foot--split">
          <a class="yb-btn yb-btn--ghost" href="{{ mailto_ask }}">{{ t.faq_cta_ask }}</a>
          <button class="yb-btn yb-btn--primary" data-open-photo-booking>{{ t.faq_cta_book }}</button>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════
     Big Photo + Quote — full-height portrait
     ═══════════════════════════════════════════════════════ -->
<section class="yphoto-quote" aria-label="{{ t.quote1_kicker }}">
  <div class="yphoto-quote__wrap yphoto-reveal">
    {# CLOUDINARY: yoga-bible-DK/yogaphotography/quote-hero.jpg — tall portrait, 1159x2048 #}
    <img
      class="yphoto-quote__img"
      src="{{ 'yoga-bible-DK/yogaphotography/quote-hero' | cloudimg('w_1400,c_fill,g_auto') }}"
      alt="Yoga Photography — Yoga Bible"
      loading="lazy"
      decoding="async"
    />
    <div class="yphoto-quote__overlay">
      <div class="yphoto-quote__glass yphoto-reveal yphoto-delay-2">
        <div class="yphoto-quote__bar" aria-hidden="true"></div>
        <div class="yphoto-quote__eyebrow">
          <span class="yphoto-quote__eyebrow-dot" aria-hidden="true"></span>
          <span>{{ t.quote1_kicker }}</span>
        </div>
        <h2 class="yphoto-quote__headline">{{ t.quote1_text }}</h2>
        <button class="yb-btn yb-btn--primary" data-open-photo-booking>{{ t.quote1_cta }}</button>
        <p class="yphoto-quote__micro">{{ t.quote1_micro }}</p>
      </div>
    </div>
  </div>
</section>


<!-- ═══════════════════════════════════════════════════════
     Models Header
     ═══════════════════════════════════════════════════════ -->
<section class="yphoto-models-header">
  <div class="yphoto-models-header__inner yphoto-reveal">
    <p class="yphoto-models-header__eyebrow">{{ t.models_eyebrow }}</p>
    <h2 class="yphoto-models-header__title">{{ t.models_title }}</h2>
    <p class="yphoto-models-header__subtitle">{{ t.models_subtitle }}</p>
  </div>
</section>


