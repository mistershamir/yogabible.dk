{% set t = i18n.concepts[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

{# ═══════════════════════════════════════════
   HERO — Dark Cinematic
   ═══════════════════════════════════════════ #}
<section class="yb-k-hero">
  <div class="yb-k-hero__bg">
    <img src="/assets/images/concepts/hero-bg.jpg" alt="" loading="eager" />
  </div>
  <div class="yb-k-hero__glow"></div>
  <div class="container">
    <p class="yb-k-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-k-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-k-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-k-hero__line"></div>
    <div class="yb-k-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-k-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-k-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
      <span class="yb-k-hero__trust-dot"></span>
      <span>{{ t.hero_trust4 }}</span>
    </div>
  </div>
  <div class="yb-k-hero__scroll">
    <span>Scroll</span>
    <div class="yb-k-hero__scroll-line"></div>
  </div>
</section>

{# ═══════════════════════════════════════════
   INTRO
   ═══════════════════════════════════════════ #}
<section class="yb-k-intro">
  <div class="container">
    <p class="yb-k-intro__text">{{ t.intro_text }}</p>
    <p class="yb-k-intro__text yb-k-intro__text--secondary">{{ t.intro_text2 }}</p>
  </div>
</section>

{# ═══════════════════════════════════════════════════════
   BRAND 1: HOT YOGA COPENHAGEN
   Orange primary + #3f99a5 teal accent
   ═══════════════════════════════════════════════════════ #}

{# ── Hot Yoga: Brand Hero ── #}
<section class="yb-k-brand-hero yb-k-brand-hero--hy" id="hotyoga">
  <div class="container">
    <div class="yb-k-brand-hero__inner">
      <div class="yb-k-brand-hero__content">
        <div class="yb-k-brand-hero__badge yb-k-brand-hero__badge--hy">{{ t.hy_badge }}</div>
        <h2 class="yb-k-brand-hero__title">{{ t.hy_title }}</h2>
        <p class="yb-k-brand-hero__subtitle">{{ t.hy_subtitle }}</p>
        <p class="yb-k-brand-hero__text">{{ t.hy_intro }}</p>
        <p class="yb-k-brand-hero__text">{{ t.hy_intro2 }}</p>
      </div>
      <div class="yb-k-brand-hero__image">
        {% cldimg "v1772433753/hyc_logo_hero_concepts_sumzwc", "Hot Yoga Copenhagen Logo", "w_800,c_scale", "800", "600" %}
      </div>
    </div>
    <div class="yb-k-stats yb-k-stats--hy">
      <div class="yb-k-stats__item">
        <span class="yb-k-stats__num">{{ t.hy_stat1_num }}</span>
        <span class="yb-k-stats__label">{{ t.hy_stat1_label }}</span>
      </div>
      <div class="yb-k-stats__item">
        <span class="yb-k-stats__num">{{ t.hy_stat2_num }}</span>
        <span class="yb-k-stats__label">{{ t.hy_stat2_label }}</span>
      </div>
      <div class="yb-k-stats__item">
        <span class="yb-k-stats__num">{{ t.hy_stat3_num }}</span>
        <span class="yb-k-stats__label">{{ t.hy_stat3_label }}</span>
      </div>
      <div class="yb-k-stats__item">
        <span class="yb-k-stats__num">{{ t.hy_stat4_num }}</span>
        <span class="yb-k-stats__label">{{ t.hy_stat4_label }}</span>
      </div>
    </div>
  </div>
</section>

{# ── Hot Yoga: Infrared Technology ── #}
<section class="yb-k-split yb-k-split--hy">
  <div class="container">
    <div class="yb-k-split__inner yb-k-split__inner--reverse">
      <div class="yb-k-split__media">
        {% cldimg "v1772433754/infrared_k3a1xv", "Infrared Technology", "w_900,h_650,c_fill", "700", "500" %}
      </div>
      <div class="yb-k-split__content">
        <h3 class="yb-k-split__title yb-k-split__title--hy">{{ t.hy_ir_title }}</h3>
        <p class="yb-k-split__text">{{ t.hy_ir_desc }}</p>
      </div>
    </div>
  </div>
</section>

