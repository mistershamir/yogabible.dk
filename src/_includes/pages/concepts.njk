{# ── Hot Yoga: Video + CTA ── #}
<section class="yb-k-video">
  <div class="container">
    <div class="yb-k-video__wrap yb-k-video__wrap--hy">
      <video controls playsinline preload="metadata" poster="/assets/images/concepts/hotyoga-hero.jpg">
        <source src="/assets/images/concepts/hotyoga-video.mp4" type="video/mp4" />
      </video>
    </div>
    <div class="yb-k-video__cta">
      <a href="https://www.hotyogacph.dk" target="_blank" rel="noopener" class="btn btn--large yb-k-btn--hy">{{ t.hy_visit }}</a>
    </div>
  </div>
</section>

{# ── Brand Divider ── #}
<div class="yb-k-divider">
  <div class="yb-k-divider__line"></div>
</div>

