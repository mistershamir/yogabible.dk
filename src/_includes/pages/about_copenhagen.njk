{% set t = i18n.about_copenhagen[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

{# ── FAQPage Structured Data (SEO / AEO) ── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for i in range(1, 13) %}
    {
      "@type": "Question",
      "name": {{ t["faq" + i + "_q"] | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ t["faq" + i + "_a"] | dump | safe }}
      }
    }{% if i < 12 %},{% endif %}
    {% endfor %}
  ]
}
</script>


{# ════════════════════════════════════════════════════════════════════
   SECTION 0 — HERO (Video background)
   Adopted from main — yb-hero with looping video
   ════════════════════════════════════════════════════════════════════ #}
<section class="yb-hero">
  <div class="yb-hero__bg">
    <video autoplay muted loop playsinline preload="auto" aria-hidden="true"
      poster="{{ "yoga-bible-DK/copenhagen/about-copenhagen-hero-loop.jpg" | cloudvid("w_1920,c_fill,so_0,q_60") }}">
      <source src="{{ "yoga-bible-DK/copenhagen/about-copenhagen-hero-loop" | cloudvid("w_1920,q_auto") }}" type="video/mp4">
    </video>
  </div>
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="{% if lang == 'en' %}/en/apply{% else %}/apply{% endif %}" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta_apply }}</a>
      <a href="#life-in-copenhagen" class="yb-btn yb-btn--outline-white yb-btn--large">{{ t.hero_cta_explore }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>


{# ════════════════════════════════════════════════════════════════════
   SECTION 1 — LIFE IN COPENHAGEN
   4-column image card grid with gradient overlays
   ════════════════════════════════════════════════════════════════════ #}
