          {# UK & Ireland #}
          <path class="yb-cph-flights-svg__land" d="M148,125 C145,118 150,108 158,105 C165,102 168,110 172,115 C178,122 175,132 168,138 C160,145 152,140 148,132 Z M128,118 C125,112 130,105 138,108 C142,110 140,118 135,120 Z" stroke="#E8E4E0" stroke-width="1.2"/>

          {# Scandinavia #}
