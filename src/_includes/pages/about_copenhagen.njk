<!-- The Studio -->
<section class="program-overview">
  <div class="container">
    <h2 class="section-title">{{ t.studio_title }}</h2>
    <p class="section-subtitle">{{ t.studio_subtitle }}</p>

    <div class="program-grid" style="max-width:800px; margin:0 auto;">
      <div class="program-feature">
        <img src="/assets/images/studio/studio-hot-room.jpg" alt="{{ t.studio_hot_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <h3>{{ t.studio_hot_title }}</h3>
        <p>{{ t.studio_hot_desc }}</p>
      </div>
      <div class="program-feature">
        <img src="/assets/images/studio/studio-main-room.jpg" alt="{{ t.studio_main_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <h3>{{ t.studio_main_title }}</h3>
        <p>{{ t.studio_main_desc }}</p>
      </div>
    </div>
  </div>
</section>

