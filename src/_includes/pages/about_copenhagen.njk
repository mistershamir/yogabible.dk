      <p class="yb-cph-section-subtitle">{{ t.life_subtitle }}</p>
    </div>

    <div class="yb-cph-life__grid">
      {# Card 1: Bike Culture #}
      <div class="yb-cph-life__card">
        <div class="yb-cph-life__card-img">
          {% cldimg media.copenhagen.bikeCulture, t.life1_img_alt, "w_600,h_400,c_fill", "600", "400" %}
        </div>
        <div class="yb-cph-life__card-overlay">
          <h3 class="yb-cph-life__card-title">{{ t.life1_title }}</h3>
          <p class="yb-cph-life__card-desc">{{ t.life1_desc }}</p>
        </div>
      </div>

      {# Card 2: Cafe Scene #}
      <div class="yb-cph-life__card">
