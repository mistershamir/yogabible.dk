          {# Iberian Peninsula #}
          <path d="M168,332 L160,336 L152,342 L146,348 L140,356 L136,364 L134,372 L138,380 L144,386 L150,390 L158,392 L166,388 L174,382 L182,376 L190,372 L198,368 L206,362 L212,356 L218,350 L224,344 L228,336 L232,328 L234,320 L232,314 L228,308" fill="#F5F3F0" stroke="#E0DCD8" stroke-width="1.2" stroke-linejoin="round"/>

