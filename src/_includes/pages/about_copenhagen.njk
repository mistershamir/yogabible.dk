{# ════════════════════════════════════════════════════════════════════
   SECTION 2 — CHRISTIANSHAVN (Our Location)
   Split layout: video left, text right. Blockquote, pills, gallery.
   ════════════════════════════════════════════════════════════════════ #}
<section class="yb-cph-location">
  <div class="yb-cph-inner">
    <div class="yb-cph-location__header">
      <span class="yb-cph-eyebrow">{{ t.location_eyebrow }}</span>
      <h2 class="yb-cph-section-title">{{ t.location_title }}</h2>
      <p class="yb-cph-section-subtitle">{{ t.location_subtitle }}</p>
    </div>

    <div class="yb-cph-location__content">
      <div class="yb-cph-location__video-wrap">
        {# BUNNY: yoga-bible-DK/copenhagen/christianshavn-neighborhood-walkthrough — vertical video, 9:16 or 4:5 #}
        {% cldvid media.copenhagen.locationVideo, media.copenhagen.canalPanorama, "w_600" %}
      </div>
      <div class="yb-cph-location__text">
        <h3 class="yb-cph-location__text-title">{{ t.location_text_title }}</h3>
        <p>{{ t.location_text1 }}</p>
        <p>{{ t.location_text2 }}</p>
        <blockquote class="yb-cph-location__highlight">
          {{ t.location_blockquote }}
        </blockquote>
        <p>{{ t.location_text3 }}</p>
        <div class="yb-cph-location__pills">
          {% for pill in [t.loc_pill1, t.loc_pill2, t.loc_pill3, t.loc_pill4, t.loc_pill5] %}
          <span class="yb-cph-location__pill">{{ pill }}</span>
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="yb-cph-location__gallery">
      <div class="yb-cph-location__gallery-img">
        {% cldimg media.copenhagen.locationGallery1, t.loc_gallery1_alt, "w_400,h_300,c_fill", "400", "300" %}
      </div>
      <div class="yb-cph-location__gallery-img">
        {% cldimg media.copenhagen.locationGallery2, t.loc_gallery2_alt, "w_400,h_300,c_fill", "400", "300" %}
      </div>
      <div class="yb-cph-location__gallery-img">
        {% cldimg media.copenhagen.locationGallery3, t.loc_gallery3_alt, "w_400,h_300,c_fill", "400", "300" %}
      </div>
    </div>
  </div>
</section>


{# ════════════════════════════════════════════════════════════════════
   SECTION 3 — WHY COPENHAGEN FOR YTT
   Benefits cards left, media right. Flight connections box.
   ════════════════════════════════════════════════════════════════════ #}
<section class="yb-cph-why">
  <div class="yb-cph-inner">
    <div class="yb-cph-why__header">
      <span class="yb-cph-eyebrow">{{ t.why_eyebrow }}</span>
      <h2 class="yb-cph-section-title">{{ t.why_title }}</h2>
      <p class="yb-cph-section-subtitle">{{ t.why_subtitle }}</p>
    </div>

    <div class="yb-cph-why__content">
      <div class="yb-cph-why__benefits">
        <div class="yb-cph-why__benefit">
          <h3 class="yb-cph-why__benefit-title">
            <span class="yb-cph-why__benefit-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="10" r="3"/><path d="M12 2a8 8 0 0 0-8 8c0 5.4 7 12 8 12s8-6.6 8-12a8 8 0 0 0-8-8z"/></svg></span>
            {{ t.why1_title }}
          </h3>
          <p class="yb-cph-why__benefit-desc">{{ t.why1_desc }}</p>
        </div>
        <div class="yb-cph-why__benefit">
          <h3 class="yb-cph-why__benefit-title">
            <span class="yb-cph-why__benefit-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 10 3 12 0v-5"/></svg></span>
            {{ t.why2_title }}
          </h3>
          <p class="yb-cph-why__benefit-desc">{{ t.why2_desc }}</p>
        </div>
        <div class="yb-cph-why__benefit">
          <h3 class="yb-cph-why__benefit-title">
            <span class="yb-cph-why__benefit-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg></span>
            {{ t.why3_title }}
          </h3>
          <p class="yb-cph-why__benefit-desc">{{ t.why3_desc }}</p>
        </div>
        <div class="yb-cph-why__benefit">
          <h3 class="yb-cph-why__benefit-title">
