{% set t = i18n.about_copenhagen[lang or "da"] %}

<!-- Hero -->
<section class="program-hero">
  <div class="container">
    <div class="program-hero__badge">{{ t.hero_badge }}</div>
    <h1 class="program-hero__title">{{ t.hero_title }}</h1>
    <p class="program-hero__subtitle">
      {{ t.hero_subtitle }}
    </p>

    <div class="program-hero__cta">
      <a href="{% if lang == 'en' %}/en/apply{% else %}/apply{% endif %}" class="btn btn--large btn--primary">{{ t.hero_cta_apply }}</a>
      <a href="#life-in-copenhagen" class="btn btn--large btn--secondary">{{ t.hero_cta_explore }}</a>
    </div>
  </div>
</section>

<!-- Hero Image -->
<section class="program-overview" style="padding-top:0;">
  <div class="container">
    <img src="/assets/images/copenhagen/copenhagen-hero.jpg" alt="{{ t.hero_img_alt }}" style="width:100%; border-radius:12px; aspect-ratio:7/3; object-fit:cover; background:#f5f3f0;" loading="lazy">
  </div>
</section>

<!-- Life in Copenhagen -->
<section class="program-overview" id="life-in-copenhagen">
  <div class="container">
    <h2 class="section-title">{{ t.life_title }}</h2>
    <p class="section-subtitle">{{ t.life_subtitle }}</p>

    <div class="program-grid">
      <div class="program-feature">
        <div class="program-feature__icon">🚲</div>
        <h3>{{ t.life1_title }}</h3>
        <img src="/assets/images/copenhagen/bike-culture.jpg" alt="{{ t.life1_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <p>{{ t.life1_desc }}</p>
      </div>

      <div class="program-feature">
        <div class="program-feature__icon">☕</div>
        <h3>{{ t.life2_title }}</h3>
        <img src="/assets/images/copenhagen/cafe-scene.jpg" alt="{{ t.life2_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <p>{{ t.life2_desc }}</p>
      </div>

      <div class="program-feature">
        <div class="program-feature__icon">🧖</div>
        <h3>{{ t.life3_title }}</h3>
        <img src="/assets/images/copenhagen/saunagus.jpg" alt="{{ t.life3_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <p>{{ t.life3_desc }}</p>
      </div>

      <div class="program-feature">
        <div class="program-feature__icon">🏊</div>
        <h3>{{ t.life4_title }}</h3>
        <img src="/assets/images/copenhagen/cold-dip.jpg" alt="{{ t.life4_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <p>{{ t.life4_desc }}</p>
      </div>

      <div class="program-feature">
        <div class="program-feature__icon">🎶</div>
        <h3>{{ t.life5_title }}</h3>
        <img src="/assets/images/copenhagen/concerts.jpg" alt="{{ t.life5_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <p>{{ t.life5_desc }}</p>
      </div>

      <div class="program-feature">
        <div class="program-feature__icon">🏛️</div>
        <h3>{{ t.life6_title }}</h3>
        <img src="/assets/images/copenhagen/scandinavian-design.jpg" alt="{{ t.life6_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <p>{{ t.life6_desc }}</p>
      </div>

      <div class="program-feature">
        <div class="program-feature__icon">🌿</div>
        <h3>{{ t.life7_title }}</h3>
        <img src="/assets/images/copenhagen/green-spaces.jpg" alt="{{ t.life7_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <p>{{ t.life7_desc }}</p>
      </div>

      <div class="program-feature">
        <div class="program-feature__icon">🍽️</div>
        <h3>{{ t.life8_title }}</h3>
        <img src="/assets/images/copenhagen/food-scene.jpg" alt="{{ t.life8_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <p>{{ t.life8_desc }}</p>
