{# ════════════════════════════════════════════════════════════════════
   SECTION 8 — CTA (Your Journey Starts Here)
   Dark section with 2 program cards
   ════════════════════════════════════════════════════════════════════ #}
<section class="yb-cph-cta">
  <div class="yb-cph-inner">
    <div class="yb-cph-cta__header">
      <span class="yb-cph-eyebrow" style="color: rgba(255,255,255,0.5);">{{ t.cta_eyebrow }}</span>
      <h2 class="yb-cph-section-title" style="color: #fff;">{{ t.cta_title }}</h2>
      <p class="yb-cph-section-subtitle" style="color: rgba(255,255,255,0.7);">{{ t.cta_subtitle }}</p>
    </div>

    <div class="yb-cph-cta__grid">
      {# Card 1: 4-Week Intensive — featured #}
      <div class="yb-cph-cta__card yb-cph-cta__card--featured">
        <span class="yb-cph-cta__card-badge">{{ t.cta_card1_badge }}</span>
        <p style="font-size:0.78rem; text-transform:uppercase; letter-spacing:0.05em; color:rgba(255,255,255,0.5); margin:0;">{{ t.cta_card1_tag }}</p>
        <h3 class="yb-cph-cta__card-title">{{ t.cta_card1_title }}</h3>
        <p class="yb-cph-cta__card-text">{{ t.cta_card1_desc }}</p>
        <div class="yb-cph-cta__card-features">
          {% for feat in t.cta_card1_features.split("|") %}
          <span class="yb-cph-cta__feature-pill">{{ feat }}</span>
          {% endfor %}
        </div>
        <a href="{{ lp }}/om-200hrs-yogalreruddannelser" class="yb-cph-cta__btn">{{ t.cta_card1_btn }}</a>
      </div>

      {# Card 2: Course Bundles #}
      <div class="yb-cph-cta__card">
        <span class="yb-cph-cta__card-badge">{{ t.cta_card2_badge }}</span>
        <p style="font-size:0.78rem; text-transform:uppercase; letter-spacing:0.05em; color:rgba(255,255,255,0.5); margin:0;">{{ t.cta_card2_tag }}</p>
        <h3 class="yb-cph-cta__card-title">{{ t.cta_card2_title }}</h3>
        <p class="yb-cph-cta__card-text">{{ t.cta_card2_desc }}</p>
        <div class="yb-cph-cta__course-pills">
          {% set courses = t.cta_card2_courses.split("|") %}
          {% set subs = t.cta_card2_courses_sub.split("|") %}
          {% for course in courses %}
          <span class="yb-cph-cta__course-pill">{{ course }}<br><small style="opacity:0.7; font-weight:400;">{{ subs[loop.index0] }}</small></span>
          {% endfor %}
        </div>
        <p style="font-size:0.82rem; color:rgba(255,255,255,0.65); margin:0.5rem 0 0;">{{ t.cta_card2_discount | safe }}</p>
        <a href="{{ lp }}/sammenlign-yogalreruddannelser" class="yb-cph-cta__btn yb-cph-cta__btn--secondary">{{ t.cta_card2_btn }}</a>
      </div>
    </div>

    <div class="yb-cph-cta__contact">
      <p>{{ t.cta_contact }} <a href="{{ lp }}/kontakt">{{ t.cta_contact_link }}</a></p>
    </div>
  </div>
</section>


{# ════════════════════════════════════════════════════════════════════
   SECTION 9 — FAQ (SEO / AEO)
   Accordion using native <details>/<summary>
   ════════════════════════════════════════════════════════════════════ #}
<section class="yb-cph-faq">
  <div class="yb-cph-inner">
    <div class="yb-cph-faq__header">
      <span class="yb-cph-eyebrow">{{ t.faq_eyebrow }}</span>
      <h2 class="yb-cph-section-title">{{ t.faq_title }}</h2>
      <p class="yb-cph-section-subtitle">{{ t.faq_subtitle }}</p>
    </div>

    <div class="yb-cph-faq__list">
      {% for i in range(1, 13) %}
      <details class="yb-cph-faq__item">
        <summary>{{ t["faq" + i + "_q"] }}</summary>
        <p>{{ t["faq" + i + "_a"] }}</p>
      </details>
      {% endfor %}
    </div>
  </div>
</section>
