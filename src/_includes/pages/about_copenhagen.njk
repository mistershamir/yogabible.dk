{% set t = i18n.about_copenhagen[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

{# ── FAQPage Structured Data (SEO / AEO) ── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for i in range(1, 13) %}
    {
      "@type": "Question",
      "name": {{ t["faq" + i + "_q"] | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ t["faq" + i + "_a"] | dump | safe }}
      }
    }{% if i < 12 %},{% endif %}
    {% endfor %}
  ]
}
</script>


{# ════════════════════════════════════════════════════════════════════
   SECTION 0 — HERO (Cinema)
   Keep existing dark cinematic hero
   ════════════════════════════════════════════════════════════════════ #}
<section class="yb-cph-cinema">
  <div class="yb-cph-cinema__bg">
    {% cldimg media.copenhagen.hero, t.hero_img_alt, "w_1920,h_900,c_fill", "1920", "900" %}
  </div>
  <div class="yb-cph-cinema__overlay"></div>
  <div class="yb-cph-cinema__content">
    <span class="yb-cph-cinema__badge">{{ t.hero_badge }}</span>
    <h1 class="yb-cph-cinema__title">{{ t.hero_title }}</h1>
    <p class="yb-cph-cinema__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-cph-cinema__ctas">
      <a href="{{ lp }}/apply" class="yb-cph-cinema__btn yb-cph-cinema__btn--primary">{{ t.hero_cta_apply }}</a>
      <a href="#life-in-copenhagen" class="yb-cph-cinema__btn yb-cph-cinema__btn--outline">{{ t.hero_cta_explore }}</a>
    </div>
    <div class="yb-cph-cinema__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-cph-cinema__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-cph-cinema__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
</section>


{# ════════════════════════════════════════════════════════════════════
