{% set t = i18n.about_copenhagen[lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

{# ── FAQPage Structured Data (SEO / AEO) ── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for i in range(1, 13) %}
    {
      "@type": "Question",
      "name": {{ t["faq" + i + "_q"] | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ t["faq" + i + "_a"] | dump | safe }}
      }
    }{% if i < 12 %},{% endif %}
    {% endfor %}
  ]
}
</script>


{# ════════════════════════════════════════════════════════════════════
   SECTION 0 — HERO (Video background)
   Adopted from main — yb-hero with looping video
   ════════════════════════════════════════════════════════════════════ #}
<section class="yb-hero">
  <div class="yb-hero__bg">
    <video autoplay muted loop playsinline preload="auto" aria-hidden="true"
      poster="{{ "yoga-bible-DK/copenhagen/about-copenhagen-hero-loop.jpg" | cloudvid("w_1920,c_fill,so_0,q_60") }}">
      <source src="{{ "yoga-bible-DK/copenhagen/about-copenhagen-hero-loop" | cloudvid("w_1920,q_auto") }}" type="video/mp4">
    </video>
  </div>
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="{% if lang == 'en' %}/en/apply{% else %}/apply{% endif %}" class="yb-btn yb-btn--primary yb-btn--large">{{ t.hero_cta_apply }}</a>
      <a href="#life-in-copenhagen" class="yb-btn yb-btn--outline-white yb-btn--large">{{ t.hero_cta_explore }}</a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>


{# ════════════════════════════════════════════════════════════════════
   SECTION 1 — LIFE IN COPENHAGEN
   4-column image card grid with gradient overlays
   ════════════════════════════════════════════════════════════════════ #}
<section class="yb-cph-life" id="life-in-copenhagen">
  <div class="yb-cph-inner">
    <div class="yb-cph-life__header">
      <span class="yb-cph-eyebrow">{{ t.life_eyebrow }}</span>
      <h2 class="yb-cph-section-title">{{ t.life_title }}</h2>
      <p class="yb-cph-section-subtitle">{{ t.life_subtitle }}</p>
    </div>

    <div class="yb-cph-life__grid">
      {# Card 1: Bike Culture #}
      <div class="yb-cph-life__card">
        <div class="yb-cph-life__card-img">
          {% cldimg media.copenhagen.bikeCulture, t.life1_img_alt, "w_600,h_400,c_fill", "600", "400" %}
        </div>
        <div class="yb-cph-life__card-overlay">
          <h3 class="yb-cph-life__card-title">{{ t.life1_title }}</h3>
          <p class="yb-cph-life__card-desc">{{ t.life1_desc }}</p>
        </div>
      </div>

      {# Card 2: Cafe Scene #}
      <div class="yb-cph-life__card">
        <div class="yb-cph-life__card-img">
          {% cldimg media.copenhagen.cafeScene, t.life2_img_alt, "w_600,h_400,c_fill", "600", "400" %}
        </div>
        <div class="yb-cph-life__card-overlay">
          <h3 class="yb-cph-life__card-title">{{ t.life2_title }}</h3>
          <p class="yb-cph-life__card-desc">{{ t.life2_desc }}</p>
        </div>
      </div>

      {# Card 3: Saunagus #}
      <div class="yb-cph-life__card">
        <div class="yb-cph-life__card-img">
          {% cldimg media.copenhagen.saunagus, t.life3_img_alt, "w_600,h_400,c_fill", "600", "400" %}
        </div>
        <div class="yb-cph-life__card-overlay">
          <h3 class="yb-cph-life__card-title">{{ t.life3_title }}</h3>
          <p class="yb-cph-life__card-desc">{{ t.life3_desc }}</p>
        </div>
      </div>

      {# Card 4: Cold Dips #}
      <div class="yb-cph-life__card">
        <div class="yb-cph-life__card-img">
          {% cldimg media.copenhagen.coldDip, t.life4_img_alt, "w_600,h_400,c_fill", "600", "400" %}
        </div>
        <div class="yb-cph-life__card-overlay">
          <h3 class="yb-cph-life__card-title">{{ t.life4_title }}</h3>
          <p class="yb-cph-life__card-desc">{{ t.life4_desc }}</p>
        </div>
      </div>

      {# Card 5: Concerts #}
      <div class="yb-cph-life__card">
        <div class="yb-cph-life__card-img">
          {% cldimg media.copenhagen.concerts, t.life5_img_alt, "w_600,h_400,c_fill", "600", "400" %}
        </div>
        <div class="yb-cph-life__card-overlay">
          <h3 class="yb-cph-life__card-title">{{ t.life5_title }}</h3>
          <p class="yb-cph-life__card-desc">{{ t.life5_desc }}</p>
        </div>
      </div>

      {# Card 6: Design #}
      <div class="yb-cph-life__card">
        <div class="yb-cph-life__card-img">
          {% cldimg media.copenhagen.design, t.life6_img_alt, "w_600,h_400,c_fill", "600", "400" %}
        </div>
        <div class="yb-cph-life__card-overlay">
          <h3 class="yb-cph-life__card-title">{{ t.life6_title }}</h3>
          <p class="yb-cph-life__card-desc">{{ t.life6_desc }}</p>
        </div>
      </div>

      {# Card 7: Green Spaces #}
      <div class="yb-cph-life__card">
        <div class="yb-cph-life__card-img">
          {% cldimg media.copenhagen.greenSpaces, t.life7_img_alt, "w_600,h_400,c_fill", "600", "400" %}
        </div>
        <div class="yb-cph-life__card-overlay">
          <h3 class="yb-cph-life__card-title">{{ t.life7_title }}</h3>
          <p class="yb-cph-life__card-desc">{{ t.life7_desc }}</p>
        </div>
      </div>

      {# Card 8: Design Capital #}
      <div class="yb-cph-life__card">
        <div class="yb-cph-life__card-img">
