{# ════════════════════════════════════════════════════════════════════
   SECTION 4 — HYGGE
   Dark section. Split with accent image, values, yoga connection.
   ════════════════════════════════════════════════════════════════════ #}
<section class="yb-cph-hygge">
  <div class="yb-cph-inner">
    <div class="yb-cph-hygge__header">
      <span class="yb-cph-eyebrow" style="color: rgba(255,255,255,0.5);">{{ t.hygge_eyebrow }}</span>
      <h2 class="yb-cph-section-title" style="color: #fff;">{{ t.hygge_title }}</h2>
      <span class="yb-cph-hygge__pronunciation">{{ t.hygge_pronunciation }}</span>
    </div>

    <div class="yb-cph-hygge__split">
      <div class="yb-cph-hygge__content">
        <p class="yb-cph-hygge__desc">{{ t.hygge_desc }}</p>

        <blockquote class="yb-cph-hygge__quote">
          {{ t.hygge_quote }}
