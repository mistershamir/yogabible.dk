            {{ t.why6_title }}
          </h3>
          <p class="yb-cph-why__benefit-desc">{{ t.why6_desc }}</p>
        </div>
      </div>

      <div class="yb-cph-why__media">
        <div class="yb-cph-why__media-main">
          <div class="yba-carousel-wrapper">
            <div class="yba-carousel" style="border-radius:18px;">
              <div class="yba-carousel__track" id="studioCarouselTrack">
                {% for img in media.copenhagen.studioCarousel %}
                <div class="yba-carousel__slide" style="aspect-ratio:4/3;">
                  {% cldimg img, t.studio_carousel_alt, "w_600,h_450,c_fill", "600", "450" %}
