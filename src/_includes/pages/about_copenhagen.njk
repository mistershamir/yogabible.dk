      {# Card 6: Design #}
      <div class="yb-cph-life__card">
        <div class="yb-cph-life__card-img">
          {% cldimg media.copenhagen.design, t.life6_img_alt, "w_600,h_400,c_fill", "600", "400" %}
        </div>
        <div class="yb-cph-life__card-overlay">
          <h3 class="yb-cph-life__card-title">{{ t.life6_title }}</h3>
