        <p class="yb-cph-hygge__desc">{{ t.hygge_text2 }}</p>

        <div class="yb-cph-hygge__values">
          <div class="yb-cph-hygge__value">{{ t.hygge_value1 }}</div>
          <div class="yb-cph-hygge__value">{{ t.hygge_value2 }}</div>
          <div class="yb-cph-hygge__value">{{ t.hygge_value3 }}</div>
          <div class="yb-cph-hygge__value">{{ t.hygge_value4 }}</div>
        </div>
      </div>

      <div class="yb-cph-hygge__media">
        <div class="yb-cph-hygge__img-main">
          {% cldimg media.copenhagen.hyggeMain, t.hygge_main_alt, "w_600,h_700,c_fill", "600", "700" %}
        </div>
        <div class="yb-cph-hygge__img-accent">
          {% cldimg media.copenhagen.hyggeAccent, t.hygge_accent_alt, "w_280,h_280,c_fill", "280", "280" %}
        </div>
      </div>
    </div>

    {# Yoga connection card #}
    <div class="yb-cph-hygge__yoga">
      <h3 class="yb-cph-hygge__yoga-title">{{ t.hygge_yoga_title }}</h3>
      <p class="yb-cph-hygge__yoga-desc">{{ t.hygge_yoga_desc }}</p>
    </div>
  </div>
</section>


