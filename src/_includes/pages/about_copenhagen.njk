<!-- Practical Info -->
<section class="program-overview">
  <div class="container">
    <h2 class="section-title">{{ t.practical_title }}</h2>

    <div class="schedule-options">
      <div class="schedule-card">
        <h3>{{ t.prac_getting_here_title }}</h3>
        <ul>
          {% for item in t.prac_getting_here_items.split("|") %}
          <li>{{ item | safe }}</li>
          {% endfor %}
        </ul>
      </div>
      <div class="schedule-card">
        <h3>{{ t.prac_getting_around_title }}</h3>
        <ul>
          {% for item in t.prac_getting_around_items.split("|") %}
          <li>{{ item | safe }}</li>
          {% endfor %}
        </ul>
      </div>
      <div class="schedule-card">
        <h3>{{ t.prac_living_costs_title }}</h3>
        <ul>
          {% for item in t.prac_living_costs_items.split("|") %}
          <li>{{ item | safe }}</li>
          {% endfor %}
        </ul>
      </div>
      <div class="schedule-card">
        <h3>{{ t.prac_weather_title }}</h3>
        <ul>
          {% for item in t.prac_weather_items.split("|") %}
          <li>{{ item | safe }}</li>
          {% endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Accommodation -->
<section class="program-schedule">
  <div class="container">
    <h2 class="section-title">{{ t.accom_title }}</h2>
    <p class="section-subtitle">{{ t.accom_subtitle }}</p>

    <div class="schedule-options">
      <div class="schedule-card">
        <img src="/assets/images/accommodation/studio-apartment.jpg" alt="{{ t.accom_studio_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <h3>{{ t.accom_studio_title }}</h3>
        <p>{{ t.accom_studio_desc }}</p>
      </div>
      <div class="schedule-card">
        <img src="/assets/images/accommodation/shared-apartment.jpg" alt="{{ t.accom_shared_img_alt }}" style="width:100%; border-radius:8px; aspect-ratio:3/2; object-fit:cover; background:#f5f3f0; margin-bottom:12px;" loading="lazy">
        <h3>{{ t.accom_shared_title }}</h3>
        <p>{{ t.accom_shared_desc }}</p>
      </div>
    </div>

    <div style="text-align:center; margin-top:24px;">
      <a href="{% if lang == 'en' %}/en/kontakt{% else %}/kontakt{% endif %}" class="btn btn--primary">{{ t.accom_cta }}</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <div class="container">
    <h2 class="cta-section__title">{{ t.cta_title }}</h2>
    <p class="cta-section__text">{{ t.cta_text }}</p>
    <div style="display:flex; gap:16px; justify-content:center; flex-wrap:wrap;">
      <a href="{% if lang == 'en' %}/en/om-200hrs-yogalreruddannelser{% else %}/om-200hrs-yogalreruddannelser{% endif %}" class="btn btn--large btn--primary">{{ t.cta_programs }}</a>
      <a href="{% if lang == 'en' %}/en/sammenlign-yogalreruddannelser{% else %}/sammenlign-yogalreruddannelser{% endif %}" class="btn btn--large btn--secondary">{{ t.cta_compare }}</a>
    </div>
  </div>
</section>
