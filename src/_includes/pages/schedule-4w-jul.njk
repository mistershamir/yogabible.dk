{# CLOUDINARY: yoga-bible-DK/schedule-pages/4w-jul/ — hero and og images #}
{% set t = i18n.schedule_4w_jul[lang or "da"] %}

<section id="schedule-4w-jul">

  {# ── HERO ─────────────────────────────────────────────── #}
  <div style="background:#0F0F0F;color:#fff;padding:clamp(80px,12vw,160px) 24px clamp(60px,8vw,100px);text-align:center;">
    <div style="max-width:640px;margin:0 auto;">
      <p style="font-size:clamp(5rem,16vw,10rem);font-weight:700;line-height:1.05;padding-bottom:0.12em;background:linear-gradient(135deg,#f75c03,#ff9966);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin:0 0 16px;">{{ t.heroTitle }}</p>
      <p style="font-size:clamp(1.25rem,3.5vw,1.8rem);font-weight:700;color:#fff;letter-spacing:-.015em;line-height:1.2;margin:0 0 12px;">{{ t.heroSubtitle }}</p>
      <p style="font-size:.95rem;color:rgba(255,255,255,.4);letter-spacing:.04em;">{{ t.heroPeriod }}</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:28px;">
        <button onclick="openBookingModal('info-session')" style="background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.5);padding:13px 24px;border-radius:50px;font-size:.92rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;" onmouseenter="this.style.borderColor='#fff';this.style.background='rgba(255,255,255,.08)'" onmouseleave="this.style.borderColor='rgba(255,255,255,.5)';this.style.background='transparent'">{{ t.ctaBook }}</button>
        <button onclick="startCheckoutFunnel('100211')" style="background:#f75c03;color:#fff;border:none;padding:13px 24px;border-radius:50px;font-size:.92rem;font-weight:600;cursor:pointer;font-family:inherit;transition:background .2s;" onmouseenter="this.style.background='#d94f02'" onmouseleave="this.style.background='#f75c03'">{{ t.ctaStart }}</button>
      </div>
    </div>
  </div>

  {# ── STATS BAR ────────────────────────────────────────── #}
  <div style="background:#F5F3F0;padding:28px 24px;border-bottom:1px solid #E8E4E0;">
    <div style="max-width:700px;margin:0 auto;">
      <div style="display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:20px;">
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">{{ t.pillYA }}</span>
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">{{ t.pillStudents }}</span>
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">{{ t.pillPeriod }}</span>
        <span style="background:#FFF0E6;color:#f75c03;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:600;border:1px solid rgba(247,92,3,.2);">{{ t.pillFocus }}</span>
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">{{ t.pillVenue }}</span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;text-align:center;">
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">4</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">{{ t.statWeeks }}</p>
        </div>
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">21</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">{{ t.statDays }}</p>
        </div>
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">200+</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">{{ t.statHours }}</p>
        </div>
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">{{ t.statCertDate }}</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">{{ t.certificationLabel }}</p>
        </div>
      </div>
    </div>
  </div>

  {# ── HOURS BREAKDOWN ──────────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:32px 24px 0;">
    <p style="font-size:.72rem;text-transform:uppercase;letter-spacing:.14em;color:#6F6A66;font-weight:700;margin-bottom:16px;">{{ t.hoursTitle }}</p>
    {% set hoursData4jul = [
      { pct: 30,  hours: 60, color: "#f75c03", key: "hLabel0" },
      { pct: 5,   hours: 10, color: "#ff9966", key: "hLabel1" },
      { pct: 22,  hours: 44, color: "#1a1a1a", key: "hLabel2" },
      { pct: 7,   hours: 14, color: "#3d3d3d", key: "hLabel3" },
      { pct: 6,   hours: 12, color: "#666666", key: "hLabel4" },
      { pct: 6,   hours: 12, color: "#6F6A66", key: "hLabel5" },
      { pct: 7,   hours: 14, color: "#ffb380", key: "hLabel6" },
      { pct: 5.5, hours: 11, color: "#ffd5b8", key: "hLabel7" },
      { pct: 10,  hours: 20, color: "#E8E4E0", key: "hLabel8" },
      { pct: 1.5, hours: 3,  color: "#F0EDEA", key: "hLabel9" }
    ] %}

    {# Stacked segment bar #}
    <div style="height:22px;border-radius:50px;overflow:hidden;display:flex;gap:2px;margin-bottom:20px;">
      {% for h in hoursData4jul %}
      <div style="flex:{{ h.pct }};background:{{ h.color }};" title="{{ t[h.key] }} — {{ h.hours }}{{ 'h' if lang == 'en' else 't' }}"></div>
      {% endfor %}
    </div>

    {# Legend: 2-column grid #}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px 24px;">
      {% for h in hoursData4jul %}
      <div style="display:flex;align-items:center;gap:8px;">
        <span style="width:10px;height:10px;border-radius:3px;background:{{ h.color }};flex-shrink:0;{% if h.color == '#E8E4E0' or h.color == '#F0EDEA' %}border:1px solid #ccc;{% endif %}"></span>
        <span style="font-size:.78rem;color:#0F0F0F;flex:1;">{{ t[h.key] }}</span>
        <span style="font-size:.78rem;font-weight:700;color:#0F0F0F;">{{ h.hours }}{{ "h" if lang == "en" else "t" }}</span>
      </div>
      {% endfor %}
    </div>
    <p style="font-size:.72rem;color:#6F6A66;text-align:right;margin-top:10px;font-style:italic;">{{ t.hoursTotal }}</p>
  </div>

  {# ── CONFLICT FINDER ──────────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:24px 24px 0;">
    <details id="s4wj-conflict-finder" style="background:#fff;border:1.5px solid #E8E4E0;border-radius:16px;overflow:hidden;">
      <summary style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;cursor:pointer;list-style:none;-webkit-appearance:none;">
        <div style="display:flex;align-items:center;gap:12px;">
          <span style="background:#FFF0E6;color:#f75c03;width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;">&#128197;</span>
          <div>
            <p style="font-weight:700;font-size:.92rem;">{{ t.conflictTitle }}</p>
            <p style="font-size:.78rem;color:#6F6A66;">{{ t.conflictDesc }}</p>
          </div>
        </div>
        <svg class="s4wj-cf-chevron" style="flex-shrink:0;transition:transform .25s;" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div style="padding:0 20px 20px;border-top:1px solid #E8E4E0;">
        <p style="font-size:.8rem;color:#6F6A66;padding:14px 0 10px;margin:0;">{{ t.conflictDesc }}</p>
        <div style="display:flex;flex-direction:column;gap:6px;" id="s4wj-busy-days">
          {% set busyDays4j = [
            { val: "1", label: "Mandag" if lang != "en" else "Monday", checked: true, start: "09:00", end: "17:00" },
            { val: "2", label: "Tirsdag" if lang != "en" else "Tuesday", checked: true, start: "09:00", end: "17:00" },
            { val: "3", label: "Onsdag" if lang != "en" else "Wednesday", checked: true, start: "09:00", end: "17:00" },
            { val: "4", label: "Torsdag" if lang != "en" else "Thursday", checked: true, start: "09:00", end: "17:00" },
            { val: "5", label: "Fredag" if lang != "en" else "Friday", checked: true, start: "09:00", end: "17:00" },
            { val: "6", label: "Lørdag" if lang != "en" else "Saturday", checked: false, start: "10:00", end: "14:00" },
            { val: "0", label: "Søndag" if lang != "en" else "Sunday", checked: false, start: "10:00", end: "14:00" }
          ] %}
          {% for d in busyDays4j %}
          <div class="s4wj-busy-row" style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:12px;background:{% if d.checked %}#F5F3F0{% else %}transparent{% endif %};transition:background .2s;">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;min-width:110px;">
              <input type="checkbox" name="s4wj-busy" value="{{ d.val }}" {% if d.checked %}checked{% endif %} onchange="s4wjToggleBusyRow(this)" style="accent-color:#f75c03;width:16px;height:16px;">
              <span style="font-size:.85rem;font-weight:600;">{{ d.label }}</span>
            </label>
            <div class="s4wj-busy-times" style="display:flex;align-items:center;gap:6px;{% if not d.checked %}opacity:.3;pointer-events:none;{% endif %}">
              <input type="time" value="{{ d.start }}" class="s4wj-time-from" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;width:100px;">
              <span style="color:#6F6A66;font-size:.75rem;">{{ "til" if lang != "en" else "to" }}</span>
              <input type="time" value="{{ d.end }}" class="s4wj-time-to" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;width:100px;">
            </div>
          </div>
          {% endfor %}
        </div>

        {# Specific dates #}
        <div style="margin-top:18px;padding-top:14px;border-top:1px dashed #E8E4E0;">
          <p style="font-size:.82rem;font-weight:700;margin:0 0 2px;">{{ t.conflictSpecificLabel }}</p>
          <p style="font-size:.72rem;color:#6F6A66;margin:0 0 10px;">{{ t.conflictSpecificHint }}</p>
          <div id="s4wj-specific-dates" style="display:flex;flex-direction:column;gap:6px;"></div>
          <button type="button" onclick="s4wjAddSpecificDate()" style="margin-top:8px;background:none;border:1.5px dashed #E8E4E0;border-radius:10px;padding:8px 16px;font-size:.78rem;font-weight:600;color:#f75c03;cursor:pointer;font-family:inherit;transition:border-color .2s;" onmouseenter="this.style.borderColor='#f75c03'" onmouseleave="this.style.borderColor='#E8E4E0'">{{ t.conflictAddDate }}</button>
        </div>

        <button onclick="s4wjCheckConflicts()" style="margin-top:16px;background:#f75c03;color:#fff;border:none;padding:12px 24px;border-radius:50px;font-size:.88rem;font-weight:600;cursor:pointer;font-family:inherit;transition:background .2s;" onmouseenter="this.style.background='#d94f02'" onmouseleave="this.style.background='#f75c03'">{{ t.conflictBtn }}</button>
        <div id="s4wj-conflict-results" style="display:none;margin-top:16px;"></div>
        <p style="font-size:.75rem;color:#6F6A66;margin:16px 0 0;line-height:1.5;">{{ t.conflictNote | safe }}</p>
      </div>
    </details>
  </div>

  {# ── SCHEDULE BODY ─────────────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:40px 24px 0;">

    <div style="display:flex;justify-content:flex-end;margin-bottom:24px;">
      <button style="display:inline-flex;align-items:center;gap:6px;background:none;color:#6F6A66;border:1.5px solid #E8E4E0;padding:8px 16px;border-radius:50px;font-size:.78rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;" onmouseenter="this.style.borderColor='#f75c03';this.style.color='#f75c03'" onmouseleave="this.style.borderColor='#E8E4E0';this.style.color='#6F6A66'">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        {{ t.calendarBtn }}
      </button>
    </div>

    {% set months4wJul = [
      { name: "Juli", name_en: "July", year: "2026", weeks: [
        { num: 1, label: "Introduktion", label_en: "Introduction", range: "6–12 jul", range_en: "Jul 6–12", days: [
          { dn: "6",  dd: "Man", dd_en: "Mon", time: "09:00–15:00", topic: "Vinyasa Flow & Creative Sequencing — Introduktion", topic_en: "Vinyasa Flow & Creative Sequencing — Introduction", type: "workshop" },
          { dn: "7",  dd: "Tir", dd_en: "Tue", time: "11:00–17:00", topic: "Yin Yoga & Recovery — Introduktion", topic_en: "Yin Yoga & Recovery — Introduction", type: "workshop" },
          { dn: "9",  dd: "Tor", dd_en: "Thu", time: "11:00–17:00", topic: "Vinyasa Flow & Class Management", type: "workshop" },
          { dn: "11", dd: "Lør", dd_en: "Sat", time: "13:00–18:00", topic: "Yoga Anatomi", topic_en: "Yoga Anatomy", type: "workshop" },
          { dn: "12", dd: "Søn", dd_en: "Sun", time: "14:00–18:00", topic: "Yogafilosofi 01 — Online", topic_en: "Yoga Philosophy 01 — Online", type: "online" }
        ]},
        { num: 2, range: "13–19 jul", range_en: "Jul 13–19", days: [
          { dn: "13", dd: "Man", dd_en: "Mon", time: "09:00–15:00", topic: "Vinyasa Flow & Creative Sequencing", type: "workshop" },
          { dn: "14", dd: "Tir", dd_en: "Tue", time: "11:00–17:00", topic: "Hot Yoga & Heated Vinyasa", type: "workshop" },
          { dn: "15", dd: "Ons", dd_en: "Wed", time: "10:00–15:00", topic: "Vinyasa Flow & Class Management", type: "workshop" },
          { dn: "16", dd: "Tor", dd_en: "Thu", time: "11:00–17:00", topic: "Yin Yoga & Recovery", type: "workshop" },
          { dn: "18", dd: "Lør", dd_en: "Sat", time: "13:00–18:00", topic: "Yoga Anatomi", topic_en: "Yoga Anatomy", type: "workshop" },
          { dn: "19", dd: "Søn", dd_en: "Sun", time: "13:00–17:00", topic: "Yogafilosofi 02 — Online", topic_en: "Yoga Philosophy 02 — Online", type: "online" }
        ]},
        { num: 3, range: "20–26 jul", range_en: "Jul 20–26", days: [
          { dn: "20", dd: "Man", dd_en: "Mon", time: "10:00–15:00", topic: "Vinyasa Flow & Creative Sequencing", type: "workshop" },
          { dn: "21", dd: "Tir", dd_en: "Tue", time: "09:00–15:00", topic: "Hot Yoga & Heated Vinyasa", type: "workshop" },
          { dn: "23", dd: "Tor", dd_en: "Thu", time: "11:00–15:00", topic: "Yin Yoga & Recovery", type: "workshop" },
          { dn: "24", dd: "Fre", dd_en: "Fri", time: "11:00–16:00", topic: "Vinyasa Flow & Class Management", type: "workshop" },
          { dn: "25", dd: "Lør", dd_en: "Sat", time: "13:00–18:00", topic: "Yoga Anatomi", topic_en: "Yoga Anatomy", type: "workshop" },
          { dn: "26", dd: "Søn", dd_en: "Sun", time: "13:00–17:00", topic: "Yogafilosofi 03 — Online", topic_en: "Yoga Philosophy 03 — Online", type: "online" }
        ]}
      ]},
      { name: "August", name_en: "August", year: "2026", weeks: [
        { num: 4, label: "Eksamen & Graduation", label_en: "Exam & Graduation", range: "27 jul – 2 aug", range_en: "Jul 27 – Aug 2", graduation: true, days: [
          { dn: "27", dd: "Man", dd_en: "Mon", time: "10:00–15:00", topic: "Vinyasa Flow & Creative Sequencing", type: "workshop" },
          { dn: "29", dd: "Ons", dd_en: "Wed", time: "09:00–15:00", topic: "Business of Yoga", type: "workshop" },
          { dn: "31", dd: "Fre", dd_en: "Fri", time: "11:00–17:00", topic: "Hot Yoga & Heated Vinyasa", type: "workshop" },
          { dn: "1",  dd: "Lør", dd_en: "Sat", time: "13:00–18:00", topic: "Vinyasa Flow — Eksamen", topic_en: "Vinyasa Flow — Exam", type: "exam" },
          { dn: "2",  dd: "Søn", dd_en: "Sun", time: "14:00–17:00", topic: "Yin Yoga & Hot Yoga — Eksamen + Graduation 🎓", topic_en: "Yin Yoga & Hot Yoga — Exam + Graduation 🎓", type: "graduation" }
        ]}
      ]}
    ] %}

    {% for month in months4wJul %}
    <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:32px;{% if not loop.first %}margin-top:40px;{% endif %}">
      <span style="font-size:3.4rem;font-weight:700;line-height:1;color:#0F0F0F;">{{ month.name_en if lang == "en" else month.name }}</span>
      <span style="font-size:1.1rem;color:#6F6A66;">{{ month.year }}</span>
      <div style="flex:1;height:2px;background:linear-gradient(to right, #E8E4E0, transparent);margin-left:12px;"></div>
    </div>

    {% for week in month.weeks %}
      {% if week.graduation %}
      <details class="s4w-combo-accordion" open style="margin-bottom:10px;">
        <summary class="s4w-combo-summary" style="display:flex;align-items:center;justify-content:space-between;padding:18px 22px;cursor:pointer;list-style:none;-webkit-appearance:none;background:linear-gradient(135deg,#f0fff0,#e8f5e8);border:1.5px solid #2ecc71;border-radius:14px;transition:all .2s;">
          <div style="display:flex;align-items:center;gap:14px;">
            <span style="background:#2ecc71;color:#fff;font-size:.68rem;font-weight:700;padding:5px 12px;border-radius:50px;letter-spacing:.06em;">{{ t.weekLabel }} {{ week.num }}</span>
            <div>
              <p style="font-weight:700;font-size:.92rem;color:#0F0F0F;">{{ week.label_en if lang == "en" else week.label }}</p>
              <p style="font-size:.75rem;color:#6F6A66;">{{ week.range_en if lang == "en" else week.range }}</p>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <span style="background:#d4edda;color:#155724;padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:700;text-transform:uppercase;">{{ t.graduationBadge }}</span>
            <span class="s4w-combo-icon" style="background:#2ecc71;color:#fff;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.88rem;font-weight:700;transition:transform .25s;flex-shrink:0;">+</span>
          </div>
        </summary>
        <div style="padding:6px 22px 18px;background:#fff;border:1.5px solid #2ecc71;border-top:none;border-radius:0 0 14px 14px;margin-top:-1px;">
          {% for day in week.days %}
          <div style="display:flex;gap:16px;align-items:center;padding:12px 0;{% if not loop.last %}border-bottom:1px solid #F0EDE9;{% endif %}">
            <div style="background:{% if day.type == 'graduation' %}#2ecc71{% elif day.type == 'exam' %}#0F0F0F{% else %}#f75c03{% endif %};color:#fff;width:46px;height:46px;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;">
              <span style="font-size:1.1rem;font-weight:700;line-height:1;">{{ day.dn }}</span>
              <span style="font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;opacity:.75;">{{ day.dd_en if lang == "en" else day.dd }}</span>
            </div>
            <div style="flex:1;">
              <p style="font-weight:600;font-size:.92rem;color:#0F0F0F;">{{ day.topic_en if lang == "en" else day.topic }}</p>
              <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">{{ day.time }}</p>
            </div>
            {% if day.type == 'graduation' %}<span style="background:#d4edda;color:#155724;padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:600;text-transform:uppercase;">{{ t.graduationLabel }}</span>{% elif day.type == 'exam' %}<span style="background:#FFF0E6;color:#f75c03;padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:600;text-transform:uppercase;">{{ t.examLabel }}</span>{% endif %}
          </div>
          {% endfor %}
        </div>
      </details>
      {% else %}
      <details class="s4w-combo-accordion" {% if week.num == 1 %}open{% endif %} style="margin-bottom:10px;">
        <summary class="s4w-combo-summary" style="display:flex;align-items:center;justify-content:space-between;padding:18px 22px;cursor:pointer;list-style:none;-webkit-appearance:none;background:#fff;border:1px solid #E8E4E0;border-radius:14px;transition:all .2s;">
          <div style="display:flex;align-items:center;gap:14px;">
            <span style="background:#f75c03;color:#fff;font-size:.68rem;font-weight:700;padding:5px 12px;border-radius:50px;letter-spacing:.06em;">{{ t.weekLabel }} {{ week.num }}</span>
            <div>
              <p style="font-weight:700;font-size:.92rem;color:#0F0F0F;">{% if week.label %}{{ week.label_en if lang == "en" else week.label }}{% else %}{{ week.range_en if lang == "en" else week.range }}{% endif %}</p>
              <p style="font-size:.75rem;color:#6F6A66;">{{ week.days | length }} {% if week.days | length == 1 %}{{ t.dayLabel }}{% else %}{{ t.daysLabel }}{% endif %}</p>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <span style="font-size:.72rem;color:#6F6A66;font-weight:500;">{% for day in week.days %}{{ day.dd_en if lang == "en" else day.dd }}{% if not loop.last %} · {% endif %}{% endfor %}</span>
            <span class="s4w-combo-icon" style="background:#f75c03;color:#fff;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.88rem;font-weight:700;transition:transform .25s;flex-shrink:0;">+</span>
          </div>
        </summary>
        <div style="padding:6px 22px 18px;background:#fff;border:1px solid #E8E4E0;border-top:none;border-radius:0 0 14px 14px;margin-top:-1px;">
          {% for day in week.days %}
          <div style="display:flex;gap:16px;align-items:center;padding:12px 0;{% if not loop.last %}border-bottom:1px solid #F0EDE9;{% endif %}">
            <div style="background:#f75c03;color:#fff;width:46px;height:46px;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;{% if day.type == 'online' %}box-shadow:0 0 0 2px #fff, 0 0 0 3px #f75c03;{% endif %}">
              <span style="font-size:1.1rem;font-weight:700;line-height:1;">{{ day.dn }}</span>
              <span style="font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;opacity:.75;">{{ day.dd_en if lang == "en" else day.dd }}</span>
            </div>
            <div style="flex:1;min-width:0;">
              <p style="font-weight:600;font-size:.92rem;color:#0F0F0F;">{{ day.topic_en if lang == "en" else day.topic }}</p>
              <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">{{ day.time }}{% if day.type == 'online' %} · <span style="color:#f75c03;font-weight:600;">{{ t.onlineLabel }}</span>{% endif %}</p>
            </div>
          </div>
          {% endfor %}
        </div>
      </details>
      {% endif %}
    {% endfor %}
    {% endfor %}

    {# ── GRADUATION ENDPOINT ────────────────────────────── #}
    <div style="position:relative;padding-left:48px;margin-top:40px;">
      <div style="position:absolute;left:18px;top:0;bottom:50%;width:2px;background:linear-gradient(to bottom, #E8E4E0, #2ecc71);"></div>
      <div style="position:relative;">
        <div style="position:absolute;left:-42px;top:4px;width:22px;height:22px;background:#2ecc71;border-radius:50%;border:3px solid #fff;box-shadow:0 0 0 2px #2ecc71, 0 0 20px rgba(46,204,113,.25);z-index:1;display:flex;align-items:center;justify-content:center;">
          <span style="color:#fff;font-size:.7rem;">&#10003;</span>
        </div>
        <div>
          <p style="font-weight:700;font-size:1.05rem;color:#2ecc71;">{{ t.certifiedTitle }}</p>
          <p style="font-size:.82rem;color:#6F6A66;line-height:1.5;margin-top:4px;">{{ t.certDate }}</p>
        </div>
      </div>
    </div>

    <div style="margin-top:32px;">
      <div style="background:#f0fff0;border:1px solid #c3e6c3;border-radius:12px;padding:18px;">
        <p style="font-weight:700;font-size:.85rem;margin-bottom:4px;">{{ t.certificationLabel }}</p>
        <p style="font-size:.78rem;color:#6F6A66;">{{ t.certGradDate }}</p>
      </div>
    </div>

    <blockquote style="border-left:4px solid #f75c03;padding:24px 28px;margin:40px 0 0;background:#FFFCF9;border-radius:0 14px 14px 0;">
      <p style="font-size:1.05rem;font-weight:600;font-style:italic;line-height:1.5;color:#0F0F0F;">"{{ t.quoteText }}"</p>
      <p style="font-size:.82rem;color:#6F6A66;margin-top:8px;">{{ t.quoteAuthor }}</p>
    </blockquote>

  </div>

  {# ── CROSS-LINK: April Complete Program ──────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:32px 24px 0;">
    <div style="background:#FFF7ED;border:1px solid rgba(247,92,3,.15);border-radius:14px;padding:20px 24px;display:flex;align-items:center;gap:16px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;">
        <p style="font-weight:700;font-size:.95rem;color:#0F0F0F;margin-bottom:4px;">{{ t.crossLinkTitle }}</p>
        <p style="font-size:.82rem;color:#6F6A66;line-height:1.5;">{{ t.crossLinkDesc }}</p>
      </div>
      <a href="{% if lang == 'en' %}/en/schedule/4-weeks/{% else %}/skema/4-uger/{% endif %}" style="display:inline-block;background:#f75c03;color:#fff;padding:10px 20px;border-radius:50px;font-size:.85rem;font-weight:600;text-decoration:none;white-space:nowrap;transition:background .2s;" onmouseenter="this.style.background='#d94f02'" onmouseleave="this.style.background='#f75c03'">{{ t.crossLinkCta }} →</a>
    </div>
  </div>

  {# ── DARK CTA ─────────────────────────────────────────── #}
  <div style="background:#0F0F0F;color:#fff;padding:60px 24px;text-align:center;">
    <div style="max-width:600px;margin:0 auto;">
      <h2 style="font-size:1.6rem;font-weight:700;margin-bottom:12px;">{{ t.ctaSectionTitle }}</h2>
      <p style="color:rgba(255,255,255,.68);margin-bottom:28px;line-height:1.55;">{{ t.ctaSectionDesc }}</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <button onclick="openBookingModal('info-session')" style="background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.5);padding:14px 28px;border-radius:50px;font-size:.95rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;" onmouseenter="this.style.borderColor='#fff';this.style.background='rgba(255,255,255,.08)'" onmouseleave="this.style.borderColor='rgba(255,255,255,.5)';this.style.background='transparent'">{{ t.ctaBook }}</button>
        <button onclick="startCheckoutFunnel('100211')" style="background:#f75c03;color:#fff;border:none;padding:14px 28px;border-radius:50px;font-size:.95rem;font-weight:600;cursor:pointer;font-family:inherit;transition:background .2s;" onmouseenter="this.style.background='#d94f02'" onmouseleave="this.style.background='#f75c03'">{{ t.ctaStart }}</button>
      </div>
    </div>
  </div>

</section>

<script>
(function() {
  /* ── Conflict Finder ────────────────────────── */
  var s4wjDateCounter = 0;
  var s4wjFromLabel = '{{ t.conflictDateFrom }}';
  var s4wjToLabel = '{{ t.conflictDateTo }}';

  window.s4wjToggleBusyRow = function(cb) {
    var row = cb.closest('.s4wj-busy-row');
    var times = row.querySelector('.s4wj-busy-times');
    if (cb.checked) { row.style.background = '#F5F3F0'; times.style.opacity = '1'; times.style.pointerEvents = 'auto'; }
    else { row.style.background = 'transparent'; times.style.opacity = '.3'; times.style.pointerEvents = 'none'; }
  };

  window.s4wjAddSpecificDate = function() {
    var wrap = document.getElementById('s4wj-specific-dates');
    if (!wrap) return;
    var row = document.createElement('div');
    row.className = 's4wj-specific-row';
    row.style.cssText = 'display:flex;align-items:center;gap:8px;padding:8px 12px;border-radius:12px;background:#F5F3F0;flex-wrap:wrap;';
    row.innerHTML =
      '<input type="date" class="s4wj-sd-date" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;flex:1;min-width:130px;">' +
      '<span style="color:#6F6A66;font-size:.75rem;">' + s4wjFromLabel + '</span>' +
      '<input type="time" value="09:00" class="s4wj-sd-from" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;width:90px;">' +
      '<span style="color:#6F6A66;font-size:.75rem;">' + s4wjToLabel + '</span>' +
      '<input type="time" value="17:00" class="s4wj-sd-to" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;width:90px;">' +
      '<button type="button" onclick="this.parentElement.remove()" style="background:none;border:none;cursor:pointer;padding:4px;color:#6F6A66;font-size:1.1rem;line-height:1;" aria-label="Remove">&times;</button>';
    wrap.appendChild(row);
  };
  s4wjAddSpecificDate();

  function s4wjTimeMin(t) { var p = t.split(':'); return parseInt(p[0]) * 60 + parseInt(p[1]); }

  /* All 4w-jul training dates */
  var s4wjSchedule = [
    {d:'2026-07-06',s:'09:00',e:'15:00'},{d:'2026-07-07',s:'11:00',e:'17:00'},{d:'2026-07-09',s:'11:00',e:'17:00'},{d:'2026-07-11',s:'13:00',e:'18:00'},{d:'2026-07-12',s:'14:00',e:'18:00'},
    {d:'2026-07-13',s:'09:00',e:'15:00'},{d:'2026-07-14',s:'11:00',e:'17:00'},{d:'2026-07-15',s:'10:00',e:'15:00'},{d:'2026-07-16',s:'11:00',e:'17:00'},{d:'2026-07-18',s:'13:00',e:'18:00'},{d:'2026-07-19',s:'13:00',e:'17:00'},
    {d:'2026-07-20',s:'10:00',e:'15:00'},{d:'2026-07-21',s:'09:00',e:'15:00'},{d:'2026-07-23',s:'11:00',e:'15:00'},{d:'2026-07-24',s:'11:00',e:'16:00'},{d:'2026-07-25',s:'13:00',e:'18:00'},{d:'2026-07-26',s:'13:00',e:'17:00'},
    {d:'2026-07-27',s:'10:00',e:'15:00'},{d:'2026-07-29',s:'09:00',e:'15:00'},{d:'2026-07-31',s:'11:00',e:'17:00'},{d:'2026-08-01',s:'13:00',e:'18:00'},{d:'2026-08-02',s:'14:00',e:'17:00'}
  ];
  s4wjSchedule.forEach(function(item) {
    var dt = new Date(item.d + 'T12:00:00');
    item.dow = dt.getDay();
    item.sMin = s4wjTimeMin(item.s);
    item.eMin = s4wjTimeMin(item.e);
    var days = {% if lang == "en" %}['Sun','Mon','Tue','Wed','Thu','Fri','Sat']{% else %}['Søn','Man','Tir','Ons','Tor','Fre','Lør']{% endif %};
    item.label = days[item.dow] + ' ' + item.d.split('-')[2].replace(/^0/,'') + '/' + item.d.split('-')[1].replace(/^0/,'');
  });

  window.s4wjCheckConflicts = function() {
    var busySlots = {};
    document.querySelectorAll('.s4wj-busy-row').forEach(function(row) {
      var cb = row.querySelector('input[name="s4wj-busy"]');
      if (!cb.checked) return;
      var dow = parseInt(cb.value);
      var from = row.querySelector('.s4wj-time-from').value || '09:00';
      var to = row.querySelector('.s4wj-time-to').value || '17:00';
      busySlots[dow] = { s: s4wjTimeMin(from), e: s4wjTimeMin(to) };
    });

    var specificDates = [];
    document.querySelectorAll('.s4wj-specific-row').forEach(function(row) {
      var dateVal = row.querySelector('.s4wj-sd-date').value;
      if (!dateVal) return;
      var from = row.querySelector('.s4wj-sd-from').value || '09:00';
      var to = row.querySelector('.s4wj-sd-to').value || '17:00';
      specificDates.push({ date: dateVal, s: s4wjTimeMin(from), e: s4wjTimeMin(to) });
    });

    var conflicts = [];
    s4wjSchedule.forEach(function(item) {
      var hit = false;
      var slot = busySlots[item.dow];
      if (slot && item.sMin < slot.e && item.eMin > slot.s) hit = true;
      specificDates.forEach(function(sd) {
        if (sd.date === item.d && sd.s < item.eMin && sd.e > item.sMin) hit = true;
      });
      if (hit) conflicts.push(item);
    });

    var el = document.getElementById('s4wj-conflict-results');
    if (!el) return;
    el.style.display = 'block';
    var total = s4wjSchedule.length;
    var html = '';
    if (conflicts.length === 0) {
      html += '<div style="background:#f0fff0;border:1px solid #c3e6c3;border-radius:12px;padding:16px;text-align:center;"><p style="font-weight:700;color:#2ecc71;">{{ t.conflictNone }}</p></div>';
    } else {
      html += '<div style="background:#FFF8F3;border:1px solid #FFE5D0;border-radius:12px;padding:16px;">';
      html += '<p style="font-size:.92rem;font-weight:700;margin-bottom:8px;"><span style="color:#f75c03;font-size:1.4rem;">' + conflicts.length + '</span> / ' + total + ' {{ t.conflictSome }}</p>';
      html += '<div style="background:#E8E4E0;border-radius:50px;height:6px;overflow:hidden;margin-bottom:12px;"><div style="background:#2ecc71;height:100%;width:' + Math.round(((total - conflicts.length) / total) * 100) + '%;border-radius:50px;"></div></div>';
      html += '<ul style="margin:0;padding:0 0 0 18px;font-size:.82rem;color:#0F0F0F;">';
      conflicts.forEach(function(c) {
        html += '<li style="margin-bottom:4px;">' + c.label + ' <span style="color:#6F6A66;">(' + c.s + '–' + c.e + ')</span></li>';
      });
      html += '</ul></div>';
    }
    el.innerHTML = html;
  };

  /* Chevron toggle */
  var cfDetails = document.getElementById('s4wj-conflict-finder');
  if (cfDetails) {
    cfDetails.addEventListener('toggle', function() {
      var chev = cfDetails.querySelector('.s4wj-cf-chevron');
      if (chev) chev.style.transform = cfDetails.open ? 'rotate(180deg)' : '';
    });
  }

  var params = new URLSearchParams(window.location.search);
  var tid = params.get('tid');
  var tok = params.get('tok');
})();
</script>

<style>
  .s4w-combo-accordion summary::-webkit-details-marker { display: none; }
  .s4w-combo-accordion summary::marker { display: none; content: ''; }
  .s4w-combo-summary:hover { box-shadow: 0 4px 16px rgba(0,0,0,.06); transform: translateY(-1px); }
  .s4w-combo-accordion[open] .s4w-combo-summary { border-radius: 14px 14px 0 0 !important; border-bottom-color: transparent !important; }
  .s4w-combo-accordion[open] .s4w-combo-icon { transform: rotate(45deg); }
</style>
