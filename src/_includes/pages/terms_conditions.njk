{% set t = i18n.terms_conditions[lang or "da"] %}

<!-- Hero — yb-hero unified design -->
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a class="yb-btn yb-btn--primary yb-btn--large" href="#yb-terms">{{ t.hero_cta_read }}</a>
      <a class="yb-btn yb-btn--outline-light yb-btn--large" href="mailto:info@yogabible.dk?subject={{ t.hero_cta_contact_subject | urlencode }}">{{ t.hero_cta_contact }}</a>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>{{ t.hero_scroll }}</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

<!-- Terms & Conditions — Full v4.1 accordion layout -->
<section id="yb-terms" class="yb-terms" lang="{{ lang or 'da' }}" aria-label="{{ t.section_aria }}">
  <div class="yb-terms__inner yb-font">

    <header class="yb-terms__head">
      <p class="yb-terms__eyebrow">{{ t.head_eyebrow }}</p>
      <h2 class="yb-terms__title">{{ t.head_title }}</h2>
      <p class="yb-terms__lead">{{ t.head_lead }}</p>

      <div class="yb-terms__meta">
        <span class="yb-terms__metaItem"><strong>{{ t.label_company }}:</strong> Hot Yoga Copenhagen ApS</span>
        <span class="yb-terms__metaSep" aria-hidden="true">&bull;</span>
        <span class="yb-terms__metaItem"><strong>CVR:</strong> 41295252</span>
        <span class="yb-terms__metaSep" aria-hidden="true">&bull;</span>
        <span class="yb-terms__metaItem"><strong>VAT:</strong> DK41295252</span>
      </div>

      <div class="yb-terms__meta">
        <span class="yb-terms__metaItem"><strong>{{ t.label_address }}:</strong> {{ t.address_value }}</span>
        <span class="yb-terms__metaSep" aria-hidden="true">&bull;</span>
        <span class="yb-terms__metaItem"><strong>{{ t.label_phone }}:</strong> <a href="tel:+4553881209">+45 53 88 12 09</a></span>
        <span class="yb-terms__metaSep" aria-hidden="true">&bull;</span>
        <span class="yb-terms__metaItem"><strong>{{ t.label_email }}:</strong> <a href="mailto:info@yogabible.dk">info@yogabible.dk</a></span>
      </div>

      <div class="yb-terms__meta">
        <span class="yb-terms__metaItem"><strong>{{ t.label_last_updated }}:</strong> <time datetime="2026-01-11">{{ t.last_updated_value }}</time></span>
      </div>

      <div class="yb-terms__notice" role="note" aria-label="{{ t.notice_label }}">
        {{ t.notice_html | safe }}
      </div>

      <nav class="yb-terms__toc" aria-label="{{ t.toc_aria }}">
        <a class="yb-chip" href="#t1">{{ t.toc_1 }}</a>
        <a class="yb-chip" href="#t2">{{ t.toc_2 }}</a>
        <a class="yb-chip" href="#t3">{{ t.toc_3 }}</a>
        <a class="yb-chip" href="#t4">{{ t.toc_4 }}</a>
        <a class="yb-chip" href="#t5">{{ t.toc_5 }}</a>
        <a class="yb-chip" href="#t6">{{ t.toc_6 }}</a>
        <a class="yb-chip" href="#t7">{{ t.toc_7 }}</a>
        <a class="yb-chip" href="#t8">{{ t.toc_8 }}</a>
        <a class="yb-chip" href="#t9">{{ t.toc_9 }}</a>
        <a class="yb-chip" href="#t10">{{ t.toc_10 }}</a>
        <a class="yb-chip" href="#t11">{{ t.toc_11 }}</a>
        <a class="yb-chip" href="#t12">{{ t.toc_12 }}</a>
        <a class="yb-chip" href="#t13">{{ t.toc_13 }}</a>
        <a class="yb-chip" href="#t14">{{ t.toc_14 }}</a>
      </nav>
    </header>

    <div class="yb-terms__grid">
      <aside class="yb-terms__side" aria-label="{{ t.side_aria }}">
        <div class="yb-card">
          <h2 class="yb-card__title">{{ t.side_title }}</h2>
          <p class="yb-muted">{{ t.side_lead }}</p>
          <ul class="yb-list yb-list--compact">
            <li>Yoga Bible (YogaBible.dk)</li>
            <li>Hot Yoga Copenhagen</li>
            <li>Vibro Yoga</li>
            <li>Namaste Studios</li>
            <li>Namaste Online</li>
            <li>Yoga Bible International (YogaBible.com)</li>
          </ul>

          <div class="yb-divider" role="separator" aria-hidden="true"></div>

          <h3 class="yb-card__subtitle">{{ t.side_summary_title }}</h3>
          <ul class="yb-list">
            {{ t.side_summary_html | safe }}
          </ul>
        </div>
      </aside>

      <main class="yb-terms__main" aria-label="{{ t.main_aria }}">

        <details class="yb-acc" id="t1">
          <summary class="yb-acc__sum">{{ t.s1_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s1_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t2">
          <summary class="yb-acc__sum">{{ t.s2_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s2_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t3">
          <summary class="yb-acc__sum">{{ t.s3_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s3_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t4">
          <summary class="yb-acc__sum">{{ t.s4_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s4_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t5">
          <summary class="yb-acc__sum">{{ t.s5_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s5_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t6">
          <summary class="yb-acc__sum">{{ t.s6_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s6_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t7">
          <summary class="yb-acc__sum">{{ t.s7_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s7_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t8">
          <summary class="yb-acc__sum">{{ t.s8_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s8_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t9">
          <summary class="yb-acc__sum">{{ t.s9_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s9_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t10">
          <summary class="yb-acc__sum">{{ t.s10_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s10_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t11">
          <summary class="yb-acc__sum">{{ t.s11_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s11_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t12">
          <summary class="yb-acc__sum">{{ t.s12_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s12_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t13">
          <summary class="yb-acc__sum">{{ t.s13_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s13_html | safe }}
          </div>
        </details>

        <details class="yb-acc" id="t14">
          <summary class="yb-acc__sum">{{ t.s14_title }}</summary>
          <div class="yb-acc__body">
            {{ t.s14_html | safe }}
          </div>
        </details>

        <div class="yb-terms__bottomCard">
          <div class="yb-card">
            <h2 class="yb-card__title">{{ t.contact_title }}</h2>
            <ul class="yb-list">
              <li><strong>{{ t.label_email }}:</strong> <a href="mailto:info@yogabible.dk">info@yogabible.dk</a></li>
              <li><strong>{{ t.label_phone }}:</strong> <a href="tel:+4553881209">+45 53 88 12 09</a></li>
              <li><strong>{{ t.label_address }}:</strong> {{ t.address_value }}</li>
              <li><strong>CVR:</strong> 41295252</li>
              <li><strong>VAT:</strong> DK41295252</li>
            </ul>

            <div class="yb-actions">
              <a class="yb-btn yb-btn--primary" href="mailto:info@yogabible.dk?subject={{ t.contact_cta_subject | urlencode }}">{{ t.contact_cta }}</a>
              <a class="yb-btn yb-btn--ghost" href="#t3">{{ t.contact_secondary_cta }}</a>
            </div>
          </div>
        </div>

      </main>
    </div>
  </div>
</section>

<style>
  #yb-terms{
    --yb-accent:#f75c03;
    --yb-bg:#FCFBF9;
    --yb-card:#ffffff;
    --yb-border:#EBE7E3;
    --yb-text:#1A1A1A;
    --yb-muted:#6B6B6B;
    font-family:'Abacaxi', "Helvetica Neue", Helvetica, Arial, system-ui, -apple-system, sans-serif;
    color:var(--yb-text);
    background:var(--yb-bg);
    padding:72px 20px;
  }
  #yb-terms, #yb-terms *{ box-sizing:border-box; }
  #yb-terms .yb-font{ font-family:inherit; }

  #yb-terms .yb-terms__inner{ max-width:1120px; margin:0 auto; }

  #yb-terms .yb-terms__eyebrow{
    letter-spacing:.12em; text-transform:uppercase; font-size:12px;
    color:var(--yb-muted); margin:0 0 10px;
  }
  #yb-terms .yb-terms__title{
    margin:0 0 10px; font-size:44px; line-height:1.08; letter-spacing:-.02em;
  }
  #yb-terms .yb-terms__lead{
    margin:0 0 16px; font-size:16px; line-height:1.65; color:#2a2a2a; max-width:78ch;
  }
  #yb-terms .yb-terms__meta{
    display:flex; flex-wrap:wrap; gap:10px; align-items:center;
    color:var(--yb-muted); font-size:13px; margin:0 0 10px;
  }
  #yb-terms .yb-terms__metaSep{ opacity:.65; }
  #yb-terms .yb-terms__meta a{
    color:var(--yb-accent);
    text-decoration:underline; text-decoration-thickness:1px; text-underline-offset:3px;
  }
  #yb-terms .yb-terms__notice{
    background:#fff; border:1px solid var(--yb-border);
    border-radius:16px; padding:14px 16px; line-height:1.55; margin:10px 0 18px;
  }

  #yb-terms .yb-terms__toc{ display:flex; flex-wrap:wrap; gap:10px; margin:14px 0 0; }
  #yb-terms .yb-chip{
    display:inline-flex; align-items:center;
    border:1px solid var(--yb-border); background:#fff;
    border-radius:999px; padding:10px 12px; font-size:13px;
    color:var(--yb-text); text-decoration:none;
    transition:transform .15s ease, box-shadow .15s ease, border-color .15s ease;
  }
  #yb-terms .yb-chip:hover{
    border-color:rgba(247,92,3,.45);
    box-shadow:0 18px 60px rgba(0,0,0,.10);
    transform:translateY(-1px);
  }

  #yb-terms .yb-terms__grid{ display:grid; gap:18px; margin-top:26px; }
  @media (min-width:980px){
    #yb-terms .yb-terms__grid{ grid-template-columns:360px minmax(0,1fr); align-items:start; }
    #yb-terms .yb-terms__side{ position:sticky; top:20px; }
  }

  #yb-terms .yb-card{
    background:var(--yb-card);
    border:1px solid var(--yb-border);
    border-radius:20px;
    padding:18px;
    box-shadow:0 18px 60px rgba(0,0,0,.10);
  }
  #yb-terms .yb-card__title{ margin:0 0 10px; font-size:16px; letter-spacing:-.01em; }
  #yb-terms .yb-card__subtitle{
    margin:0 0 8px; font-size:13px; color:var(--yb-muted);
    text-transform:uppercase; letter-spacing:.10em;
  }

  #yb-terms .yb-divider{ height:1px; background:var(--yb-border); margin:14px 0; }

  #yb-terms .yb-list{
    margin:0; padding-left:18px;
    color:#2a2a2a; line-height:1.7; font-size:14px;
  }
  #yb-terms .yb-list--compact{ font-size:13px; color:var(--yb-muted); }
  #yb-terms .yb-muted{ color:var(--yb-muted); line-height:1.6; font-size:14px; margin:0; }

  #yb-terms .yb-acc{
    border:1px solid var(--yb-border);
    border-radius:20px;
    background:#fff;
    margin:0 0 12px;
    overflow:hidden;
    scroll-margin-top:18px;
  }
  #yb-terms .yb-acc__sum{
    list-style:none;
    cursor:pointer;
    padding:16px 16px;
    font-weight:700;
    letter-spacing:-.01em;
    display:flex;
    align-items:center;
    justify-content:space-between;
    gap:12px;
    outline:none;
  }
  #yb-terms details > summary::-webkit-details-marker{ display:none; }
  #yb-terms .yb-acc__sum:after{
    content:"\25BE"; color:var(--yb-muted); font-weight:600; transition:transform .15s ease;
  }
  #yb-terms details[open] .yb-acc__sum:after{ transform:rotate(180deg); }
  #yb-terms .yb-acc__sum:focus-visible{
    box-shadow:0 0 0 3px rgba(247,92,3,.22);
    border-radius:14px;
    margin:6px;
  }
  #yb-terms .yb-acc__body{
    padding:0 16px 16px;
    line-height:1.7;
    font-size:14px;
    color:#2a2a2a;
  }
  #yb-terms .yb-acc__body a{
    color:var(--yb-accent);
    text-decoration:underline;
    text-decoration-thickness:1px;
    text-underline-offset:3px;
  }
  #yb-terms .yb-acc__body h3{
    margin:14px 0 8px;
    font-size:14px;
    letter-spacing:-.01em;
  }

  #yb-terms .yb-callout{
    border:1px solid rgba(247,92,3,.28);
    background:rgba(247,92,3,.06);
    border-radius:16px;
    padding:12px 12px;
    margin:12px 0;
  }

  #yb-terms .yb-terms__bottomCard{ margin-top:10px; }
  #yb-terms .yb-actions{ display:flex; flex-wrap:wrap; gap:10px; margin-top:14px; }
  #yb-terms .yb-btn{
    display:inline-flex; align-items:center; justify-content:center;
    border-radius:999px; padding:10px 14px; font-size:13px;
    text-decoration:none; border:1px solid var(--yb-border);
    transition:transform .15s ease, box-shadow .15s ease, filter .15s ease, background .15s ease, color .15s ease;
    white-space:nowrap;
  }
  #yb-terms .yb-btn--primary{
    background:var(--yb-accent); border-color:var(--yb-accent);
    color:#fff; box-shadow:0 18px 60px rgba(0,0,0,.12);
  }
  #yb-terms .yb-btn--primary:hover{ filter:brightness(.98); transform:translateY(-1px); }
  #yb-terms .yb-btn--ghost{
    background:#fff; color:var(--yb-accent);
    border-color:rgba(247,92,3,.45);
  }
  #yb-terms .yb-btn--ghost:hover{
    background:rgba(247,92,3,.06);
    transform:translateY(-1px);
  }

  @media (max-width:520px){
    #yb-terms .yb-terms__title{ font-size:34px; }
  }
</style>

<script>
  (function(){
    var root = document.getElementById('yb-terms');
    if(!root) return;

    var details = root.querySelectorAll('details.yb-acc');
    details.forEach(function(d){
      d.addEventListener('toggle', function(){
        if(!d.open) return;
        details.forEach(function(other){ if(other !== d) other.open = false; });
      });
    });

    function openFromHash(){
      var id = (window.location.hash || '').replace('#','');
      if(!id) return;
      var target = root.querySelector('#' + CSS.escape(id));
      if(target && target.tagName.toLowerCase() === 'details'){
        target.open = true;
        target.scrollIntoView({behavior:'smooth', block:'start'});
      }
    }
    window.addEventListener('hashchange', openFromHash);
    setTimeout(openFromHash, 40);
  })();
</script>
