{# ── Hero ── #}
<section class="yb-hero">
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline" data-glossary-i18n="hero_tagline">Yoga Bible · Ordbog</p>
    <h1 class="yb-hero__title" data-glossary-i18n="hero_title">Yoga Glossary</h1>
    <p class="yb-hero__subtitle" data-glossary-i18n="hero_subtitle">
      Denne ordliste er udviklet af Yoga Bible i København som et fagligt opslagsværk til vores yogalæreruddannelser, studerende og nysgerrige udøvere. Her samler vi centrale begreber fra klassisk og moderne yoga — på sanskrit, dansk og engelsk.
    </p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__trust">
      <span data-glossary-i18n="hero_trust1">Sanskrit · Dansk · Engelsk</span>
      <span class="yb-hero__trust-dot"></span>
      <span data-glossary-i18n="hero_trust2">Klassisk & Moderne Yoga</span>
      <span class="yb-hero__trust-dot"></span>
      <span data-glossary-i18n="hero_trust3">Fagligt Opslagsværk</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>

{# ── Glossary Module ── #}
<section class="program-overview">
  <div class="container">
    <div class="yb-glossary">

      {# Scope toggle (language comes from global subdomain switcher) #}
      <div class="yb-glossary__controls">
        <div class="yb-glossary__scope" role="group" aria-label="Omfang">
          <button class="yb-glossary__scope-btn active" data-scope="common" type="button">Mest brugte</button>
          <button class="yb-glossary__scope-btn" data-scope="all" type="button">Komplet ordbog</button>
        </div>
      </div>

      {# Search #}
      <div class="yb-glossary__search">
        <svg class="yb-glossary__search-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" id="ybGlossarySearch" placeholder="Søg fx &quot;tadasana&quot;, &quot;pranayama&quot; eller &quot;vinyasa&quot;..." class="yb-glossary__input" autocomplete="off" spellcheck="false">
      </div>

      {# Category Filters #}
      <div class="yb-glossary__filters" role="group" aria-label="Kategori">
        <button class="yb-glossary__filter-btn active" data-filter="all" type="button">Alle</button>
        {% for cat in glossary.categories %}
        <button class="yb-glossary__filter-btn" data-filter="{{ cat.id }}" type="button">{{ cat.name_da }}</button>
        {% endfor %}
      </div>

      {# Dynamic sub-filters (JS populates when a category with sub-filters is active) #}
      <div id="ybGlossarySubFilters" class="yb-glossary__subfilters" hidden></div>

      {# Toolbar: A-Z + count #}
      <div class="yb-glossary__toolbar">
        <nav class="yb-glossary__alpha" id="ybGlossaryAlpha" aria-label="A–Z"></nav>
        <p class="yb-glossary__count" id="ybGlossaryCount" aria-live="polite"></p>
      </div>

      {# Results grid #}
      <div id="ybGlossaryResults" class="yb-glossary__grid">
        <p class="yb-glossary__loading">Ordlisten indlæses...</p>
      </div>

      <button id="ybGlossaryMore" class="btn btn--secondary yb-glossary__more-btn" type="button" style="display:none;">Vis flere begreber</button>
    </div>
  </div>
</section>

{# ── CTA ── #}
<section class="cta-section">
  <div class="container">
    <h2 class="cta-section__title" data-glossary-i18n="cta_title">Vil du lære mere?</h2>
    <p class="cta-section__text" data-glossary-i18n="cta_text">Vores 200-timers yogalæreruddannelse dækker alle disse begreber i dybden.</p>
    <a href="{% if lang == 'en' %}/en/om-200hrs-yogalaereruddannelser{% else %}/om-200hrs-yogalaereruddannelser{% endif %}" class="btn btn--large btn--primary" data-glossary-i18n="cta_btn">Se Uddannelser</a>
  </div>
</section>

{# ── JSON-LD: DefinedTermSet (AEO — makes each term citable by AI & search engines) ── #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "DefinedTermSet",
  "name": {{ ("Yoga Glossary — Sanskrit, Danish & English | Yoga Bible" if lang == "en" else "Yoga Ordbog — Sanskrit, dansk & engelsk | Yoga Bible") | dump | safe }},
  "description": {{ ("Searchable yoga glossary with 290+ terms in Sanskrit, Danish and English. Covering asanas, pranayama, philosophy, anatomy and more." if lang == "en" else "Søgbar yoga-ordbog med 290+ begreber på sanskrit, dansk og engelsk. Dækker stillinger, pranayama, filosofi, anatomi og mere.") | dump | safe }},
  "url": "{{ site.url }}{% if lang == 'en' %}/en/yoga-glossary/{% else %}/yoga-glossary/{% endif %}",
  "inLanguage": {{ (["en", "da", "sa"] if lang == "en" else ["da", "en", "sa"]) | dump | safe }},
  "publisher": {
    "@type": "EducationalOrganization",
    "name": "Yoga Bible",
    "url": "{{ site.url }}"
  },
  "hasDefinedTerm": [
    {%- for term in allGlossaryTerms %}
    {
      "@type": "DefinedTerm",
      "name": {{ term.sanskrit | dump | safe }},
      "alternateName": [{{ (term.en if lang == "en" else term.da) | dump | safe }}, {{ (term.da if lang == "en" else term.en) | dump | safe }}],
      "description": {{ (term.desc_en if lang == "en" else term.desc_da) | dump | safe }},
      "inDefinedTermSet": "{{ site.url }}{% if lang == 'en' %}/en/yoga-glossary/{% else %}/yoga-glossary/{% endif %}",
      "termCode": {{ term.category | dump | safe }}
    }{%- if not loop.last %},{% endif %}
    {%- endfor %}
  ]
}
</script>

{# ── Inject glossary data at build time ── #}
<script>
window.YB_GLOSSARY_DATA = {
  terms: {{ allGlossaryTerms | dump | safe }},
  categories: {{ glossary.categories | dump | safe }}
};
</script>
<script src="/js/glossary.js"></script>
