{% set t = i18n.yogamusic[lang or "da"] %}

<!-- ======================= HERO ======================= -->
<section class="yb-hero">
  <div class="yb-hero__bg">
    {# CLOUDINARY: yoga-bible-DK/yogamusic/hero-loop.mp4 — looping ambient video, dark mood #}
    <video autoplay muted loop playsinline poster="{{ 'yoga-bible-DK/yogamusic/hero-poster' | cloudimg('w_1920,h_1080,c_fill') }}">
      <source src="{{ 'yoga-bible-DK/yogamusic/hero-loop' | cloudvid }}" type="video/mp4">
    </video>
  </div>
  <div class="yb-hero__glow"></div>
  <div class="yb-hero__content">
    <p class="yb-hero__tagline">{{ t.hero_tagline }}</p>
    <h1 class="yb-hero__title">{{ t.hero_title }}</h1>
    <p class="yb-hero__subtitle">{{ t.hero_subtitle }}</p>
    <div class="yb-hero__line"></div>
    <div class="yb-hero__ctas">
      <a href="https://on.soundcloud.com/N92LNtGPzJqwYbScA" target="_blank" rel="noopener" class="yb-btn yb-btn--primary yb-btn--large">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="margin-right:6px"><path d="M11.56 8.87V17h8.76c1.85 0 3.35-1.5 3.35-3.35 0-1.85-1.5-3.35-3.35-3.35-.15 0-.29.01-.43.04-.15-1.28-1.23-2.27-2.52-2.27-.34 0-.67.07-.98.2V8.87c0-3.47-2.81-5.87-5.58-5.87C8.05 3 5.97 5.4 5.97 8.87h1.35c0-2.72 1.52-4.52 3.49-4.52 1.97 0 3.75 1.8 3.75 4.52zM1.13 12.22c-.05 0-.09.05-.1.1l-.23 2.15.23 2.1c.01.06.05.1.1.1s.09-.04.1-.1l.25-2.1-.27-2.15c-.01-.06-.05-.1-.08-.1zm.95-1.09c-.06 0-.11.05-.12.12l-.21 3.24.21 3.14c.01.07.06.12.12.12s.11-.05.12-.12l.24-3.14-.25-3.24c-.01-.07-.06-.12-.11-.12zm1.14-.18c-.07 0-.13.06-.14.14l-.18 3.42.18 3.15c.01.08.07.14.14.14s.13-.06.14-.14l.2-3.15-.22-3.42c-.01-.08-.07-.14-.12-.14zm1.15-.43c-.01-.09-.07-.16-.16-.16s-.16.07-.16.16l-.16 3.86.16 3.18c.01.09.07.16.16.16s.16-.07.16-.16l.19-3.18-.19-3.86zm1.17-.16c-.1 0-.18.08-.18.18l-.15 4.01.15 3.2c.01.1.09.18.18.18.1 0 .18-.08.18-.18l.17-3.2-.17-4.01c-.01-.1-.09-.18-.18-.18z"/></svg>
        {{ t.hero_cta_soundcloud }}
      </a>
      <a href="https://open.spotify.com/user/31draywwpkwp4lljbv6onkmr6i5i" target="_blank" rel="noopener" class="yb-btn yb-btn--outline-white yb-btn--large">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" style="margin-right:6px"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
        {{ t.hero_cta_spotify }}
      </a>
    </div>
    <div class="yb-hero__trust">
      <span>{{ t.hero_trust1 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust2 }}</span>
      <span class="yb-hero__trust-dot"></span>
      <span>{{ t.hero_trust3 }}</span>
    </div>
  </div>
  <div class="yb-hero__scroll">
    <span>Scroll</span>
    <div class="yb-hero__scroll-line"></div>
  </div>
</section>


<!-- ======================= OUR UNIVERSE (Split Layout) ======================= -->
<section class="ym-universe">
  <div class="ym-universe__inner">
    <div class="ym-universe__grid">

      <div class="ym-universe__content" data-scroll="fade-up">
        <span class="ym-eyebrow">{{ t.universe_eyebrow }}</span>
        <h2 class="ym-universe__title">{{ t.universe_title }}</h2>
        <p class="ym-universe__text">{{ t.universe_text1 | safe }}</p>
        <p class="ym-universe__text">{{ t.universe_text2 | safe }}</p>
        <div class="ym-stream-links">
          <a href="https://on.soundcloud.com/N92LNtGPzJqwYbScA" target="_blank" rel="noopener" class="yb-btn yb-btn--primary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M11.56 8.87V17h8.76c1.85 0 3.35-1.5 3.35-3.35 0-1.85-1.5-3.35-3.35-3.35-.15 0-.29.01-.43.04-.15-1.28-1.23-2.27-2.52-2.27-.34 0-.67.07-.98.2V8.87c0-3.47-2.81-5.87-5.58-5.87C8.05 3 5.97 5.4 5.97 8.87h1.35c0-2.72 1.52-4.52 3.49-4.52 1.97 0 3.75 1.8 3.75 4.52zM1.13 12.22c-.05 0-.09.05-.1.1l-.23 2.15.23 2.1c.01.06.05.1.1.1s.09-.04.1-.1l.25-2.1-.27-2.15c-.01-.06-.05-.1-.08-.1zm.95-1.09c-.06 0-.11.05-.12.12l-.21 3.24.21 3.14c.01.07.06.12.12.12s.11-.05.12-.12l.24-3.14-.25-3.24c-.01-.07-.06-.12-.11-.12zm1.14-.18c-.07 0-.13.06-.14.14l-.18 3.42.18 3.15c.01.08.07.14.14.14s.13-.06.14-.14l.2-3.15-.22-3.42c-.01-.08-.07-.14-.12-.14zm1.15-.43c-.01-.09-.07-.16-.16-.16s-.16.07-.16.16l-.16 3.86.16 3.18c.01.09.07.16.16.16s.16-.07.16-.16l.19-3.18-.19-3.86zm1.17-.16c-.1 0-.18.08-.18.18l-.15 4.01.15 3.2c.01.1.09.18.18.18.1 0 .18-.08.18-.18l.17-3.2-.17-4.01c-.01-.1-.09-.18-.18-.18z"/></svg>
            {{ t.universe_cta_soundcloud }}
          </a>
          <a href="https://open.spotify.com/user/31draywwpkwp4lljbv6onkmr6i5i" target="_blank" rel="noopener" class="yb-btn yb-btn--outline">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.4 0 0 5.4 0 12s5.4 12 12 12 12-5.4 12-12S18.66 0 12 0zm5.521 17.34c-.24.359-.66.48-1.021.24-2.82-1.74-6.36-2.101-10.561-1.141-.418.122-.779-.179-.899-.539-.12-.421.18-.78.54-.9 4.56-1.021 8.52-.6 11.64 1.32.42.18.479.659.301 1.02zm1.44-3.3c-.301.42-.841.6-1.262.3-3.239-1.98-8.159-2.58-11.939-1.38-.479.12-1.02-.12-1.14-.6-.12-.48.12-1.021.6-1.141C9.6 9.9 15 10.561 18.72 12.84c.361.181.54.78.241 1.2zm.12-3.36C15.24 8.4 8.82 8.16 5.16 9.301c-.6.179-1.2-.181-1.38-.721-.18-.601.18-1.2.72-1.381 4.26-1.26 11.28-1.02 15.721 1.621.539.3.719 1.02.419 1.56-.299.421-1.02.599-1.559.3z"/></svg>
            {{ t.universe_cta_spotify }}
          </a>
        </div>
      </div>

      <div class="ym-universe__visual" data-scroll="fade-up" data-scroll-delay="150">
        <div class="ym-phone-frame">
          {# CLOUDINARY: yoga-bible-DK/yogamusic/phone-loop.mp4 — vertical video, 9:16 aspect #}
          <video autoplay muted loop playsinline poster="{{ 'yoga-bible-DK/yogamusic/phone-poster' | cloudimg('w_680,h_1210,c_fill') }}">
            <source src="{{ 'yoga-bible-DK/yogamusic/phone-loop' | cloudvid }}" type="video/mp4">
          </video>
        </div>
      </div>

    </div>
  </div>
</section>


<!-- ======================= ENERGY ARC (Behind The Music) ======================= -->
<section class="ym-arc">
  <div class="ym-arc__inner">
    <div class="ym-arc__header" data-scroll="fade-up">
      <span class="ym-eyebrow ym-eyebrow--center">{{ t.arc_eyebrow }}</span>
      <h2 class="ym-section-title">{{ t.arc_title }}</h2>
      <p class="ym-section-subtitle">{{ t.arc_subtitle }}</p>
    </div>

    <div class="ym-arc__box" data-scroll="fade-up">
      <div class="ym-arc__box-intro">
        <h3>{{ t.arc_journey_title }}</h3>
        <p>{{ t.arc_journey_desc }}</p>
      </div>

      <!-- SVG Energy Curve -->
      <div class="ym-arc__curve-wrap">
        <div class="ym-arc__peak-label"><span>{{ t.arc_peak }}</span></div>
        <div class="ym-arc__svg-container">
          <svg viewBox="0 0 800 120" preserveAspectRatio="none" class="ym-arc__svg">
            <defs>
              <linearGradient id="ymCurveGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" style="stop-color:#64b5f6;stop-opacity:0.8"/>
                <stop offset="25%" style="stop-color:#81c784;stop-opacity:0.8"/>
                <stop offset="50%" style="stop-color:#f75c03;stop-opacity:1"/>
                <stop offset="75%" style="stop-color:#81c784;stop-opacity:0.8"/>
                <stop offset="100%" style="stop-color:#64b5f6;stop-opacity:0.8"/>
              </linearGradient>
              <linearGradient id="ymFillGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" style="stop-color:#f75c03;stop-opacity:0.1"/>
                <stop offset="100%" style="stop-color:#f75c03;stop-opacity:0.01"/>
              </linearGradient>
            </defs>
            <path d="M 0,115 Q 200,115 300,60 Q 400,5 400,5 Q 400,5 500,60 Q 600,115 800,115 L 800,120 L 0,120 Z" fill="url(#ymFillGrad)"/>
            <path d="M 0,115 Q 200,115 300,60 Q 400,5 400,5 Q 400,5 500,60 Q 600,115 800,115" fill="none" stroke="url(#ymCurveGrad)" stroke-width="3.5" stroke-linecap="round"/>
            <circle cx="400" cy="5" r="5" fill="#f75c03"/>
          </svg>
        </div>
        <div class="ym-arc__side-labels">
          <div class="ym-arc__side-label">{{ t.arc_grounding }}<small>{{ t.arc_grounding_sub }}</small></div>
          <div class="ym-arc__side-label">{{ t.arc_shavasana }}<small>{{ t.arc_shavasana_sub }}</small></div>
        </div>
      </div>

      <!-- Phase Cards -->
      <div class="ym-arc__phases">
        <div class="ym-arc__phase">
          <div class="ym-arc__phase-time">{{ t.arc_phase1_time }}</div>
          <div class="ym-arc__phase-name">{{ t.arc_phase1_name }}</div>
          <div class="ym-arc__phase-bpm">{{ t.arc_phase1_bpm }} <span>BPM</span></div>
          <p>{{ t.arc_phase1_desc }}</p>
        </div>
        <div class="ym-arc__phase">
          <div class="ym-arc__phase-time">{{ t.arc_phase2_time }}</div>
          <div class="ym-arc__phase-name">{{ t.arc_phase2_name }}</div>
          <div class="ym-arc__phase-bpm">{{ t.arc_phase2_bpm }} <span>BPM</span></div>
          <p>{{ t.arc_phase2_desc }}</p>
        </div>
        <div class="ym-arc__phase">
          <div class="ym-arc__phase-time">{{ t.arc_phase3_time }}</div>
          <div class="ym-arc__phase-name">{{ t.arc_phase3_name }}</div>
          <div class="ym-arc__phase-bpm">{{ t.arc_phase3_bpm }} <span>BPM</span></div>
          <p>{{ t.arc_phase3_desc }}</p>
        </div>
      </div>
    </div>
  </div>
</section>


<!-- ======================= DESIGN PRINCIPLES ======================= -->
<section class="ym-principles">
  <div class="ym-principles__inner">
    <div class="ym-principles__header" data-scroll="fade-up">
      <span class="ym-eyebrow ym-eyebrow--center">{{ t.principles_eyebrow }}</span>
      <h2 class="ym-section-title">{{ t.principles_title }}</h2>
      <p class="ym-section-subtitle">{{ t.principles_subtitle }}</p>
    </div>

    <div class="ym-principles__grid" data-scroll="stagger">
      <div class="ym-principles__card">
        <div class="ym-principles__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand)" stroke-width="2" stroke-linecap="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        </div>
        <h3>{{ t.prin1_title }}</h3>
        <p>{{ t.prin1_desc }}</p>
      </div>
      <div class="ym-principles__card">
        <div class="ym-principles__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand)" stroke-width="2" stroke-linecap="round"><path d="M17 2.1l4 4-4 4"/><path d="M3 12.2v-2a4 4 0 0 1 4-4h12.8M7 21.9l-4-4 4-4"/><path d="M21 11.8v2a4 4 0 0 1-4 4H4.2"/></svg>
        </div>
        <h3>{{ t.prin2_title }}</h3>
        <p>{{ t.prin2_desc }}</p>
      </div>
      <div class="ym-principles__card">
        <div class="ym-principles__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand)" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
        </div>
        <h3>{{ t.prin3_title }}</h3>
        <p>{{ t.prin3_desc }}</p>
      </div>
      <div class="ym-principles__card">
        <div class="ym-principles__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--yb-brand)" stroke-width="2" stroke-linecap="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        </div>
        <h3>{{ t.prin4_title }}</h3>
        <p>{{ t.prin4_desc }}</p>
      </div>
    </div>
  </div>
</section>


<!-- ======================= LISTEN NOW (SoundCloud Embed) ======================= -->
<section class="ym-listen">
  <div class="ym-listen__inner">
    <div class="ym-listen__header" data-scroll="fade-up">
      <span class="ym-eyebrow ym-eyebrow--center ym-eyebrow--light">{{ t.listen_eyebrow }}</span>
      <h2 class="ym-section-title ym-section-title--light">{{ t.listen_title }}</h2>
      <p class="ym-section-subtitle ym-section-subtitle--light">{{ t.listen_subtitle }}</p>
    </div>
    <div class="ym-listen__embed" data-scroll="fade-up">
      <iframe
        width="100%"
        height="166"
        scrolling="no"
        frameborder="no"
        allow="autoplay"
        src="https://w.soundcloud.com/player/?url=https%3A//api.soundcloud.com/users/yogabible&color=%23f75c03&auto_play=false&hide_related=true&show_comments=false&show_user=true&show_reposts=false&show_teaser=false"
        loading="lazy"
      ></iframe>
    </div>
  </div>
</section>


<!-- ======================= FOR ARTISTS & DJs (Dark Section) ======================= -->
<section class="ym-artists">
  <div class="ym-artists__inner">

    <div class="ym-artists__header" data-scroll="fade-up">
      <span class="ym-eyebrow ym-eyebrow--center ym-eyebrow--light">{{ t.artists_eyebrow }}</span>
      <h2 class="ym-section-title ym-section-title--light">{{ t.artists_title }}</h2>
      <p class="ym-section-subtitle ym-section-subtitle--light">{{ t.artists_subtitle }}</p>
    </div>

    <!-- Philosophy Quote -->
    <div class="ym-artists__philosophy" data-scroll="fade-up">
      <p>{{ t.artists_philosophy | safe }}</p>
    </div>

    <!-- Detailed Arc Visualization -->
    <div class="ym-artists__arc" data-scroll="fade-up">
      <h3 class="ym-artists__arc-title">{{ t.artists_arc_title }}</h3>

      <div class="ym-artists__phases-bar">
        <div class="ym-artists__phase-bar ym-artists__phase-bar--warmup">{{ t.artists_warmup }} <span>20 min</span></div>
        <div class="ym-artists__phase-bar ym-artists__phase-bar--peak">{{ t.artists_peak }} <span>20 min</span></div>
        <div class="ym-artists__phase-bar ym-artists__phase-bar--cooldown">{{ t.artists_cooldown }} <span>20 min</span></div>
      </div>

      <div class="ym-artists__curve-wrap">
        <div class="ym-artists__peak-label"><span>{{ t.artists_peak_energy }}</span></div>
        <div class="ym-artists__svg-container">
          <svg viewBox="0 0 1000 140" preserveAspectRatio="none" class="ym-artists__svg">
            <defs>
              <linearGradient id="ymArtistCurveGrad" x1="0%" y1="0%" x2="100%" y2="0%">
                <stop offset="0%" style="stop-color:#64b5f6;stop-opacity:1"/>
                <stop offset="17%" style="stop-color:#81c784;stop-opacity:1"/>
                <stop offset="33%" style="stop-color:#9ccc65;stop-opacity:1"/>
                <stop offset="50%" style="stop-color:#f75c03;stop-opacity:1"/>
                <stop offset="67%" style="stop-color:#9ccc65;stop-opacity:1"/>
                <stop offset="83%" style="stop-color:#81c784;stop-opacity:1"/>
                <stop offset="100%" style="stop-color:#64b5f6;stop-opacity:1"/>
              </linearGradient>
              <linearGradient id="ymArtistFillGrad" x1="0%" y1="0%" x2="0%" y2="100%">
                <stop offset="0%" style="stop-color:#f75c03;stop-opacity:0.15"/>
                <stop offset="100%" style="stop-color:#f75c03;stop-opacity:0.01"/>
              </linearGradient>
            </defs>
            <line x1="167" y1="20" x2="167" y2="125" stroke="rgba(255,255,255,0.06)" stroke-dasharray="4,4"/>
            <line x1="333" y1="20" x2="333" y2="125" stroke="rgba(255,255,255,0.06)" stroke-dasharray="4,4"/>
            <line x1="500" y1="20" x2="500" y2="125" stroke="rgba(247,92,3,0.25)" stroke-dasharray="4,4"/>
            <line x1="667" y1="20" x2="667" y2="125" stroke="rgba(255,255,255,0.06)" stroke-dasharray="4,4"/>
            <line x1="833" y1="20" x2="833" y2="125" stroke="rgba(255,255,255,0.06)" stroke-dasharray="4,4"/>
            <path d="M 0,125 C 100,125 150,120 200,110 C 280,95 350,70 400,45 C 450,25 480,12 500,10 C 520,12 550,25 600,45 C 650,70 720,95 800,110 C 850,120 900,125 1000,125 L 1000,140 L 0,140 Z" fill="url(#ymArtistFillGrad)"/>
            <path d="M 0,125 C 100,125 150,120 200,110 C 280,95 350,70 400,45 C 450,25 480,12 500,10 C 520,12 550,25 600,45 C 650,70 720,95 800,110 C 850,120 900,125 1000,125" fill="none" stroke="url(#ymArtistCurveGrad)" stroke-width="4" stroke-linecap="round"/>
            <circle cx="500" cy="10" r="6" fill="#f75c03"/>
            <circle cx="500" cy="10" r="10" fill="none" stroke="#f75c03" stroke-opacity="0.4" stroke-width="2"/>
          </svg>
        </div>
        <div class="ym-artists__side-labels">
          <div class="ym-artists__side-label">{{ t.artists_grounding }}<small>{{ t.artists_grounding_sub }}</small></div>
          <div class="ym-artists__side-label ym-artists__side-label--right">{{ t.artists_surrender }}<small>{{ t.artists_surrender_sub }}</small></div>
        </div>
        <div class="ym-artists__timeline">
          <span>0:00</span><span>10:00</span><span>20:00</span><span>30:00</span><span>40:00</span><span>50:00</span><span>60:00</span>
        </div>
      </div>

      <!-- 6-Segment Cards -->
      <div class="ym-artists__segments">
        {% set segs = [1,2,3,4,5,6] %}
        {% for s in segs %}
        <div class="ym-artists__segment">
          <div class="ym-artists__segment-label">{{ t["artists_seg" + s + "_label"] }}</div>
          <div class="ym-artists__segment-bpm">{{ t["artists_seg" + s + "_bpm"] }} <span>BPM</span></div>
          <div class="ym-artists__segment-desc">{{ t["artists_seg" + s + "_desc"] }}</div>
        </div>
        {% endfor %}
      </div>
    </div>

    <!-- Rules Grid -->
    <div class="ym-artists__rules" data-scroll="stagger">
      {% set rules = [
        { num: 1, icon: "M9 18V5l12-2v13M6 18a3 3 0 1 0 0-6 3 3 0 0 0 0 6zM18 16a3 3 0 1 0 0-6 3 3 0 0 0 0 6z", type: "" },
        { num: 2, icon: "M2 20h.01M7 20v-4M12 20v-8M17 20V8M22 4v16", type: "" },
        { num: 3, icon: "M18.36 6.64a9 9 0 1 1-12.73 0M12 2v10", type: "avoid" },
        { num: 4, icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5", type: "prefer" }
      ] %}
      {% for rule in rules %}
      <div class="ym-artists__rule{% if rule.type %} ym-artists__rule--{{ rule.type }}{% endif %}">
        <div class="ym-artists__rule-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="{{ rule.icon }}"/></svg>
        </div>
        <h3>{{ t["artists_rule" + rule.num + "_title"] }}</h3>
        <ul>
          {% for item in t["artists_rule" + rule.num + "_items"] %}
          <li>{{ item }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endfor %}
    </div>

    <!-- Tech Specs -->
    <div class="ym-artists__specs" data-scroll="fade-up">
      <div class="ym-artists__spec">
        <div class="ym-artists__spec-value">{{ t.artists_spec1_value }}<span>{{ t.artists_spec1_unit }}</span></div>
        <div class="ym-artists__spec-label">{{ t.artists_spec1_label }}</div>
      </div>
      <div class="ym-artists__spec">
        <div class="ym-artists__spec-value">{{ t.artists_spec2_value }}</div>
        <div class="ym-artists__spec-label">{{ t.artists_spec2_label }}</div>
      </div>
      <div class="ym-artists__spec">
        <div class="ym-artists__spec-value">{{ t.artists_spec3_value }}</div>
        <div class="ym-artists__spec-label">{{ t.artists_spec3_label }}</div>
      </div>
      <div class="ym-artists__spec">
        <div class="ym-artists__spec-value">{{ t.artists_spec4_value }}</div>
        <div class="ym-artists__spec-label">{{ t.artists_spec4_label }}</div>
      </div>
    </div>

    <!-- Artist CTA -->
    <div class="ym-artists__cta" data-scroll="fade-up">
      <h3>{{ t.artists_cta_title }}</h3>
      <p>{{ t.artists_cta_text }}</p>
      <a href="mailto:info@yogabible.dk?subject=Music%20Collaboration" class="yb-btn yb-btn--primary yb-btn--large">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" style="margin-right:6px"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        {{ t.artists_cta_btn }}
      </a>
      <p class="ym-artists__cta-email">{{ t.artists_cta_email }} <a href="mailto:info@yogabible.dk">info@yogabible.dk</a></p>
    </div>

  </div>
</section>


<!-- ======================= MEET THE CREATORS ======================= -->
<section class="ym-creators">
  <div class="ym-creators__inner">
    <div class="ym-creators__header" data-scroll="fade-up">
      <span class="ym-eyebrow ym-eyebrow--center">{{ t.creators_eyebrow }}</span>
      <h2 class="ym-section-title">{{ t.creators_title }}</h2>
      <p class="ym-section-subtitle">{{ t.creators_desc }}</p>
    </div>
    {# Creator cards can be added here when artist profiles are ready #}
  </div>
</section>


<!-- ======================= FAQ ======================= -->
<section class="ym-faq">
  <div class="ym-faq__inner">
    <div class="ym-faq__header" data-scroll="fade-up">
      <span class="ym-eyebrow ym-eyebrow--center">{{ t.faq_eyebrow }}</span>
      <h2 class="ym-section-title">{{ t.faq_title }}</h2>
    </div>

    <div class="ym-faq__list" data-scroll="stagger">
      {% set faqs = [1,2,3,4,5] %}
      {% for n in faqs %}
      <details class="ym-faq__item">
        <summary class="ym-faq__question">
          <span>{{ t["faq" + n + "_q"] }}</span>
          <div class="ym-faq__toggle"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></div>
        </summary>
        <div class="ym-faq__answer">
          <p>{{ t["faq" + n + "_a"] }}</p>
        </div>
      </details>
      {% endfor %}
    </div>
  </div>
</section>


