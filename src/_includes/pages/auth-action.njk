{% set t = i18n["auth-action"][lang or "da"] %}

<section class="yb-auth-action">
  <div class="yb-auth-action__card">
    <div class="yb-auth-action__logo">
      <img src="/assets/images/brand/logo-orange-on-transparent.png" alt="Yoga Bible" loading="lazy" />
    </div>

    <!-- Loading state -->
    <div id="yb-aa-loading" class="yb-auth-action__step">
      <h2 class="yb-auth-action__title">{{ t.loading }}</h2>
      <div class="yb-auth-action__spinner"></div>
    </div>

    <!-- Reset password form -->
    <div id="yb-aa-reset" class="yb-auth-action__step" hidden>
      <h2 class="yb-auth-action__title">{{ t.title_reset }}</h2>
      <p class="yb-auth-action__subtitle">{{ t.subtitle_reset }}</p>

      <form id="yb-aa-reset-form" class="yb-auth-form" novalidate>
        <div class="yb-auth-field">
          <label for="yb-aa-password">{{ t.label_password }}</label>
          <input type="password" id="yb-aa-password" required autocomplete="new-password" placeholder="{{ t.placeholder_password }}" minlength="6">
        </div>
        <div class="yb-auth-field">
          <label for="yb-aa-confirm">{{ t.label_confirm }}</label>
          <input type="password" id="yb-aa-confirm" required autocomplete="new-password" placeholder="{{ t.placeholder_confirm }}" minlength="6">
        </div>
        <div class="yb-auth-error" id="yb-aa-error" hidden role="alert"></div>
        <button type="submit" class="yb-auth-submit">{{ t.btn_submit }}</button>
      </form>
    </div>

    <!-- Success -->
    <div id="yb-aa-success" class="yb-auth-action__step" hidden>
      <div class="yb-auth-action__icon yb-auth-action__icon--success">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </div>
      <h2 class="yb-auth-action__title">{{ t.success_title }}</h2>
      <p class="yb-auth-action__subtitle">{{ t.success_text }}</p>
      <button type="button" class="yb-auth-submit" onclick="if(window.openAuthModal){window.openAuthModal()}else{window.location.href='{% if lang == 'en' %}/en{% endif %}/profile'}">{{ t.btn_login }}</button>
    </div>

    <!-- Email verified -->
    <div id="yb-aa-verified" class="yb-auth-action__step" hidden>
      <div class="yb-auth-action__icon yb-auth-action__icon--success">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </div>
      <h2 class="yb-auth-action__title">{{ t.title_verify }}</h2>
      <p class="yb-auth-action__subtitle">{{ t.subtitle_verify }}</p>
    </div>

    <!-- Expired / invalid -->
    <div id="yb-aa-expired" class="yb-auth-action__step" hidden>
      <div class="yb-auth-action__icon yb-auth-action__icon--error">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      </div>
      <h2 class="yb-auth-action__title">{{ t.title_expired }}</h2>
      <p class="yb-auth-action__subtitle">{{ t.subtitle_expired }}</p>
      <button type="button" class="yb-auth-submit" onclick="if(window.openAuthModal){document.querySelector('[data-yb-auth-switch=reset]').click()}else{window.location.href='{% if lang == 'en' %}/en{% endif %}/profile'}">{{ t.btn_request_new }}</button>
    </div>
  </div>
</section>

<script>
(function() {
  'use strict';

  var params = new URLSearchParams(window.location.search);
  var mode = params.get('mode');
  var oobCode = params.get('oobCode');
  var lang = '{{ lang or "da" }}';

  var t = {
    error_mismatch: {{ t.error_mismatch | dump | safe }},
    error_short: {{ t.error_short | dump | safe }},
    error_invalid: {{ t.error_invalid | dump | safe }},
    error_generic: {{ t.error_generic | dump | safe }}
  };

  function showStep(id) {
    var steps = document.querySelectorAll('.yb-auth-action__step');
    for (var i = 0; i < steps.length; i++) { steps[i].hidden = true; }
    var el = document.getElementById(id);
    if (el) el.hidden = false;
  }

  function showError(msg) {
    var el = document.getElementById('yb-aa-error');
    if (el) { el.textContent = msg; el.hidden = false; }
  }

  // Wait for Firebase to be available
  function waitForFirebase(cb) {
    if (typeof firebase !== 'undefined' && firebase.apps && firebase.apps.length) {
      cb(firebase.auth());
    } else {
      setTimeout(function() { waitForFirebase(cb); }, 100);
    }
  }

  if (!mode || !oobCode) {
    showStep('yb-aa-expired');
    return;
  }

  waitForFirebase(function(auth) {
    if (mode === 'resetPassword') {
      // Verify the code is valid first
      auth.verifyPasswordResetCode(oobCode)
        .then(function() {
          showStep('yb-aa-reset');
        })
        .catch(function() {
          showStep('yb-aa-expired');
        });

      // Handle form submission
      var form = document.getElementById('yb-aa-reset-form');
      if (form) {
        form.addEventListener('submit', function(e) {
          e.preventDefault();
          var pw = document.getElementById('yb-aa-password').value;
          var confirm = document.getElementById('yb-aa-confirm').value;
          var btn = form.querySelector('button[type="submit"]');

          if (pw.length < 6) { showError(t.error_short); return; }
          if (pw !== confirm) { showError(t.error_mismatch); return; }

          btn.disabled = true;

          auth.confirmPasswordReset(oobCode, pw)
            .then(function() {
              showStep('yb-aa-success');
            })
            .catch(function(err) {
              btn.disabled = false;
              if (err.code === 'auth/expired-action-code' || err.code === 'auth/invalid-action-code') {
                showStep('yb-aa-expired');
              } else if (err.code === 'auth/weak-password') {
                showError(t.error_short);
              } else {
                showError(t.error_generic);
              }
            });
        });
      }

    } else if (mode === 'verifyEmail') {
      auth.applyActionCode(oobCode)
        .then(function() { showStep('yb-aa-verified'); })
        .catch(function() { showStep('yb-aa-expired'); });

    } else {
      showStep('yb-aa-expired');
    }
  });
})();
</script>
