</style>

<script>
/* ===== Inversions: month chip -> CTA text/link (new tab) ===== */
(function(){
  const root = document.getElementById('ybC-hero');
  if(!root) return;
  const chips = root.querySelectorAll('.ybC-chip');
  const cta   = root.querySelector('#ybC-ctaMain');
  const prefix = {{ t.hero_cta_prefix | dump | safe }};
  const suffix = {{ t.hero_cta_suffix | dump | safe }};

  function setMonth(btn){
    chips.forEach(b => b.classList.toggle('is-active', b === btn));
    const label = (btn.dataset.month || btn.textContent || '').trim();
    const link  = btn.dataset.href || '#';
    if (cta){
      cta.textContent = prefix + ' ' + label.toLowerCase() + suffix;
      cta.setAttribute('href', link);
      cta.setAttribute('target','_blank');
      cta.setAttribute('rel','noopener noreferrer nofollow');
    }
  }

  chips.forEach(btn => btn.addEventListener('click', ()=> setMonth(btn)));
  const active = root.querySelector('.ybC-chip.is-active') || chips[0];
  if (active) setMonth(active);
})();
</script>


