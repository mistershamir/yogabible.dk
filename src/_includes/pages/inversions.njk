  }
</style>

<script>
(function(){
  var root = document.getElementById('yb-inversions-4weeks');
  if (!root) return;

  var left = document.getElementById('yb-left');
  var right = document.getElementById('yb-right');
  var faq = document.getElementById('yb-faq');
  var rightWrap = right ? right.querySelector('.yb-inversions4__video-wrap') : null;

  /* FAQ accordion */
  var faqItems = root.querySelectorAll('.yb-faq__item');
  function recalcHeight(){ if (window.matchMedia('(min-width: 880px)').matches) matchHeights(); }
  faqItems.forEach(function(item){
    var btn = item.querySelector('.yb-faq__toggle');
    var panel = item.querySelector('.yb-faq__panel');
    if(!btn || !panel) return;
    btn.addEventListener('click', function(){
      var open = item.classList.contains('is-open');
      if(open){
        item.classList.remove('is-open');
        panel.style.maxHeight = '0px';
      } else {
        faqItems.forEach(function(o){
          if(o !== item){
            o.classList.remove('is-open');
            var op = o.querySelector('.yb-faq__panel');
            if(op) op.style.maxHeight = '0px';
          }
        });
        item.classList.add('is-open');
        panel.style.maxHeight = panel.scrollHeight + 'px';
      }
      setTimeout(recalcHeight, 180);
    });
  });

  /* Video play/pause + poster */
  var video = document.getElementById('yb-inversions-video');
  var toggle = root.querySelector('.yb-video-toggle');
  var posterBtn = document.getElementById('yb-video-poster');
  var posterImg = posterBtn ? posterBtn.querySelector('img') : null;

  function setUI(playing){
    if(toggle){
      toggle.classList.toggle('is-playing', playing);
      toggle.setAttribute('aria-pressed', playing ? 'true' : 'false');
    }
    if(posterBtn){ posterBtn.classList.toggle('is-hidden', playing); }
  }

  function tryPlay(resetToStart){
    if(!video) return;
    if (resetToStart){ try { video.currentTime = 0; } catch(e){} }
    video.muted = false;
    video.loop = true;
    var p = video.play();
    if (p && p.catch){
      p.catch(function(){
        video.setAttribute('controls','');
        video.play().catch(function(){});
      });
    }
  }

  if (posterBtn){ posterBtn.addEventListener('click', function(){ tryPlay(); }); }
  if (toggle){
    toggle.addEventListener('click', function(){
      if(!video) return;
      if(video.paused){ tryPlay(); } else { video.pause(); }
    });
  }
  if (video){
    video.addEventListener('click', function(){ if(video.paused){ tryPlay(); } else { video.pause(); } });
    video.addEventListener('play', function(){ setUI(true); });
    video.addEventListener('pause', function(){ setUI(false); });
    video.addEventListener('ended', function(){ setUI(false); tryPlay(true); });
  }

  function capturePoster(){
    if(!video || !posterImg) return;
    try{
      if (video.readyState >= 2) {
        var w = video.videoWidth || 720;
        var h = video.videoHeight || 1280;
        var canvas = document.createElement('canvas');
        canvas.width = w; canvas.height = h;
        canvas.getContext('2d').drawImage(video, 0, 0, w, h);
        posterImg.src = canvas.toDataURL('image/jpeg', 0.86);
      }
    }catch(e){}
  }
  (function preparePoster(){
    if(!video) return;
    let captured = false;
    video.addEventListener('loadeddata', function(){
      if (!captured){
        captured = true;
        try { video.currentTime = Math.min(0.3, (video.duration || 1) * 0.03); } catch(e){}
      }
    });
    video.addEventListener('seeked', capturePoster);
    setTimeout(capturePoster, 1200);
  })();

  function matchHeights(){
    if(!left || !rightWrap) return;
    if (!window.matchMedia('(min-width: 880px)').matches){
      rightWrap.style.height = 'auto';
      return;
    }
    var h = left.offsetHeight;
    rightWrap.style.height = Math.max(200, h - 1) + 'px';
  }

  function placeFAQ(){
    if(!faq || !left || !right) return;
    if (window.matchMedia('(max-width: 879px)').matches){
      if (faq.parentElement !== root.querySelector('.yb-inversions4__grid')){
        root.querySelector('.yb-inversions4__grid').appendChild(faq);
      }
    } else {
      if (faq.parentElement !== left){ left.appendChild(faq); }
    }
    matchHeights();
  }

  window.addEventListener('load', function(){ placeFAQ(); matchHeights(); setUI(false); });
  window.addEventListener('resize', placeFAQ);
  setTimeout(placeFAQ, 300);
})();
</script>


