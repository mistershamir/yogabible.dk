<script>
(function(){
  const section = document.getElementById('yb-inversions-fall');
  if(!section) return;

  const video = section.querySelector('.ybFall__video');
  const lines = Array.from(section.querySelectorAll('.ybFall__line'));

  let seqTimer = null;
  let index = 0;

  const tryPlay = () => video && video.play && video.play().catch(()=>{});
  if (document.readyState === 'complete' || document.readyState === 'interactive') {
    tryPlay();
  } else {
    window.addEventListener('DOMContentLoaded', tryPlay, { once:true });
  }
  const nudge = ()=>{
    tryPlay();
    window.removeEventListener('touchstart', nudge);
    window.removeEventListener('click', nudge);
  };
  window.addEventListener('touchstart', nudge, { once:true, passive:true });
  window.addEventListener('click', nudge, { once:true });

  function clearHot(){
    lines.forEach(l => l.classList.remove('is-hot'));
  }

  function startLoop(){
    if(seqTimer || !lines.length) return;

    clearHot();
    index = 0;
    if(lines[index]) lines[index].classList.add('is-hot');

    const stepMs = 1200;
    const fadeGapMs = 120;

    seqTimer = setInterval(() => {
      if(lines[index]) lines[index].classList.remove('is-hot');
      index = (index + 1) % lines.length;

      setTimeout(() => {
        if(!section.classList.contains('is-inview')) return;
        if(lines[index]) lines[index].classList.add('is-hot');
      }, fadeGapMs);

    }, stepMs);
  }

  function stopLoop(){
    if(seqTimer){
      clearInterval(seqTimer);
      seqTimer = null;
    }
    clearHot();
  }

  const io = ('IntersectionObserver' in window)
    ? new IntersectionObserver((entries)=>{
        entries.forEach(e=>{
          if(e.isIntersecting){
            section.classList.add('is-inview');
            startLoop();
          }else{
            section.classList.remove('is-inview');
            stopLoop();
          }
        });
      }, { threshold:0.35 })
    : null;

  if(io) io.observe(section);
  else {
    section.classList.add('is-inview');
    startLoop();
  }
})();
</script>


