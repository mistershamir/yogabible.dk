<!-- ===== YogaBible.dk • Inversions Hero (matched) ===== -->
<section id="ybC-hero" class="ybC-hero" aria-label="{{ t.hero_aria_label }}">
  <div class="ybC-hero__inner">

    <!-- LEFT: Text -->
    <div class="ybC-hero__content">
      <p class="ybC-eyebrow">{{ t.hero_eyebrow }}</p>

      <h1 class="ybC-title">
        {{ t.hero_title | safe }}
      </h1>

      <p class="ybC-sub">{{ t.hero_sub }}</p>
      <p class="ybC-kicker">{{ t.hero_kicker }}</p>

      <p class="ybC-lead">
        {{ t.hero_lead }}
      </p>

      <p class="ybC-meta">
        {{ t.hero_meta }}
      </p>

      <!-- Pricing pill -->
      <div class="ybC-price">
        <div class="ybC-price__row">
          <span class="ybC-price__label">{{ t.hero_price_label }}</span>
          <span class="ybC-price__value">{{ t.hero_price_value }}</span>
          <span class="ybC-price__hint">{{ t.hero_price_hint }}</span>
        </div>
        <div class="ybC-price__row">
          <span class="ybC-price__label">{{ t.hero_dropin_label }}</span>
          <span class="ybC-price__value">{{ t.hero_dropin_value }}</span>
        </div>
      </div>

      <!-- Months -->
      <div class="ybC-months" role="tablist" aria-label="{{ t.hero_months_aria }}">
        <button class="ybC-chip is-active" data-month="Januar 2026"
                data-href="https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=41&sTG=33&prodId=100143">Januar 2026</button>
        <button class="ybC-chip" data-month="Februar 2026"
                data-href="https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=41&sTG=33&prodId=100109">Februar 2026</button>
        <button class="ybC-chip" data-month="Marts 2026"
                data-href="https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=41&sTG=33&prodId=100144">Marts 2026</button>
        <button class="ybC-chip" data-month="April 2026"
                data-href="https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=41&sTG=33&prodId=100145">April 2026</button>
        <button class="ybC-chip" data-month="Maj 2026"
                data-href="https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=41&sTG=33&prodId=100146">Maj 2026</button>
      </div>

      <!-- CTAs -->
      <div class="ybC-ctas">
        <button id="ybC-openModal" class="ybC-btn ybC-btn--outline" type="button"
                data-ybc-open="brochure" data-ybc-course="Inversions" data-ybc-source="Inversions – hero">{{ t.hero_btn_schedule }}</button>

        <a id="ybC-ctaMain" class="ybC-btn"
           href="https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=41&sTG=33&prodId=100143"
           target="_blank" rel="noopener noreferrer nofollow">
          {{ t.hero_cta_prefix }} januar 2026{{ t.hero_cta_suffix }}
        </a>
      </div>
    </div>

    <!-- RIGHT: Media -->
    <figure class="ybC-hero__media" aria-hidden="true">
      <img
        src="/assets/images/inversions/hero.jpg"
        alt="{{ t.hero_img_alt }}"
        loading="eager" decoding="async">
      <span class="ybC-frame"></span>
    </figure>
  </div>
</section>

