      </div>

      {% elif week.graduation %}
      <details class="s18w-combo-accordion s18w-week" data-s18w-route="shared" open style="margin-bottom:10px;">
        <summary class="s18w-combo-summary" style="display:flex;align-items:center;justify-content:space-between;padding:18px 22px;cursor:pointer;list-style:none;-webkit-appearance:none;background:linear-gradient(135deg,#f0fff0,#e8f5e8);border:1.5px solid #2ecc71;border-radius:14px;transition:all .2s;">
          <div style="display:flex;align-items:center;gap:14px;">
            <span style="background:#2ecc71;color:#fff;font-size:.68rem;font-weight:700;padding:5px 12px;border-radius:50px;letter-spacing:.06em;">{{ t.weekLabel }} {{ week.num }}</span>
            <div>
              <p style="font-weight:700;font-size:.92rem;color:#0F0F0F;">{{ week.label_en if lang == "en" else week.label }}</p>
              <p style="font-size:.75rem;color:#6F6A66;">{{ week.days | length }} {{ t.daysLabel }} · {{ week.range_en if lang == "en" else week.range }}</p>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <span style="background:#d4edda;color:#155724;padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:700;text-transform:uppercase;">{{ t.graduationBadge }}</span>
            <span class="s18w-combo-icon" style="background:#2ecc71;color:#fff;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.88rem;font-weight:700;transition:transform .25s;flex-shrink:0;">+</span>
          </div>
        </summary>
        <div style="padding:6px 22px 18px;background:#fff;border:1.5px solid #2ecc71;border-top:none;border-radius:0 0 14px 14px;margin-top:-1px;">
          {% for day in week.days %}
