              <p style="font-weight:700;font-size:.92rem;color:#0F0F0F;">{% if week.label %}{{ week.label_en if lang == "en" else week.label }}{% else %}{{ week.range_en if lang == "en" else week.range }}{% endif %}</p>
              <p style="font-size:.75rem;color:#6F6A66;">{{ week.days | length }} {% if week.days | length == 1 %}{{ t.dayLabel }}{% else %}{{ t.daysLabel }}{% endif %} · {{ week.range_en if lang == "en" else week.range }}</p>
            </div>
          </div>
          <div style="display:flex;align-items:center;gap:12px;">
            <span style="font-size:.72rem;color:#6F6A66;font-weight:500;">{% for day in week.days %}{{ day.dd_en if lang == "en" else day.dd }}{% if not loop.last %} · {% endif %}{% endfor %}</span>
            <span class="s18w-combo-icon" style="background:#f75c03;color:#fff;width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:.88rem;font-weight:700;transition:transform .25s;flex-shrink:0;">+</span>
          </div>
        </summary>
        <div style="padding:6px 22px 18px;background:#fff;border:1px solid #E8E4E0;border-top:none;border-radius:0 0 14px 14px;margin-top:-1px;">
          {% for day in week.days %}
          <div class="s18w-day" data-s18w-route="{{ day.route }}" style="display:flex;gap:16px;align-items:center;padding:12px 0;{% if not loop.last %}border-bottom:1px solid #F0EDE9;{% endif %}">
            <div style="background:{% if day.route == 'shared' %}#f75c03{% elif day.route == 'weekend' %}#ff9966{% else %}#0F0F0F{% endif %};color:#fff;width:46px;height:46px;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;{% if day.type == 'online' %}box-shadow:0 0 0 2px #fff, 0 0 0 3px #f75c03;{% endif %}">
              <span style="font-size:1.1rem;font-weight:700;line-height:1;">{{ day.dn }}</span>
              <span style="font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;opacity:.75;">{{ day.dd_en if lang == "en" else day.dd }}</span>
            </div>
            <div style="flex:1;min-width:0;">
              <p style="font-weight:600;font-size:.92rem;color:#0F0F0F;">{{ day.topic_en if lang == "en" else day.topic }}</p>
              <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">{{ day.time }}{% if day.type == 'online' %} · <span style="color:#f75c03;font-weight:600;">{{ t.onlineLabel }}</span>{% endif %}</p>
            </div>
            {% if day.route == 'weekday' %}
            <span class="s18w-route-label" style="font-size:.68rem;color:#6F6A66;font-weight:500;white-space:nowrap;">{{ t.routeWeekdayLabel }}</span>
            {% elif day.route == 'weekend' %}
            <span class="s18w-route-label" style="font-size:.68rem;color:#ff9966;font-weight:500;white-space:nowrap;">{{ t.routeWeekendLabel }}</span>
            {% else %}
            <span class="s18w-route-label" style="font-size:.68rem;color:#f75c03;font-weight:600;white-space:nowrap;">{{ t.routeSharedLabel }}</span>
            {% endif %}
          </div>
          {% endfor %}
        </div>
      </details>
      {% endif %}
    {% endfor %}
    {% endfor %}

    </div> {# /s18w-view-single #}

    {# ── GRADUATION ENDPOINT ──────────────────────────────── #}
    <div style="position:relative;padding-left:48px;margin-top:40px;">
      <div style="position:absolute;left:18px;top:0;bottom:50%;width:2px;background:linear-gradient(to bottom, #E8E4E0, #2ecc71);"></div>
      <div style="position:relative;">
        <div style="position:absolute;left:-42px;top:4px;width:22px;height:22px;background:#2ecc71;border-radius:50%;border:3px solid #fff;box-shadow:0 0 0 2px #2ecc71, 0 0 20px rgba(46,204,113,.25);z-index:1;display:flex;align-items:center;justify-content:center;">
          <span style="color:#fff;font-size:.7rem;">&#10003;</span>
        </div>
        <div>
          <p style="font-weight:700;font-size:1.05rem;color:#2ecc71;">{{ t.certifiedTitle }}</p>
          <p style="font-size:.82rem;color:#6F6A66;line-height:1.5;margin-top:4px;">{{ t.certDate }}</p>
        </div>
      </div>
    </div>

    {# ── INFO CARDS ───────────────────────────────────────── #}
    <div style="margin-top:32px;display:grid;grid-template-columns:1fr 1fr;gap:12px;">
      <div style="background:#FFF8F3;border:1px solid #FFE5D0;border-radius:12px;padding:18px;">
        <p style="font-weight:700;font-size:.85rem;margin-bottom:4px;">{{ t.studyHoursLabel }}</p>
        <p style="font-size:.78rem;color:#6F6A66;">{{ t.studyHoursDeadline }}</p>
      </div>
      <div style="background:#f0fff0;border:1px solid #c3e6c3;border-radius:12px;padding:18px;">
        <p style="font-weight:700;font-size:.85rem;margin-bottom:4px;">{{ t.certificationLabel }}</p>
        <p style="font-size:.78rem;color:#6F6A66;">{{ t.certGradDate }}</p>
      </div>
    </div>

    {# ── BLOCKQUOTE ───────────────────────────────────────── #}
    <blockquote style="border-left:4px solid #f75c03;padding:24px 28px;margin:40px 0 0;background:#FFFCF9;border-radius:0 14px 14px 0;">
      <p style="font-size:1.05rem;font-weight:600;font-style:italic;line-height:1.5;color:#0F0F0F;">"{{ t.quoteText }}"</p>
      <p style="font-size:.82rem;color:#6F6A66;margin-top:8px;">{{ t.quoteAuthor }}</p>
    </blockquote>

  </div>

  {# ── CROSS-LINK ─────────────────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:32px 24px 0;">
    <div style="background:#FFF7ED;border:1px solid rgba(247,92,3,.15);border-radius:14px;padding:24px 28px;display:flex;align-items:center;gap:18px;flex-wrap:wrap;">
      <div style="flex:1;min-width:200px;">
        <p style="font-weight:700;">{{ t.crossLinkTitle }}</p>
        <p style="font-size:.85rem;color:#6F6A66;margin-top:4px;">{{ t.crossLinkDesc }}</p>
      </div>
      <a href="{% if lang == 'en' %}/en/schedule/18-weeks/{% else %}/skema/18-uger/{% endif %}" style="background:#f75c03;color:#fff;padding:10px 20px;border-radius:50px;font-size:.85rem;font-weight:600;text-decoration:none;white-space:nowrap;">{{ t.crossLinkCta }} →</a>
    </div>
  </div>

  {# ── DARK CTA ─────────────────────────────────────────── #}
  <div style="background:#0F0F0F;color:#fff;padding:60px 24px;text-align:center;">
    <div style="max-width:600px;margin:0 auto;">
      <h2 style="font-size:1.6rem;font-weight:700;margin-bottom:12px;">{{ t.ctaSectionTitle }}</h2>
      <p style="color:rgba(255,255,255,.68);margin-bottom:28px;line-height:1.55;">{{ t.ctaSectionDesc }}</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <button onclick="openBookingModal('info-session')" style="background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.5);padding:14px 28px;border-radius:50px;font-size:.95rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;" onmouseenter="this.style.borderColor='#fff';this.style.background='rgba(255,255,255,.08)'" onmouseleave="this.style.borderColor='rgba(255,255,255,.5)';this.style.background='transparent'">{{ t.ctaBook }}</button>
        <button onclick="startCheckoutFunnel('100210')" style="background:#f75c03;color:#fff;border:none;padding:14px 28px;border-radius:50px;font-size:.95rem;font-weight:600;cursor:pointer;font-family:inherit;transition:background .2s;" onmouseenter="this.style.background='#d94f02'" onmouseleave="this.style.background='#f75c03'">{{ t.ctaStart }}</button>
      </div>
    </div>
  </div>

</section>

<script>
(function() {
  /* ── Route toggle ──────────────────────────── */
  window.s18wSetRoute = function(route) {
    var tabs = document.querySelectorAll('[data-s18w-tab]');
    tabs.forEach(function(btn) {
      if (btn.dataset.s18wTab === route) {
        btn.style.background = '#f75c03'; btn.style.color = '#fff'; btn.style.boxShadow = '0 4px 12px rgba(247,92,3,.3)';
      } else {
        btn.style.background = 'transparent'; btn.style.color = '#6F6A66'; btn.style.boxShadow = 'none';
      }
    });
    var viewBoth = document.getElementById('s18w-view-both');
    var viewSingle = document.getElementById('s18w-view-single');
    if (route === 'both') {
      if (viewBoth) viewBoth.style.display = '';
      if (viewSingle) viewSingle.style.display = 'none';
    } else {
      if (viewBoth) viewBoth.style.display = 'none';
      if (viewSingle) viewSingle.style.display = '';
      var days = document.querySelectorAll('.s18w-day');
      days.forEach(function(row) {
        var dayRoute = row.dataset.s18wRoute;
        row.style.display = (dayRoute === 'shared' || dayRoute === route) ? 'flex' : 'none';
      });
      document.querySelectorAll('.s18w-route-label').forEach(function(lbl) { lbl.style.display = 'none'; });
      document.querySelectorAll('.s18w-week').forEach(function(wk) {
        if (wk.dataset.s18wRoute === 'shared') { wk.style.display = ''; return; }
        var vis = wk.querySelectorAll('.s18w-day');
        if (!vis.length) { wk.style.display = ''; return; }
        var any = false;
        vis.forEach(function(d) { if (d.style.display !== 'none') any = true; });
        wk.style.display = any ? '' : 'none';
      });
      document.querySelectorAll('#schedule-18w .s18w-combo-accordion').forEach(function(acc) {
        var rows = acc.querySelectorAll('.s18w-day');
        var last = null;
        rows.forEach(function(r) { if (r.style.display !== 'none') { r.style.borderBottom = '1px solid #F0EDE9'; last = r; } });
        if (last) last.style.borderBottom = 'none';
      });
    }
    var statDays = document.getElementById('s18w-stat-days');
    var statLabel = document.getElementById('s18w-stat-days-label');
    if (statDays && statLabel) {
      if (route === 'both') {
        statDays.textContent = '25';
      } else {
        var count = 0;
        document.querySelectorAll('.s18w-day').forEach(function(d) { if (d.style.display !== 'none') count++; });
        statDays.textContent = count;
      }
    }
  };

  /* ── Busy-day toggle ───────────────────────── */
  window.s18wToggleBusyRow = function(cb) {
    var row = cb.closest('.s18w-busy-row');
    var times = row.querySelector('.s18w-busy-times');
    if (cb.checked) { row.style.background = '#F5F3F0'; times.style.opacity = '1'; times.style.pointerEvents = ''; }
    else { row.style.background = 'transparent'; times.style.opacity = '.3'; times.style.pointerEvents = 'none'; }
  };

  /* ── Conflict checker ──────────────────────── */
  var s18wSchedule = [
    {dow:1,s:'10:00',e:'15:00',r:'weekday'},{dow:3,s:'10:00',e:'15:00',r:'weekday'},
    {dow:6,s:'13:00',e:'18:00',r:'weekend'},{dow:0,s:'14:00',e:'19:00',r:'weekend'},
    {dow:6,s:'13:00',e:'17:00',r:'shared'},{dow:0,s:'14:00',e:'17:00',r:'shared'}
  ];
  function s18wTimeMin(t){var p=t.split(':');return parseInt(p[0])*60+parseInt(p[1]);}
  function s18wGetBusySlots() {
    var slots = {};
    document.querySelectorAll('.s18w-busy-row').forEach(function(row) {
      var cb = row.querySelector('input[name="s18w-busy"]');
      if (!cb.checked) return;
      var dow = parseInt(cb.value);
      var from = row.querySelector('.s18w-time-from').value || '09:00';
      var to = row.querySelector('.s18w-time-to').value || '17:00';
      slots[dow] = { s: s18wTimeMin(from), e: s18wTimeMin(to) };
    });
    return slots;
  }
  function s18wCount(route, busySlots) {
    var days = s18wSchedule.filter(function(d) { return d.r === route || d.r === 'shared'; });
    var c = 0;
    days.forEach(function(d) {
      var slot = busySlots[d.dow];
      if (!slot) return;
      if (s18wTimeMin(d.s) < slot.e && s18wTimeMin(d.e) > slot.s) c++;
    });
    return { total: days.length, conflicts: c, clear: days.length - c };
  }
  window.s18wCheckConflicts = function() {
    var busySlots = s18wGetBusySlots();
    var el = document.getElementById('s18w-conflict-results');
    if (!el) return;
    el.style.display = 'block';
    var wd = s18wCount('weekday', busySlots);
    var wec = s18wCount('weekend', busySlots);
    var wdPct = Math.round((wd.clear / wd.total) * 100);
    var wePct = Math.round((wec.clear / wec.total) * 100);
    var wdBest = wd.conflicts < wec.conflicts;
    var weBest = wec.conflicts < wd.conflicts;
    {% if lang == "en" %}
    var wdName = 'Weekday Track'; var weName = 'Weekend Track';
    var bestMatch = 'Best match'; var conflictsOf = 'conflicts out of';
    var bothFit = 'Both tracks fit perfectly!';
    {% else %}
    var wdName = 'Hverdagshold'; var weName = 'Weekendhold';
    var bestMatch = 'Bedste match'; var conflictsOf = 'konflikter af';
    var bothFit = 'Begge hold passer perfekt!';
    {% endif %}
    var html = '<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">';
    html += '<div style="background:'+(wdBest?'#f0fff0':'#fff')+';border:2px solid '+(wdBest?'#2ecc71':'#E8E4E0')+';border-radius:12px;padding:16px;text-align:center;position:relative;">';
    if (wdBest) html += '<span style="position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:#2ecc71;color:#fff;padding:3px 12px;border-radius:50px;font-size:.68rem;font-weight:700;">'+bestMatch+'</span>';
    html += '<p style="font-weight:700;font-size:.85rem;margin-bottom:4px;">'+wdName+'</p>';
    html += '<p style="font-size:2.2rem;font-weight:700;'+(wd.conflicts===0?'color:#2ecc71;':'color:#0F0F0F;')+'">'+wd.conflicts+'</p>';
    html += '<p style="font-size:.75rem;color:#6F6A66;">'+conflictsOf+' '+wd.total+'</p>';
    html += '<div style="background:#E8E4E0;border-radius:50px;height:6px;overflow:hidden;margin-top:10px;"><div style="background:#2ecc71;height:100%;width:'+wdPct+'%;border-radius:50px;"></div></div></div>';
    html += '<div style="background:'+(weBest?'#f0fff0':'#fff')+';border:2px solid '+(weBest?'#2ecc71':'#E8E4E0')+';border-radius:12px;padding:16px;text-align:center;position:relative;">';
    if (weBest) html += '<span style="position:absolute;top:-10px;left:50%;transform:translateX(-50%);background:#2ecc71;color:#fff;padding:3px 12px;border-radius:50px;font-size:.68rem;font-weight:700;">'+bestMatch+'</span>';
    html += '<p style="font-weight:700;font-size:.85rem;margin-bottom:4px;">'+weName+'</p>';
    html += '<p style="font-size:2.2rem;font-weight:700;'+(wec.conflicts===0?'color:#2ecc71;':'color:#0F0F0F;')+'">'+wec.conflicts+'</p>';
    html += '<p style="font-size:.75rem;color:#6F6A66;">'+conflictsOf+' '+wec.total+'</p>';
    html += '<div style="background:#E8E4E0;border-radius:50px;height:6px;overflow:hidden;margin-top:10px;"><div style="background:#2ecc71;height:100%;width:'+wePct+'%;border-radius:50px;"></div></div></div>';
    html += '</div>';
    if (wd.conflicts===0 && wec.conflicts===0) {
      html += '<div style="background:#f0fff0;border:1px solid #c3e6c3;border-radius:12px;padding:16px;text-align:center;margin-top:12px;"><p style="font-weight:700;color:#2ecc71;">'+bothFit+'</p></div>';
    } else {
      var bestName2 = wdBest ? wdName : weName;
      var bestCount = Math.min(wd.conflicts, wec.conflicts);
      {% if lang == "en" %}
      var rec = 'Use '+bestName2+' as your base'+(bestCount>0?' and swap the '+bestCount+' conflicting weeks to the other track':'');
      {% else %}
      var rec = 'Brug '+bestName2+' som base'+(bestCount>0?' og byt de '+bestCount+' konfliktuger til det andet hold':'');
      {% endif %}
      html += '<div style="background:#FFF8F3;border:1px solid #FFE5D0;border-radius:12px;padding:16px;margin-top:12px;"><p style="font-size:.88rem;"><strong>{% if lang == "en" %}Recommendation{% else %}Anbefaling{% endif %}:</strong> '+rec+'.</p></div>';
    }
    el.innerHTML = html;
  };

  /* ── Conflict finder chevron ──────────────── */
  var cfDetails = document.getElementById('s18w-conflict-finder');
  if (cfDetails) {
    cfDetails.addEventListener('toggle', function() {
      var chev = cfDetails.querySelector('.s18w-cf-chevron');
      if (chev) chev.style.transform = cfDetails.open ? 'rotate(180deg)' : '';
    });
  }

  /* ── Personalization token ────────────────── */
  (function() {
    var params = new URLSearchParams(window.location.search);
    var tid = params.get('tid');
    var tok = params.get('tok');
    if (!tid || !tok) return;
  })();

})();
</script>

<style>
  .s18w-combo-accordion summary::-webkit-details-marker { display: none; }
  .s18w-combo-accordion summary::marker { display: none; content: ''; }
  .s18w-combo-summary:hover { box-shadow: 0 4px 16px rgba(0,0,0,.06); transform: translateY(-1px); }
  .s18w-combo-accordion[open] .s18w-combo-summary { border-radius: 14px 14px 0 0 !important; border-bottom-color: transparent !important; }
  .s18w-combo-accordion[open] .s18w-combo-icon { transform: rotate(45deg); }
  .s18w-day { transition: opacity .2s; }
  .s18w-week { transition: opacity .2s; }
  html { scroll-behavior: smooth; }
  @media (max-width: 700px) {
    #schedule-18w .s18w-combo-summary [style*="gap:12px"]:last-child > span:first-child { display: none !important; }
  }
</style>
