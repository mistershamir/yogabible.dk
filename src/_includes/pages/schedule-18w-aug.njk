{# CLOUDINARY: yoga-bible-DK/schedule-pages/18w/ — hero and og images #}
{% set t = i18n.schedule_18w_aug[lang or "da"] %}

<section id="schedule-18w">

  {# ── HERO ─────────────────────────────────────────────── #}
  <div style="background:#0F0F0F;color:#fff;padding:clamp(80px,12vw,160px) 24px clamp(60px,8vw,100px);text-align:center;">
    <div style="max-width:640px;margin:0 auto;">
      <p style="font-size:clamp(5rem,16vw,10rem);font-weight:700;line-height:1.05;padding-bottom:0.12em;background:linear-gradient(135deg,#f75c03,#ff9966);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;margin:0 0 16px;">{{ t.heroTitle }}</p>
      <p style="font-size:clamp(1.25rem,3.5vw,1.8rem);font-weight:700;color:#fff;letter-spacing:-.015em;line-height:1.2;margin:0 0 12px;">{{ t.heroSubtitle }}</p>
      <p style="font-size:.95rem;color:rgba(255,255,255,.4);letter-spacing:.04em;">{{ t.heroPeriod }}</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;margin-top:28px;">
        <button onclick="openBookingModal('info-session')" style="background:transparent;color:#fff;border:1.5px solid rgba(255,255,255,.5);padding:13px 24px;border-radius:50px;font-size:.92rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;" onmouseenter="this.style.borderColor='#fff';this.style.background='rgba(255,255,255,.08)'" onmouseleave="this.style.borderColor='rgba(255,255,255,.5)';this.style.background='transparent'">{{ t.ctaBook }}</button>
        <button onclick="startCheckoutFunnel('100210')" style="background:#f75c03;color:#fff;border:none;padding:13px 24px;border-radius:50px;font-size:.92rem;font-weight:600;cursor:pointer;font-family:inherit;transition:background .2s;" onmouseenter="this.style.background='#d94f02'" onmouseleave="this.style.background='#f75c03'">{{ t.ctaStart }}</button>
      </div>
    </div>
  </div>

  {# ── STATS BAR ────────────────────────────────────────── #}
  <div style="background:#F5F3F0;padding:28px 24px;border-bottom:1px solid #E8E4E0;">
    <div style="max-width:700px;margin:0 auto;">
      <div style="display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-bottom:20px;">
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">{{ t.pillYA }}</span>
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">{{ t.pillStudents }}</span>
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">{{ t.pillTracks }}</span>
        <span style="background:#F5F3F0;color:#6F6A66;padding:5px 14px;border-radius:50px;font-size:.72rem;font-weight:500;border:1px solid #E8E4E0;">{{ t.pillPeriod }}</span>
      </div>
      <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:16px;text-align:center;">
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">18</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">{{ t.statWeeks }}</p>
        </div>
        <div>
          <span id="s18w-stat-days" style="font-size:1.8rem;font-weight:700;color:#f75c03;">25</span>
          <p id="s18w-stat-days-label" style="font-size:.82rem;color:#6F6A66;margin-top:4px;">{{ t.statDays }}</p>
        </div>
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">200+</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">{{ t.statHours }}</p>
        </div>
        <div>
          <span style="font-size:1.8rem;font-weight:700;color:#f75c03;">4</span>
          <p style="font-size:.82rem;color:#6F6A66;margin-top:4px;">{{ t.statFreeWeeks }}</p>
        </div>
      </div>
    </div>
  </div>

  {# ── HOURS BREAKDOWN ──────────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:32px 24px 0;">
    <p style="font-size:.72rem;text-transform:uppercase;letter-spacing:.14em;color:#6F6A66;font-weight:700;margin-bottom:16px;">{{ t.hoursTitle }}</p>
    {% set hoursData = [
      { pct: 30,  hours: 60, color: "#f75c03", key: "hLabel0" },
      { pct: 5,   hours: 10, color: "#ff9966", key: "hLabel1" },
      { pct: 15,  hours: 30, color: "#1a1a1a", key: "hLabel2" },
      { pct: 10,  hours: 20, color: "#3d3d3d", key: "hLabel3" },
      { pct: 8.5, hours: 17, color: "#666666", key: "hLabel4" },
      { pct: 6,   hours: 12, color: "#6F6A66", key: "hLabel5" },
      { pct: 8,   hours: 16, color: "#ffb380", key: "hLabel6" },
      { pct: 6,   hours: 12, color: "#ffd5b8", key: "hLabel7" },
      { pct: 10,  hours: 20, color: "#E8E4E0", key: "hLabel8" },
      { pct: 1.5, hours: 3,  color: "#F0EDEA", key: "hLabel9" }
    ] %}

    {# Stacked segment bar #}
    <div style="height:22px;border-radius:50px;overflow:hidden;display:flex;gap:2px;margin-bottom:20px;">
      {% for h in hoursData %}
      <div style="flex:{{ h.pct }};background:{{ h.color }};" title="{{ t[h.key] }} — {{ h.hours }}{{ 'h' if lang == 'en' else 't' }}"></div>
      {% endfor %}
    </div>

    {# Legend: 2-column grid #}
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:6px 24px;">
      {% for h in hoursData %}
      <div style="display:flex;align-items:center;gap:8px;">
        <span style="width:10px;height:10px;border-radius:3px;background:{{ h.color }};flex-shrink:0;{% if h.color == '#E8E4E0' or h.color == '#F0EDEA' %}border:1px solid #ccc;{% endif %}"></span>
        <span style="font-size:.78rem;color:#0F0F0F;flex:1;">{{ t[h.key] }}</span>
        <span style="font-size:.78rem;font-weight:700;color:#0F0F0F;">{{ h.hours }}{{ "h" if lang == "en" else "t" }}</span>
      </div>
      {% endfor %}
    </div>
    <p style="font-size:.72rem;color:#6F6A66;text-align:right;margin-top:10px;font-style:italic;">{{ t.hoursTotal }}</p>
  </div>

  {# ── CONFLICT FINDER ──────────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:24px 24px 0;">
    <details id="s18w-conflict-finder" style="background:#fff;border:1.5px solid #E8E4E0;border-radius:16px;overflow:hidden;">
      <summary style="display:flex;align-items:center;justify-content:space-between;padding:16px 20px;cursor:pointer;list-style:none;-webkit-appearance:none;">
        <div style="display:flex;align-items:center;gap:12px;">
          <span style="background:#FFF0E6;color:#f75c03;width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-size:1.1rem;">&#128197;</span>
          <div>
            <p style="font-weight:700;font-size:.92rem;">{{ t.conflictTitle }}</p>
            <p style="font-size:.78rem;color:#6F6A66;">{{ t.conflictDesc }}</p>
          </div>
        </div>
        <svg class="s18w-cf-chevron" style="flex-shrink:0;transition:transform .25s;" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>
      </summary>
      <div style="padding:0 20px 20px;border-top:1px solid #E8E4E0;">
        <p style="font-size:.8rem;color:#6F6A66;padding:14px 0 10px;margin:0;">{{ t.conflictDesc }}</p>
        <div style="display:flex;flex-direction:column;gap:6px;" id="s18w-busy-days">
          {% set busyDays18 = [
            { val: "1", label: "Mandag" if lang != "en" else "Monday", abbr: "Man" if lang != "en" else "Mon", checked: true, start: "09:00", end: "17:00" },
            { val: "2", label: "Tirsdag" if lang != "en" else "Tuesday", abbr: "Tir" if lang != "en" else "Tue", checked: true, start: "09:00", end: "17:00" },
            { val: "3", label: "Onsdag" if lang != "en" else "Wednesday", abbr: "Ons" if lang != "en" else "Wed", checked: true, start: "09:00", end: "17:00" },
            { val: "4", label: "Torsdag" if lang != "en" else "Thursday", abbr: "Tor" if lang != "en" else "Thu", checked: true, start: "09:00", end: "17:00" },
            { val: "5", label: "Fredag" if lang != "en" else "Friday", abbr: "Fre" if lang != "en" else "Fri", checked: true, start: "09:00", end: "17:00" },
            { val: "6", label: "Lørdag" if lang != "en" else "Saturday", abbr: "Lør" if lang != "en" else "Sat", checked: false, start: "10:00", end: "14:00" },
            { val: "0", label: "Søndag" if lang != "en" else "Sunday", abbr: "Søn" if lang != "en" else "Sun", checked: false, start: "10:00", end: "14:00" }
          ] %}
          {% for d in busyDays18 %}
          <div class="s18w-busy-row" style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:12px;background:{% if d.checked %}#F5F3F0{% else %}transparent{% endif %};transition:background .2s;">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;min-width:110px;">
              <input type="checkbox" name="s18w-busy" value="{{ d.val }}" {% if d.checked %}checked{% endif %} onchange="s18wToggleBusyRow(this)" style="accent-color:#f75c03;width:16px;height:16px;">
              <span style="font-size:.85rem;font-weight:600;">{{ d.label }}</span>
            </label>
            <div class="s18w-busy-times" style="display:flex;align-items:center;gap:6px;{% if not d.checked %}opacity:.3;pointer-events:none;{% endif %}">
              <input type="time" value="{{ d.start }}" class="s18w-time-from" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;width:100px;">
              <span style="color:#6F6A66;font-size:.75rem;">{{ "til" if lang != "en" else "to" }}</span>
              <input type="time" value="{{ d.end }}" class="s18w-time-to" style="border:1px solid #E8E4E0;border-radius:8px;padding:5px 8px;font-family:inherit;font-size:.8rem;width:100px;">
            </div>
          </div>
          {% endfor %}
        </div>
        <button onclick="s18wCheckConflicts()" style="margin-top:16px;background:#f75c03;color:#fff;border:none;padding:12px 24px;border-radius:50px;font-size:.88rem;font-weight:600;cursor:pointer;font-family:inherit;transition:background .2s;" onmouseenter="this.style.background='#d94f02'" onmouseleave="this.style.background='#f75c03'">{{ t.conflictBtn }}</button>
        <div id="s18w-conflict-results" style="display:none;margin-top:16px;"></div>
      </div>
    </details>
  </div>

  {# ── ROUTE TOGGLE ─────────────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:24px 24px 0;">
    <p style="text-align:center;font-size:.9rem;color:#6F6A66;margin:0 0 18px;line-height:1.6;">{{ t.routeDesc }}</p>
    <div id="s18w-route-toggle" style="display:flex;gap:0;background:rgba(15,15,15,.06);border-radius:16px;padding:4px;max-width:480px;margin:0 auto;">
      <button onclick="s18wSetRoute('both')" data-s18w-tab="both" style="flex:1;padding:12px 14px;border-radius:12px;border:none;cursor:pointer;font-family:inherit;text-align:center;transition:all .25s;background:#f75c03;color:#fff;box-shadow:0 4px 12px rgba(247,92,3,.3);">
        <span style="display:block;font-weight:700;font-size:.85rem;">{{ t.routeBoth }}</span>
        <span style="display:block;font-size:.68rem;margin-top:2px;opacity:.8;">{{ t.routeBothSubtitle }}</span>
      </button>
      <button onclick="s18wSetRoute('weekday')" data-s18w-tab="weekday" style="flex:1;padding:12px 14px;border-radius:12px;border:none;cursor:pointer;font-family:inherit;text-align:center;transition:all .25s;background:transparent;color:#6F6A66;">
        <span style="display:block;font-weight:700;font-size:.85rem;">{{ t.routeWeekdayBtn }}</span>
        <span style="display:block;font-size:.68rem;margin-top:2px;opacity:.8;">{{ t.routeWeekdaySubtitle }}</span>
      </button>
      <button onclick="s18wSetRoute('weekend')" data-s18w-tab="weekend" style="flex:1;padding:12px 14px;border-radius:12px;border:none;cursor:pointer;font-family:inherit;text-align:center;transition:all .25s;background:transparent;color:#6F6A66;">
        <span style="display:block;font-weight:700;font-size:.85rem;">{{ t.routeWeekendBtn }}</span>
        <span style="display:block;font-size:.68rem;margin-top:2px;opacity:.8;">{{ t.routeWeekendSubtitle }}</span>
      </button>
    </div>
  </div>

  {# ── SCHEDULE BODY ─────────────────────────────────────── #}
  <div style="max-width:700px;margin:0 auto;padding:40px 24px 0;">

    {# Calendar export #}
    <div style="display:flex;justify-content:flex-end;margin-bottom:24px;">
      <button style="display:inline-flex;align-items:center;gap:6px;background:none;color:#6F6A66;border:1.5px solid #E8E4E0;padding:8px 16px;border-radius:50px;font-size:.78rem;font-weight:600;cursor:pointer;font-family:inherit;transition:all .2s;" onmouseenter="this.style.borderColor='#f75c03';this.style.color='#f75c03'" onmouseleave="this.style.borderColor='#E8E4E0';this.style.color='#6F6A66'">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
        {{ t.calendarBtn }}
      </button>
    </div>

    {# VIEW A: Both — Paired ELLER cards #}
    <div id="s18w-view-both">

    {% set months18wPairs = [
      { name: "August", name_en: "August", year: "2026", weeks: [
        { num: 1, label: "Introduktion", label_en: "Introduction", pairs: [
          { topic: "Hatha & Class Management — Introduktion", topic_en: "Hatha & Class Management — Introduction",
            wd: { date: "Man 10. aug", date_en: "Mon Aug 10", time: "10:00–15:00" },
            we: { date: "Lør 15. aug", date_en: "Sat Aug 15", time: "13:00–18:00" } },
          { topic: "Vinyasa & Yin Yoga — Introduktion", topic_en: "Vinyasa & Yin Yoga — Introduction",
            wd: { date: "Ons 12. aug", date_en: "Wed Aug 12", time: "10:00–15:00" },
            we: { date: "Søn 16. aug", date_en: "Sun Aug 16", time: "14:00–19:00" } }
        ]},
        { num: 2, label: "Anatomi & Filosofi", label_en: "Anatomy & Philosophy", sharedPairs: [
          { topic: "Yoga Anatomi 01", topic_en: "Yoga Anatomy 01", date: "Lør 22. aug", date_en: "Sat Aug 22", time: "13:00–17:00" },
          { topic: "Yogafilosofi 01 — Online", topic_en: "Yoga Philosophy 01 — Online", date: "Søn 23. aug", date_en: "Sun Aug 23", time: "14:00–17:00", online: true }
        ]},
        { num: 3, off: true, offLabel: "Fri uge", offLabel_en: "Free week" }
      ]},
      { name: "September", name_en: "September", year: "2026", weeks: [
        { num: 4, pairs: [
          { topic: "Vinyasa & Yin Yoga 02",
            wd: { date: "Man 31. aug", date_en: "Mon Aug 31", time: "10:00–15:00" },
            we: { date: "Lør 5. sep", date_en: "Sat Sep 5", time: "13:00–18:00" } }
        ]},
        { num: 5, pairs: [
          { topic: "Hatha & Class Management 02",
            wd: { date: "Man 7. sep", date_en: "Mon Sep 7", time: "10:00–15:00" },
            we: { date: "Lør 12. sep", date_en: "Sat Sep 12", time: "13:00–18:00" } },
          { topic: "Vinyasa & Yin Yoga 03",
            wd: { date: "Ons 9. sep", date_en: "Wed Sep 9", time: "10:00–15:00" },
            we: { date: "Søn 13. sep", date_en: "Sun Sep 13", time: "14:00–19:00" } }
        ]},
        { num: 6, label: "Anatomi & Filosofi", label_en: "Anatomy & Philosophy", sharedPairs: [
          { topic: "Yoga Anatomi 02", topic_en: "Yoga Anatomy 02", date: "Lør 19. sep", date_en: "Sat Sep 19", time: "13:00–17:00" },
          { topic: "Yogafilosofi 02 — Online", topic_en: "Yoga Philosophy 02 — Online", date: "Søn 20. sep", date_en: "Sun Sep 20", time: "14:00–17:00", online: true }
        ]},
        { num: 7, pairs: [
          { topic: "Vinyasa & Yin Yoga 04",
            wd: { date: "Man 21. sep", date_en: "Mon Sep 21", time: "10:00–15:00" },
            we: { date: "Lør 26. sep", date_en: "Sat Sep 26", time: "13:00–18:00" } },
          { topic: "Hatha & Class Management 03",
            wd: { date: "Ons 23. sep", date_en: "Wed Sep 23", time: "10:00–15:00" },
            we: { date: "Søn 27. sep", date_en: "Sun Sep 27", time: "14:00–19:00" } }
        ]},
        { num: 8, off: true, offLabel: "Fri uge", offLabel_en: "Free week" }
      ]},
      { name: "Oktober", name_en: "October", year: "2026", weeks: [
        { num: 9, pairs: [
          { topic: "Vinyasa & Yin Yoga 05",
            wd: { date: "Man 5. okt", date_en: "Mon Oct 5", time: "10:00–15:00" },
            we: { date: "Lør 10. okt", date_en: "Sat Oct 10", time: "13:00–18:00" } },
          { topic: "Hatha & Class Management 04",
            wd: { date: "Ons 7. okt", date_en: "Wed Oct 7", time: "10:00–15:00" },
            we: { date: "Søn 11. okt", date_en: "Sun Oct 11", time: "14:00–19:00" } }
        ]},
        { num: 10, off: true, offLabel: "Efterårsferie", offLabel_en: "Fall break" },
        { num: 11, label: "Anatomi & Filosofi", label_en: "Anatomy & Philosophy", sharedPairs: [
          { topic: "Yoga Anatomi 03", topic_en: "Yoga Anatomy 03", date: "Lør 24. okt", date_en: "Sat Oct 24", time: "13:00–17:00" },
          { topic: "Yogafilosofi 03 — Online", topic_en: "Yoga Philosophy 03 — Online", date: "Søn 25. okt", date_en: "Sun Oct 25", time: "14:00–17:00", online: true }
        ]},
        { num: 12, pairs: [
          { topic: "Vinyasa & Yin Yoga 06",
            wd: { date: "Man 26. okt", date_en: "Mon Oct 26", time: "10:00–15:00" },
            we: { date: "Lør 31. okt", date_en: "Sat Oct 31", time: "13:00–18:00" } }
        ]}
      ]},
      { name: "November", name_en: "November", year: "2026", weeks: [
        { num: 13, pairs: [
          { topic: "Vinyasa & Yin Yoga 07",
            wd: { date: "Man 2. nov", date_en: "Mon Nov 2", time: "10:00–15:00" },
            we: { date: "Lør 7. nov", date_en: "Sat Nov 7", time: "13:00–18:00" } }
        ]},
        { num: 14, label: "Anatomi & Filosofi", label_en: "Anatomy & Philosophy", sharedPairs: [
          { topic: "Yoga Anatomi 04", topic_en: "Yoga Anatomy 04", date: "Lør 14. nov", date_en: "Sat Nov 14", time: "13:00–17:00" },
          { topic: "Yogafilosofi 04 — Online", topic_en: "Yoga Philosophy 04 — Online", date: "Søn 15. nov", date_en: "Sun Nov 15", time: "14:00–17:00", online: true }
        ]},
        { num: 15, pairs: [
          { topic: "Vinyasa & Yin Yoga 08",
            wd: { date: "Man 16. nov", date_en: "Mon Nov 16", time: "10:00–15:00" },
            we: { date: "Lør 21. nov", date_en: "Sat Nov 21", time: "13:00–18:00" } },
          { topic: "Hatha & Class Management 05",
            wd: { date: "Ons 18. nov", date_en: "Wed Nov 18", time: "10:00–14:00" },
            we: { date: "Søn 22. nov", date_en: "Sun Nov 22", time: "14:00–18:00" } }
        ]},
        { num: 16, label: "Business of Yoga", label_en: "Business of Yoga", pairs: [
          { topic: "Vinyasa & Yin Yoga 09",
            wd: { date: "Man 23. nov", date_en: "Mon Nov 23", time: "10:00–15:00" },
            we: { date: "Lør 28. nov", date_en: "Sat Nov 28", time: "13:00–18:00" } },
          { topic: "Business of Yoga",
            wd: { date: "Ons 25. nov", date_en: "Wed Nov 25", time: "11:00–14:00" },
            we: { date: "Søn 29. nov", date_en: "Sun Nov 29", time: "14:00–17:00" } }
        ]}
      ]},
      { name: "December", name_en: "December", year: "2026", weeks: [
        { num: 17, off: true, offLabel: "Fri uge — forbered dig til eksamen", offLabel_en: "Free week — prepare for exam" },
        { num: 18, label: "Eksamen & Graduation", label_en: "Exam & Graduation", graduation: true, sharedPairs: [
          { topic: "Vinyasa & Yin Yoga — Eksamen", topic_en: "Vinyasa & Yin Yoga — Exam", date: "Lør 12. dec", date_en: "Sat Dec 12", time: "13:00–18:00", exam: true },
          { topic: "Hatha & Class Management — Eksamen + Graduation 🎓", topic_en: "Hatha & Class Management — Exam + Graduation 🎓", date: "Søn 13. dec", date_en: "Sun Dec 13", time: "14:00–17:00", graduation: true }
        ]}
      ]}
    ] %}

    {% for month in months18wPairs %}

    <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:32px;{% if not loop.first %}margin-top:40px;{% endif %}">
      <span style="font-size:3.4rem;font-weight:700;line-height:1;color:#0F0F0F;">{{ month.name_en if lang == "en" else month.name }}</span>
      <span style="font-size:1.1rem;color:#6F6A66;">{{ month.year }}</span>
      <div style="flex:1;height:2px;background:linear-gradient(to right, #E8E4E0, transparent);margin-left:12px;"></div>
    </div>

    {% for week in month.weeks %}
      {% if week.off %}
      <div style="margin-bottom:10px;padding:14px 22px;background:#FAFAFA;border:1px dashed #E8E4E0;border-radius:14px;display:flex;align-items:center;gap:14px;">
        <span style="background:#E8E4E0;color:#6F6A66;font-size:.68rem;font-weight:700;padding:5px 12px;border-radius:50px;letter-spacing:.06em;">{{ t.weekLabel }} {{ week.num }}</span>
