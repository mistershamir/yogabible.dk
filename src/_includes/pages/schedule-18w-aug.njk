            <div style="background:{% if day.type == 'graduation' %}#2ecc71{% else %}#0F0F0F{% endif %};color:#fff;width:46px;height:46px;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;flex-shrink:0;">
              <span style="font-size:1.1rem;font-weight:700;line-height:1;">{{ day.dn }}</span>
              <span style="font-size:.52rem;text-transform:uppercase;letter-spacing:.06em;opacity:.75;">{{ day.dd_en if lang == "en" else day.dd }}</span>
            </div>
            <div style="flex:1;">
              <p style="font-weight:600;font-size:.92rem;color:#0F0F0F;">{{ day.topic_en if lang == "en" else day.topic }}</p>
              <p style="font-size:.78rem;color:#6F6A66;margin-top:2px;">{{ day.time }}</p>
            </div>
            <span style="background:{% if day.type == 'graduation' %}#d4edda{% else %}#FFF0E6{% endif %};color:{% if day.type == 'graduation' %}#155724{% else %}#f75c03{% endif %};padding:3px 10px;border-radius:50px;font-size:.65rem;font-weight:600;text-transform:uppercase;">{% if day.type == 'graduation' %}{{ t.graduationLabel }}{% else %}{{ t.examLabel }}{% endif %}</span>
          </div>
          {% endfor %}
        </div>
      </details>

      {% else %}
      <details class="s18w-combo-accordion s18w-week" {% if week.num == 1 %}open{% endif %} style="margin-bottom:10px;">
        <summary class="s18w-combo-summary" style="display:flex;align-items:center;justify-content:space-between;padding:18px 22px;cursor:pointer;list-style:none;-webkit-appearance:none;background:#fff;border:1px solid #E8E4E0;border-radius:14px;transition:all .2s;">
