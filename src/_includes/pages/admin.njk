            </div>

            <div class="yb-admin__field">
              <label for="yb-cat-notes">{{ t.catalog_field_notes }}</label>
              <textarea id="yb-cat-notes" rows="2"></textarea>
            </div>

            <div class="yb-admin__form-row" style="flex-wrap:wrap;gap:1rem">
              <label class="yb-admin__checkbox-label">
                <input type="checkbox" id="yb-cat-active" checked> {{ t.catalog_field_active }}
              </label>
              <label class="yb-admin__checkbox-label">
                <input type="checkbox" id="yb-cat-waitlist-enabled"> {{ t.catalog_field_waitlist }}
              </label>
              <label class="yb-admin__checkbox-label">
                <input type="checkbox" id="yb-cat-allow-deposit"> {{ t.catalog_field_allow_deposit }}
              </label>
              <label class="yb-admin__checkbox-label">
                <input type="checkbox" id="yb-cat-allow-instalments"> {{ t.catalog_field_allow_instalments }}
              </label>
              <label class="yb-admin__checkbox-label">
                <input type="checkbox" id="yb-cat-external-only"> {{ t.catalog_field_external_only }}
              </label>
            </div>

            <div class="yb-admin__field" id="yb-cat-external-url-wrap" hidden>
              <label for="yb-cat-external-url">{{ t.catalog_field_external_url }}</label>
              <input type="url" id="yb-cat-external-url" placeholder="https://...">
            </div>

            <div class="yb-admin__form-actions">
              <button type="submit" class="yb-btn yb-btn--primary">{{ t.save }}</button>
              <button type="button" class="yb-btn yb-btn--outline" data-action="catalog-cancel">{{ t.cancel }}</button>
            </div>
          </form>
        </div>

      </div>{# end catalog tab panel #}

    </div>{# end yb-admin-panel #}

  </div>{# end container #}

  {# Toast #}
  <div class="yb-admin__toast" id="yb-admin-toast" hidden></div>
</section>

<script src="/js/course-admin.js"></script>
<script src="/js/lead-admin.js"></script>
<script src="/js/catalog-admin.js"></script>
