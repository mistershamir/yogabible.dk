{% set t = i18n["course-admin"][lang or "da"] %}
{% set lp = "/en" if lang == "en" else "" %}

<script>
  window._ybAdminLang = '{{ lang or "da" }}';
  window._ybAdminT = {{ i18n["course-admin"][lang or "da"] | dump | safe }};
</script>

<section class="yb-admin" id="yb-admin">
  <div class="container">

    {# ── Header ── #}
    <div class="yb-admin__header">
      <p class="yb-profile__eyebrow">Admin</p>
      <h1 class="yb-profile__title">{{ t.page_title }}</h1>
      <p class="yb-profile__subtitle">{{ t.page_subtitle }}</p>
    </div>

    {# ── Gate: not logged in (visible by default, JS hides when authenticated) ── #}
    <div class="yb-admin__gate" id="yb-admin-gate">
      <div class="yb-profile__guest-inner">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#6F6A66" stroke-width="1.5"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        <h2 class="yb-profile__guest-title">{{ t.not_logged_in_title }}</h2>
        <p class="yb-profile__guest-text">{{ t.not_logged_in_text }}</p>
        <div class="yb-profile__guest-actions">
          <button class="yb-btn yb-btn--primary" type="button" data-yb-auth-open="login">{{ t.login_btn }}</button>
        </div>
      </div>
    </div>

    {# ── Logged-in content ── #}
    <div id="yb-admin-panel" style="display:none" class="yb-admin__layout">

      {# Mobile sidebar toggle — MUST be outside sidebar so it's visible when sidebar is closed #}
      <button class="yb-admin__sidebar-toggle" id="yb-admin-sidebar-toggle" type="button" aria-label="Toggle menu">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
      </button>

      {# ── Sidebar Navigation ── #}
      <nav class="yb-admin__sidebar" id="yb-admin-sidebar">
        <button class="yb-admin__sidebar-close" id="yb-admin-sidebar-close" type="button" aria-label="Close menu">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <div class="yb-admin__sidebar-header">Admin</div>

        {# Overview group #}
        <div class="yb-admin__nav-group">
          <span class="yb-admin__nav-label">{{ t.nav_overview }}</span>
          <button class="yb-admin__nav-item is-active" type="button" data-yb-admin-tab="analytics">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            <span>{{ t.tab_analytics }}</span>
          </button>
        </div>

        {# CRM group #}
        <div class="yb-admin__nav-group">
          <span class="yb-admin__nav-label">{{ t.nav_crm }}</span>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="leads">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            <span>{{ t.tab_leads }}</span>
          </button>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="applications">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <span>{{ t.tab_applications }}</span>
          </button>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="users">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            <span>{{ t.tab_users }}</span>
          </button>
        </div>

        {# Content group #}
        <div class="yb-admin__nav-group">
          <span class="yb-admin__nav-label">{{ t.nav_content }}</span>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="courses">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
            <span>{{ t.tab_courses }}</span>
          </button>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="catalog">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            <span>{{ t.tab_catalog }}</span>
          </button>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="documents">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>
            <span>{{ t.tab_documents }}</span>
          </button>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="knowledge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            <span>{{ t.tab_knowledge or "Knowledge" }}</span>
          </button>
        </div>

        {# Marketing group #}
        <div class="yb-admin__nav-group">
          <span class="yb-admin__nav-label">{{ t.nav_marketing }}</span>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="email-lists">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            <span>{{ t.tab_campaigns or "Campaigns" }}</span>
          </button>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="ads">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <span>{{ t.tab_ads or "Ads" }}</span>
          </button>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="careers">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>
            <span>{{ t.tab_careers }}</span>
          </button>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="social">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            <span>{{ t.tab_social or "Social" }}</span>
          </button>
        </div>

        {# Operations group #}
        <div class="yb-admin__nav-group">
          <span class="yb-admin__nav-label">{{ t.nav_operations }}</span>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="appointments">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            <span>{{ t.tab_appointments }}</span>
          </button>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="live">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2" ry="2"/></svg>
            <span>{{ t.tab_live }}</span>
          </button>
          <button class="yb-admin__nav-item" type="button" data-yb-admin-tab="billing">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="1" y="4" width="22" height="16" rx="2" ry="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
            <span>{{ t.tab_billing }}</span>
          </button>
        </div>
      </nav>

      {# ── Main content area ── #}
      <div class="yb-admin__main">

      {# ═══════════════════════════════════
         TAB: Course Builder
         ═══════════════════════════════════ #}
      <div class="yb-admin__tab-panel" data-yb-admin-panel="courses">

        {# Breadcrumb #}
        <div class="yb-admin__breadcrumb" id="yb-admin-breadcrumb"></div>

        {# VIEW: Courses list (default) #}
        <div class="yb-admin__view" id="yb-admin-v-courses">
          <div class="yb-admin__view-head">
            <h2>{{ t.courses_title }}</h2>
            <button class="yb-btn yb-btn--primary" data-action="new-course">+ {{ t.new_course }}</button>
          </div>
          {# Course cards rendered by JS — each card includes:
             - Status badge (draft/published): .yb-admin__status-badge[data-status="draft|published"]
             - Toggle button: data-action="toggle-course-status" data-id="{courseId}" #}
          <div id="yb-admin-course-list" class="yb-admin__card-grid"></div>
        </div>

        {# VIEW: Course form #}
        <div class="yb-admin__view" id="yb-admin-v-course-form" hidden>
          <div class="yb-admin__view-head">
            <button class="yb-admin__back-btn" data-action="back-courses">&larr; {{ t.back }}</button>
            <h2 id="yb-admin-course-form-title">{{ t.new_course }}</h2>
          </div>
          <form id="yb-admin-course-form" class="yb-admin__form">
            <input type="hidden" id="yb-cf-id">
            <div class="yb-admin__field">
              <label for="yb-cf-title">{{ t.title }}</label>
              <input type="text" id="yb-cf-title" required>
            </div>
            <div class="yb-admin__field">
              <label for="yb-cf-desc">{{ t.description }}</label>
              <textarea id="yb-cf-desc" rows="3"></textarea>
            </div>
            <div class="yb-admin__form-row">
              <div class="yb-admin__field">
                <label for="yb-cf-icon">{{ t.icon }}</label>
                <input type="text" id="yb-cf-icon" placeholder="🧘" style="max-width:80px">
              </div>
              <div class="yb-admin__field">
                <label for="yb-cf-program">{{ t.program }}</label>
                <input type="text" id="yb-cf-program" placeholder="200h">
              </div>
            </div>
            <div class="yb-admin__form-actions">
              <button type="submit" class="yb-btn yb-btn--primary">{{ t.save }}</button>
              <button type="button" class="yb-btn yb-btn--outline" data-action="back-courses">{{ t.cancel }}</button>
            </div>
          </form>
        </div>

        {# VIEW: Modules list + Enrollments + Student Progress #}
        <div class="yb-admin__view" id="yb-admin-v-modules" hidden>
          <div class="yb-admin__view-head">
            <button class="yb-admin__back-btn" data-action="back-courses">&larr; {{ t.back }}</button>
            <h2 id="yb-admin-modules-heading">{{ t.modules_title }}</h2>
            <button class="yb-btn yb-btn--primary" data-action="new-module">+ {{ t.new_module }}</button>
          </div>
          <div id="yb-admin-module-list" class="yb-admin__item-list"></div>

          <div class="yb-admin__section-divider"></div>
          <div class="yb-admin__view-head">
            <h2>{{ t.enrollments_title }}</h2>
          </div>
          <form id="yb-admin-enroll-form" class="yb-admin__enroll-form">
            <input type="text" id="yb-admin-enroll-input" placeholder="{{ t.enroll_placeholder }}" required>
            <button type="submit" class="yb-btn yb-btn--primary">{{ t.enroll_btn }}</button>
          </form>
          <div id="yb-admin-enroll-list"></div>

          {# Student Progress #}
          <div class="yb-admin__section-divider"></div>
          <div class="yb-admin__view-head">
            <h2>{{ t.student_progress_title }}</h2>
          </div>
          <div id="yb-admin-student-progress"></div>
        </div>

        {# VIEW: Module form #}
        <div class="yb-admin__view" id="yb-admin-v-module-form" hidden>
          <div class="yb-admin__view-head">
            <button class="yb-admin__back-btn" data-action="back-modules">&larr; {{ t.back }}</button>
            <h2 id="yb-admin-module-form-title">{{ t.new_module }}</h2>
          </div>
          <form id="yb-admin-module-form" class="yb-admin__form">
            <input type="hidden" id="yb-mf-id">
            <div class="yb-admin__field">
              <label for="yb-mf-title">{{ t.title }}</label>
              <input type="text" id="yb-mf-title" required>
            </div>
            <div class="yb-admin__field">
              <label for="yb-mf-desc">{{ t.description }}</label>
              <textarea id="yb-mf-desc" rows="3"></textarea>
            </div>
            <div class="yb-admin__form-row">
              <div class="yb-admin__field">
                <label for="yb-mf-icon">{{ t.icon }}</label>
                <input type="text" id="yb-mf-icon" placeholder="📖" style="max-width:80px">
              </div>
              <div class="yb-admin__field">
                <label for="yb-mf-order">{{ t.order }}</label>
                <input type="number" id="yb-mf-order" min="1" value="1" style="max-width:80px">
              </div>
            </div>
            <div class="yb-admin__form-actions">
              <button type="submit" class="yb-btn yb-btn--primary">{{ t.save }}</button>
              <button type="button" class="yb-btn yb-btn--outline" data-action="back-modules">{{ t.cancel }}</button>
            </div>
          </form>
        </div>

        {# VIEW: Chapters list #}
        <div class="yb-admin__view" id="yb-admin-v-chapters" hidden>
          <div class="yb-admin__view-head">
            <button class="yb-admin__back-btn" data-action="back-modules">&larr; {{ t.back }}</button>
            <h2 id="yb-admin-chapters-heading">{{ t.chapters_title }}</h2>
            <div class="yb-admin__view-head-btns">
              <button class="yb-btn yb-btn--outline" data-action="bulk-import">{{ t.bulk_import }}</button>
              <button class="yb-btn yb-btn--primary" data-action="new-chapter">+ {{ t.new_chapter }}</button>
            </div>
          </div>
          {# Chapter items rendered by JS — each item includes:
             - Duplicate button: data-action="duplicate-chapter" data-id="{chapterId}" with ⧉ icon #}
          <div id="yb-admin-chapter-list" class="yb-admin__item-list"></div>
        </div>

        {# VIEW: Chapter form #}
        <div class="yb-admin__view" id="yb-admin-v-chapter-form" hidden>
          <div class="yb-admin__view-head">
            <button class="yb-admin__back-btn" data-action="back-chapters">&larr; {{ t.back }}</button>
            <h2 id="yb-admin-chapter-form-title">{{ t.new_chapter }}</h2>
          </div>
          <form id="yb-admin-chapter-form" class="yb-admin__form">
            <input type="hidden" id="yb-chf-id">
            <div class="yb-admin__form-row">
              <div class="yb-admin__field">
                <label for="yb-chf-title">{{ t.title }}</label>
                <input type="text" id="yb-chf-title" required>
              </div>
              <div class="yb-admin__field">
                <label for="yb-chf-order">{{ t.order }}</label>
                <input type="number" id="yb-chf-order" min="1" value="1" style="max-width:80px">
              </div>
            </div>
            <label class="yb-admin__field-label">{{ t.content }}</label>
            {# Rich Text Toolbar #}
            <div class="yb-admin__toolbar" id="yb-admin-toolbar">
              <button type="button" class="yb-admin__toolbar-btn" data-action="toolbar-bold" title="Bold"><strong>B</strong></button>
              <button type="button" class="yb-admin__toolbar-btn" data-action="toolbar-italic" title="Italic"><em>I</em></button>
              <span class="yb-admin__toolbar-sep"></span>
              <button type="button" class="yb-admin__toolbar-btn" data-action="toolbar-h2" title="Heading 2">H2</button>
              <button type="button" class="yb-admin__toolbar-btn" data-action="toolbar-h3" title="Heading 3">H3</button>
              <span class="yb-admin__toolbar-sep"></span>
              <button type="button" class="yb-admin__toolbar-btn" data-action="toolbar-ul" title="Bullet List">&bull; List</button>
              <button type="button" class="yb-admin__toolbar-btn" data-action="toolbar-ol" title="Numbered List">1. List</button>
              <span class="yb-admin__toolbar-sep"></span>
              <button type="button" class="yb-admin__toolbar-btn" data-action="toolbar-blockquote" title="Blockquote">&ldquo; Quote</button>
              <button type="button" class="yb-admin__toolbar-btn" data-action="toolbar-link" title="Link">&#128279; Link</button>
            </div>
            <div class="yb-admin__editor-wrap">
              <div class="yb-admin__editor-panel">
                <textarea id="yb-chf-content" class="yb-admin__editor-textarea" rows="20" placeholder="<h2>Heading</h2><p>Content...</p>"></textarea>
              </div>
              <div class="yb-admin__preview-panel" id="yb-admin-preview">
                <div class="yb-admin__preview-label">{{ t.preview }}</div>
                <div class="yb-admin__preview-body yb-cv__content" id="yb-admin-preview-body"></div>
              </div>
            </div>
            {# Word Count #}
            <span id="yb-admin-word-count" class="yb-admin__word-count"></span>
            <div class="yb-admin__form-actions">
              <button type="submit" class="yb-btn yb-btn--primary">{{ t.save }}</button>
              <button type="button" class="yb-btn yb-btn--outline" data-action="back-chapters">{{ t.cancel }}</button>
            </div>
          </form>
        </div>

        {# VIEW: Bulk import #}
        <div class="yb-admin__view" id="yb-admin-v-bulk" hidden>
          <div class="yb-admin__view-head">
            <button class="yb-admin__back-btn" data-action="back-chapters">&larr; {{ t.back }}</button>
            <h2>{{ t.bulk_import }}</h2>
          </div>
          <div id="yb-admin-bulk-step1">
            <textarea id="yb-admin-bulk-text" class="yb-admin__bulk-textarea" rows="16" placeholder="{{ t.bulk_paste }}"></textarea>
            <div class="yb-admin__bulk-options">
              <div class="yb-admin__bulk-opt">
                <strong>{{ t.bulk_split_by }}</strong>
                <label><input type="radio" name="bulk-split" value="headings" checked> {{ t.bulk_split_headings }}</label>
                <label><input type="radio" name="bulk-split" value="blank"> {{ t.bulk_split_blank }}</label>
                <label><input type="radio" name="bulk-split" value="hr"> {{ t.bulk_split_hr }}</label>
              </div>
            </div>
            <button class="yb-btn yb-btn--primary" id="yb-admin-bulk-preview-btn">{{ t.bulk_preview_btn }}</button>
          </div>
          <div id="yb-admin-bulk-step2" hidden>
            <div class="yb-admin__bulk-count" id="yb-admin-bulk-count"></div>
            <div id="yb-admin-bulk-cards" class="yb-admin__bulk-cards"></div>
            <div class="yb-admin__bulk-actions">
              <button class="yb-btn yb-btn--primary" id="yb-admin-bulk-create-btn">{{ t.bulk_create_btn }}</button>
              <button class="yb-btn yb-btn--outline" id="yb-admin-bulk-back-btn">{{ t.back }}</button>
            </div>
          </div>
          <div id="yb-admin-bulk-progress" hidden>
            <div class="yb-admin__progress-bar"><div class="yb-admin__progress-fill" id="yb-admin-bulk-fill"></div></div>
            <p id="yb-admin-bulk-status"></p>
          </div>
        </div>

      </div>{# end courses tab panel #}

      {# ═══════════════════════════════════
         TAB: Users
         ═══════════════════════════════════ #}
      <div class="yb-admin__tab-panel" data-yb-admin-panel="users">
        {% include "partials/admin-users-panel.njk" %}
      </div>{# end users tab panel #}

      {# ═══════════════════════════════════
         TAB: Analytics
         ═══════════════════════════════════ #}
      <div class="yb-admin__tab-panel is-active" data-yb-admin-panel="analytics">

        {# ── SECTION 1: Conversion & Ad Tracking ── #}
        <div class="yb-admin__view-head">
          <h2>{{ t.conv_title }}</h2>
          <p style="color:#6F6A66;margin:4px 0 0">{{ t.conv_subtitle }}</p>
        </div>

        {# Period filter #}
        <div style="display:flex;gap:8px;margin:12px 0 16px;flex-wrap:wrap">
          <button class="yb-admin__btn yb-admin__btn--sm yb-admin__conv-period" data-conv-days="7">{{ t.conv_period_7d }}</button>
