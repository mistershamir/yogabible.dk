<script>
  (function(){
    var root = document.getElementById('yb-coc');
    if(!root) return;

    var details = root.querySelectorAll('details.yb-acc');
    details.forEach(function(d){
      d.addEventListener('toggle', function(){
        if(!d.open) return;
        details.forEach(function(other){ if(other !== d) other.open = false; });
      });
    });

    function openFromHash(){
      var id = (window.location.hash || '').replace('#','');
      if(!id) return;
      var target = root.querySelector('#' + CSS.escape(id));
      if(target && target.tagName.toLowerCase() === 'details'){
        target.open = true;
        target.scrollIntoView({behavior:'smooth', block:'start'});
      }
    }
    window.addEventListener('hashchange', openFromHash);
    setTimeout(openFromHash, 40);
  })();
</script>
