}

/* Grid */
.yba-rooms__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  align-items: stretch;
}
@media (min-width: 960px) {
  .yba-rooms__grid { grid-template-columns: 1fr 1fr; gap: 1.75rem; }
}

/* Card */
.yba-room-card {
  border: 1px solid var(--yba-border);
  border-radius: 20px;
  background: #fff;
  box-shadow: 0 18px 60px rgba(0,0,0,.10);
  overflow: hidden;
  display: grid;
  grid-template-rows: auto auto auto 1fr auto auto;
  min-height: 100%;
}

/* Gallery */
.yba-gallery {
  position: relative;
  width: 100%;
  aspect-ratio: 16/11;
  background: #f6f3f0;
  overflow: hidden;
}

.yba-gallery__track {
  height: 100%;
  display: flex;
  transform: translateX(0);
  transition: transform 0.35s ease;
}

.yba-gallery__track img {
  flex: 0 0 100%;
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.yba-gallery__frame {
  position: absolute;
  inset: 0;
  pointer-events: none;
  box-shadow: inset 0 0 0 1px rgba(0,0,0,.06), inset 0 0 0 2px rgba(247,92,3,.10);
}

.yba-gallery__prev,
.yba-gallery__next {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 42px;
  height: 42px;
  border-radius: 999px;
  border: 1px solid rgba(255,255,255,.55);
  background: rgba(15,15,15,.35);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  cursor: pointer;
  z-index: 2;
  transition: background 0.18s, transform 0.1s, box-shadow 0.18s;
  box-shadow: 0 10px 22px rgba(0,0,0,.18);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.yba-gallery__prev { left: 12px; }
.yba-gallery__next { right: 12px; }

.yba-gallery__prev:hover,
.yba-gallery__next:hover {
  background: rgba(247,92,3,.92);
  border-color: rgba(247,92,3,.4);
  transform: translateY(-50%) translateY(-1px);
  box-shadow: 0 16px 34px rgba(247,92,3,.25);
}

.yba-gallery__prev:focus-visible,
.yba-gallery__next:focus-visible {
  outline: 0;
  box-shadow: 0 0 0 6px var(--yba-ring);
}

/* Dots */
.yba-gallery__dots {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 12px;
  display: flex;
  justify-content: center;
  gap: 6px;
  z-index: 2;
}

.yba-gallery__dot {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: rgba(255,255,255,.6);
  border: 1px solid rgba(0,0,0,.10);
  box-shadow: 0 6px 14px rgba(0,0,0,.12);
