  padding: 0;
  transition: all 0.15s;
}

.yba-gallery__dot.is-active {
  background: rgba(247,92,3,.95);
  border-color: rgba(247,92,3,.25);
  box-shadow: 0 10px 22px rgba(247,92,3,.20);
  transform: scale(1.15);
}

