<!-- ═══════════════════════════════════════════════════════════
     JAVASCRIPT — Galleries, Chips, FAQ Accordion
     ═══════════════════════════════════════════════════════════ -->
<script>
(function(){
  /* ── Payment Links ── */
  var reserveLinks = {
    feb: {
      single: 'https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=43&prodid=100114',
      double: 'https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=43&catid=100003&prodGroupId=100136'
    },
    mar: {
      single: 'https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=43&prodid=100115',
      double: 'https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=43&catid=100003&prodGroupId=100135'
    },
    apr: {
      single: 'https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=43&catid=100001&prodGroupId=100116',
      double: 'https://clients.mindbodyonline.com/classic/ws?studioid=5748831&stype=43&catid=100003&prodGroupId=100134'
    }
  };

  var monthLabels = {
    feb: 'februar 2026',
    mar: 'marts 2026',
    apr: 'april 2026'
  };

  /* ── Room Cards: Chips + Gallery ── */
  document.querySelectorAll('.yba-room-card').forEach(function(card) {
    var type = card.dataset.type;
    var chips = card.querySelectorAll('.yba-chip');
    var reserveBtn = card.querySelector('.js-reserve');
    var currentMonth = 'feb';

    function updateReserveBtn() {
      if (!reserveBtn) return;
      var url = (reserveLinks[currentMonth] && reserveLinks[currentMonth][type]) || '#';
      var label = monthLabels[currentMonth] || currentMonth;
      reserveBtn.href = url;
      reserveBtn.textContent = 'Reserver & betal for ' + label;
    }
    updateReserveBtn();

    chips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        chips.forEach(function(c) {
          c.classList.remove('is-active');
          c.setAttribute('aria-selected', 'false');
        });
        chip.classList.add('is-active');
        chip.setAttribute('aria-selected', 'true');
        currentMonth = chip.dataset.month;
        updateReserveBtn();
      });
    });

    /* Gallery */
    var gallery = card.querySelector('.yba-gallery');
    if (!gallery) return;

    var track = gallery.querySelector('.yba-gallery__track');
    var imgs = track ? Array.from(track.querySelectorAll('img')) : [];
    var prevBtn = gallery.querySelector('.yba-gallery__prev');
    var nextBtn = gallery.querySelector('.yba-gallery__next');
    var dotsWrap = gallery.querySelector('.yba-gallery__dots');

    if (imgs.length <= 1) return;

    var index = 0;

    var dots = imgs.map(function(_, i) {
      var d = document.createElement('button');
      d.type = 'button';
      d.className = 'yba-gallery__dot' + (i === 0 ? ' is-active' : '');
      d.setAttribute('aria-label', 'Gå til billede ' + (i + 1));
      d.addEventListener('click', function() { goTo(i); });
      dotsWrap.appendChild(d);
      return d;
    });

    function goTo(n) {
      index = (n + imgs.length) % imgs.length;
      track.style.transform = 'translateX(-' + (index * 100) + '%)';
      dots.forEach(function(d, i) { d.classList.toggle('is-active', i === index); });
    }

    prevBtn.addEventListener('click', function(e) { e.preventDefault(); goTo(index - 1); });
    nextBtn.addEventListener('click', function(e) { e.preventDefault(); goTo(index + 1); });

    /* Touch/Swipe */
    var startX = 0, diffX = 0, dragging = false;
    gallery.addEventListener('touchstart', function(e) { startX = e.touches[0].clientX; diffX = 0; dragging = true; }, { passive: true });
    gallery.addEventListener('touchmove', function(e) { if (!dragging) return; diffX = e.touches[0].clientX - startX; }, { passive: true });
    gallery.addEventListener('touchend', function() { dragging = false; if (diffX < -40) goTo(index + 1); if (diffX > 40) goTo(index - 1); startX = diffX = 0; });

    /* Auto-advance */
    var prefersReduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (!prefersReduced) {
      var timer = setInterval(function() { goTo(index + 1); }, 5000);
      card.addEventListener('mouseenter', function() { clearInterval(timer); });
      card.addEventListener('mouseleave', function() { timer = setInterval(function() { goTo(index + 1); }, 5000); });
    }
  });


  /* ── FAQ Accordion ── */
  document.querySelectorAll('.yba-faq-trigger').forEach(function(trigger) {
    trigger.addEventListener('click', function() {
      var item = trigger.closest('.yba-faq-item');
      var body = item.querySelector('.yba-faq-body');
      var icon = trigger.querySelector('.yba-faq-icon');
      var isOpen = item.classList.contains('is-open');

      if (isOpen) {
        item.classList.remove('is-open');
        body.hidden = true;
        icon.textContent = '+';
        trigger.setAttribute('aria-expanded', 'false');
      } else {
        item.classList.add('is-open');
        body.hidden = false;
        icon.textContent = '×';
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });


  /* ── Smooth scroll for anchor links ── */
  document.querySelectorAll('a[href^="#"]').forEach(function(a) {
    a.addEventListener('click', function(e) {
      var target = document.querySelector(a.getAttribute('href'));
      if (target) {
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

})();
</script>
