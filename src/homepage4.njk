<!-- ═══════════════════════════════════════════════════════════════
     SCRIPTS
     ═══════════════════════════════════════════════════════════════ -->
<script>
(function() {
  // Accordion
  var accordionItems = document.querySelectorAll('.hp4-accordion__item');
  accordionItems.forEach(function(item) {
    var header = item.querySelector('.hp4-accordion__header');
    header.addEventListener('click', function() {
      var wasActive = item.classList.contains('active');
      accordionItems.forEach(function(i) { i.classList.remove('active'); });
      if (!wasActive) {
        item.classList.add('active');
      }
    });
  });

  // Course Tabs
  var courseTabs = document.querySelectorAll('.hp4-courses__tab');
  var coursePanels = document.querySelectorAll('.hp4-courses__panel');
  courseTabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var target = this.getAttribute('data-tab');
      courseTabs.forEach(function(t) { t.classList.remove('active'); });
      coursePanels.forEach(function(p) { p.classList.remove('active'); });
      this.classList.add('active');
      document.getElementById(target).classList.add('active');
    });
  });
})();
</script>
