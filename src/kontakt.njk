            <option value="uddannelse">Om en uddannelse</option>
            <option value="kursus">Om et kursus</option>
            <option value="indkvartering">Indkvartering under uddannelse</option>
            <option value="job">Jobansøgning</option>
          </select>
        </label>

        <label class="yb-modal-u__field">
          <span>Anti-spam: Skriv NAMASTE *</span>
          <input type="text" name="antispam" id="ybAntispam" required autocomplete="off">
        </label>

        <label class="yb-modal-u__field">
          <span>Din besked *</span>
          <textarea name="message" id="ybMessage" rows="5" required></textarea>
        </label>

        <p class="yb-modal-u__fine">* Obligatoriske felter</p>

        <p id="ybFormError" class="yb-modal-u__error" hidden></p>

        <button id="ybSubmitBtn" class="yb-btn yb-btn--cta" type="submit">Send henvendelse</button>
