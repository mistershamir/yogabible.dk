            <input type="text" name="lastName" id="ybLastName" required>
          </label>

          <label class="yb-modal-u__field">
            <span>E-mail *</span>
            <input type="email" name="email" id="ybEmail" required>
          </label>

          <label class="yb-modal-u__field">
