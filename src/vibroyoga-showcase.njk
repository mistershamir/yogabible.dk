  <!-- ── Progress Bar ── -->
  <div class="vs-progress"><div class="vs-progress__bar" id="vs-progress-bar"></div></div>

  <!-- ========================================
       SECTION 1: OSCILLOSCOPE
       ======================================== -->
  <section class="vs-section vs-section--oscilloscope" id="oscilloscope" data-vs-idx="0" data-vs-bg="#0d0a1a">
    <canvas class="vs-canvas" data-vs-type="oscilloscope"></canvas>
    <div class="vs-section__overlay">
      <span class="vs-section__number">01</span>
      <h2 class="vs-section__title">Oscilloscope</h2>
      <p class="vs-section__subtitle">Move your cursor up and down to change the waveform amplitude</p>
    </div>
    <div class="vs-section__cards">
      <div class="vs-card vs-card--oscilloscope">
        <div class="vs-card__freq">10 Hz</div>
        <h3 class="vs-card__title">Low Frequency</h3>
        <p class="vs-card__text">Deep, slow waves that penetrate muscle tissue for maximum release.</p>
      </div>
      <div class="vs-card vs-card--oscilloscope">
        <div class="vs-card__freq">30 Hz</div>
        <h3 class="vs-card__title">Mid Frequency</h3>
        <p class="vs-card__text">The sweet spot for neuromuscular activation and core engagement.</p>
      </div>
      <div class="vs-card vs-card--oscilloscope">
        <div class="vs-card__freq">50 Hz</div>
        <h3 class="vs-card__title">High Frequency</h3>
        <p class="vs-card__text">Rapid micro-vibrations that boost circulation and warm tissues.</p>
      </div>
    </div>
  </section>

  <!-- ========================================
       SECTION 2: SEISMIC
       ======================================== -->
  <section class="vs-section vs-section--seismic" id="seismic" data-vs-idx="1" data-vs-bg="#0f0806">
    <div class="vs-section__overlay">
      <span class="vs-section__number">02</span>
      <h2 class="vs-section__title" data-vs-tremor>Seismic</h2>
      <p class="vs-section__subtitle">Feel the earth move — scroll to increase intensity</p>
    </div>
    <div class="vs-seismic-readout">
      <canvas class="vs-seismic-canvas" height="120"></canvas>
      <div class="vs-seismic-metrics">
        <div class="vs-seismic-metric">
          <span class="vs-seismic-metric__value">10</span>
          <span class="vs-seismic-metric__label">Hz Base</span>
        </div>
        <div class="vs-seismic-metric">
          <span class="vs-seismic-metric__value">50</span>
          <span class="vs-seismic-metric__label">Hz Peak</span>
        </div>
        <div class="vs-seismic-metric">
          <span class="vs-seismic-metric__value">3×</span>
          <span class="vs-seismic-metric__label">Deeper</span>
        </div>
        <div class="vs-seismic-metric">
          <span class="vs-seismic-metric__value">35%</span>
          <span class="vs-seismic-metric__label">More Flow</span>
        </div>
      </div>
    </div>
    <div class="vs-section__cards">
      <div class="vs-card vs-card--seismic" data-vs-shake>
        <h3 class="vs-card__title">Foundation</h3>
        <p class="vs-card__text">Vibration challenges your base, making still poses profoundly powerful.</p>
      </div>
      <div class="vs-card vs-card--seismic" data-vs-shake>
        <h3 class="vs-card__title">Aftershock</h3>
        <p class="vs-card__text">Benefits ripple outward — better balance, deeper sleep, reduced tension.</p>
      </div>
      <div class="vs-card vs-card--seismic" data-vs-shake>
        <h3 class="vs-card__title">Release</h3>
        <p class="vs-card__text">Vibration helps your body release stored tension in muscles and fascia.</p>
      </div>
    </div>
  </section>

  <!-- ========================================
       SECTION 3: RESONANCE CASCADE
       ======================================== -->
  <section class="vs-section vs-section--resonance" id="resonance" data-vs-idx="2" data-vs-bg="#080810">
    <div class="vs-resonance-rings">
      <div class="vs-resonance-ring"></div>
      <div class="vs-resonance-ring"></div>
      <div class="vs-resonance-ring"></div>
      <div class="vs-resonance-ring"></div>
      <div class="vs-resonance-ring"></div>
    </div>
    <div class="vs-section__overlay">
      <span class="vs-section__number">03</span>
      <h2 class="vs-section__title">Resonance Cascade</h2>
      <p class="vs-section__subtitle">Hover a card — watch the vibration spread to the others</p>
    </div>
    <div class="vs-section__cards vs-section__cards--cascade">
      <div class="vs-card vs-card--resonance" data-vs-cascade="0">
        <h3 class="vs-card__title">Touch</h3>
        <p class="vs-card__text">The vibration begins at the point of contact.</p>
      </div>
      <div class="vs-card vs-card--resonance" data-vs-cascade="1">
        <h3 class="vs-card__title">Travel</h3>
        <p class="vs-card__text">It travels through muscle, tendon, and bone.</p>
      </div>
      <div class="vs-card vs-card--resonance" data-vs-cascade="2">
        <h3 class="vs-card__title">Resonate</h3>
        <p class="vs-card__text">External frequency meets your body's natural frequency.</p>
      </div>
      <div class="vs-card vs-card--resonance" data-vs-cascade="3">
        <h3 class="vs-card__title">Release</h3>
        <p class="vs-card__text">Tension dissolves. Fascia softens. Deep rest begins.</p>
      </div>
      <div class="vs-card vs-card--resonance" data-vs-cascade="4">
        <h3 class="vs-card__title">Transform</h3>
        <p class="vs-card__text">Each session compounds. Your body deepens its capacity.</p>
      </div>
      <div class="vs-card vs-card--resonance" data-vs-cascade="5">
        <h3 class="vs-card__title">Radiate</h3>
        <p class="vs-card__text">Benefits extend beyond the mat into every part of life.</p>
      </div>
    </div>
  </section>

  <!-- ========================================
       SECTION 4: MOLECULAR
       ======================================== -->
  <section class="vs-section vs-section--molecular" id="molecular" data-vs-idx="3" data-vs-bg="#061515">
    <canvas class="vs-canvas" data-vs-type="molecular"></canvas>
    <div class="vs-section__overlay">
      <span class="vs-section__number">04</span>
      <h2 class="vs-section__title">Molecular</h2>
      <p class="vs-section__subtitle">Scroll to increase molecular energy — watch particles accelerate</p>
    </div>
    <div class="vs-temp-meter">
      <div class="vs-temp-meter__track">
        <div class="vs-temp-meter__fill" id="vs-temp-fill"></div>
      </div>
      <span class="vs-temp-meter__label">Energy Level</span>
    </div>
  </section>

  <!-- ========================================
       SECTION 5: FREQUENCY
       ======================================== -->
  <section class="vs-section vs-section--frequency" id="frequency" data-vs-idx="4" data-vs-bg="#050508">
    <canvas class="vs-canvas" data-vs-type="frequency"></canvas>
    <div class="vs-section__overlay">
      <span class="vs-section__number">05</span>
      <h2 class="vs-section__title vs-section__title--vibrate">
        <span class="vs-vibrate-letter">F</span><span class="vs-vibrate-letter">R</span><span class="vs-vibrate-letter">E</span><span class="vs-vibrate-letter">Q</span><span class="vs-vibrate-letter">U</span><span class="vs-vibrate-letter">E</span><span class="vs-vibrate-letter">N</span><span class="vs-vibrate-letter">C</span><span class="vs-vibrate-letter">Y</span>
      </h2>
      <p class="vs-section__subtitle">Your body is an instrument — we help you find its frequency</p>
    </div>
    <div class="vs-freq-bars" id="vs-freq-bars">
      <div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div>
      <div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div>
      <div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div>
      <div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div>
      <div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div>
      <div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div>
      <div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div>
      <div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div><div class="vs-freq-bar"></div>
    </div>
  </section>

  <!-- ========================================
       SECTION 6: CURSOR FIELD
       ======================================== -->
  <section class="vs-section vs-section--cursor" id="cursor-field" data-vs-idx="5" data-vs-bg="#030306">
    <canvas class="vs-canvas" data-vs-type="cursor-field"></canvas>
    <div class="vs-section__overlay">
      <span class="vs-section__number">06</span>
      <h2 class="vs-section__title" data-vs-magnetic>Cursor Field</h2>
      <p class="vs-section__subtitle">Move your cursor — particles react to your presence</p>
    </div>
  </section>

  <!-- ========================================
       SECTION 7: CYMATICS
       ======================================== -->
  <section class="vs-section vs-section--cymatics" id="cymatics" data-vs-idx="6" data-vs-bg="#060608">
    <canvas class="vs-canvas" data-vs-type="cymatics"></canvas>
    <div class="vs-section__overlay">
      <span class="vs-section__number">07</span>
      <h2 class="vs-section__title">Cymatics</h2>
      <p class="vs-section__subtitle">When vibration creates form — scroll to change the wave frequency</p>
    </div>
    <div class="vs-mandala">
      <svg class="vs-mandala__svg" viewBox="0 0 400 400">
        <circle cx="200" cy="200" r="60" fill="none" stroke="#e8dcc8" stroke-width="0.5" opacity="0.3"/>
        <circle cx="200" cy="200" r="100" fill="none" stroke="#e8dcc8" stroke-width="0.5" opacity="0.25"/>
        <circle cx="200" cy="200" r="140" fill="none" stroke="#e8dcc8" stroke-width="0.5" opacity="0.2"/>
        <circle cx="200" cy="200" r="180" fill="none" stroke="#e8dcc8" stroke-width="0.5" opacity="0.15"/>
      </svg>
    </div>
  </section>

  <!-- ========================================
       SECTION 8: STRING RESONANCE (NEW)
       ======================================== -->
  <section class="vs-section vs-section--strings" id="strings" data-vs-idx="7" data-vs-bg="#120808">
    <div class="vs-section__overlay">
      <span class="vs-section__number">08</span>
      <h2 class="vs-section__title">String Resonance</h2>
      <p class="vs-section__subtitle">Hover over the strings to pluck them — each vibrates at a different frequency</p>
    </div>
    <div class="vs-strings-container" id="vs-strings">
      <svg class="vs-string-svg" viewBox="0 0 1000 50" preserveAspectRatio="none" data-vs-string="0" data-vs-note="C">
        <line x1="0" y1="25" x2="1000" y2="25" stroke="#e05555" stroke-width="2"/>
      </svg>
      <svg class="vs-string-svg" viewBox="0 0 1000 50" preserveAspectRatio="none" data-vs-string="1" data-vs-note="D">
        <line x1="0" y1="25" x2="1000" y2="25" stroke="#e06666" stroke-width="1.8"/>
      </svg>
      <svg class="vs-string-svg" viewBox="0 0 1000 50" preserveAspectRatio="none" data-vs-string="2" data-vs-note="E">
        <line x1="0" y1="25" x2="1000" y2="25" stroke="#e07777" stroke-width="1.6"/>
      </svg>
      <svg class="vs-string-svg" viewBox="0 0 1000 50" preserveAspectRatio="none" data-vs-string="3" data-vs-note="G">
        <line x1="0" y1="25" x2="1000" y2="25" stroke="#e08888" stroke-width="1.4"/>
      </svg>
      <svg class="vs-string-svg" viewBox="0 0 1000 50" preserveAspectRatio="none" data-vs-string="4" data-vs-note="A">
        <line x1="0" y1="25" x2="1000" y2="25" stroke="#e09999" stroke-width="1.2"/>
      </svg>
      <svg class="vs-string-svg" viewBox="0 0 1000 50" preserveAspectRatio="none" data-vs-string="5" data-vs-note="B">
        <line x1="0" y1="25" x2="1000" y2="25" stroke="#e0aaaa" stroke-width="1"/>
      </svg>
    </div>
    <div class="vs-string-labels" id="vs-string-labels">
      <span>65 Hz</span><span>73 Hz</span><span>82 Hz</span><span>98 Hz</span><span>110 Hz</span><span>123 Hz</span>
    </div>
  </section>

  <!-- ========================================
       SECTION 9: RIPPLE INTERFERENCE (NEW)
       ======================================== -->
  <section class="vs-section vs-section--ripple" id="ripple" data-vs-idx="8" data-vs-bg="#060a14">
    <canvas class="vs-canvas" data-vs-type="ripple"></canvas>
    <div class="vs-section__overlay">
      <span class="vs-section__number">09</span>
      <h2 class="vs-section__title">Ripple Interference</h2>
      <p class="vs-section__subtitle">Click anywhere to create wave sources — watch the interference patterns form</p>
    </div>
    <div class="vs-ripple-counter">
      <span id="vs-ripple-count">0</span> sources
    </div>
  </section>

  <!-- ========================================
       SECTION 10: PENDULUM WAVE (NEW)
       ======================================== -->
  <section class="vs-section vs-section--pendulum" id="pendulum" data-vs-idx="9" data-vs-bg="#061008">
    <canvas class="vs-canvas" data-vs-type="pendulum"></canvas>
    <div class="vs-section__overlay">
      <span class="vs-section__number">10</span>
      <h2 class="vs-section__title">Pendulum Wave</h2>
      <p class="vs-section__subtitle">15 pendulums of different lengths create mesmerizing wave patterns</p>
    </div>
    <div class="vs-pendulum-controls">
      <button class="vs-pendulum-btn" id="vs-pendulum-reset">Reset Wave</button>
    </div>
  </section>

  <!-- ── Footer ── -->
  <footer class="vs-footer">
    <div class="vs-footer__inner">
      <p class="vs-footer__logo">Vibro Yoga</p>
      <p class="vs-footer__text">10 ways to visualize vibration — Christianshavn, Copenhagen</p>
      <a href="/vibroyogadesign/" class="vs-footer__link">&larr; Back to Design Playground</a>
