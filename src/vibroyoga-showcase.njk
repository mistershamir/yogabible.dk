        <a href="#oscilloscope" class="vs-nav__link is-active" data-section="0">Oscilloscope</a>
        <a href="#seismic" class="vs-nav__link" data-section="1">Seismic</a>
        <a href="#resonance" class="vs-nav__link" data-section="2">Resonance</a>
        <a href="#molecular" class="vs-nav__link" data-section="3">Molecular</a>
        <a href="#frequency" class="vs-nav__link" data-section="4">Frequency</a>
