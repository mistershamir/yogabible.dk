  bottom: 20px;
  left: 20px;
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: #fff;
  background: rgba(0,0,0,0.6);
  padding: 8px 16px;
}

/* Deep Dive Tabs */
