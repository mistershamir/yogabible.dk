.hp2-card__tag {
  font-size: 0.7rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--yb-brand);
  margin-bottom: 12px;
}

.hp2-card__title {
  font-size: 1.5rem;
  font-weight: 700;
  margin-bottom: 12px;
