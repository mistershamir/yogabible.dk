<script>
// Scroll-triggered animations
document.addEventListener('DOMContentLoaded', function() {
  var animElements = document.querySelectorAll('.ds-scroll-anim, .ds-stagger');

  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
      }
    });
  }, { threshold: 0.2 });

  animElements.forEach(function(el) {
    observer.observe(el);
  });

  // Counter animation
  var counters = document.querySelectorAll('.ds-counter');
  counters.forEach(function(counter) {
    var target = parseInt(counter.getAttribute('data-target'));
    var count = 0;
    var increment = target / 50;

    var counterObserver = new IntersectionObserver(function(entries) {
      if (entries[0].isIntersecting) {
        var updateCount = function() {
          if (count < target) {
            count += increment;
            counter.textContent = Math.ceil(count);
            requestAnimationFrame(updateCount);
          } else {
            counter.textContent = target + '+';
          }
        };
        updateCount();
        counterObserver.disconnect();
      }
    }, { threshold: 0.5 });

    counterObserver.observe(counter);
  });

  // ══════════════════════════════════════════════════════════════
  // SCROLL-DRAW PATH ANIMATION
  // SVG paths draw themselves as you scroll inside their container
  // Supports: shadow trails, growing leaves
  // ══════════════════════════════════════════════════════════════
  var drawPreviews = document.querySelectorAll('[data-scroll-draw]');
  drawPreviews.forEach(function(container) {
    var paths = container.querySelectorAll('.ds-draw-path');
    var shadows = container.querySelectorAll('.ds-draw-shadow');
    var leaves = container.querySelectorAll('.ds-vine-leaf');

    // Initialize all paths with dash offset
    paths.forEach(function(path) {
      var length = path.getTotalLength();
      path.style.strokeDasharray = length;
      path.style.strokeDashoffset = length;
      path.style.transition = 'none';
    });

    shadows.forEach(function(shadow) {
      var length = shadow.getTotalLength();
      shadow.style.strokeDasharray = length;
      shadow.style.strokeDashoffset = length;
      shadow.style.transition = 'none';
    });

    // Listen for scroll inside the container
    container.addEventListener('scroll', function() {
      var scrollTop = container.scrollTop;
      var scrollHeight = container.scrollHeight - container.clientHeight;
      if (scrollHeight <= 0) return;
      var progress = scrollTop / scrollHeight;

      paths.forEach(function(path) {
        var length = path.getTotalLength();
        var speed = parseFloat(path.getAttribute('data-draw-speed')) || 1;
        var drawLength = Math.min(progress * speed, 1) * length;
        path.style.strokeDashoffset = length - drawLength;
      });

      shadows.forEach(function(shadow) {
        var length = shadow.getTotalLength();
        var drawLength = Math.min(progress * 1.15, 1) * length;
        shadow.style.strokeDashoffset = length - drawLength;
      });

      // Grow leaves when the vine reaches their position
      leaves.forEach(function(leaf) {
        var appearAt = parseFloat(leaf.getAttribute('data-appear-at')) || 0;
        if (progress >= appearAt) {
          leaf.classList.add('ds-leaf--visible');
        } else {
          leaf.classList.remove('ds-leaf--visible');
        }
      });
    });
  });
});
</script>


