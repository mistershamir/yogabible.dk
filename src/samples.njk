---
layout: base.njk
title: "Design System & Samples | YOGA BIBLE"
description: "Comprehensive design system with all UI components, patterns, and styles."
permalink: /samples/
includeScheduleModal: false
eleventyExcludeFromCollections: true
---

<style>
/* ================================================================
   SAMPLES PAGE - DESIGN SYSTEM STYLES
   ================================================================ */

.ds {
  --ds-border: #E8E4E0;
  --ds-bg-light: #FFFCF9;
  --ds-bg-dark: #0F0F0F;
  --ds-text: #1C1C1C;
  --ds-text-muted: #6F6A66;
}

.ds-page {
  max-width: 1400px;
  margin: 0 auto;
  padding: 60px 24px 120px;
}

.ds-header {
  text-align: center;
  margin-bottom: 80px;
  padding-bottom: 60px;
  border-bottom: 1px solid var(--ds-border);
}

.ds-header__title {
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 700;
  margin-bottom: 16px;
}

.ds-header__subtitle {
  font-size: 1.2rem;
  color: var(--ds-text-muted);
  max-width: 700px;
  margin: 0 auto;
}

/* Section */
.ds-section {
  margin-bottom: 100px;
}

.ds-section__header {
  margin-bottom: 40px;
  padding-bottom: 20px;
  border-bottom: 2px solid var(--yb-brand);
}

.ds-section__title {
  font-size: 1.75rem;
  font-weight: 700;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 12px;
}

.ds-section__title::before {
  content: attr(data-number);
  background: var(--yb-brand);
  color: #fff;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85rem;
  flex-shrink: 0;
}

.ds-section__desc {
  color: var(--ds-text-muted);
  font-size: 1rem;
}

/* Subsection */
.ds-sub {
  margin-bottom: 48px;
}

.ds-sub__title {
  font-size: 1.1rem;
  font-weight: 700;
  margin-bottom: 6px;
}

.ds-sub__desc {
  font-size: 0.85rem;
  color: var(--ds-text-muted);
  margin-bottom: 20px;
}

/* Demo Container */
.ds-demo {
  background: var(--ds-bg-light);
  border: 1px solid var(--ds-border);
  border-radius: 12px;
  padding: 40px;
}

.ds-demo--dark {
  background: var(--ds-bg-dark);
  border-color: #333;
}

.ds-demo--grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 24px;
}

.ds-demo--flex {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  align-items: center;
}

.ds-demo--full {
  margin-left: -24px;
  margin-right: -24px;
  border-radius: 0;
  border-left: none;
  border-right: none;
}

.ds-code {
  background: #1C1C1C;
  color: #E8E4E0;
  padding: 12px 16px;
  border-radius: 6px;
  font-family: 'SF Mono', Monaco, monospace;
  font-size: 0.75rem;
  margin-top: 12px;
  overflow-x: auto;
}

.ds-label {
  display: inline-block;
  background: #F5F3F0;
  padding: 4px 10px;
  border-radius: 4px;
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--ds-text-muted);
  margin-bottom: 8px;
}

/* ================================================================
   1. COLORS
   ================================================================ */
.ds-color-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  gap: 16px;
}

.ds-color__swatch {
  height: 80px;
  border-radius: 8px;
  margin-bottom: 8px;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 8px;
  font-size: 0.65rem;
  font-family: monospace;
}

.ds-color__name {
  font-weight: 700;
  font-size: 0.8rem;
}

.ds-color__usage {
  font-size: 0.7rem;
  color: var(--ds-text-muted);
}

/* ================================================================
   2. TYPOGRAPHY
   ================================================================ */
.ds-type {
  margin-bottom: 28px;
  padding-bottom: 28px;
  border-bottom: 1px solid var(--ds-border);
}

.ds-type:last-child { border-bottom: none; }

.ds-type__specs {
  font-size: 0.75rem;
  color: var(--ds-text-muted);
  font-family: monospace;
  margin-top: 6px;
}

/* ================================================================
   3. BUTTONS - All variations
   ================================================================ */
.ds-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 14px 28px;
  font-size: 0.8rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  text-decoration: none;
  border: 2px solid transparent;
  border-radius: 4px;
  cursor: pointer;
  transition: all 0.3s ease;
  font-family: inherit;
}

.ds-btn--primary { background: var(--yb-brand); color: #fff; border-color: var(--yb-brand); }
.ds-btn--primary:hover { background: #d94f02; transform: translateY(-2px); box-shadow: 0 8px 25px rgba(247,92,3,0.35); }

.ds-btn--secondary { background: #0F0F0F; color: #fff; }
.ds-btn--secondary:hover { background: var(--yb-brand); }

.ds-btn--outline { background: transparent; color: #0F0F0F; border-color: #0F0F0F; }
.ds-btn--outline:hover { background: #0F0F0F; color: #fff; }

.ds-btn--outline-light { background: transparent; color: #fff; border-color: rgba(255,255,255,0.5); }
.ds-btn--outline-light:hover { background: rgba(255,255,255,0.1); border-color: #fff; }

.ds-btn--ghost { background: transparent; color: var(--yb-brand); border: none; padding: 10px 0; }
.ds-btn--ghost::after { content: " →"; }
.ds-btn--ghost:hover { color: #d94f02; }

.ds-btn--pill { border-radius: 100px; }
.ds-btn--large { padding: 18px 44px; font-size: 0.9rem; }
.ds-btn--small { padding: 10px 18px; font-size: 0.7rem; }
.ds-btn--icon { width: 44px; height: 44px; padding: 0; border-radius: 50%; }

/* Magnetic Button */
.ds-btn--magnetic {
  position: relative;
  transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* Gradient Border Button */
.ds-btn--gradient-border {
  background: #fff;
  border: none;
  position: relative;
  z-index: 1;
}
.ds-btn--gradient-border::before {
  content: "";
  position: absolute;
  inset: -2px;
  background: linear-gradient(135deg, var(--yb-brand), #ff9966, var(--yb-brand));
  border-radius: inherit;
  z-index: -1;
  background-size: 200% 200%;
  animation: gradientMove 3s ease infinite;
}
@keyframes gradientMove {
  0%, 100% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
}

/* Shimmer Button */
.ds-btn--shimmer {
  position: relative;
  overflow: hidden;
}
.ds-btn--shimmer::after {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
  transition: left 0.5s;
}
.ds-btn--shimmer:hover::after {
  left: 100%;
}

/* ================================================================
   4. CARDS - All variations
   ================================================================ */
.ds-card {
  background: #fff;
  border: 1px solid var(--ds-border);
  border-radius: 12px;
  overflow: hidden;
  transition: all 0.3s ease;
}

.ds-card__img {
  height: 180px;
  background: linear-gradient(135deg, var(--yb-brand), #d94f02);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.3);
  font-size: 1.5rem;
  position: relative;
  overflow: hidden;
}

.ds-card__body {
  padding: 24px;
}

.ds-card__tag {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: var(--yb-brand);
  margin-bottom: 6px;
}

.ds-card__title {
  font-size: 1.15rem;
  font-weight: 700;
  margin-bottom: 6px;
}

.ds-card__desc {
  font-size: 0.9rem;
  color: var(--ds-text-muted);
  line-height: 1.5;
}

/* Card Hover Effects */
.ds-card--lift:hover { transform: translateY(-8px); box-shadow: 0 20px 50px rgba(0,0,0,0.12); }
.ds-card--border:hover { border-color: var(--yb-brand); }
.ds-card--glow:hover { box-shadow: 0 0 40px rgba(247,92,3,0.25); }
.ds-card--scale:hover { transform: scale(1.03); }

/* Image Zoom on Hover */
.ds-card--img-zoom .ds-card__img img,
.ds-card--img-zoom .ds-card__img::before {
  transition: transform 0.5s ease;
}
.ds-card--img-zoom:hover .ds-card__img img,
.ds-card--img-zoom:hover .ds-card__img::before {
  transform: scale(1.1);
}

/* Reveal Content on Hover */
.ds-card--reveal .ds-card__hidden {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease;
}
.ds-card--reveal:hover .ds-card__hidden {
  max-height: 100px;
}

/* Tilt 3D Card */
.ds-card--tilt {
  transform-style: preserve-3d;
  perspective: 1000px;
}
.ds-card--tilt:hover {
  transform: perspective(1000px) rotateX(5deg) rotateY(-5deg);
}

/* Glass Card */
.ds-card--glass {
  background: rgba(255,255,255,0.7);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.3);
}

/* Dark Card */
.ds-card--dark {
  background: #0F0F0F;
  border-color: #333;
  color: #fff;
}
.ds-card--dark .ds-card__desc { color: rgba(255,255,255,0.7); }

/* Stat Card */
.ds-card--stat {
  text-align: center;
  padding: 36px;
}
.ds-card--stat .num {
  font-size: 2.8rem;
  font-weight: 700;
  color: var(--yb-brand);
  line-height: 1;
}
.ds-card--stat .label {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--ds-text-muted);
  margin-top: 6px;
}

/* Testimonial Card */
.ds-card--testimonial {
  padding: 28px;
}
.ds-card--testimonial .stars {
  color: var(--yb-brand);
  margin-bottom: 12px;
}
.ds-card--testimonial .quote {
  font-size: 1rem;
  line-height: 1.7;
  font-style: italic;
  margin-bottom: 16px;
}
.ds-card--testimonial .author {
  display: flex;
  align-items: center;
  gap: 12px;
}
.ds-card--testimonial .avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--yb-brand), #d94f02);
}

/* Pricing Card */
.ds-card--pricing {
  text-align: center;
  padding: 40px 32px;
}
.ds-card--pricing .price {
  font-size: 2.5rem;
  font-weight: 700;
}
.ds-card--pricing .period {
  font-size: 0.85rem;
  color: var(--ds-text-muted);
}
.ds-card--pricing.featured {
  border: 2px solid var(--yb-brand);
  transform: scale(1.05);
}

/* ================================================================
   5. HOVER EFFECTS SHOWCASE
   ================================================================ */
.ds-hover {
  width: 160px;
  height: 100px;
  background: var(--ds-bg-light);
  border: 1px solid var(--ds-border);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.8rem;
  font-weight: 600;
  transition: all 0.3s ease;
  cursor: pointer;
}

.ds-hover--lift:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.15); }
.ds-hover--scale:hover { transform: scale(1.08); }
.ds-hover--rotate:hover { transform: rotate(3deg); }
.ds-hover--skew:hover { transform: skewX(-3deg); }
.ds-hover--border:hover { border-color: var(--yb-brand); border-width: 2px; }
.ds-hover--glow:hover { box-shadow: 0 0 30px rgba(247,92,3,0.4); }
.ds-hover--bg:hover { background: var(--yb-brand); color: #fff; }
.ds-hover--invert:hover { background: #0F0F0F; color: #fff; }

/* Shine Effect */
.ds-hover--shine {
  position: relative;
  overflow: hidden;
}
.ds-hover--shine::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.5), transparent);
  transform: skewX(-25deg);
  transition: left 0.6s;
}
.ds-hover--shine:hover::before { left: 150%; }

/* Underline Grow */
.ds-hover--underline {
  position: relative;
}
.ds-hover--underline::after {
  content: "";
  position: absolute;
  bottom: 8px;
  left: 50%;
  width: 0;
  height: 2px;
  background: var(--yb-brand);
  transition: all 0.3s ease;
}
.ds-hover--underline:hover::after {
  left: 20%;
  width: 60%;
}

/* Fill Up */
.ds-hover--fill {
  position: relative;
  overflow: hidden;
  z-index: 1;
}
.ds-hover--fill::before {
  content: "";
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 0;
  background: var(--yb-brand);
  transition: height 0.3s ease;
  z-index: -1;
}
.ds-hover--fill:hover::before { height: 100%; }
.ds-hover--fill:hover { color: #fff; }

/* Pulse */
.ds-hover--pulse:hover {
  animation: dsPulse 0.5s ease;
}
@keyframes dsPulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

/* ================================================================
   6. ANIMATIONS
   ================================================================ */
.ds-anim {
  width: 70px;
  height: 70px;
  background: var(--yb-brand);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 0.6rem;
  font-weight: 700;
}

.ds-anim--pulse { animation: animPulse 2s infinite; }
@keyframes animPulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.1); }
}

.ds-anim--breathe { animation: animBreathe 4s ease-in-out infinite; }
@keyframes animBreathe {
  0%, 100% { opacity: 0.6; transform: scale(0.95); }
  50% { opacity: 1; transform: scale(1.05); }
}

.ds-anim--float { animation: animFloat 3s ease-in-out infinite; }
@keyframes animFloat {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12px); }
}

.ds-anim--bounce { animation: animBounce 1s infinite; }
@keyframes animBounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-18px); }
}

.ds-anim--spin { animation: animSpin 3s linear infinite; }
@keyframes animSpin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.ds-anim--shake { animation: animShake 0.5s ease-in-out infinite; }
@keyframes animShake {
  0%, 100% { transform: translateX(0); }
  25% { transform: translateX(-5px); }
  75% { transform: translateX(5px); }
}

.ds-anim--swing { animation: animSwing 1s ease-in-out infinite; transform-origin: top center; }
@keyframes animSwing {
  0%, 100% { transform: rotate(0deg); }
  25% { transform: rotate(10deg); }
  75% { transform: rotate(-10deg); }
}

.ds-anim--heartbeat { animation: animHeartbeat 1.5s ease-in-out infinite; }
@keyframes animHeartbeat {
  0%, 100% { transform: scale(1); }
  14% { transform: scale(1.15); }
  28% { transform: scale(1); }
  42% { transform: scale(1.15); }
  70% { transform: scale(1); }
}

/* ================================================================
   7. SCROLL-TRIGGERED ANIMATIONS
   ================================================================ */
.ds-scroll-anim {
  padding: 40px;
  background: #fff;
  border: 1px solid var(--ds-border);
  border-radius: 12px;
  text-align: center;
  opacity: 0;
  transform: translateY(30px);
  transition: all 0.6s ease;
}

.ds-scroll-anim.visible {
  opacity: 1;
  transform: translateY(0);
}

.ds-scroll-anim--left {
  opacity: 0;
  transform: translateX(-50px);
}
.ds-scroll-anim--left.visible {
  opacity: 1;
  transform: translateX(0);
}

.ds-scroll-anim--right {
  opacity: 0;
  transform: translateX(50px);
}
.ds-scroll-anim--right.visible {
  opacity: 1;
  transform: translateX(0);
}

.ds-scroll-anim--scale {
  opacity: 0;
  transform: scale(0.8);
}
.ds-scroll-anim--scale.visible {
  opacity: 1;
  transform: scale(1);
}

.ds-scroll-anim--rotate {
  opacity: 0;
  transform: rotate(-10deg);
}
.ds-scroll-anim--rotate.visible {
  opacity: 1;
  transform: rotate(0);
}

/* Stagger Children */
.ds-stagger > * {
  opacity: 0;
  transform: translateY(20px);
  transition: all 0.4s ease;
}
.ds-stagger.visible > *:nth-child(1) { transition-delay: 0s; }
.ds-stagger.visible > *:nth-child(2) { transition-delay: 0.1s; }
.ds-stagger.visible > *:nth-child(3) { transition-delay: 0.2s; }
.ds-stagger.visible > *:nth-child(4) { transition-delay: 0.3s; }
.ds-stagger.visible > * {
  opacity: 1;
  transform: translateY(0);
}

/* ================================================================
   8. PARALLAX & SCROLL EFFECTS
   ================================================================ */
.ds-parallax-container {
  height: 400px;
  overflow: hidden;
  position: relative;
  border-radius: 12px;
}

.ds-parallax-bg {
  position: absolute;
  inset: -50px;
  background: linear-gradient(135deg, var(--yb-brand), #d94f02);
  will-change: transform;
}

.ds-parallax-content {
  position: relative;
  z-index: 2;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 1.5rem;
  font-weight: 700;
}

/* Sticky Scroll Section */
.ds-sticky-demo {
  height: 200vh;
  position: relative;
}

.ds-sticky-element {
  position: sticky;
  top: 150px;
  background: var(--yb-brand);
  color: #fff;
  padding: 40px;
  border-radius: 12px;
  text-align: center;
}

/* Horizontal Scroll */
.ds-hscroll {
  display: flex;
  gap: 20px;
  overflow-x: auto;
  padding: 20px 0;
  scroll-snap-type: x mandatory;
  -webkit-overflow-scrolling: touch;
}

.ds-hscroll::-webkit-scrollbar { height: 6px; }
.ds-hscroll::-webkit-scrollbar-track { background: #f0f0f0; border-radius: 3px; }
.ds-hscroll::-webkit-scrollbar-thumb { background: var(--yb-brand); border-radius: 3px; }

.ds-hscroll__item {
  flex: 0 0 300px;
  height: 200px;
  background: linear-gradient(135deg, var(--yb-brand), #d94f02);
  border-radius: 12px;
  scroll-snap-align: start;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 700;
}

/* ================================================================
   9. APPLE-STYLE SCROLL EFFECTS
   ================================================================ */
.ds-apple-hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.ds-apple-hero__title {
  font-size: clamp(3rem, 10vw, 8rem);
  font-weight: 700;
  line-height: 1;
  background: linear-gradient(135deg, var(--yb-brand), #ff9966);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.ds-apple-hero__subtitle {
  font-size: clamp(1rem, 2vw, 1.5rem);
  color: var(--ds-text-muted);
  margin-top: 20px;
}

/* Text Reveal on Scroll */
.ds-text-reveal {
  font-size: 2rem;
  font-weight: 700;
  overflow: hidden;
}

.ds-text-reveal span {
  display: inline-block;
  transform: translateY(100%);
  transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
}

.ds-text-reveal.visible span {
  transform: translateY(0);
}

/* Counter Animation */
.ds-counter {
  font-size: 4rem;
  font-weight: 700;
  color: var(--yb-brand);
}

/* Progress on Scroll */
.ds-scroll-progress {
  position: fixed;
  top: 107px;
  left: 0;
  height: 3px;
  background: var(--yb-brand);
  width: 0%;
  z-index: 1000;
  transition: width 0.1s;
}

/* Zoom on Scroll */
.ds-zoom-scroll {
  height: 300px;
  background: linear-gradient(135deg, #0F0F0F, #1C1C1C);
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 2rem;
  font-weight: 700;
  transition: transform 0.3s ease;
}

/* ================================================================
   10. BACKGROUNDS & GRADIENTS
   ================================================================ */
.ds-bg {
  height: 150px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 700;
  font-size: 0.85rem;
}

.ds-bg--dark { background: #0F0F0F; }
.ds-bg--brand { background: var(--yb-brand); }
.ds-bg--gradient-h { background: linear-gradient(90deg, var(--yb-brand), #ff9966); }
.ds-bg--gradient-v { background: linear-gradient(180deg, var(--yb-brand), #d94f02); }
.ds-bg--gradient-d { background: linear-gradient(135deg, var(--yb-brand), #ff6633); }
.ds-bg--gradient-radial { background: radial-gradient(circle, var(--yb-brand), #0F0F0F); }
.ds-bg--gradient-conic { background: conic-gradient(var(--yb-brand), #ff9966, var(--yb-brand)); }
.ds-bg--mesh {
  background:
    radial-gradient(at 40% 20%, #f75c03 0px, transparent 50%),
    radial-gradient(at 80% 0%, #ff9966 0px, transparent 50%),
    radial-gradient(at 0% 50%, #d94f02 0px, transparent 50%),
    #0F0F0F;
}
.ds-bg--noise {
  background: var(--yb-brand);
  position: relative;
}
.ds-bg--noise::after {
  content: "";
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%' height='100%' filter='url(%23noise)'/%3E%3C/svg%3E");
  opacity: 0.15;
  mix-blend-mode: overlay;
}
.ds-bg--glass {
  background: rgba(255,255,255,0.1);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.2);
}
.ds-bg--animated {
  background: linear-gradient(-45deg, #f75c03, #ff9966, #d94f02, #f75c03);
  background-size: 400% 400%;
  animation: gradientAnim 8s ease infinite;
}
@keyframes gradientAnim {
  0% { background-position: 0% 50%; }
  50% { background-position: 100% 50%; }
  100% { background-position: 0% 50%; }
}

/* ================================================================
   11. SECTION LAYOUTS
   ================================================================ */
.ds-split {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 350px;
  border-radius: 12px;
  overflow: hidden;
}

.ds-split__side {
  padding: 48px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.ds-split--dark-light .ds-split__side:first-child { background: #0F0F0F; color: #fff; }
.ds-split--dark-light .ds-split__side:last-child { background: var(--ds-bg-light); }

.ds-split--brand-light .ds-split__side:first-child { background: var(--yb-brand); color: #fff; }
.ds-split--brand-light .ds-split__side:last-child { background: #fff; }

/* Asymmetric Split */
.ds-split--asymmetric {
  grid-template-columns: 1.5fr 1fr;
}

/* Overlap Layout */
.ds-overlap {
  position: relative;
  padding: 80px 40px;
}

.ds-overlap__bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 30%;
  bottom: 0;
  background: #0F0F0F;
  border-radius: 12px;
}

.ds-overlap__content {
  position: relative;
  z-index: 2;
  max-width: 500px;
  color: #fff;
}

.ds-overlap__card {
  position: absolute;
  right: 40px;
  top: 50%;
  transform: translateY(-50%);
  width: 350px;
  background: #fff;
  padding: 40px;
  border-radius: 12px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.2);
  z-index: 3;
}

/* ================================================================
   12. EYEBROWS & LABELS
   ================================================================ */
.ds-eyebrow {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.25em;
  margin-bottom: 10px;
  display: inline-flex;
  align-items: center;
}

.ds-eyebrow--brand { color: var(--yb-brand); }
.ds-eyebrow--muted { color: var(--ds-text-muted); }
.ds-eyebrow--white { color: rgba(255,255,255,0.7); }

.ds-eyebrow--line::before {
  content: "";
  width: 30px;
  height: 1px;
  background: currentColor;
  margin-right: 10px;
}

.ds-eyebrow--dot::before {
  content: "";
  width: 6px;
  height: 6px;
  background: var(--yb-brand);
  border-radius: 50%;
  margin-right: 8px;
}

.ds-eyebrow--badge {
  background: rgba(247,92,3,0.1);
  color: var(--yb-brand);
  padding: 4px 12px;
  border-radius: 100px;
}

/* ================================================================
   13. BADGES & TAGS
   ================================================================ */
.ds-badge {
  display: inline-flex;
  align-items: center;
  padding: 5px 12px;
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  border-radius: 4px;
}

.ds-badge--primary { background: var(--yb-brand); color: #fff; }
.ds-badge--secondary { background: #0F0F0F; color: #fff; }
.ds-badge--outline { background: transparent; border: 1px solid var(--yb-brand); color: var(--yb-brand); }
.ds-badge--muted { background: #F5F3F0; color: var(--ds-text-muted); }
.ds-badge--success { background: #10B981; color: #fff; }
.ds-badge--warning { background: #F59E0B; color: #fff; }
.ds-badge--pill { border-radius: 100px; }

/* ================================================================
   14. FORMS
   ================================================================ */
.ds-input {
  width: 100%;
  padding: 14px 18px;
  font-size: 0.95rem;
  font-family: inherit;
  border: 1px solid var(--ds-border);
  border-radius: 8px;
  background: #fff;
  transition: all 0.2s ease;
}

.ds-input:focus {
  outline: none;
  border-color: var(--yb-brand);
  box-shadow: 0 0 0 3px rgba(247,92,3,0.1);
}

.ds-input--dark {
  background: #1C1C1C;
  border-color: #333;
  color: #fff;
}

.ds-input--floating {
  padding-top: 24px;
}

.ds-field {
  position: relative;
  margin-bottom: 20px;
}

.ds-field__label {
  position: absolute;
  left: 18px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 0.9rem;
  color: var(--ds-text-muted);
  pointer-events: none;
  transition: all 0.2s ease;
}

.ds-input:focus + .ds-field__label,
.ds-input:not(:placeholder-shown) + .ds-field__label {
  top: 10px;
  font-size: 0.7rem;
  color: var(--yb-brand);
}

/* ================================================================
   15. ACCORDIONS
   ================================================================ */
.ds-accordion {
  border: 1px solid var(--ds-border);
  border-radius: 12px;
  overflow: hidden;
}

.ds-accordion__item {
  border-bottom: 1px solid var(--ds-border);
}
.ds-accordion__item:last-child { border-bottom: none; }

.ds-accordion__header {
  padding: 18px 22px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  background: #fff;
  transition: background 0.2s;
}
.ds-accordion__header:hover { background: var(--ds-bg-light); }

.ds-accordion__icon {
  width: 28px;
  height: 28px;
  background: #F5F3F0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  transition: all 0.3s;
}

.ds-accordion__item.active .ds-accordion__icon {
  background: var(--yb-brand);
  color: #fff;
  transform: rotate(45deg);
}

.ds-accordion__body {
  display: none;
  padding: 0 22px 22px;
  color: var(--ds-text-muted);
  line-height: 1.6;
}
.ds-accordion__item.active .ds-accordion__body { display: block; }

/* ================================================================
   16. TABS
   ================================================================ */
.ds-tabs--underline {
  display: flex;
  border-bottom: 2px solid var(--ds-border);
}

.ds-tabs--underline .ds-tab {
  padding: 14px 22px;
  font-size: 0.85rem;
  font-weight: 600;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ds-text-muted);
  position: relative;
}
.ds-tabs--underline .ds-tab.active { color: var(--yb-brand); }
.ds-tabs--underline .ds-tab.active::after {
  content: "";
  position: absolute;
  bottom: -2px;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--yb-brand);
}

.ds-tabs--pills {
  display: inline-flex;
  gap: 4px;
  background: #F5F3F0;
  padding: 4px;
  border-radius: 8px;
}

.ds-tabs--pills .ds-tab {
  padding: 10px 20px;
  font-size: 0.8rem;
  font-weight: 600;
  background: none;
  border: none;
  border-radius: 6px;
  cursor: pointer;
  color: var(--ds-text-muted);
}
.ds-tabs--pills .ds-tab.active {
  background: #fff;
  color: var(--ds-text);
  box-shadow: 0 2px 6px rgba(0,0,0,0.08);
}

.ds-tabs--buttons {
  display: flex;
  gap: 8px;
}

.ds-tabs--buttons .ds-tab {
  padding: 12px 24px;
  font-size: 0.8rem;
  font-weight: 700;
  background: transparent;
  border: 2px solid var(--ds-border);
  border-radius: 6px;
  cursor: pointer;
  color: var(--ds-text-muted);
}
.ds-tabs--buttons .ds-tab.active {
  background: var(--yb-brand);
  border-color: var(--yb-brand);
  color: #fff;
}

/* ================================================================
   17. LISTS
   ================================================================ */
.ds-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.ds-list--check li {
  padding-left: 26px;
  position: relative;
  margin-bottom: 10px;
}
.ds-list--check li::before {
  content: "✓";
  position: absolute;
  left: 0;
  color: var(--yb-brand);
  font-weight: 700;
}

.ds-list--numbers {
  counter-reset: list;
}
.ds-list--numbers li {
  padding-left: 34px;
  position: relative;
  margin-bottom: 14px;
  counter-increment: list;
}
.ds-list--numbers li::before {
  content: counter(list);
  position: absolute;
  left: 0;
  width: 22px;
  height: 22px;
  background: var(--yb-brand);
  color: #fff;
  border-radius: 50%;
  font-size: 0.7rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ds-list--arrows li {
  padding-left: 20px;
  position: relative;
  margin-bottom: 10px;
}
.ds-list--arrows li::before {
  content: "→";
  position: absolute;
  left: 0;
  color: var(--yb-brand);
}

/* ================================================================
   18. QUOTES
   ================================================================ */
.ds-quote {
  font-size: 1.25rem;
  line-height: 1.7;
  font-style: italic;
  position: relative;
  padding-left: 28px;
}

.ds-quote::before {
  content: """;
  position: absolute;
  left: 0;
  top: -8px;
  font-size: 3.5rem;
  color: var(--yb-brand);
  opacity: 0.3;
  font-style: normal;
  line-height: 1;
}

.ds-quote__author {
  margin-top: 14px;
  font-size: 0.85rem;
  font-style: normal;
  color: var(--ds-text-muted);
}

/* ================================================================
   19. TIMELINE
   ================================================================ */
.ds-timeline {
  position: relative;
  padding-left: 28px;
}

.ds-timeline::before {
  content: "";
  position: absolute;
  left: 5px;
  top: 6px;
  bottom: 6px;
  width: 2px;
  background: linear-gradient(to bottom, var(--yb-brand), var(--ds-border));
}

.ds-timeline__item {
  position: relative;
  padding-bottom: 28px;
}
.ds-timeline__item:last-child { padding-bottom: 0; }

.ds-timeline__dot {
  position: absolute;
  left: -25px;
  top: 4px;
  width: 10px;
  height: 10px;
  background: var(--yb-brand);
  border-radius: 50%;
  box-shadow: 0 0 0 3px #fff;
}

.ds-timeline__title {
  font-weight: 700;
  margin-bottom: 4px;
}

.ds-timeline__desc {
  color: var(--ds-text-muted);
  font-size: 0.9rem;
}

/* ================================================================
   20. DIVIDERS
   ================================================================ */
.ds-divider {
  height: 1px;
  background: var(--ds-border);
  margin: 20px 0;
}
.ds-divider--thick { height: 2px; }
.ds-divider--brand { background: var(--yb-brand); }
.ds-divider--gradient { background: linear-gradient(90deg, transparent, var(--yb-brand), transparent); }
.ds-divider--dashed { background: none; border-top: 2px dashed var(--ds-border); height: 0; }
.ds-divider--dots {
  background: none;
  text-align: center;
  height: auto;
}
.ds-divider--dots::before {
  content: "• • •";
  color: var(--ds-text-muted);
  letter-spacing: 6px;
}

/* ================================================================
   21. TOOLTIPS
   ================================================================ */
.ds-tooltip {
  position: relative;
  display: inline-block;
  cursor: help;
}

.ds-tooltip::after {
  content: attr(data-tip);
  position: absolute;
  bottom: 100%;
  left: 50%;
  transform: translateX(-50%) translateY(-6px);
  padding: 6px 12px;
  background: #0F0F0F;
  color: #fff;
  font-size: 0.75rem;
  border-radius: 4px;
  white-space: nowrap;
  opacity: 0;
  visibility: hidden;
  transition: all 0.2s;
}

.ds-tooltip:hover::after {
  opacity: 1;
  visibility: visible;
  transform: translateX(-50%) translateY(-10px);
}

/* ================================================================
   22. MODALS PREVIEW
   ================================================================ */
.ds-modal-preview {
  background: rgba(0,0,0,0.5);
  padding: 60px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ds-modal-box {
  background: #fff;
  padding: 40px;
  border-radius: 16px;
  max-width: 400px;
  text-align: center;
  box-shadow: 0 25px 80px rgba(0,0,0,0.3);
}

/* ================================================================
   23. LOADING STATES
   ================================================================ */
.ds-skeleton {
  background: linear-gradient(90deg, #F5F3F0 25%, #E8E4E0 50%, #F5F3F0 75%);
  background-size: 200% 100%;
  animation: skeleton 1.5s ease-in-out infinite;
  border-radius: 4px;
}

@keyframes skeleton {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.ds-spinner {
  width: 40px;
  height: 40px;
  border: 3px solid #F5F3F0;
  border-top-color: var(--yb-brand);
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* ================================================================
   24. SPECIAL EFFECTS
   ================================================================ */

/* Gradient Text */
.ds-gradient-text {
  background: linear-gradient(135deg, var(--yb-brand), #ff9966);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* Glow Text */
.ds-glow-text {
  text-shadow: 0 0 20px rgba(247,92,3,0.5), 0 0 40px rgba(247,92,3,0.3);
  color: var(--yb-brand);
}

/* Blur Reveal */
.ds-blur-reveal {
  filter: blur(8px);
  transition: filter 0.5s ease;
}
.ds-blur-reveal:hover {
  filter: blur(0);
}

/* Clip Path Shapes */
.ds-clip-diagonal {
  clip-path: polygon(0 0, 100% 0, 100% 85%, 0 100%);
}

.ds-clip-wave {
  clip-path: url(#wave-clip);
}

/* Marquee */
.ds-marquee {
  overflow: hidden;
  white-space: nowrap;
}

.ds-marquee__content {
  display: inline-block;
  animation: marquee 20s linear infinite;
}

@keyframes marquee {
  0% { transform: translateX(0); }
  100% { transform: translateX(-50%); }
}

/* Number Counter */
.ds-number {
  font-size: 3rem;
  font-weight: 700;
  color: var(--yb-brand);
  font-variant-numeric: tabular-nums;
}

/* ================================================================
   RESPONSIVE
   ================================================================ */
@media (max-width: 900px) {
  .ds-demo--grid {
    grid-template-columns: 1fr 1fr;
  }

  .ds-split {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 600px) {
  .ds-demo--grid {
    grid-template-columns: 1fr;
  }
}

/* ================================================================
   25. REVIEWS SECTION (Screenshot-style)
   ================================================================ */
.ds-reviews {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.ds-review-card {
  background: #fff;
  border: 1.5px solid var(--yb-brand);
  border-radius: 16px;
  padding: 32px;
  transition: all 0.3s ease;
}

.ds-review-card:hover {
  box-shadow: 0 12px 40px rgba(247,92,3,0.12);
  transform: translateY(-4px);
}

.ds-review-card .stars {
  color: var(--yb-brand);
  font-size: 1rem;
  margin-bottom: 16px;
  letter-spacing: 2px;
}

.ds-review-card .review-text {
  font-size: 0.95rem;
  line-height: 1.7;
  color: var(--ds-text);
  margin-bottom: 20px;
}

.ds-review-card .reviewer {
  display: flex;
  align-items: center;
  gap: 12px;
}

.ds-review-card .reviewer-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  background: var(--yb-brand);
  flex-shrink: 0;
}

.ds-review-card .reviewer-name {
  font-weight: 700;
  font-size: 0.9rem;
}

.ds-review-card .reviewer-detail {
  font-size: 0.75rem;
  color: var(--ds-text-muted);
}

@media (max-width: 900px) {
  .ds-reviews { grid-template-columns: 1fr; }
}

/* ================================================================
   26. PRICING / FORMAT SECTIONS
   ================================================================ */
.ds-pricing-accordion {
  border: 1.5px solid var(--ds-border);
  border-radius: 16px;
  overflow: hidden;
  transition: all 0.3s ease;
}

.ds-pricing-accordion.ds-pricing--active {
  border-color: var(--yb-brand);
}

.ds-pricing-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20px 28px;
  cursor: pointer;
  background: #fff;
  transition: background 0.2s;
}

.ds-pricing-header:hover {
  background: var(--ds-bg-light);
}

.ds-pricing-duration {
  display: inline-flex;
  align-items: center;
  padding: 6px 16px;
  background: var(--yb-brand);
  color: #fff;
  font-size: 0.7rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  border-radius: 4px;
  margin-right: 16px;
}

.ds-pricing-name {
  font-weight: 700;
  font-size: 1.1rem;
  flex: 1;
}

.ds-pricing-price {
  font-weight: 700;
  font-size: 1.1rem;
  margin-right: 16px;
}

.ds-pricing-toggle {
  width: 32px;
  height: 32px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.2rem;
  transition: all 0.3s;
  flex-shrink: 0;
}

.ds-pricing--active .ds-pricing-toggle {
  background: var(--yb-brand);
  color: #fff;
}

.ds-pricing-body {
  display: none;
  padding: 0 28px 28px;
  border-top: 1px solid var(--ds-border);
}

.ds-pricing--active .ds-pricing-body {
  display: block;
}

.ds-pricing-details {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-top: 20px;
}

.ds-pricing-detail-label {
  font-size: 0.65rem;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--ds-text-muted);
  margin-bottom: 4px;
}

.ds-pricing-detail-value {
  font-weight: 700;
  font-size: 0.95rem;
}

/* Pricing Variant B: Cards Side-by-Side */
.ds-pricing-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 24px;
}

.ds-pricing-card {
  background: #fff;
  border: 1.5px solid var(--ds-border);
  border-radius: 16px;
  padding: 40px 28px;
  text-align: center;
  transition: all 0.3s ease;
  position: relative;
}

.ds-pricing-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 20px 50px rgba(0,0,0,0.1);
}

.ds-pricing-card--featured {
  border-color: var(--yb-brand);
  transform: scale(1.03);
}

.ds-pricing-card--featured::before {
  content: "Mest populaer";
  position: absolute;
  top: -12px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--yb-brand);
  color: #fff;
  padding: 4px 16px;
  border-radius: 100px;
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  white-space: nowrap;
}

.ds-pricing-card .card-duration {
  display: inline-block;
  background: rgba(247,92,3,0.1);
  color: var(--yb-brand);
  padding: 4px 14px;
  border-radius: 100px;
  font-size: 0.7rem;
  font-weight: 700;
  margin-bottom: 16px;
}

.ds-pricing-card .card-title {
  font-size: 1.2rem;
  font-weight: 700;
  margin-bottom: 8px;
}

.ds-pricing-card .card-price {
  font-size: 2.2rem;
  font-weight: 700;
  margin-bottom: 4px;
}

.ds-pricing-card .card-period {
  font-size: 0.8rem;
  color: var(--ds-text-muted);
  margin-bottom: 24px;
}

.ds-pricing-card .card-features {
  list-style: none;
  padding: 0;
  margin: 0 0 28px;
  text-align: left;
}

.ds-pricing-card .card-features li {
  padding: 8px 0;
  font-size: 0.85rem;
  border-bottom: 1px solid var(--ds-border);
  padding-left: 22px;
  position: relative;
}

.ds-pricing-card .card-features li::before {
  content: "✓";
  position: absolute;
  left: 0;
  color: var(--yb-brand);
  font-weight: 700;
}

/* Pricing Variant C: Horizontal Comparison */
.ds-pricing-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  border: 1px solid var(--ds-border);
  border-radius: 12px;
  overflow: hidden;
}

.ds-pricing-table th {
  background: var(--yb-brand);
  color: #fff;
  padding: 18px 20px;
  text-align: left;
  font-size: 0.85rem;
  font-weight: 700;
}

.ds-pricing-table th:not(:first-child) {
  text-align: center;
}

.ds-pricing-table td {
  padding: 14px 20px;
  border-bottom: 1px solid var(--ds-border);
  font-size: 0.85rem;
}

.ds-pricing-table td:not(:first-child) {
  text-align: center;
  font-weight: 600;
}

.ds-pricing-table tr:last-child td {
  border-bottom: none;
}

.ds-pricing-table tr:hover td {
