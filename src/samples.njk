/* ================================================================
   28. NAVIGATION ARROWS
   ================================================================ */
.ds-arrow {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.3s ease;
  flex-shrink: 0;
}

/* Style A: Circle outline */
.ds-arrow--circle {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 1.5px solid var(--ds-border);
  background: #fff;
  font-size: 1.2rem;
  color: var(--ds-text);
}

.ds-arrow--circle:hover {
  border-color: var(--yb-brand);
  color: var(--yb-brand);
}

/* Style B: Circle filled */
.ds-arrow--circle-filled {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: var(--yb-brand);
  color: #fff;
  font-size: 1.2rem;
  border: none;
}

.ds-arrow--circle-filled:hover {
  background: #d94f02;
  transform: scale(1.08);
}

/* Style C: Square */
.ds-arrow--square {
  width: 44px;
  height: 44px;
  border-radius: 6px;
  border: 1.5px solid var(--ds-border);
  background: #fff;
  font-size: 1rem;
  color: var(--ds-text);
}

.ds-arrow--square:hover {
  background: #0F0F0F;
  color: #fff;
  border-color: #0F0F0F;
}

/* Style D: Pill with text */
.ds-arrow--pill {
  padding: 10px 20px;
  border-radius: 100px;
  border: 1.5px solid var(--ds-border);
  background: #fff;
  font-size: 0.75rem;
  font-weight: 700;
  gap: 6px;
  color: var(--ds-text);
}

.ds-arrow--pill:hover {
  background: var(--yb-brand);
  color: #fff;
  border-color: var(--yb-brand);
}

/* Style E: Ghost (dark BG) */
.ds-arrow--ghost {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  color: #fff;
  font-size: 1.2rem;
  border: 1px solid rgba(255,255,255,0.2);
}

.ds-arrow--ghost:hover {
  background: rgba(255,255,255,0.2);
}

/* Style F: Large minimal */
.ds-arrow--minimal {
  font-size: 2rem;
  color: var(--ds-text-muted);
  background: none;
  border: none;
  padding: 8px;
}

.ds-arrow--minimal:hover {
  color: var(--yb-brand);
  transform: translateX(4px);
}

.ds-arrow--minimal.ds-arrow--left:hover {
  transform: translateX(-4px);
}

/* Arrow group */
.ds-arrow-group {
  display: inline-flex;
  gap: 8px;
}

/* ================================================================
   29. SECTION LAYOUT VARIATIONS
   ================================================================ */
/* Content + Video */
.ds-layout-video {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
  min-height: 400px;
  border-radius: 12px;
  overflow: hidden;
}

.ds-layout-video__content {
  padding: 60px 48px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: var(--ds-bg-light);
}

.ds-layout-video__media {
  background: #0F0F0F;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.ds-layout-video__media .play-btn {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: var(--yb-brand);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  z-index: 2;
  transition: transform 0.3s;
  cursor: pointer;
}

.ds-layout-video__media .play-btn:hover {
  transform: scale(1.1);
}

/* Image Mosaic */
.ds-layout-mosaic {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr;
  grid-template-rows: 200px 200px;
  gap: 12px;
  border-radius: 12px;
  overflow: hidden;
}

.ds-layout-mosaic__item {
  background: linear-gradient(135deg, var(--yb-brand), #d94f02);
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.5);
  font-weight: 700;
  font-size: 0.8rem;
}

.ds-layout-mosaic__item:first-child {
  grid-row: 1 / 3;
}

/* Content + Looping Visual */
.ds-layout-loop {
  display: grid;
  grid-template-columns: 1fr 1fr;
  min-height: 350px;
  border-radius: 12px;
  overflow: hidden;
  border: 1px solid var(--ds-border);
}

.ds-layout-loop__content {
  padding: 48px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: #fff;
}

.ds-layout-loop__visual {
  background: linear-gradient(-45deg, #f75c03, #ff9966, #d94f02, #f75c03);
  background-size: 400% 400%;
  animation: gradientAnim 8s ease infinite;
  display: flex;
  align-items: center;
  justify-content: center;
  color: rgba(255,255,255,0.4);
  font-size: 0.8rem;
  font-weight: 700;
}

/* Full-width hero-style with overlay text */
.ds-layout-fullmedia {
  position: relative;
  min-height: 400px;
  border-radius: 12px;
  overflow: hidden;
  background: linear-gradient(135deg, #0F0F0F 0%, #1C1C1C 100%);
  display: flex;
  align-items: center;
}

.ds-layout-fullmedia__overlay {
  position: relative;
  z-index: 2;
  padding: 60px;
  max-width: 600px;
  color: #fff;
}

/* Three-column feature */
.ds-layout-triple {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 32px;
}

.ds-layout-triple__item {
  text-align: center;
  padding: 40px 24px;
}

.ds-layout-triple__icon {
  width: 64px;
  height: 64px;
  border-radius: 50%;
  background: rgba(247,92,3,0.1);
  color: var(--yb-brand);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.5rem;
  margin: 0 auto 16px;
}

@media (max-width: 900px) {
  .ds-layout-video,
  .ds-layout-loop { grid-template-columns: 1fr; }
  .ds-layout-mosaic { grid-template-columns: 1fr 1fr; grid-template-rows: auto; }
  .ds-layout-mosaic__item:first-child { grid-row: auto; }
  .ds-layout-triple { grid-template-columns: 1fr; }
}

