    <style>
    /* ── Section 34: Hot Yoga CPH Design Tokens ── */
    .hyc { --hyc: #3f99a5; --hyc-dark: #357f89; --hyc-light: #5bb8c4; --hyc-pale: #e8f4f6; --hyc-glow: rgba(63,153,165,.15); --hyc-black: #0F0F0F; --hyc-muted: #6F6A66; --hyc-border: #E8E4E0; --hyc-bg: #F5F3F0; --hyc-white: #FFFCF9; --hyc-radius: 14px; --hyc-font: 'Abacaxi', 'Helvetica Neue', Helvetica, Arial, system-ui, sans-serif; }
