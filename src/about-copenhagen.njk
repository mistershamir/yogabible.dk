<!-- Practical Info -->
<section class="program-overview">
  <div class="container">
    <h2 class="section-title">Practical Information for International Students</h2>

    <div class="schedule-options">
      <div class="schedule-card">
        <h3>Getting Here</h3>
        <ul>
          <li><strong>Airport:</strong> Copenhagen Airport (CPH) — 15 min by metro to Christianshavn</li>
          <li><strong>Train:</strong> Direct connections from Hamburg, Stockholm, Malmö</li>
          <li><strong>Visa:</strong> EU/EEA citizens — no visa needed. Others — check Danish immigration (nyidanmark.dk)</li>
        </ul>
      </div>
      <div class="schedule-card">
        <h3>Getting Around</h3>
        <ul>
          <li><strong>Bike:</strong> Rent for ~75 kr/day or buy second-hand from ~500 kr</li>
          <li><strong>Metro/Bus:</strong> Rejsekort (travel card) — ~25 kr per trip</li>
          <li><strong>Walking:</strong> Most of Copenhagen is walkable and flat</li>
        </ul>
      </div>
      <div class="schedule-card">
        <h3>Living Costs (Monthly Estimate)</h3>
        <ul>
          <li><strong>Accommodation:</strong> 5.000–10.000 kr (we offer student housing)</li>
          <li><strong>Food:</strong> 2.500–4.000 kr (cooking at home)</li>
          <li><strong>Transport:</strong> 0–400 kr (bike = free)</li>
          <li><strong>Total:</strong> ~8.000–14.000 kr / ~1.100–2.000 EUR per month</li>
        </ul>
      </div>
      <div class="schedule-card">
        <h3>Weather & Seasons</h3>
        <ul>
          <li><strong>Spring (Mar–May):</strong> 5–15°C, blossoming parks, long days return</li>
          <li><strong>Summer (Jun–Aug):</strong> 18–25°C, 17+ hours of daylight, outdoor living</li>
          <li><strong>Autumn (Sep–Nov):</strong> 5–15°C, cozy (hygge) season, golden colors</li>
          <li><strong>Winter (Dec–Feb):</strong> 0–5°C, short days, candlelit cafes, sauna culture</li>
        </ul>
      </div>
    </div>
  </div>
</section>

