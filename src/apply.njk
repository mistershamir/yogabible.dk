<!-- Application Form -->
<section class="program-schedule">
  <div class="container">
    <h2 class="section-title">Ny Ansøgning</h2>
    <p class="section-subtitle">
      Vælg først om du vil ansøge om <strong>Yoga læreruddannelse (YTT)</strong> og/eller <strong>Kursus</strong>. Betaling håndteres <strong>separat</strong> for hver del. Hvis du <strong>ikke allerede har betalt</strong>, og ansøgning er åben, kan du betale via link og derefter indsende ansøgningen.
    </p>

    <form id="ybApplyForm" class="yb-apply-form" novalidate>
      <input class="yb-modal-u__hp" type="text" name="website" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px">

      <!-- Step 1: What to apply for -->
      <div class="yb-apply-section">
        <h3 class="yb-apply-section__title">Hvad vil du ansøge om? *</h3>
        <div class="yb-apply-radio-group">
          <label class="yb-apply-radio">
            <input type="radio" name="applyType" value="ytt" required>
            <span>Yoga læreruddannelse (YTT)</span>
          </label>
          <label class="yb-apply-radio">
            <input type="radio" name="applyType" value="kursus">
            <span>Kursus</span>
          </label>
          <label class="yb-apply-radio">
            <input type="radio" name="applyType" value="mentorship">
            <span>Mentorship — privat træning</span>
          </label>
        </div>
      </div>

      <!-- YTT Block (shown when YTT selected) -->
      <div id="ybYttBlock" class="yb-apply-card" hidden>
        <h3>Yoga læreruddannelse (YTT)</h3>
        <p class="yb-apply-hint">Vælg program, periode — og evt. spor.</p>

        <div class="yb-modal-u__grid">
          <label class="yb-modal-u__field">
            <span>YTT program *</span>
            <select name="yttProgram" id="ybYttProgram" required>
              <option value="">Vælg...</option>
              <option value="200h-18w">200-timer — 18 ugers fleksibel</option>
              <option value="200h-8w">200-timer — 8 ugers semi-intensiv</option>
              <option value="200h-4w">200-timer — 4 ugers intensiv</option>
            </select>
          </label>

          <label class="yb-modal-u__field">
            <span>YTT periode *</span>
            <select name="yttPeriod" id="ybYttPeriod" disabled>
              <option value="">Vælg program først...</option>
            </select>
          </label>

          <label class="yb-modal-u__field">
            <span>YTT spor</span>
            <select name="yttTrack" id="ybYttTrack" disabled>
              <option value="">Vælg...</option>
              <option value="hverdag">Hverdagsforløb</option>
              <option value="weekend">Weekend-forløb</option>
            </select>
          </label>
        </div>

        <!-- YTT Payment -->
        <div class="yb-apply-payment">
          <h4>YTT betaling</h4>
          <div class="yb-apply-radio-group">
            <label class="yb-apply-radio">
              <input type="radio" name="yttPayment" value="paid">
              <span>Jeg har betalt (fuldt / depositum) for YTT</span>
            </label>
            <label class="yb-apply-radio">
              <input type="radio" name="yttPayment" value="pay-now">
              <span>Jeg betaler nu for YTT (åbn betalingslink)</span>
            </label>
          </div>

          <div id="ybYttPayAlert" class="yb-apply-alert" hidden>
            <p><strong>Vigtigt:</strong> Betal først — og indsend derefter ansøgningen. Så kan vi hurtigt matche din betaling og behandle din ansøgning korrekt.</p>
            <a id="ybYttPayLink" class="btn btn--primary" href="#" target="_blank" rel="noopener">Betal — YTT ↗</a>
          </div>

          <label class="yb-apply-checkbox" id="ybYttConfirmWrap" hidden>
            <input type="checkbox" name="yttPayConfirm" id="ybYttPayConfirm">
            <span>Jeg bekræfter, at jeg har gennemført YTT-betalingen</span>
          </label>
        </div>
      </div>

      <!-- Course Block (shown when Kursus selected) -->
      <div id="ybCourseBlock" class="yb-apply-card" hidden>
        <h3>Kursus</h3>
        <p class="yb-apply-hint">Vælg kursus, periode — eller en kursuspakke (bundle).</p>

        <div class="yb-modal-u__grid">
          <label class="yb-modal-u__field">
            <span>Kursus *</span>
            <select name="course" id="ybCourse">
              <option value="">Vælg...</option>
              <option value="inversions">Inversions</option>
              <option value="splits">Splits</option>
              <option value="backbends">Backbends</option>
            </select>
          </label>

          <label class="yb-modal-u__field">
            <span>Periode *</span>
            <select name="coursePeriod" id="ybCoursePeriod" disabled>
              <option value="">Vælg kursus først...</option>
            </select>
          </label>

          <label class="yb-modal-u__field">
            <span>Kursuspakke</span>
            <select name="courseBundle" id="ybCourseBundle">
              <option value="">Ingen bundle</option>
              <option value="inv-back">Inversions + Backbends</option>
              <option value="inv-splits">Inversions + Splits</option>
              <option value="back-splits">Backbends + Splits</option>
              <option value="all-in">All-in (Inversions + Backbends + Splits)</option>
            </select>
          </label>
        </div>

        <!-- Course Payment -->
        <div class="yb-apply-payment">
          <h4>Kursus betaling</h4>
          <div class="yb-apply-radio-group">
            <label class="yb-apply-radio">
              <input type="radio" name="coursePayment" value="paid">
              <span>Jeg har betalt for dette kursus</span>
            </label>
            <label class="yb-apply-radio">
              <input type="radio" name="coursePayment" value="pay-now">
              <span>Jeg betaler nu for dette kursus (åbn betalingslink)</span>
            </label>
          </div>

          <div id="ybCoursePayAlert" class="yb-apply-alert" hidden>
            <p><strong>Vigtigt:</strong> Betal først — og indsend derefter ansøgningen.</p>
            <a id="ybCoursePayLink" class="btn btn--primary" href="#" target="_blank" rel="noopener">Betal fuld betaling — Kursus ↗</a>
          </div>

          <label class="yb-apply-checkbox" id="ybCourseConfirmWrap" hidden>
            <input type="checkbox" name="coursePayConfirm" id="ybCoursePayConfirm">
            <span>Jeg bekræfter, at jeg har gennemført kursus-betalingen</span>
          </label>
        </div>
      </div>

      <!-- Accommodation Block -->
      <div id="ybAccBlock" class="yb-apply-card" hidden>
        <h3>Overnatning</h3>
        <p class="yb-apply-hint">Har du brug for overnatning i 2026? (Feb–Jun)</p>

        <div class="yb-apply-radio-group">
          <label class="yb-apply-radio">
            <input type="radio" name="accommodation" value="no" checked>
            <span>Nej tak</span>
          </label>
          <label class="yb-apply-radio">
            <input type="radio" name="accommodation" value="yes">
            <span>Ja tak</span>
          </label>
        </div>

        <div id="ybAccMonths" class="yb-apply-months" hidden>
          <p>Vælg de måneder du ønsker (du kan vælge flere):</p>
          <div class="yb-month-chips">
            <label class="yb-month-chip"><input type="checkbox" name="accMonth" value="feb"><span>Februar</span></label>
            <label class="yb-month-chip"><input type="checkbox" name="accMonth" value="mar"><span>Marts</span></label>
            <label class="yb-month-chip"><input type="checkbox" name="accMonth" value="apr"><span>April</span></label>
            <label class="yb-month-chip"><input type="checkbox" name="accMonth" value="maj"><span>Maj</span></label>
          </div>
        </div>
      </div>

      <!-- Contact Info -->
      <div class="yb-apply-card">
        <h3>Dine Oplysninger</h3>

        <div class="yb-modal-u__grid">
          <label class="yb-modal-u__field">
            <span>Fornavn *</span>
            <input type="text" name="firstName" required>
          </label>
          <label class="yb-modal-u__field">
            <span>Efternavn *</span>
            <input type="text" name="lastName" required>
          </label>
          <label class="yb-modal-u__field">
            <span>E-mail *</span>
            <input type="email" name="email" required>
          </label>
          <label class="yb-modal-u__field">
            <span>Telefon *</span>
            <input type="tel" name="phone" required>
          </label>
        </div>

        <label class="yb-modal-u__field">
          <span>Hvordan hørte du om os? *</span>
          <select name="source" id="ybSource" required>
            <option value="">Vælg...</option>
            <option value="google">Google</option>
            <option value="social">Sociale medier</option>
            <option value="friend">En ven</option>
            <option value="hyc">Hot Yoga Copenhagen medlem</option>
            <option value="ai">AI ChatBots (fx ChatGPT..)</option>
            <option value="unsure">Ikke sikker endnu</option>
            <option value="other">Andet</option>
          </select>
        </label>

        <label class="yb-modal-u__field" id="ybSourceOtherWrap" hidden>
          <span>Andet — skriv her</span>
          <input type="text" name="sourceOther">
        </label>

        <label class="yb-modal-u__field">
          <span>Anti-spam: Skriv NAMASTE *</span>
          <input type="text" name="antispam" id="ybApplyAntispam" required autocomplete="off">
        </label>

        <label class="yb-apply-checkbox">
          <input type="checkbox" name="consent" id="ybConsent" required>
          <span>Jeg accepterer, at Yoga Bible gemmer mine oplysninger for at administrere ansøgningen.</span>
        </label>
      </div>

      <p id="ybApplyError" class="yb-modal-u__error" hidden></p>

      <button id="ybApplySubmit" class="yb-btn yb-btn--cta" type="submit" disabled>Send ansøgning</button>
    </form>

    <div id="ybApplySuccess" class="yb-modal-u__success" hidden role="status" aria-live="polite">
      <div class="yb-modal-u__success-icon">&#10003;</div>
      <h3>Tak for din ansøgning!</h3>
      <p>Vi har modtaget din ansøgning og vender tilbage snarest med næste skridt.</p>
    </div>
  </div>
</section>
