  <script>
    /* ===== Course switcher (scoped) ===== */
    (function(){
      const root = document.getElementById('yb-explore');
      if(!root) return;

      const COURSE_DATA = {
        inv: {
          image: 'https://www.yogabible.dk/s/Inversions_Course_Copenhagen.jpg?format=1500w',
          blurb: 'Lær at arbejde sikkert med håndstande, underarmsbalancer og hovedstande – teknik, styrke og mod.',
          href: 'https://www.yogabible.dk/inversions',
          label: 'Læs mere om Inversions',
          alt: 'Inversions kursus'
        },
        spl: {
          image: 'https://www.yogabible.dk/s/Splits_Course_Kursus_Kbenhavn_Copenhagen.jpg?format=1500w',
          blurb: 'Smidighed med system – hofteåbnere, baglår og teknik til front & middle splits uden at presse kroppen.',
          href: 'https://www.yogabible.dk/splits',
          label: 'Læs mere om Splits',
          alt: 'Splits kursus'
        },
        bb: {
          image: 'https://www.yogabible.dk/s/professional-backbend-yoga-training-copenhagen.jpg?format=1500w',
          blurb: 'Sunde bagoverbøjninger med fokus på åndedræt, stabilitet og gradvis mobilitet i brystryg og hofter.',
          href: 'https://www.yogabible.dk/backbends',
          label: 'Læs mere om Backbends',
          alt: 'Backbends kursus'
        }
      };

      const img = document.getElementById('ybCourseImg');
      const blurb = document.getElementById('ybCourseBlurb');
      const cta = document.getElementById('ybCourseCta');
      const pills = root.querySelectorAll('.ybEX-pill');

      if (!img || !blurb || !cta || !pills.length) return;

      const setCourse = (key) => {
        const data = COURSE_DATA[key];
        if (!data) return;

        pills.forEach(p => {
          const isActive = p.dataset.course === key;
          p.classList.toggle('is-active', isActive);
          p.setAttribute('aria-selected', isActive);
        });

        img.src = data.image;
        img.alt = data.alt;
        blurb.textContent = data.blurb;
        cta.href = data.href;
        cta.textContent = data.label + ' →';
      };

      pills.forEach(p => {
        p.addEventListener('click', () => setCourse(p.dataset.course));
      });

      // Initialize
      setCourse('inv');
    })();
  </script>
</section>
