  <!-- ========================================
       DESIGN 2: OSCILLOSCOPE
       ======================================== -->
  <div class="vyd-panel" data-panel="2" style="display:none">
    <div class="vy2">
      <section class="vy2-hero">
        <canvas class="vy2-scope-canvas"></canvas>
        <div class="vy2-hero__content">
          <h1 class="vy2-hero__title">OSCILLATE</h1>
          <p class="vy2-hero__subtitle">Move your cursor up and down. Change the waveform.</p>
        </div>
      </section>

      <section class="vy2-section">
        <div class="vy2-section__inner">
          <div class="vy2-spectrum"></div>
          <div class="vy2-section__content">
            <h2 class="vy2-section__title">Your Body's Waveform</h2>
            <p class="vy2-section__text">Every movement creates a signal. Every breath is a frequency. At Vibro Yoga, we tune into these natural rhythms and amplify them through precisely calibrated vibration platforms.</p>
            <p class="vy2-section__text">The result is a practice that resonates with your body's own oscillations—deeper stretches, faster recovery, and a meditative state that's felt, not forced.</p>
          </div>
        </div>
      </section>

      <section class="vy2-sound-zone">
        <div class="vy2-sound-zone__inner">
          <p class="vy2-sound-zone__text">Send a pulse</p>
          <p class="vy2-sound-zone__hint">Click anywhere in this space</p>
