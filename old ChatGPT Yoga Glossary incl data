      function mapPosition(pos) {
        if (!pos) return "";
        pos = String(pos).toLowerCase();
        if (pos === "standing") return "standing";
        if (pos === "seated" || pos === "kneeling") return "seated-kneeling";
        if (pos === "supine") return "supine";
        if (pos === "prone") return "prone";
        if (pos === "all-fours" || pos === "quadruped" || pos === "tabletop") return "all-fours";
        if (pos === "arm-balance" || pos === "arm_balance") return "arm-balance";
        if (pos === "inversion") return "inversion";
        return "";
      }

      function mapRegion(entry) {
        if (!entry || !Array.isArray(entry.body_areas) || !entry.body_areas.length) return "";
        var key = String(entry.body_areas[0] || "").toLowerCase();
        var allowed = [
          "spine",
          "hip-pelvis",
          "shoulder",
          "knee",
          "ankle-foot",
          "wrist-hand",
          "core-abdomen",
          "breath-ribcage",
          "nervous-system",
          "general"
        ];
        if (allowed.indexOf(key) !== -1) return key;

        if (key.indexOf("spine") !== -1 || key.indexOf("back") !== -1) return "spine";
        if (key.indexOf("hip") !== -1 || key.indexOf("pelvis") !== -1) return "hip-pelvis";
        if (key.indexOf("shoulder") !== -1) return "shoulder";
        if (key.indexOf("knee") !== -1) return "knee";
        if (key.indexOf("ankle") !== -1 || key.indexOf("foot") !== -1 || key.indexOf("feet") !== -1) return "ankle-foot";
        if (key.indexOf("wrist") !== -1 || key.indexOf("hand") !== -1) return "wrist-hand";
        if (key.indexOf("core") !== -1 || key.indexOf("abdomen") !== -1) return "core-abdomen";
        if (key.indexOf("rib") !== -1 || key.indexOf("breath") !== -1 || key.indexOf("chest") !== -1) return "breath-ribcage";
        if (key.indexOf("nervous") !== -1) return "nervous-system";
        return "general";
      }

      function buildSeriesLookup() {
        seriesLookup = {};
        if (!sequenceData || !sequenceData.length) return;
