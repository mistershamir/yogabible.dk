      function clearSequencePanel() {
        if (!sequencePanel) return;
        sequencePanel.hidden = true;
        if (sequenceTitleEl) sequenceTitleEl.textContent = "";
        if (sequenceSubDkEl) sequenceSubDkEl.textContent = "";
        if (sequenceSubEnEl) sequenceSubEnEl.textContent = "";
        if (sequenceMetaDkEl) sequenceMetaDkEl.textContent = "";
        if (sequenceMetaEnEl) sequenceMetaEnEl.textContent = "";
        if (sequenceStepsEl) {
          while (sequenceStepsEl.firstChild) {
            sequenceStepsEl.removeChild(sequenceStepsEl.firstChild);
          }
        }
      }

      function renderSequencePanel(seriesId) {
        if (!sequencePanel || !seriesId || seriesId === "all") {
          clearSequencePanel();
          return;
        }
        if (!sequenceData || !sequenceData.length) {
          clearSequencePanel();
          return;
        }

        var record = seriesLookup[seriesId] || null;
        if (!record || !record.meta) {
          clearSequencePanel();
          return;
        }

        var seq = record.meta;

        if (sequenceTitleEl) {
          sequenceTitleEl.textContent = seq.english || seq.danish || "";
        }
        if (sequenceSubDkEl) {
          sequenceSubDkEl.textContent = seq.description_dk || seq.danish || "";
        }
        if (sequenceSubEnEl) {
          sequenceSubEnEl.textContent = seq.description_en || seq.english || "";
        }

        if (sequenceMetaDkEl || sequenceMetaEnEl) {
          var dkBits = [];
          var enBits = [];
          if (seq.tradition) {
            dkBits.push("Tradition: " + seq.tradition);
            enBits.push("Tradition: " + seq.tradition);
          }
          if (seq.level) {
            dkBits.push("Niveau: " + seq.level);
            enBits.push("Level: " + seq.level);
          }
          if (typeof seq.length_breaths_estimate === "number" && !isNaN(seq.length_breaths_estimate)) {
            dkBits.push("Ca. " + seq.length_breaths_estimate + " åndedrag");
            enBits.push("Approx. " + seq.length_breaths_estimate + " breaths");
          }
          if (sequenceMetaDkEl) sequenceMetaDkEl.textContent = dkBits.join(" · ");
          if (sequenceMetaEnEl) sequenceMetaEnEl.textContent = enBits.join(" · ");
        }

        if (sequenceStepsEl) {
          while (sequenceStepsEl.firstChild) {
            sequenceStepsEl.removeChild(sequenceStepsEl.firstChild);
          }
          if (Array.isArray(seq.steps)) {
            for (var i = 0; i < seq.steps.length; i++) {
              var step = seq.steps[i] || {};
              var li = document.createElement("li");
              li.className = "yb-sequence-step";

              var main = document.createElement("div");
              main.className = "yb-sequence-step-main";

              var nameSpan = document.createElement("span");
              nameSpan.className = "yb-sequence-step-name";
              var primaryName = step.sanskrit || step.english || "";
              var secondaryName = (step.sanskrit && step.english && step.sanskrit !== step.english) ? step.english : "";
              if (primaryName && secondaryName) {
                nameSpan.textContent = primaryName + " – " + secondaryName;
              } else {
                nameSpan.textContent = primaryName || secondaryName;
              }
              main.appendChild(nameSpan);

              var metaBitsDk = [];
              var metaBitsEn = [];

              if (step.side) {
                metaBitsDk.push(step.side);
                metaBitsEn.push(step.side);
              }
              if (typeof step.breaths === "number" && !isNaN(step.breaths)) {
                var b = step.breaths;
                metaBitsDk.push(b + " åndedrag");
                metaBitsEn.push(b + (b === 1 ? " breath" : " breaths"));
              }
              if (typeof step.hold_seconds === "number" && !isNaN(step.hold_seconds)) {
                metaBitsDk.push(step.hold_seconds + " sek.");
                metaBitsEn.push(step.hold_seconds + " s");
              }

              if (metaBitsDk.length || metaBitsEn.length) {
                if (metaBitsDk.length) {
                  var metaDk = document.createElement("span");
                  metaDk.className = "yb-sequence-step-meta yb-seq-dk";
                  metaDk.textContent = metaBitsDk.join(" · ");
                  main.appendChild(metaDk);
                }
                if (metaBitsEn.length) {
                  var metaEn = document.createElement("span");
                  metaEn.className = "yb-sequence-step-meta yb-seq-en";
                  metaEn.textContent = metaBitsEn.join(" · ");
                  main.appendChild(metaEn);
                }
              }

              li.appendChild(main);

              var hasNotesDk = step.notes_dk && step.notes_dk.trim().length;
              var hasNotesEn = step.notes_en && step.notes_en.trim().length;

              if (hasNotesDk) {
                var notesDk = document.createElement("p");
                notesDk.className = "yb-sequence-step-notes yb-seq-dk";
                notesDk.textContent = step.notes_dk;
                li.appendChild(notesDk);
              }
              if (hasNotesEn) {
                var notesEn = document.createElement("p");
                notesEn.className = "yb-sequence-step-notes yb-seq-en";
                notesEn.textContent = step.notes_en;
                li.appendChild(notesEn);
              }

              sequenceStepsEl.appendChild(li);
            }
          }
        }

        sequencePanel.hidden = false;
      }

      /* ====== BUILD CARDS ====== */
      function createCard(entry) {
        var article = document.createElement("article");
        article.className = "yb-glossary-item";

        if (entry.id) {
          article.setAttribute("data-id", entry.id);
        }

        if (entry.sanskrit) {
          article.setAttribute("data-sanskrit", normalise(entry.sanskrit));
        }
        if (entry.english) {
          article.setAttribute("data-english", normalise(entry.english));
        }

        var letterSource = entry.english || entry.sanskrit || entry.danish || "";
        var letter = (letterSource || "").trim().charAt(0).toUpperCase();
        if (!letter) letter = "A";
        article.setAttribute("data-letter", letter);

        var cat = entry.category || "general";
        article.setAttribute("data-category", cat);

        article.setAttribute("data-core", entry.is_common ? "1" : "0");

        if (Array.isArray(entry.yoga_styles) && entry.yoga_styles.length) {
          article.setAttribute("data-yogastyles", entry.yoga_styles.join(" "));
        }

        var mappedPos = mapPosition(entry.position);
        if (mappedPos) {
          article.setAttribute("data-position", mappedPos);
        }

        if (entry.series) {
          article.setAttribute("data-series", String(entry.series));
        }

        if (cat === "anatomy") {
          var region = mapRegion(entry);
          if (region) {
            article.setAttribute("data-body-region", region);
          }
        }

        var iconWrap = document.createElement("div");
        iconWrap.className = "yb-glossary-icon";

        // Category-based icon by default. To enable pose icons, set USE_CUSTOM_ICONS = true.
        if (USE_CUSTOM_ICONS && entry.icon_url && entry.icon_url.trim() !== "") {
          var img = document.createElement("img");
          img.src = entry.icon_url;
          img.loading = "lazy";
          img.decoding = "async";
          img.alt =
            (entry.english || entry.sanskrit || entry.danish || "Yoga pose") + " icon";
          iconWrap.appendChild(img);
        } else {
          var svg = document.createElementNS("http://www.w3.org/2000/svg", "svg");
          svg.setAttribute("viewBox", "0 0 64 64");

          var useEl = document.createElementNS("http://www.w3.org/2000/svg", "use");
          var iconId = getCategoryIconId(cat);
          useEl.setAttributeNS("http://www.w3.org/1999/xlink", "xlink:href", "#" + iconId);
          useEl.setAttribute("href", "#" + iconId);
          svg.appendChild(useEl);
          iconWrap.appendChild(svg);
        }

        var copy = document.createElement("div");
        copy.className = "yb-glossary-copy";

        // Heading
        var heading = document.createElement("div");
        heading.className = "yb-term-heading";

        if (entry.sanskrit) {
          var sSpan = document.createElement("span");
          sSpan.className = "yb-term-sanskrit";
          sSpan.textContent = entry.sanskrit;
          heading.appendChild(sSpan);
        }

        if (entry.english) {
          var eSpan = document.createElement("span");
          eSpan.className = "yb-term-english";
          eSpan.textContent = " – " + entry.english;
          heading.appendChild(eSpan);
        }

        if (entry.pronunciation) {
          var pSpan = document.createElement("span");
          pSpan.className = "yb-term-pron";
          pSpan.textContent = entry.pronunciation;
          heading.appendChild(pSpan);
        }

        copy.appendChild(heading);

        if (entry.danish) {
          var langLine = document.createElement("p");
          langLine.className = "yb-term-langline";
          langLine.textContent = "Dansk: " + entry.danish;
          copy.appendChild(langLine);
        }

        // Meta line
        var metaPieces = [];
        if (entry.category) metaPieces.push(entry.category);
        if (entry.level) metaPieces.push("Level: " + entry.level);
        if (Array.isArray(entry.yoga_styles) && entry.yoga_styles.length) {
          metaPieces.push("Styles: " + entry.yoga_styles.join(", "));
        }

        // Asana-specific
        if (cat === "asana" && entry.pose_family) {
          metaPieces.push("Family: " + entry.pose_family);
        }
        if (cat === "asana" && typeof entry.holds_seconds_yin === "number") {
          metaPieces.push("Yin: " + entry.holds_seconds_yin + "s hold");
        }
        if (cat === "asana" && typeof entry.holds_breaths_hatha === "number") {
          metaPieces.push("Hatha: " + entry.holds_breaths_hatha + " breaths");
        }
        if (cat === "asana" && entry.series) {
          metaPieces.push("Series: " + entry.series);
        }

        // Breath-specific
        if (cat === "breath") {
          if (entry.effect) metaPieces.push("Effect: " + entry.effect);
          if (entry.pattern) metaPieces.push("Pattern: " + entry.pattern);
          if (entry.ratio && typeof entry.ratio === "object") {
            var r = entry.ratio;
            var hasNumber = ["inhale", "hold", "exhale", "hold_out"].some(function (k) {
              return typeof r[k] === "number" && !isNaN(r[k]);
            });
            if (hasNumber) {
              metaPieces.push(
                "Ratio: " +
                  (r.inhale || 0) + "-" +
                  (r.hold || 0) + "-" +
                  (r.exhale || 0) + "-" +
                  (r.hold_out || 0)
              );
            }
          }
          if (entry.recommended_level) {
            metaPieces.push("Recommended: " + entry.recommended_level);
          }
        }

        // Philosophy / subtle
        if ((cat === "philosophy" || cat === "subtle") && entry.tradition) {
          metaPieces.push("Tradition: " + entry.tradition);
        }
        if ((cat === "philosophy" || cat === "subtle") && entry.text_source) {
          metaPieces.push("Source: " + entry.text_source);
        }

        // Teaching / business
        if ((cat === "teaching" || cat === "business") && entry.module) {
          metaPieces.push("Module: " + entry.module);
        }

        if (metaPieces.length) {
          var meta = document.createElement("p");
          meta.className = "yb-term-meta";
          meta.textContent = metaPieces.join(" · ");
          copy.appendChild(meta);
        }

        // Descriptions – summary_* if present
        var desc = document.createElement("p");
        desc.className = "yb-term-desc";

        var shortDk = entry.summary_dk || entry.description_dk || "";
        var shortEn = entry.summary_en || entry.description_en || "";

        var descDkSpan = document.createElement("span");
        descDkSpan.className = "yb-desc-dk";
        descDkSpan.textContent = shortDk;
        desc.appendChild(descDkSpan);

        var descEnSpan = document.createElement("span");
        descEnSpan.className = "yb-desc-en";
        descEnSpan.textContent = shortEn;
        desc.appendChild(descEnSpan);

        copy.appendChild(desc);

        // Alignment (optional)
        var hasAlignDk = entry.alignment_dk && entry.alignment_dk.trim().length;
        var hasAlignEn = entry.alignment_en && entry.alignment_en.trim().length;
        if (hasAlignDk || hasAlignEn) {
          var alignP = document.createElement("p");
          alignP.className = "yb-term-align";

          if (hasAlignDk) {
            var alignDkSpan = document.createElement("span");
            alignDkSpan.className = "yb-align-dk";
            var strongDk = document.createElement("strong");
            strongDk.textContent = "Alignment";
            alignDkSpan.appendChild(strongDk);
            alignDkSpan.appendChild(document.createTextNode(" " + entry.alignment_dk));
            alignP.appendChild(alignDkSpan);
          }

          if (hasAlignEn) {
            var alignEnSpan = document.createElement("span");
            alignEnSpan.className = "yb-align-en";
            var strongEn = document.createElement("strong");
            strongEn.textContent = "Alignment";
            alignEnSpan.appendChild(strongEn);
            alignEnSpan.appendChild(document.createTextNode(" " + entry.alignment_en));
            alignP.appendChild(alignEnSpan);
          }

          copy.appendChild(alignP);
        }

        // Contraindications (optional)
        var hasContraDk = entry.contraindications_dk && entry.contraindications_dk.trim().length;
        var hasContraEn = entry.contraindications_en && entry.contraindications_en.trim().length;
        if (hasContraDk || hasContraEn) {
          var safetyP = document.createElement("p");
          safetyP.className = "yb-term-safety";

          if (hasContraDk) {
            var safetyDkSpan = document.createElement("span");
            safetyDkSpan.className = "yb-safety-dk";
            var safetyStrongDk = document.createElement("strong");
            safetyStrongDk.textContent = "Kontraindikationer";
            safetyDkSpan.appendChild(safetyStrongDk);
            safetyDkSpan.appendChild(document.createTextNode(" " + entry.contraindications_dk));
            safetyP.appendChild(safetyDkSpan);
          }

          if (hasContraEn) {
            var safetyEnSpan = document.createElement("span");
            safetyEnSpan.className = "yb-safety-en";
            var safetyStrongEn = document.createElement("strong");
            safetyStrongEn.textContent = "Contraindications";
            safetyEnSpan.appendChild(safetyStrongEn);
            safetyEnSpan.appendChild(document.createTextNode(" " + entry.contraindications_en));
            safetyP.appendChild(safetyEnSpan);
          }

          copy.appendChild(safetyP);
        }

        // Modifications
        var hasModsDk = entry.modifications_dk && entry.modifications_dk.trim().length;
        var hasModsEn = entry.modifications_en && entry.modifications_en.trim().length;
        if (hasModsDk || hasModsEn) {
          var modsP = document.createElement("p");
          modsP.className = "yb-term-mods";

          if (hasModsDk) {
            var modsDkSpan = document.createElement("span");
            modsDkSpan.className = "yb-mods-dk";
            var modsStrongDk = document.createElement("strong");
            modsStrongDk.textContent = "Variationer";
            modsDkSpan.appendChild(modsStrongDk);
            modsDkSpan.appendChild(document.createTextNode(" " + entry.modifications_dk));
            modsP.appendChild(modsDkSpan);
          }

          if (hasModsEn) {
            var modsEnSpan = document.createElement("span");
            modsEnSpan.className = "yb-mods-en";
            var modsStrongEn = document.createElement("strong");
            modsStrongEn.textContent = "Modifications";
            modsEnSpan.appendChild(modsStrongEn);
            modsEnSpan.appendChild(document.createTextNode(" " + entry.modifications_en));
            modsP.appendChild(modsEnSpan);
          }

          copy.appendChild(modsP);
        }

        // Tags – base + derived
        var tagList = [];
        if (Array.isArray(entry.tags)) {
          for (var i = 0; i < entry.tags.length; i++) {
            if (entry.tags[i]) tagList.push(entry.tags[i]);
          }
        }

        if (cat === "asana") {
          if (entry.pose_family) tagList.push(entry.pose_family);
          if (entry.bikram_hot26) tagList.push("Hot26 sequence");
          if (entry.salutation_component === "sun-a") tagList.push("Sun Salutation A");
          else if (entry.salutation_component === "sun-b") tagList.push("Sun Salutation B");
          if (Array.isArray(entry.props_common)) {
            for (var j = 0; j < entry.props_common.length; j++) {
              if (entry.props_common[j]) tagList.push("Prop: " + entry.props_common[j]);
            }
          }
          if (entry.series) {
            tagList.push("Series: " + entry.series);
          }
        } else if (cat === "breath") {
          if (entry.effect) tagList.push(entry.effect);
          if (entry.pattern) tagList.push(entry.pattern);
          if (entry.recommended_level) tagList.push("Level: " + entry.recommended_level);
        } else if (cat === "teaching" || cat === "business") {
          if (entry.tt_200_core) tagList.push("200h core");
          if (entry.tt_300_core) tagList.push("300h core");
          if (entry.module) tagList.push("Module: " + entry.module);
          if (entry.studio_use) tagList.push(entry.studio_use);
        } else if (cat === "subtle" || cat === "philosophy") {
          if (entry.tradition) tagList.push(entry.tradition);
          if (entry.practice_context) tagList.push(entry.practice_context);
          if (entry.text_source) tagList.push(entry.text_source);
        }

        // De-duplicate tags
        var seen = {};
        var finalTags = [];
        for (var t = 0; t < tagList.length; t++) {
          var val = tagList[t];
          if (!val) continue;
          var key = String(val).toLowerCase();
          if (!seen[key]) {
            seen[key] = true;
            finalTags.push(val);
          }
        }

        if (finalTags.length) {
          var tagWrap = document.createElement("div");
          tagWrap.className = "yb-term-tags";
          for (var k = 0; k < finalTags.length; k++) {
            var tagEl = document.createElement("span");
            tagEl.className = "yb-term-tag";
            tagEl.textContent = finalTags[k];
            tagWrap.appendChild(tagEl);
          }
          copy.appendChild(tagWrap);
        }

        article.appendChild(iconWrap);
        article.appendChild(copy);
        return article;
      }

      function buildGlossary() {
        if (!listNode || !glossaryData || !glossaryData.length) return;
        var frag = document.createDocumentFragment();
        for (var i = 0; i < glossaryData.length; i++) {
          frag.appendChild(createCard(glossaryData[i]));
        }
        listNode.innerHTML = "";
        listNode.appendChild(frag);
      }

      function filterItems() {
        var items = root.querySelectorAll(".yb-glossary-item");
        var filtered = [];
        var anyVisible = false;

        for (var i = 0; i < items.length; i++) {
          var item = items[i];
          var itemLetter = item.getAttribute("data-letter") || "";
          var itemCategory = item.getAttribute("data-category") || "";
          var stylesAttr = item.getAttribute("data-yogastyles") || "";
          var styleList = stylesAttr ? stylesAttr.split(/\s+/) : [];
          var itemPosition = item.getAttribute("data-position") || "";
          var itemRegion = item.getAttribute("data-body-region") || "";
          var itemSeries = item.getAttribute("data-series") || "";
          var coreAttr = item.getAttribute("data-core") || "1";

          var matchesLetter = (state.letter === "all" || itemLetter === state.letter);
          var matchesCategory = (state.category === "all" || itemCategory === state.category);
          var matchesScope = (state.scope === "all") ? true : (coreAttr === "1");

          var matchesStyle = true;
          if (state.category === "asana" && state.style !== "all") {
            matchesStyle = styleList.indexOf(state.style) !== -1;
          }

          var matchesPosition = true;
          if (state.category === "asana" && state.position !== "all") {
            matchesPosition = (itemPosition === state.position);
          }

          var matchesSeries = true;
          if (state.category === "asana" && state.series !== "all") {
            var seriesInfo = seriesLookup[state.series] || null;
            if (seriesInfo) {
              var itemSans = normalise(item.getAttribute("data-sanskrit") || "");
              var itemEn = normalise(item.getAttribute("data-english") || "");
              matchesSeries = !!(seriesInfo.sanskrit[itemSans] || seriesInfo.english[itemEn]);
            } else {
              matchesSeries = (itemSeries === state.series);
            }
          }

          var matchesRegion = true;
          if (state.category === "anatomy" && state.region !== "all") {
            matchesRegion = (itemRegion === state.region);
          }

          var matchesSearch = true;
          if (state.search) {
            var haystack = normalise(item.textContent);
            matchesSearch = (haystack.indexOf(state.search) !== -1);
          }

          var show = matchesLetter && matchesCategory && matchesScope &&
                     matchesStyle && matchesPosition && matchesSeries &&
                     matchesRegion && matchesSearch;

          if (show) {
            filtered.push(item);
          }
        }

        var maxVisible = state.page * state.pageSize;
        for (var i2 = 0; i2 < items.length; i2++) {
          items[i2].style.display = "none";
        }

        for (var k2 = 0; k2 < filtered.length; k2++) {
          if (k2 < maxVisible) {
            filtered[k2].style.display = "";
            anyVisible = true;
          } else {
            filtered[k2].style.display = "none";
          }
        }

        if (emptyNode) {
          emptyNode.hidden = anyVisible ? true : false;
        }

        if (moreBtn) {
          moreBtn.hidden = !(filtered.length > maxVisible);
        }
      }

      function applyLanguage() {
        var t = translations[state.lang] || translations.dk;

        var scopeLabel = root.querySelector(".yb-scope-label");
        if (scopeLabel) scopeLabel.textContent = t.scopeLabel;

        var coreChip = root.querySelector('.yb-scope .yb-chip[data-scope="core"]');
        if (coreChip) coreChip.textContent = t.scopeCore;

        var allChip = root.querySelector('.yb-scope .yb-chip[data-scope="all"]');
        if (allChip) allChip.textContent = t.scopeAll;

        var lettersLabel = root.querySelector(".yb-letters-label");
        if (lettersLabel) lettersLabel.textContent = t.lettersLabel;

        var lettersAllChip = root.querySelector('.yb-letters .yb-chip[data-letter="all"]');
        if (lettersAllChip) lettersAllChip.textContent = t.lettersAll;

        var catLabel = root.querySelector(".yb-category-label");
        if (catLabel) catLabel.textContent = t.categoryLabel;

        function setChipText(selector, dataAttr, map) {
          for (var key in map) {
            if (!map.hasOwnProperty(key)) continue;
            var chip = root.querySelector(selector + "[" + dataAttr + '="' + key + '"]');
            if (chip) chip.textContent = map[key];
          }
        }

        setChipText(".yb-categories .yb-chip", "data-category", t.categories);

        var styleLabel = root.querySelector(".yb-style-label");
        if (styleLabel) styleLabel.textContent = t.styleLabel;

        var posLabel = root.querySelector(".yb-position-label");
        if (posLabel) posLabel.textContent = t.positionLabel;

        setChipText(".yb-positions .yb-chip", "data-position", t.positions);

        var seriesLabel = root.querySelector(".yb-series-label");
        if (seriesLabel && t.seriesLabel) seriesLabel.textContent = t.seriesLabel;

        if (t.series) {
          setChipText(".yb-series .yb-chip", "data-series", t.series);
        }

        var regionLabel = root.querySelector(".yb-region-label");
        if (regionLabel) regionLabel.textContent = t.regionLabel;

        setChipText(".yb-regions .yb-chip", "data-region", t.regions);

        var alignLabel = root.querySelector(".yb-align-label");
        if (alignLabel) alignLabel.textContent = t.alignLabel;

        var viewSummaryChip = root.querySelector('.yb-align-toggle .yb-chip[data-view="summary"]');
        if (viewSummaryChip && t.viewSummary) viewSummaryChip.textContent = t.viewSummary;

        var viewAlignChip = root.querySelector('.yb-align-toggle .yb-chip[data-view="align"]');
        if (viewAlignChip && t.viewAlign) viewAlignChip.textContent = t.viewAlign;

        var viewSafetyChip = root.querySelector('.yb-align-toggle .yb-chip[data-view="safety"]');
        if (viewSafetyChip && t.viewSafety) viewSafetyChip.textContent = t.viewSafety;

        var viewModsChip = root.querySelector('.yb-align-toggle .yb-chip[data-view="mods"]');
        if (viewModsChip && t.viewMods) viewModsChip.textContent = t.viewMods;

        if (searchInput) {
          searchInput.placeholder = t.searchPlaceholder;
        }

        if (moreBtn) {
          moreBtn.textContent = t.more;
        }

        if (emptyNode) {
          emptyNode.textContent = t.empty;
        }

        var seqKicker = root.querySelector(".yb-sequence-kicker");
        if (seqKicker && t.sequenceKicker) {
          seqKicker.textContent = t.sequenceKicker;
        }

        root.setAttribute("data-lang", state.lang);
      }

      function updateViewVisibility() {
        // Short definition is always on; alignment/safety/mods are optional extra views
        var showSummary = true;
        var showAlign = !!(state.view && state.view.align);
        var showSafety = !!(state.view && state.view.safety);
        var showMods = !!(state.view && state.view.mods);

        var descEls = root.querySelectorAll(".yb-term-desc");
        for (var i = 0; i < descEls.length; i++) {
          descEls[i].style.display = showSummary ? "" : "none";
        }

        var alignEls = root.querySelectorAll(".yb-term-align");
        for (var j = 0; j < alignEls.length; j++) {
          alignEls[j].style.display = showAlign ? "" : "none";
        }

        var safetyEls = root.querySelectorAll(".yb-term-safety");
        for (var k = 0; k < safetyEls.length; k++) {
          safetyEls[k].style.display = showSafety ? "" : "none";
        }

        var modsEls = root.querySelectorAll(".yb-term-mods");
        for (var m = 0; m < modsEls.length; m++) {
          modsEls[m].style.display = showMods ? "" : "none";
        }
      }

      /* ====== EVENTS (including Outseta gating) ====== */
      function attachEventHandlers() {
        root.addEventListener("click", function (evt) {
          var target = evt.target;
          if (!target) return;
          if (!target.closest) {
            target = target.parentElement || target;
          }

          // Language buttons
          var langBtn = target.closest(".yb-lang-btn");
          if (langBtn && root.contains(langBtn)) {
            var lang = langBtn.getAttribute("data-lang") || "dk";
            state.lang = lang;
            setActive(".yb-lang-btn", langBtn);
            applyLanguage();
            updateViewVisibility();
            return;
          }

          // Scope chips (Most used / Complete) – Complete is gated
          var scopeChip = target.closest(".yb-scope .yb-chip");
          if (scopeChip && root.contains(scopeChip)) {
            var scope = scopeChip.getAttribute("data-scope") || "core";
            if (scope === "all" && !isLoggedIn) {
              // Require login for full glossary
              ensureAuth();
              return;
            }
            state.scope = scope;
            setActive(".yb-scope .yb-chip", scopeChip);
            resetPage();
            filterItems();
            return;
          }

          // Letters A–Z
          var letterChip = target.closest(".yb-letters .yb-chip");
          if (letterChip && root.contains(letterChip)) {
            var letter = letterChip.getAttribute("data-letter") || "all";
            state.letter = letter;
            setActive(".yb-letters .yb-chip", letterChip);
            resetPage();
            filterItems();
            return;
          }

          // Category chips – teaching & business are gated
          var categoryChip = target.closest(".yb-categories .yb-chip");
          if (categoryChip && root.contains(categoryChip)) {
            var category = categoryChip.getAttribute("data-category") || "all";
            if ((category === "teaching" || category === "business") && !isLoggedIn) {
              ensureAuth();
              return;
            }

            state.category = category;
            setActive(".yb-categories .yb-chip", categoryChip);

            if (category !== "asana") {
              resetStyleChips();
              resetPositionChips();
              resetSeriesChips();
              clearSequencePanel();
            }
            if (category !== "anatomy") {
              resetRegionChips();
            }

            updateConditionalRows();
            resetPage();
            filterItems();
            return;
          }

          // Style chips (Asanas)
          var styleChip = target.closest(".yb-styles .yb-chip");
          if (styleChip && root.contains(styleChip)) {
            var style = styleChip.getAttribute("data-style") || "all";
            state.style = style;
            setActive(".yb-styles .yb-chip", styleChip);
            resetPage();
            filterItems();
            return;
          }

          // Pose position chips (Asanas)
          var positionChip = target.closest(".yb-positions .yb-chip");
          if (positionChip && root.contains(positionChip)) {
            var position = positionChip.getAttribute("data-position") || "all";
            state.position = position;
            setActive(".yb-positions .yb-chip", positionChip);
            resetPage();
            filterItems();
            return;
          }

          // Series chips (Asanas) – specific series are gated
          var seriesChip = target.closest(".yb-series .yb-chip");
          if (seriesChip && root.contains(seriesChip)) {
            var series = seriesChip.getAttribute("data-series") || "all";
            if (series !== "all" && !isLoggedIn) {
              ensureAuth();
              return;
            }
            state.series = series;
            setActive(".yb-series .yb-chip", seriesChip);
            resetPage();
            filterItems();
            renderSequencePanel(state.series);
            return;
          }

          // Region chips (Anatomy)
          var regionChip = target.closest(".yb-regions .yb-chip");
          if (regionChip && root.contains(regionChip)) {
            var region = regionChip.getAttribute("data-region") || "all";
            state.region = region;
            setActive(".yb-regions .yb-chip", regionChip);
            resetPage();
            filterItems();
            return;
          }

          // View toggles – alignment / safety / mods are gated
          var viewChip = target.closest(".yb-align-toggle .yb-chip");
          if (viewChip && root.contains(viewChip)) {
            var viewKey = viewChip.getAttribute("data-view") || "summary";

            // Short definition is always on; clicking it just keeps it active
            if (viewKey === "summary") {
              viewChip.classList.add("is-active");
              updateViewVisibility();
              return;
            }

            if (!isLoggedIn) {
              ensureAuth();
              return;
            }

            if (!state.view) {
              state.view = { align: false, safety: false, mods: false };
            }

            var currentlyActive = viewChip.classList.contains("is-active");
            var newActive = !currentlyActive;
            state.view[viewKey] = newActive;

            if (newActive) {
              viewChip.classList.add("is-active");
            } else {
              viewChip.classList.remove("is-active");
            }

            updateViewVisibility();
            return;
          }

          // More button
          if (moreBtn && target === moreBtn) {
            state.page += 1;
            filterItems();
            return;
          }
        });

        if (searchInput) {
          searchInput.addEventListener("input", function () {
            state.search = normalise(searchInput.value);
            resetPage();
            filterItems();
          });
        }
      }

      function startGlossary() {
        root.setAttribute("data-lang", state.lang);
        updateConditionalRows();
        applyLanguage();
        buildGlossary();
        filterItems();
        updateViewVisibility();
      }

      attachEventHandlers();
      startGlossary();
    })();
  </script>
</section>
