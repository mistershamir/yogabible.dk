          if (!seq) continue;
          var id = seq.id || seq.series_key;
          if (!id) continue;
          var key = String(id);
          var sanskritMap = {};
          var englishMap = {};
          if (Array.isArray(seq.steps)) {
            for (var j = 0; j < seq.steps.length; j++) {
              var step = seq.steps[j] || {};
              if (step.sanskrit) {
                sanskritMap[normalise(step.sanskrit)] = true;
              }
              if (step.english) {
                englishMap[normalise(step.english)] = true;
              }
            }
          }
          seriesLookup[key] = {
            meta: seq,
            sanskrit: sanskritMap,
            english: englishMap
          };
        }
