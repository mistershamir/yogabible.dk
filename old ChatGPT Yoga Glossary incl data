      /* ====== UTILS ====== */
      function setActive(selector, activeEl) {
        var nodes = root.querySelectorAll(selector);
        for (var i = 0; i < nodes.length; i++) {
          if (nodes[i] === activeEl) {
            nodes[i].classList.add("is-active");
          } else {
            nodes[i].classList.remove("is-active");
          }
        }
      }

      function resetStyleChips() {
        state.style = "all";
        var chips = root.querySelectorAll(".yb-styles .yb-chip");
        for (var i = 0; i < chips.length; i++) {
          var chip = chips[i];
          var val = chip.getAttribute("data-style") || "all";
          if (val === "all") chip.classList.add("is-active");
          else chip.classList.remove("is-active");
        }
      }

      function resetPositionChips() {
        state.position = "all";
