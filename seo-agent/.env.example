# SEO Agent — Environment Variables
# Copy to .env and fill in values

# Telegram (same as lead agent)
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=

# Site
SITE_URL=https://yogabible.dk

# Google PageSpeed Insights (free, get from Google Cloud Console)
GOOGLE_API_KEY=

# Google Search Console (optional — for ranking data)
# Path to a service account JSON with Search Console access
GOOGLE_SERVICE_ACCOUNT_JSON=
