<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<!--
  macOS launchd agent for auto-syncing yogabible.dk repo.
  Runs every 5 minutes. More reliable than cron on macOS.

  INSTALL:
  1. Edit the REPO_DIR path below to match your iCloud repo location
  2. Copy to ~/Library/LaunchAgents/:
     cp scripts/com.yogabible.git-sync.plist ~/Library/LaunchAgents/
  3. Load it:
     launchctl load ~/Library/LaunchAgents/com.yogabible.git-sync.plist
  4. Verify:
     launchctl list | grep yogabible

  UNINSTALL:
     launchctl unload ~/Library/LaunchAgents/com.yogabible.git-sync.plist
     rm ~/Library/LaunchAgents/com.yogabible.git-sync.plist
-->
<dict>
    <key>Label</key>
    <string>com.yogabible.git-sync</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <!-- UPDATE THIS PATH to your actual repo location on iCloud -->
        <string>/Users/YOUR_USERNAME/Library/Mobile Documents/com~apple~CloudDocs/yogabible.dk/scripts/git-auto-sync.sh</string>
        <string>main</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <!-- UPDATE THIS PATH to your actual repo location on iCloud -->
        <key>REPO_DIR</key>
        <string>/Users/YOUR_USERNAME/Library/Mobile Documents/com~apple~CloudDocs/yogabible.dk</string>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>

    <key>StartInterval</key>
    <!-- Sync every 300 seconds (5 minutes) -->
    <integer>300</integer>

    <key>StandardOutPath</key>
    <string>/tmp/yogabible-git-sync.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/yogabible-git-sync-error.log</string>

    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
